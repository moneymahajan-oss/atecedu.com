---
// src/components/layout/AnnouncementStrip.astro
// LIVE — fetches strip settings from Supabase at runtime in the browser.
// Admin saves → strip updates on next page load. No rebuild needed.
---

<!-- Render hidden by default; JS shows it if active -->
<div
  id="atec-strip"
  style="display:none;padding:9px 0;font-size:13px;font-weight:500;font-family:'Inter',sans-serif"
>
  <div style="max-width:1280px;margin:0 auto;padding:0 20px;display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap">
    <span class="strip-text"></span>
    <span class="strip-timer" id="atec-timer" style="display:none;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);padding:3px 12px;border-radius:4px;font-family:monospace;font-weight:700;font-size:14px;color:#d4f01a;letter-spacing:1px"></span>
    <a class="strip-link" style="font-weight:700;text-decoration:underline;text-underline-offset:3px;white-space:nowrap;opacity:0.9;color:inherit"></a>
  </div>
</div>

<script>
  import { createClient } from '@supabase/supabase-js'

  const url = (window as any).__SB_URL
  const key = (window as any).__SB_KEY
  if (!url || !key) {
    // nothing to load — leave hidden
  } else {
    const sb = createClient(url, key)
    sb.from('site_settings').select('value').eq('key', 'announcement_strip').single().then(({ data }) => {
      if (!data?.value) return
      const v = data.value
      if (!v.is_active) return

      const strip = document.getElementById('atec-strip') as HTMLElement | null
      if (!strip) return

      strip.style.display = 'block'
      strip.style.background = v.bg_color || '#0f2347'
      strip.style.color = v.text_color || '#ffffff'

      const textEl = strip.querySelector('.strip-text')
      if (textEl) textEl.textContent = v.text || ''

      const linkEl = strip.querySelector('.strip-link') as HTMLAnchorElement | null
      if (linkEl) {
        if (v.link && v.link_text) {
          linkEl.href = v.link
          linkEl.textContent = v.link_text + ' →'
          // External link → new tab
          if (v.link.startsWith('http')) {
            linkEl.target = '_blank'
            linkEl.rel = 'noopener'
          }
        } else {
          linkEl.style.display = 'none'
        }
      }

      // Countdown timer
      if (v.show_timer && v.ends_at) {
        const timerEl = document.getElementById('atec-timer')
        if (!timerEl) return
        timerEl.style.display = 'inline-block'

        const endTime = new Date(v.ends_at).getTime()
        if (isNaN(endTime)) return

        const pad = (n: number) => String(Math.floor(n)).padStart(2, '0')

        function tick() {
          const diff = endTime - Date.now()
          if (diff <= 0) { strip!.style.display = 'none'; return }
          const d = Math.floor(diff / 86400000)
          const h = Math.floor((diff % 86400000) / 3600000)
          const m = Math.floor((diff % 3600000) / 60000)
          const s = Math.floor((diff % 60000) / 1000)
          timerEl!.textContent = d > 0
            ? `⏱ ${d}d ${pad(h)}h ${pad(m)}m ${pad(s)}s`
            : `⏱ ${pad(h)}:${pad(m)}:${pad(s)}`
        }
        tick()
        setInterval(tick, 1000)
      }
    })
  }
</script>
