---
// src/components/layout/AnnouncementStrip.astro
// Live from Supabase — no rebuild needed. Colors managed from admin panel.
// Text shown in a styled pill/box. No arrow shown.
---

<div id="announcement-strip" style="display:none">
  <div id="strip-inner"></div>
</div>

<script>
  const SUPABASE_URL = (window as any).__SB_URL
  const SUPABASE_KEY = (window as any).__SB_KEY

  interface StripSettings {
    is_active: boolean
    text: string
    link: string
    link_text: string
    show_timer: boolean
    ends_at: string
    bg_color: string
    text_color: string
    box_bg_color: string
    box_text_color: string
    box_border_color: string
  }

  async function loadStrip() {
    if (!SUPABASE_URL || !SUPABASE_KEY) return

    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/site_settings?key=eq.announcement_strip&select=value`,
        { headers: { apikey: SUPABASE_KEY, Authorization: `Bearer ${SUPABASE_KEY}` } }
      )
      const rows = await res.json()
      if (!rows?.length) return

      const s: StripSettings = rows[0].value
      if (!s?.is_active) return

      const strip = document.getElementById('announcement-strip')!
      const inner = document.getElementById('strip-inner')!

      // Apply strip background
      strip.style.background = s.bg_color || '#1c3d7a'
      strip.style.padding = '9px 20px'
      strip.style.display = 'block'

      // Build timer countdown
      let timerHtml = ''
      if (s.show_timer && s.ends_at) {
        const end = new Date(s.ends_at).getTime()
        const updateTimer = () => {
          const diff = end - Date.now()
          if (diff <= 0) { clearInterval(interval); return }
          const d = Math.floor(diff / 86400000)
          const h = Math.floor((diff % 86400000) / 3600000)
          const m = Math.floor((diff % 3600000) / 60000)
          const sec = Math.floor((diff % 60000) / 1000)
          const el = document.getElementById('strip-timer')
          if (el) el.textContent = `${d}d ${h}h ${m}m ${sec}s`
        }
        const interval = setInterval(updateTimer, 1000)
        updateTimer()
        timerHtml = `<span id="strip-timer-wrap" style="
          background:rgba(0,0,0,0.25);
          border:1px solid rgba(255,255,255,0.2);
          border-radius:5px;
          padding:2px 10px;
          font-weight:700;
          font-size:13px;
          color:#d4f01a;
          font-family:monospace;
          margin-left:10px;
          flex-shrink:0;
        ">⏱ <span id="strip-timer">...</span></span>`
      }

      // Link in box (no arrow)
      let linkHtml = ''
      if (s.link && s.link_text) {
        linkHtml = `<a href="${s.link}" style="
          display:inline-flex;
          align-items:center;
          gap:5px;
          background:${s.box_bg_color || 'rgba(255,255,255,0.15)'};
          border:1px solid ${s.box_border_color || 'rgba(255,255,255,0.3)'};
          border-radius:5px;
          padding:3px 12px;
          font-size:12px;
          font-weight:700;
          color:${s.box_text_color || '#d4f01a'};
          text-decoration:none;
          white-space:nowrap;
          flex-shrink:0;
          transition:opacity 0.2s;
        " onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">${s.link_text}</a>`
      }

      inner.style.cssText = `
        display:flex;
        align-items:center;
        justify-content:center;
        gap:12px;
        flex-wrap:wrap;
        max-width:1200px;
        margin:0 auto;
      `

      inner.innerHTML = `
        <span style="
          font-size:13px;
          font-weight:600;
          color:${s.text_color || '#ffffff'};
          display:inline-flex;
          align-items:center;
          gap:8px;
        ">
          <span style="font-size:16px">🔥</span>
          <span id="strip-main-text">${s.text || ''}</span>
        </span>
        ${timerHtml}
        ${linkHtml}
      `
    } catch (e) {
      console.warn('Strip load failed:', e)
    }
  }

  loadStrip()
</script>
