---
// src/components/layout/AnnouncementStrip.astro
---

<div id="announcement-strip" style="display:none">
  <div id="strip-inner"></div>
</div>

<!-- Blink keyframes injected as a plain <style> (not Astro-scoped) -->
<!-- Using is:global so Astro does NOT scope this with a hash attribute -->
<style is:global>
  @keyframes atecTimerBlink {
    0%,49%  { opacity: 1;   }
    50%,100%{ opacity: 0.2; }
  }
  .atec-timer-badge {
    animation: atecTimerBlink 0.9s step-end infinite;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
</style>

<script>
  ;(function() {
    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string

    async function loadStrip() {
      if (!SB_URL || !SB_KEY) return

      try {
        const res  = await fetch(
          `${SB_URL}/rest/v1/site_settings?key=eq.announcement_strip&select=value`,
          { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
        )
        const rows = await res.json()
        if (!rows?.length) return

        const s = rows[0].value
        if (!s?.is_active) return

        const strip = document.getElementById('announcement-strip') as HTMLElement
        const inner = document.getElementById('strip-inner')        as HTMLElement

        strip.style.background = s.bg_color || '#1c3d7a'
        strip.style.padding    = '8px 20px'
        strip.style.display    = 'block'

        // ── Timer ─────────────────────────────────────────────────────────
        // class="atec-timer-badge" picks up the global blink animation
        let timerHtml = ''
        if (s.show_timer && s.ends_at) {
          const end = new Date(s.ends_at).getTime()

          const tick = () => {
            const diff = end - Date.now()
            if (diff <= 0) return
            const d   = Math.floor(diff / 86400000)
            const h   = Math.floor((diff % 86400000) / 3600000)
            const m   = Math.floor((diff % 3600000)  / 60000)
            const sec = Math.floor((diff % 60000)    / 1000)
            const el  = document.getElementById('strip-timer')
            if (el) el.textContent = `${d}d ${h}h ${m}m ${sec}s`
          }

          setInterval(tick, 1000)
          tick()

          timerHtml = `<span
            class="atec-timer-badge"
            style="background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.25);border-radius:5px;padding:2px 10px;font-weight:800;font-size:12px;color:#d4f01a;font-family:monospace;flex-shrink:0;"
          >⏱ <span id="strip-timer">--</span></span>`
        }

        // ── Link box ──────────────────────────────────────────────────────
        let linkHtml = ''
        if (s.link && s.link_text) {
          linkHtml = `<a href="${s.link}"
            style="display:inline-flex;align-items:center;background:${s.box_bg_color||'rgba(255,255,255,0.15)'};border:1px solid ${s.box_border_color||'rgba(255,255,255,0.3)'};border-radius:5px;padding:3px 12px;font-size:12px;font-weight:700;color:${s.box_text_color||'#d4f01a'};text-decoration:none;white-space:nowrap;flex-shrink:0;"
            onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'"
          >${s.link_text}</a>`
        }

        inner.style.cssText = 'display:flex;align-items:center;justify-content:center;gap:10px;flex-wrap:wrap;max-width:1200px;margin:0 auto;'
        inner.innerHTML = `
          <span style="font-size:13px;font-weight:600;color:${s.text_color||'#fff'};display:inline-flex;align-items:center;gap:7px;">
            <span>🔥</span><span>${s.text||''}</span>
          </span>
          ${timerHtml}
          ${linkHtml}
        `
      } catch(e) {
        console.warn('[ATEC] Strip load failed:', e)
      }
    }

    loadStrip()
  })()
</script>
