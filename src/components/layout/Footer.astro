---
// src/components/layout/Footer.astro
import { supabase } from '../../lib/supabase'

const { data: socialData } = await supabase
  .from('site_settings')
  .select('value')
  .eq('key', 'social_links')
  .single()

const social = (socialData?.value as Record<string, string>) ?? {}
const currentYear = new Date().getFullYear()
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <div class="footer-logo-mark">A</div>
          <div>
            <div class="footer-logo-name">ATEC</div>
            <div class="footer-logo-sub">Educational Society</div>
          </div>
        </a>
        <p class="footer-desc">
          Turning Students Into Professionals Since 2000.
          ISO 9001:2015 certified institute, Gurdaspur, Punjab.
        </p>
        <div class="footer-contact">
          <a href="tel:+917009933289" class="contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            +91 7009933289
          </a>
          <a href="mailto:atecgsp@gmail.com" class="contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            atecgsp@gmail.com
          </a>
          <div class="contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Hardochanni Road, Gurdaspur 143521, Punjab
          </div>
        </div>
        <!-- Social icons -->
        <div class="social-row">
          {social.youtube && (
            <a href={social.youtube} target="_blank" rel="noopener" class="social-icon" aria-label="YouTube">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          )}
          {social.instagram && (
            <a href={social.instagram} target="_blank" rel="noopener" class="social-icon" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          )}
          {social.facebook && (
            <a href={social.facebook} target="_blank" rel="noopener" class="social-icon" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
          )}
          {social.whatsapp && (
            <a href={`https://wa.me/${social.whatsapp.replace(/\D/g,'')}`} target="_blank" rel="noopener" class="social-icon" aria-label="WhatsApp">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
          )}
        </div>
      </div>

      <!-- Courses -->
      <div class="footer-col">
        <h4 class="footer-col-title">Courses</h4>
        <ul class="footer-links">
          <li><a href="/courses">All Courses</a></li>
          <li><a href="/courses/hardware-networking">Hardware & Networking</a></li>
          <li><a href="/courses/web-designing">Web Designing</a></li>
          <li><a href="/courses/tally">Tally ERP 9 / Prime</a></li>
          <li><a href="/courses/chip-level-repair">Chip-Level Repair</a></li>
          <li><a href="/courses/linux-administrator">Linux Administrator</a></li>
        </ul>
      </div>

      <!-- Institute -->
      <div class="footer-col">
        <h4 class="footer-col-title">Institute</h4>
        <ul class="footer-links">
          <li><a href="/about">About ATEC</a></li>
          <li><a href="/centres">Our Centres</a></li>
          <li><a href="/verification">Verify Certificate</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact">Contact Us</a></li>
        </ul>
      </div>

      <!-- Student -->
      <div class="footer-col">
        <h4 class="footer-col-title">Student</h4>
        <ul class="footer-links">
          <li><a href="/login">Student Login</a></li>
          <li><a href="/signup">Create Account</a></li>
          <li><a href="/dashboard">My Dashboard</a></li>
          <li><a href="/dashboard/certificates">My Certificates</a></li>
        </ul>
        <div class="footer-badge">
          <div class="iso-badge">
            <span class="iso-icon">✓</span>
            <span>ISO 9001:2015 Certified</span>
          </div>
        </div>
      </div>

    </div>

    <div class="footer-bottom">
      <span>© {currentYear} ATEC Educational Society. All rights reserved.</span>
      <div class="footer-bottom-links">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Use</a>
        <a href="/refund">Refund Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
.footer {
  background: #0b1f3f;
  color: rgba(255,255,255,0.85);
  padding: 64px 0 0;
}
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  padding-bottom: 48px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
@media (max-width: 1024px) {
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
}
@media (max-width: 640px) {
  .footer-grid { grid-template-columns: 1fr; gap: 28px; }
}

.footer-logo {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 16px; text-decoration: none;
}
.footer-logo-mark {
  width: 36px; height: 36px;
  background: var(--navy);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-weight: 800; font-size: 16px;
  color: var(--lemon);
}
.footer-logo-name {
  font-family: var(--font-display);
  font-weight: 800; font-size: 18px;
  color: #fff; line-height: 1.1;
}
.footer-logo-sub { font-size: 10px; color: rgba(255,255,255,0.45); }

.footer-desc {
  font-size: 13px; color: rgba(255,255,255,0.55);
  line-height: 1.6; margin-bottom: 20px;
}
.footer-contact { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
.contact-item {
  display: flex; align-items: flex-start; gap: 8px;
  font-size: 13px; color: rgba(255,255,255,0.65);
  text-decoration: none;
}
.contact-item:hover { color: var(--lemon); }
.contact-item svg { flex-shrink: 0; margin-top: 1px; }

.social-row { display: flex; gap: 8px; }
.social-icon {
  width: 34px; height: 34px;
  border-radius: 8px;
  background: rgba(255,255,255,0.08);
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.7);
  transition: all 0.2s;
}
.social-icon:hover { background: var(--lemon); color: var(--navy); }

.footer-col-title {
  font-family: var(--font-display);
  font-size: 13px; font-weight: 700;
  color: #fff; text-transform: uppercase;
  letter-spacing: 0.8px; margin-bottom: 16px;
}
.footer-links { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.footer-links a {
  font-size: 13px; color: rgba(255,255,255,0.55);
  transition: color 0.15s;
}
.footer-links a:hover { color: var(--lemon); }

.footer-badge { margin-top: 20px; }
.iso-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(212,240,26,0.12);
  border: 1px solid rgba(212,240,26,0.25);
  padding: 8px 14px; border-radius: 8px;
  font-size: 12px; font-weight: 600;
  color: var(--lemon);
}
.iso-icon {
  width: 18px; height: 18px;
  background: var(--lemon); color: var(--navy);
  border-radius: 50%; display: inline-flex;
  align-items: center; justify-content: center;
  font-size: 11px; font-weight: 800;
}

.footer-bottom {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 0;
  font-size: 12px; color: rgba(255,255,255,0.35);
  flex-wrap: wrap; gap: 12px;
}
.footer-bottom-links { display: flex; gap: 20px; }
.footer-bottom-links a { color: rgba(255,255,255,0.35); }
.footer-bottom-links a:hover { color: var(--lemon); }
</style>
