---
// src/pages/dashboard/course/[slug].astro
// Full-screen course player — uses bare HTML, NO public Navbar (it has its own top bar)
import { supabase } from '../../../lib/supabase'

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL || ''
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || ''

export async function getStaticPaths() {
  const { data } = await supabase.from('courses').select('slug').eq('is_active', true)
  // Fallback slugs so build doesn't fail when DB is empty
  const fallback = [{ params: { slug: 'placeholder' } }]
  if (!data || data.length === 0) return fallback
  return data.map(c => ({ params: { slug: c.slug } }))
}

const { slug } = Astro.params
const { data: course } = await supabase
  .from('courses')
  .select('id,title,thumbnail_url,mode')
  .eq('slug', slug)
  .single()

if (!course) return Astro.redirect('/dashboard/my-courses', 302)

import CoursePlayer from '../../../components/lms/CoursePlayer'
---

<!DOCTYPE html>
<html lang="en-IN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{course.title} — ATEC Learning</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <script define:vars={{ SUPABASE_URL, SUPABASE_KEY }}>
    window.__SB_URL = SUPABASE_URL
    window.__SB_KEY = SUPABASE_KEY
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; }
    body { font-family: 'Inter', sans-serif; background: #0f172a; }
    #root { height: 100vh; }
    :root {
      --font-display: 'Sora', sans-serif;
      --font-body: 'Inter', sans-serif;
    }
  </style>
</head>
<body>
  <div id="root">
    <CoursePlayer
      client:load
      courseId={course.id}
      courseTitle={course.title}
      courseSlug={slug}
    />
  </div>
</body>
</html>
