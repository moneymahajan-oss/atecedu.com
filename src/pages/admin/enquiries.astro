---
// src/pages/admin/enquiries.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="Enquiries" activeSection="enquiries">
  <div id="root"></div>
</AdminLayout>
<script>
import { createClient } from '@supabase/supabase-js'
import { createElement as h, useState, useEffect } from 'react'
import { createRoot } from 'react-dom/client'
const sb = createClient(window.__SB_URL, window.__SB_KEY)

function Mgr() {
  const [rows, setRows] = useState([])
  const [loading, setLoading] = useState(true)
  const [filter, setFilter] = useState('all')
  const [search, setSearch] = useState('')

  useEffect(() => { load() }, [])
  async function load() {
    const { data } = await sb.from('enquiries').select('*').order('created_at', { ascending: false })
    setRows(data ?? []); setLoading(false)
  }
  async function markContacted(id, cur) {
    await sb.from('enquiries').update({is_contacted: !cur}).eq('id', id)
    setRows(p => p.map(r => r.id===id ? {...r, is_contacted: !cur} : r))
  }
  async function deleteEnquiry(id) {
    if (!confirm('Delete this enquiry?')) return
    await sb.from('enquiries').delete().eq('id', id)
    setRows(p => p.filter(r => r.id !== id))
  }

  const filtered = rows.filter(r => {
    const matchFilter = filter==='all' || (filter==='pending' && !r.is_contacted) || (filter==='contacted' && r.is_contacted)
    const q = search.toLowerCase()
    const matchSearch = !q || r.name?.toLowerCase().includes(q) || r.phone?.includes(q) || r.email?.toLowerCase().includes(q) || r.course_interest?.toLowerCase().includes(q)
    return matchFilter && matchSearch
  })
  const pending = rows.filter(r => !r.is_contacted).length

  return h('div',{style:{display:'flex',flexDirection:'column',gap:'20px'}},
    h('div',{style:{display:'flex',justifyContent:'space-between',alignItems:'center',flexWrap:'wrap',gap:'12px'}},
      h('div',{},
        h('h1',{style:{fontFamily:'Sora,sans-serif',fontSize:'1.5rem',fontWeight:'800'}},'💬 Enquiries & Leads'),
        pending > 0 && h('span',{style:{background:'#fee2e2',color:'#991b1b',fontSize:'12px',fontWeight:'700',padding:'2px 10px',borderRadius:'12px',marginTop:'4px',display:'inline-block'}},`${pending} pending`)
      ),
      h('button',{onClick:load,style:{padding:'8px 16px',background:'#f8fafc',border:'1px solid #e2e8f0',borderRadius:'8px',fontWeight:'600',fontSize:'13px',cursor:'pointer'}},'🔄 Refresh')
    ),
    h('div',{style:{display:'flex',gap:'10px',flexWrap:'wrap',alignItems:'center'}},
      h('input',{type:'text',placeholder:'🔍 Search name, phone, email...',value:search,onChange:e=>setSearch(e.target.value),
        style:{flex:1,minWidth:'200px',padding:'9px 14px',border:'1px solid #e2e8f0',borderRadius:'10px',fontSize:'14px',outline:'none'}}),
      ...['all','pending','contacted'].map(f =>
        h('button',{key:f,onClick:()=>setFilter(f),
          style:{padding:'8px 16px',borderRadius:'24px',border:'1.5px solid',fontSize:'13px',fontWeight:'500',cursor:'pointer',
            background:filter===f?'#1c3d7a':'#fff',color:filter===f?'#fff':'#64748b',borderColor:filter===f?'#1c3d7a':'#e2e8f0'}
        }, f.charAt(0).toUpperCase()+f.slice(1))
      ),
      h('span',{style:{fontSize:'13px',color:'#94a3b8'}},`${filtered.length} results`)
    ),
    h('div',{style:{background:'#fff',borderRadius:'14px',border:'1px solid #e2e8f0',overflow:'hidden'}},
      loading
        ? h('div',{style:{padding:'40px',textAlign:'center',color:'#94a3b8'}},'Loading...')
        : filtered.length===0
          ? h('div',{style:{padding:'40px',textAlign:'center',color:'#94a3b8'}},'No enquiries found.')
          : h('div',{style:{overflowX:'auto'}},
              h('table',{style:{width:'100%',borderCollapse:'collapse',fontSize:'13px'}},
                h('thead',{},h('tr',{style:{background:'#f8fafc',borderBottom:'1px solid #e2e8f0'}},
                  ...['Name','Phone','Email','Course Interest','Message','Date','Status','Actions'].map(col =>
                    h('th',{key:col,style:{padding:'12px 16px',textAlign:'left',fontWeight:'700',color:'#475569',fontSize:'12px',textTransform:'uppercase',letterSpacing:'0.5px',whiteSpace:'nowrap'}},col)
                  )
                )),
                h('tbody',{},...filtered.map(r =>
                  h('tr',{key:r.id,style:{borderBottom:'1px solid #f1f5f9',background:r.is_contacted?'#fff':'#fefce8'}},
                    h('td',{style:{padding:'12px 16px',fontWeight:'600'}},r.name),
                    h('td',{style:{padding:'12px 16px'}},h('a',{href:`tel:${r.phone}`,style:{color:'#1c3d7a',fontWeight:'600'}},r.phone)),
                    h('td',{style:{padding:'12px 16px',color:'#64748b'}},r.email||'—'),
                    h('td',{style:{padding:'12px 16px'}},r.course_interest||'—'),
                    h('td',{style:{padding:'12px 16px',color:'#64748b',maxWidth:'200px'}},
                      h('span',{style:{display:'block',whiteSpace:'nowrap',overflow:'hidden',textOverflow:'ellipsis',maxWidth:'180px'}},r.message||'—')
                    ),
                    h('td',{style:{padding:'12px 16px',color:'#94a3b8',fontSize:'12px',whiteSpace:'nowrap'}},
                      new Date(r.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'})
                    ),
                    h('td',{style:{padding:'12px 16px'}},
                      h('span',{style:{background:r.is_contacted?'#dcfce7':'#fef9c3',color:r.is_contacted?'#166534':'#713f12',fontSize:'11px',fontWeight:'700',padding:'3px 10px',borderRadius:'12px'}},
                        r.is_contacted?'✅ Contacted':'⏳ Pending'
                      )
                    ),
                    h('td',{style:{padding:'12px 16px',whiteSpace:'nowrap'}},
                      h('div',{style:{display:'flex',gap:'6px'}},
                        h('button',{onClick:()=>markContacted(r.id,r.is_contacted),
                          style:{padding:'5px 10px',background:r.is_contacted?'#fef9c3':'#dcfce7',color:r.is_contacted?'#713f12':'#166534',border:'none',borderRadius:'6px',fontSize:'11px',fontWeight:'600',cursor:'pointer'}},
                          r.is_contacted?'↩ Unmark':'✅ Mark Done'
                        ),
                        h('a',{href:`https://wa.me/${r.phone?.replace(/\D/g,'')}?text=Hi ${r.name}, regarding your enquiry about ${r.course_interest||'ATEC courses'}`,
                          target:'_blank',rel:'noopener',
                          style:{padding:'5px 10px',background:'#dcfce7',color:'#166534',borderRadius:'6px',fontSize:'11px',fontWeight:'600',textDecoration:'none'}},
                          '💬 WhatsApp'
                        )
                      )
                    )
                  )
                ))
              )
            )
    )
  )
}
createRoot(document.getElementById('root')).render(h(Mgr,null))
</script>
