---
// src/pages/admin/blog.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="Blog Manager" activeSection="blog">
  <div id="blog-root"></div>
</AdminLayout>

<script>
import { createClient } from '@supabase/supabase-js'
import { createElement as h, useState, useEffect } from 'react'
import { createRoot } from 'react-dom/client'

const supabase = createClient(window.__SB_URL, window.__SB_KEY)

interface Post {
  id: string; title: string; slug: string; excerpt: string | null
  category: string | null; author: string | null; is_published: boolean
  published_at: string | null; read_time_mins: number | null
  thumbnail_url: string | null; tags: string[] | null
}

const EMPTY: Partial<Post> & { content: string; meta_title: string; meta_description: string } = {
  title: '', slug: '', excerpt: '', content: '', category: 'Career Guide',
  author: 'ATEC Team', is_published: false, read_time_mins: 5,
  thumbnail_url: '', tags: [], meta_title: '', meta_description: '',
}

function BlogManager() {
  const [posts, setPosts] = useState<Post[]>([])
  const [loading, setLoading] = useState(true)
  const [showForm, setShowForm] = useState(false)
  const [editId, setEditId] = useState<string | null>(null)
  const [form, setForm] = useState<typeof EMPTY>({ ...EMPTY })
  const [saving, setSaving] = useState(false)
  const [tagsInput, setTagsInput] = useState('')

  useEffect(() => { load() }, [])

  async function load() {
    const { data } = await supabase.from('blog_posts')
      .select('id,title,slug,excerpt,category,author,is_published,published_at,read_time_mins,thumbnail_url,tags')
      .order('created_at', { ascending: false })
    setPosts(data ?? [])
    setLoading(false)
  }

  function openAdd() {
    setForm({ ...EMPTY }); setEditId(null); setTagsInput(''); setShowForm(true)
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }

  async function openEdit(post: Post) {
    const { data } = await supabase.from('blog_posts').select('*').eq('id', post.id).single()
    setForm({ ...EMPTY, ...data })
    setTagsInput((data?.tags ?? []).join(', '))
    setEditId(post.id); setShowForm(true)
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }

  const upd = (f: string, v: unknown) => setForm((p: typeof EMPTY) => ({ ...p, [f]: v }))

  async function save() {
    setSaving(true)
    const tags = tagsInput ? tagsInput.split(',').map((t: string) => t.trim()).filter(Boolean) : []
    let slug = form.slug || (form.title ?? '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')
    const payload = {
      ...form, slug, tags,
      published_at: form.is_published ? (form.published_at || new Date().toISOString()) : null,
    }
    if (editId) {
      await supabase.from('blog_posts').update(payload).eq('id', editId)
    } else {
      await supabase.from('blog_posts').insert(payload)
    }
    setSaving(false); setShowForm(false); load()
  }

  async function togglePublish(id: string, current: boolean) {
    await supabase.from('blog_posts').update({
      is_published: !current,
      published_at: !current ? new Date().toISOString() : null
    }).eq('id', id)
    setPosts((p: Post[]) => p.map((x: Post) => x.id === id ? { ...x, is_published: !current } : x))
  }

  const s = { width: '100%', padding: '9px 12px', border: '1px solid #e2e8f0', borderRadius: '8px', fontSize: '13px', outline: 'none', boxSizing: 'border-box' as const, fontFamily: 'Inter, sans-serif' }
  const lbl = (text: string) => h('label', { style: { fontSize: '12px', fontWeight: '600', color: '#475569', display: 'block', marginBottom: '5px' } }, text)

  return h('div', { style: { display: 'flex', flexDirection: 'column', gap: '20px' } },
    h('div', { style: { display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: '12px' } },
      h('h1', { style: { fontFamily: 'Sora, sans-serif', fontSize: '1.5rem', fontWeight: '800' } }, '✍️ Blog Manager'),
      h('button', { onClick: openAdd, style: { padding: '10px 22px', background: '#1c3d7a', color: '#fff', border: 'none', borderRadius: '10px', fontWeight: '700', fontSize: '14px', cursor: 'pointer' } }, '+ New Post')
    ),

    showForm && h('div', { style: { background: '#fff', borderRadius: '16px', border: '2px solid #1c3d7a', padding: '28px' } },
      h('div', { style: { display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '20px' } },
        h('h2', { style: { fontFamily: 'Sora, sans-serif', fontWeight: '700', fontSize: '16px' } }, editId ? '✏️ Edit Post' : '➕ New Post'),
        h('button', { onClick: () => setShowForm(false), style: { background: 'none', border: 'none', fontSize: '20px', cursor: 'pointer', color: '#94a3b8' } }, '✕')
      ),
      h('div', { style: { display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '14px' } },
        ...[
          { label: 'Title *', field: 'title', span: 2 },
          { label: 'Slug (auto-generated)', field: 'slug' },
          { label: 'Category', field: 'category' },
          { label: 'Author', field: 'author' },
          { label: 'Read Time (mins)', field: 'read_time_mins', type: 'number' },
          { label: 'Thumbnail URL', field: 'thumbnail_url', span: 2 },
          { label: 'Excerpt', field: 'excerpt', span: 2 },
          { label: 'Tags (comma separated)', field: '_tags', span: 2 },
          { label: 'Meta Title (SEO)', field: 'meta_title', span: 2 },
          { label: 'Meta Description (SEO)', field: 'meta_description', span: 2 },
        ].map(({ label, field, type, span }) =>
          h('div', { key: field, style: { gridColumn: span === 2 ? '1 / -1' : 'auto' } },
            lbl(label),
            field === '_tags'
              ? h('input', { type: 'text', value: tagsInput, onChange: (e: Event) => setTagsInput((e.target as HTMLInputElement).value), placeholder: 'hardware, career, networking', style: s })
              : h('input', { type: type ?? 'text', value: (form as Record<string, unknown>)[field] ?? '', onChange: (e: Event) => upd(field, (e.target as HTMLInputElement).value), style: s })
          )
        ),
        h('div', { style: { gridColumn: '1 / -1' } },
          lbl('Content (HTML allowed)'),
          h('textarea', {
            value: (form as Record<string, unknown>).content ?? '',
            onChange: (e: Event) => upd('content', (e.target as HTMLTextAreaElement).value),
            rows: 12,
            style: { ...s, height: 'auto', resize: 'vertical' }
          })
        ),
        h('div', { style: { display: 'flex', alignItems: 'center', gap: '10px' } },
          h('input', { type: 'checkbox', checked: !!form.is_published, onChange: (e: Event) => upd('is_published', (e.target as HTMLInputElement).checked), style: { width: '16px', height: '16px', accentColor: '#1c3d7a' } }),
          lbl('Published (visible on website)')
        )
      ),
      h('div', { style: { display: 'flex', gap: '10px', marginTop: '20px' } },
        h('button', { onClick: save, disabled: saving, style: { flex: 1, padding: '12px', background: saving ? '#94a3b8' : '#1c3d7a', color: '#fff', border: 'none', borderRadius: '10px', fontWeight: '700', fontSize: '14px', cursor: saving ? 'not-allowed' : 'pointer' } },
          saving ? 'Saving...' : editId ? '✅ Update Post' : '✅ Publish Post'
        ),
        h('button', { onClick: () => setShowForm(false), style: { padding: '12px 20px', border: '1px solid #e2e8f0', borderRadius: '10px', background: '#fff', fontWeight: '600', fontSize: '14px', cursor: 'pointer' } }, 'Cancel')
      )
    ),

    h('div', { style: { background: '#fff', borderRadius: '14px', border: '1px solid #e2e8f0', overflow: 'hidden' } },
      loading
        ? h('div', { style: { padding: '40px', textAlign: 'center', color: '#94a3b8' } }, 'Loading...')
        : posts.length === 0
          ? h('div', { style: { padding: '40px', textAlign: 'center', color: '#94a3b8' } }, 'No posts yet. Click "New Post" to add your first article.')
          : h('div', { style: { overflowX: 'auto' } },
              h('table', { style: { width: '100%', borderCollapse: 'collapse', fontSize: '13px' } },
                h('thead', {},
                  h('tr', { style: { background: '#f8fafc', borderBottom: '1px solid #e2e8f0' } },
                    ...['Title', 'Category', 'Author', 'Status', 'Published', 'Actions'].map(hdr =>
                      h('th', { key: hdr, style: { padding: '12px 16px', textAlign: 'left', fontWeight: '700', color: '#475569', fontSize: '12px', textTransform: 'uppercase', letterSpacing: '0.5px', whiteSpace: 'nowrap' } }, hdr)
                    )
                  )
                ),
                h('tbody', {},
                  ...posts.map((post: Post) =>
                    h('tr', { key: post.id, style: { borderBottom: '1px solid #f1f5f9' } },
                      h('td', { style: { padding: '12px 16px', maxWidth: '280px' } },
                        h('div', { style: { fontWeight: '600', color: '#1e293b' } }, post.title),
                        h('div', { style: { fontSize: '11px', color: '#94a3b8', marginTop: '2px' } }, post.slug)
                      ),
                      h('td', { style: { padding: '12px 16px', color: '#64748b' } }, post.category ?? '—'),
                      h('td', { style: { padding: '12px 16px', color: '#64748b' } }, post.author ?? 'ATEC Team'),
                      h('td', { style: { padding: '12px 16px' } },
                        h('button', {
                          onClick: () => togglePublish(post.id, post.is_published),
                          style: { background: post.is_published ? '#dcfce7' : '#fee2e2', color: post.is_published ? '#166534' : '#991b1b', border: 'none', borderRadius: '6px', padding: '4px 10px', fontSize: '11px', fontWeight: '700', cursor: 'pointer' }
                        }, post.is_published ? '✅ Published' : '⭕ Draft')
                      ),
                      h('td', { style: { padding: '12px 16px', color: '#64748b', fontSize: '12px', whiteSpace: 'nowrap' } },
                        post.published_at ? new Date(post.published_at).toLocaleDateString('en-IN') : '—'
                      ),
                      h('td', { style: { padding: '12px 16px', whiteSpace: 'nowrap' } },
                        h('div', { style: { display: 'flex', gap: '6px' } },
                          h('button', { onClick: () => openEdit(post), style: { padding: '5px 12px', background: '#eff6ff', color: '#1c3d7a', border: 'none', borderRadius: '6px', fontSize: '12px', fontWeight: '600', cursor: 'pointer' } }, '✏️ Edit'),
                          h('a', { href: `/blog/${post.slug}`, target: '_blank', style: { padding: '5px 10px', background: '#f0fdf4', color: '#166534', border: 'none', borderRadius: '6px', fontSize: '12px', fontWeight: '600', textDecoration: 'none', display: 'inline-block' } }, '👁 View')
                        )
                      )
                    )
                  )
                )
              )
            )
    )
  )
}

const root = createRoot(document.getElementById('blog-root')!)
root.render(h(BlogManager, null))
</script>
