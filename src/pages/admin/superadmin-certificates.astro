---
// src/pages/admin/superadmin-certificates.astro
// NEW PAGE — Superadmin Certificate Management (does NOT modify any existing file)
// Features:
//   ✅ View all certificates with search + pagination
//   ✅ Add / Edit certificate
//   ✅ Bulk CSV upload with duplicate detection + preview
//   ✅ Download single or all certificates (password-gated)
//   ✅ Delete (deactivate) single or bulk — requires password + type "DELETE"
//   ✅ Full Audit Log with date/time, action, cert no, student, admin, notes
//   ✅ Export audit log as CSV
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="Superadmin – Certificates" activeSection="superadmin-certificates">
  <div id="sa-root"></div>
</AdminLayout>

<script>
import { createClient } from '@supabase/supabase-js'

// waitSB: window.__SB_URL is injected by AdminLayout after DOM ready
function waitSB(cb) {
  if (window.__SB_URL && window.__SB_KEY) { cb(); return }
  const t = setInterval(() => {
    if (window.__SB_URL && window.__SB_KEY) { clearInterval(t); cb() }
  }, 80)
}

waitSB(() => {
  const sb = createClient(window.__SB_URL, window.__SB_KEY)
  mountApp(sb)
})

function mountApp(sb) {

// ─── Passwords ────────────────────────────────────────────────────────────────
// Change these after deployment via Supabase site_settings or env if preferred
const PWD_DOWNLOAD = 'ATEC@Download2024'
const PWD_DELETE   = 'ATEC@Delete2024'
const PAGE_SIZE    = 25
const AUDIT_SIZE   = 50

// ─── State ────────────────────────────────────────────────────────────────────
let S = {
  tab: 'list',
  certs: [], totalCount: 0, page: 1, search: '', loading: false,
  form: emptyForm(), editId: null, formSaving: false, formError: '', formSuccess: '',
  csvRows: [], csvPreview: false, csvError: '', csvSuccess: '', csvLoading: false, csvDuplicates: [],
  dlModal: null, dlPwd: '', dlError: '', dlLoading: false,
  delModal: null, delPwd: '', delWord: '', delError: '', delLoading: false,
  selected: new Set(),
  bulkDelModal: false, bulkDelPwd: '', bulkDelWord: '', bulkDelError: '', bulkDelLoading: false,
  auditRows: [], auditTotal: 0, auditPage: 1, auditFilter: '', auditLoading: false,
}

function emptyForm() {
  return {
    certificate_no:'', batch_id:'', student_name:'', father_name:'', mother_name:'',
    course_name:'', course_duration:'', grade:'', marks_obtained:'', total_marks:'',
    from_date:'', issue_date:'', center_name:'ATEC Gurdaspur', is_active:true,
  }
}

function setState(patch) { Object.assign(S, patch); render() }

// ─── Formatters ───────────────────────────────────────────────────────────────
function fmt(d) {
  if (!d) return '—'
  try { return new Date(d).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) }
  catch { return d }
}
function fmtDT(d) {
  if (!d) return '—'
  try { return new Date(d).toLocaleString('en-IN', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:true }) }
  catch { return d }
}
function clean(v) { return (v||'').trim().slice(0,300) }

// ─── Audit logger ─────────────────────────────────────────────────────────────
async function logAudit(action, certNo, studentName, oldData, newData, count=1, notes='') {
  try {
    await sb.from('certificate_audit_log').insert([{
      action, certificate_no:certNo||'', student_name:studentName||'',
      old_data:oldData||null, new_data:newData||null, records_count:count,
      performed_by: window.__CURRENT_USER_EMAIL || 'superadmin', notes,
    }])
  } catch(e) { /* non-fatal */ }
}

// ─── Data loaders ─────────────────────────────────────────────────────────────
async function loadCerts(pg, q) {
  setState({ loading:true })
  const from=(pg-1)*PAGE_SIZE, to=from+PAGE_SIZE-1
  let query = sb.from('certificates').select('*',{count:'exact'})
    .order('created_at',{ascending:false}).range(from,to)
  if (q && q.trim())
    query = query.or(`certificate_no.ilike.%${q}%,student_name.ilike.%${q}%,batch_id.ilike.%${q}%,father_name.ilike.%${q}%,course_name.ilike.%${q}%`)
  const { data, count, error } = await query
  if (!error && data) setState({ certs:data, totalCount:count||0, loading:false })
  else setState({ loading:false })
}

async function loadAudit(pg, filter) {
  setState({ auditLoading:true })
  const from=(pg-1)*AUDIT_SIZE, to=from+AUDIT_SIZE-1
  let q = sb.from('certificate_audit_log').select('*',{count:'exact'})
    .order('performed_at',{ascending:false}).range(from,to)
  if (filter && filter.trim())
    q = q.or(`certificate_no.ilike.%${filter}%,student_name.ilike.%${filter}%,action.ilike.%${filter}%`)
  const { data, count } = await q
  setState({ auditRows:data||[], auditTotal:count||0, auditLoading:false })
}

// ─── Form save ────────────────────────────────────────────────────────────────
async function saveForm() {
  const f = S.form
  if (!f.certificate_no.trim()) return setState({ formError:'Certificate Number is required.' })
  if (!f.student_name.trim())   return setState({ formError:'Student Name is required.' })
  if (!f.father_name.trim())    return setState({ formError:"Father's Name is required." })
  if (!f.course_name.trim())    return setState({ formError:'Course Name is required.' })
  const payload = {
    certificate_no:  clean(f.certificate_no),
    batch_id:        clean(f.batch_id)||null,
    student_name:    clean(f.student_name),
    father_name:     clean(f.father_name),
    mother_name:     clean(f.mother_name)||null,
    course_name:     clean(f.course_name),
    course_duration: clean(f.course_duration)||null,
    grade:           clean(f.grade)||null,
    marks_obtained:  f.marks_obtained!=='' ? Number(f.marks_obtained):null,
    total_marks:     f.total_marks!==''    ? Number(f.total_marks)   :null,
    from_date:       f.from_date||null,
    issue_date:      f.issue_date||null,
    center_name:     clean(f.center_name)||'ATEC Gurdaspur',
    is_active:       f.is_active,
  }
  setState({ formSaving:true, formError:'', formSuccess:'' })
  try {
    if (S.editId) {
      const { data:old } = await sb.from('certificates').select('*').eq('id',S.editId).single()
      const { error } = await sb.from('certificates').update(payload).eq('id',S.editId)
      if (error) return setState({ formSaving:false, formError:error.message })
      await logAudit('UPDATE', payload.certificate_no, payload.student_name, old, payload)
      setState({ formSaving:false, formSuccess:`✓ Certificate ${payload.certificate_no} updated.`, editId:null, form:emptyForm() })
    } else {
      const { error } = await sb.from('certificates').insert([payload])
      if (error) return setState({ formSaving:false, formError: error.code==='23505' ? `Certificate "${payload.certificate_no}" already exists.` : error.message })
      await logAudit('INSERT', payload.certificate_no, payload.student_name, null, payload)
      setState({ formSaving:false, formSuccess:`✓ Certificate ${payload.certificate_no} added.`, form:emptyForm() })
    }
    loadCerts(S.page, S.search)
  } finally { setState({ formSaving:false }) }
}

// ─── CSV ──────────────────────────────────────────────────────────────────────
const COL_MAP = {
  certificate_no:'certificate_no','cert_no':'certificate_no','certificate number':'certificate_no',
  batch_id:'batch_id','batch id':'batch_id','student id':'batch_id',
  student_name:'student_name',name:'student_name','student name':'student_name',
  father_name:'father_name','father name':'father_name',fname:'father_name',
  mother_name:'mother_name','mother name':'mother_name',
  course_name:'course_name',course:'course_name','course name':'course_name',
  course_duration:'course_duration',duration:'course_duration',
  grade:'grade',
  marks_obtained:'marks_obtained',marks:'marks_obtained','obtained marks':'marks_obtained',
  total_marks:'total_marks','total marks':'total_marks',
  from_date:'from_date','from date':'from_date',
  issue_date:'issue_date',date:'issue_date','issue date':'issue_date',to_date:'issue_date','to date':'issue_date',
  center_name:'center_name',center:'center_name',
}

function parseCSV(text) {
  const lines = text.replace(/\r\n/g,'\n').replace(/\r/g,'\n').split('\n').filter(l=>l.trim())
  if (lines.length<2) return []
  const headers = lines[0].split(',').map(h=>h.trim().replace(/^"|"$/g,'').toLowerCase())
  return lines.slice(1).filter(l=>l.trim()).map(line=>{
    const cols=[]; let cur='',inQ=false
    for(const ch of line){
      if(ch==='"') inQ=!inQ
      else if(ch===','&&!inQ){cols.push(cur.trim());cur=''}
      else cur+=ch
    }
    cols.push(cur.trim())
    const row = { center_name:'ATEC Gurdaspur', is_active:true }
    headers.forEach((h,i)=>{
      const col=COL_MAP[h]
      if(col && cols[i]!==undefined){
        const v = cols[i].replace(/^"|"$/g,'').trim()
        if(col==='marks_obtained'||col==='total_marks') (row)[col]=v?Number(v):null
        else (row)[col]=v
      }
    })
    return row
  })
}

function handleCSVFile(file) {
  if(!file||!file.name.match(/\.csv$/i)) return setState({csvError:'Only .csv files accepted. Export Excel as CSV (File→Save As→CSV UTF-8).'})
  const reader=new FileReader()
  reader.onload=ev=>{
    const rows=parseCSV(ev.target.result)
    if(!rows.length) return setState({csvError:'Could not parse CSV. Ensure first row has column headers.'})
    const missing=rows.filter(r=>!r.certificate_no?.trim())
    if(missing.length>rows.length*0.5) return setState({csvError:`${missing.length} rows missing certificate_no. Check column names.`})
    setState({csvRows:rows,csvPreview:true,csvError:'',csvSuccess:'',csvDuplicates:[]})
  }
  reader.readAsText(file)
}

async function uploadCSV() {
  setState({csvLoading:true,csvError:'',csvSuccess:''})
  const valid=S.csvRows.filter(r=>r.certificate_no?.trim()&&r.student_name?.trim())
  if(!valid.length) return setState({csvLoading:false,csvError:'No valid rows (need certificate_no + student_name).'})
  const nos=valid.map(r=>r.certificate_no)
  const {data:existing}=await sb.from('certificates').select('certificate_no').in('certificate_no',nos)
  const existingNos=(existing||[]).map(e=>e.certificate_no)
  if(existingNos.length) return setState({csvLoading:false,csvDuplicates:existingNos})
  let inserted=0
  for(let i=0;i<valid.length;i+=100){
    const batch=valid.slice(i,i+100)
    const {error}=await sb.from('certificates').insert(batch)
    if(error) return setState({csvLoading:false,csvError:`Batch failed at row ~${i+1}: ${error.message}`})
    inserted+=batch.length
  }
  await logAudit('CSV_IMPORT',`${inserted} records`,'Bulk CSV import',null,{count:inserted},inserted,`Bulk uploaded ${inserted} records`)
  setState({csvLoading:false,csvSuccess:`✓ ${inserted} certificates imported successfully.`,csvRows:[],csvPreview:false})
  loadCerts(1,S.search)
}

function skipDuplicates() {
  setState({csvRows:S.csvRows.filter(r=>!S.csvDuplicates.includes(r.certificate_no||'')),csvDuplicates:[]})
}

// ─── Download ─────────────────────────────────────────────────────────────────
async function doDownload() {
  if(S.dlPwd!==PWD_DOWNLOAD) return setState({dlError:'Wrong download password. Please try again.'})
  setState({dlLoading:true,dlError:''})
  let rows
  if(S.dlModal==='all'){
    const {data}=await sb.from('certificates').select('*').order('created_at',{ascending:false})
    rows=data||[]
    await logAudit('DOWNLOAD','ALL RECORDS','Full export',null,null,rows.length,'Full certificate database exported to CSV')
  } else {
    rows=[S.dlModal]
    await logAudit('DOWNLOAD',S.dlModal.certificate_no,S.dlModal.student_name,null,null,1,'Single certificate exported to CSV')
  }
  const cols=['certificate_no','batch_id','student_name','father_name','mother_name','course_name','course_duration','grade','marks_obtained','total_marks','from_date','issue_date','center_name','is_active','created_at']
  const csv=[cols.join(','),...rows.map(r=>cols.map(c=>{
    const v=r[c]??''; const s=String(v)
    return s.includes(',')||s.includes('"') ? `"${s.replace(/"/g,'""')}"`:s
  }).join(','))].join('\n')
  const blob=new Blob([csv],{type:'text/csv'})
  const url=URL.createObjectURL(blob)
  const a=document.createElement('a')
  a.href=url
  a.download=S.dlModal==='all' ? `ATEC_Certificates_${new Date().toISOString().slice(0,10)}.csv` : `ATEC_Cert_${S.dlModal.certificate_no}.csv`
  a.click()
  URL.revokeObjectURL(url)
  setState({dlLoading:false,dlModal:null,dlPwd:'',dlError:''})
}

// ─── Delete (deactivate) ──────────────────────────────────────────────────────
async function doDelete() {
  if(S.delPwd!==PWD_DELETE) return setState({delError:'Wrong delete password.'})
  if(S.delWord.trim().toUpperCase()!=='DELETE') return setState({delError:'You must type DELETE (all caps) in the confirmation box.'})
  setState({delLoading:true,delError:''})
  const cert=S.delModal
  const {data:old}=await sb.from('certificates').select('*').eq('id',cert.id).single()
  const {error}=await sb.from('certificates').update({is_active:false}).eq('id',cert.id)
  if(error) return setState({delLoading:false,delError:'Failed: '+error.message})
  await logAudit('DELETE',cert.certificate_no,cert.student_name,old,{is_active:false},1,'Certificate deactivated via superadmin delete panel')
  setState({delLoading:false,delModal:null,delPwd:'',delWord:'',delError:''})
  loadCerts(S.page,S.search)
}

async function doBulkDelete() {
  if(S.bulkDelPwd!==PWD_DELETE) return setState({bulkDelError:'Wrong delete password.'})
  if(S.bulkDelWord.trim().toUpperCase()!=='DELETE') return setState({bulkDelError:'You must type DELETE (all caps) in the confirmation box.'})
  setState({bulkDelLoading:true,bulkDelError:''})
  const ids=[...S.selected]
  const {error}=await sb.from('certificates').update({is_active:false}).in('id',ids)
  if(error) return setState({bulkDelLoading:false,bulkDelError:'Failed: '+error.message})
  await logAudit('BULK_DELETE',`${ids.length} records`,'Bulk deactivation',null,{is_active:false},ids.length,`Bulk deactivated ${ids.length} records`)
  setState({bulkDelLoading:false,bulkDelModal:false,bulkDelPwd:'',bulkDelWord:'',bulkDelError:'',selected:new Set()})
  loadCerts(S.page,S.search)
}

// ─── CSS-in-JS helpers ────────────────────────────────────────────────────────
function css(obj) { return Object.entries(obj).map(([k,v])=>`${k.replace(/([A-Z])/g,'-$1').toLowerCase()}:${v}`).join(';') }
const BASE = {
  card: 'background:#fff;border-radius:14px;border:1px solid #e2e8f0;padding:24px;margin-bottom:20px',
  input: 'width:100%;padding:9px 13px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;outline:none;box-sizing:border-box;font-family:inherit;background:#fff;color:#1e293b',
  label: 'font-size:11px;font-weight:700;color:#64748b;display:block;margin-bottom:5px;text-transform:uppercase;letter-spacing:0.5px',
  primBtn: 'padding:9px 20px;background:#1c3d7a;color:#fff;border:none;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;font-family:inherit',
  dangerBtn: 'padding:9px 20px;background:#dc2626;color:#fff;border:none;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;font-family:inherit',
  ghostBtn: 'padding:8px 16px;background:transparent;color:#64748b;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;cursor:pointer;font-family:inherit',
  successBox: 'background:#f0fdf4;border:1px solid #86efac;border-radius:8px;padding:10px 14px;color:#166534;font-size:13px;margin-bottom:12px',
  errorBox: 'background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:10px 14px;color:#dc2626;font-size:13px;margin-bottom:12px',
  th: 'padding:11px 14px;text-align:left;font-weight:700;color:#64748b;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;background:#f8fafc;border-bottom:1px solid #e2e8f0;white-space:nowrap',
  td: 'padding:11px 14px;color:#1e293b;font-size:13px;border-bottom:1px solid #f1f5f9;vertical-align:middle',
}

function gradeColor(g) {
  const u=(g||'').toUpperCase()
  if(u==='A+'||u==='DISTINCTION') return '#059669'
  if(u==='A') return '#0d9488'
  if(u.startsWith('B')) return '#1c3d7a'
  if(u.startsWith('C')) return '#d97706'
  return '#64748b'
}

function auditBadgeStyle(action) {
  const map = {
    INSERT:'background:#dcfce7;color:#166534', CSV_IMPORT:'background:#d1fae5;color:#065f46',
    UPDATE:'background:#dbeafe;color:#1d4ed8', DOWNLOAD:'background:#fef9c3;color:#854d0e',
    DELETE:'background:#fee2e2;color:#991b1b', BULK_DELETE:'background:#fecaca;color:#7f1d1d',
    AUDIT_EXPORT:'background:#e0e7ff;color:#3730a3',
  }
  return (map[action]||'background:#f1f5f9;color:#475569') + ';padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700;white-space:nowrap'
}

// ─── Build HTML string ────────────────────────────────────────────────────────
function buildUI() {
  const totalPages = Math.ceil(S.totalCount / PAGE_SIZE)
  const auditTotalPages = Math.ceil(S.auditTotal / AUDIT_SIZE)

  return `
<div style="min-height:100vh;background:#f0f4f8;font-family:'Inter',sans-serif;color:#1e293b">

  <!-- Header -->
  <div style="background:#fff;border-bottom:1px solid #e2e8f0;padding:18px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
    <div>
      <div style="font-family:'Sora',sans-serif;font-size:1.35rem;font-weight:800;color:#0b1525">🛡️ Superadmin — Certificates</div>
      <div style="font-size:12px;color:#64748b;margin-top:4px">${S.totalCount.toLocaleString()} total certificates · ${S.selected.size} selected</div>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <button data-action="open-dl-all" style="${BASE.ghostBtn}">⬇️ Download All</button>
      ${S.selected.size>0 ? `<button data-action="open-bulk-del" style="${BASE.dangerBtn}">🗑️ Delete Selected (${S.selected.size})</button>` : ''}
    </div>
  </div>

  <!-- Tabs -->
  <div style="background:#fff;border-bottom:1px solid #e2e8f0;padding:0 24px;display:flex;gap:4px;overflow-x:auto">
    ${[
      {id:'list',  label:'📋 Certificates'},
      {id:'add',   label: S.editId ? '✏️ Edit Certificate' : '➕ Add Certificate'},
      {id:'csv',   label:'📊 Bulk CSV Upload'},
      {id:'audit', label:'🔍 Audit Log'},
    ].map(t=>`<button data-tab="${t.id}" style="padding:12px 18px;border:none;border-bottom:${S.tab===t.id?'2px solid #1c3d7a':'2px solid transparent'};background:transparent;color:${S.tab===t.id?'#1c3d7a':'#64748b'};cursor:pointer;font-size:13px;font-weight:600;font-family:inherit;white-space:nowrap">${t.label}</button>`).join('')}
  </div>

  <!-- Content -->
  <div style="padding:24px;max-width:1300px;margin:0 auto">
    ${S.tab==='list'  ? buildListHTML(totalPages)  : ''}
    ${S.tab==='add'   ? buildFormHTML()             : ''}
    ${S.tab==='csv'   ? buildCSVHTML()              : ''}
    ${S.tab==='audit' ? buildAuditHTML(auditTotalPages) : ''}
  </div>

  <!-- Modals -->
  ${S.dlModal    ? buildDlModalHTML()      : ''}
  ${S.delModal   ? buildDelModalHTML()     : ''}
  ${S.bulkDelModal ? buildBulkDelHTML()    : ''}
</div>`
}

function buildListHTML(totalPages) {
  return `
  <div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap">
    <input id="sa-search" type="text" value="${escH(S.search)}" placeholder="🔍 Search cert no, name, course, student ID..." style="${BASE.input};flex:1;min-width:220px">
    <button data-action="search" style="${BASE.primBtn}">Search</button>
    ${S.search ? `<button data-action="clear-search" style="${BASE.ghostBtn}">✕ Clear</button>` : ''}
    <button data-action="add-new" style="${BASE.primBtn};margin-left:auto">➕ Add Certificate</button>
  </div>

  ${S.loading ? `<div style="padding:60px;text-align:center;color:#94a3b8;font-size:14px">Loading certificates...</div>` : ''}

  ${!S.loading ? `
  <div style="${BASE.card};padding:0;overflow:hidden">
    ${S.certs.length===0 ? `<div style="padding:60px;text-align:center;color:#94a3b8">No certificates found.</div>` : `
    <div style="overflow-x:auto">
    <table style="width:100%;border-collapse:collapse;font-size:13px">
      <thead>
        <tr>
          <th style="${BASE.th}"><input type="checkbox" id="select-all" style="width:15px;height:15px;cursor:pointer;accent-color:#1c3d7a"></th>
          <th style="${BASE.th}">Cert No</th>
          <th style="${BASE.th}">Student</th>
          <th style="${BASE.th}">Father's Name</th>
          <th style="${BASE.th}">Course</th>
          <th style="${BASE.th}">Grade</th>
          <th style="${BASE.th}">Issue Date</th>
          <th style="${BASE.th}">Status</th>
          <th style="${BASE.th}">Actions</th>
        </tr>
      </thead>
      <tbody>
        ${S.certs.map((cert,i)=>`
        <tr style="background:${i%2===0?'#fff':'#f8fafc'}" onmouseenter="this.style.background='#eff6ff'" onmouseleave="this.style.background='${i%2===0?'#fff':'#f8fafc'}'">
          <td style="${BASE.td}"><input type="checkbox" data-action="toggle-sel" data-id="${cert.id}" ${S.selected.has(cert.id)?'checked':''} style="width:15px;height:15px;cursor:pointer;accent-color:#1c3d7a"></td>
          <td style="${BASE.td};font-family:monospace;font-weight:700;color:#1c3d7a">${escH(cert.certificate_no)}</td>
          <td style="${BASE.td}"><div style="font-weight:600">${escH(cert.student_name||'—')}</div><div style="font-size:11px;color:#94a3b8">${escH(cert.batch_id||'')}</div></td>
          <td style="${BASE.td};color:#64748b">${escH(cert.father_name||'—')}</td>
          <td style="${BASE.td};max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${escH(cert.course_name||'')}">${escH(cert.course_name||'—')}</td>
          <td style="${BASE.td}">${cert.grade?`<span style="background:${gradeColor(cert.grade)};color:#fff;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700">${escH(cert.grade)}</span>`:'—'}</td>
          <td style="${BASE.td};white-space:nowrap;font-size:12px">${fmt(cert.issue_date)}</td>
          <td style="${BASE.td}"><span style="background:${cert.is_active?'#dcfce7':'#fee2e2'};color:${cert.is_active?'#166534':'#991b1b'};padding:3px 10px;border-radius:12px;font-size:11px;font-weight:700">${cert.is_active?'✅ Active':'⭕ Inactive'}</span></td>
          <td style="${BASE.td};white-space:nowrap">
            <div style="display:flex;gap:5px">
              <button data-action="edit-cert" data-id="${cert.id}" style="padding:4px 9px;background:#eff6ff;color:#1c3d7a;border:none;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer">✏️ Edit</button>
              <button data-action="open-dl-single" data-id="${cert.id}" style="padding:4px 9px;background:#f0fdf4;color:#166534;border:none;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer">⬇️ DL</button>
              ${cert.is_active?`<button data-action="open-del" data-id="${cert.id}" style="padding:4px 9px;background:#fef2f2;color:#dc2626;border:none;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer">🗑️ Del</button>`:''}
            </div>
          </td>
        </tr>`).join('')}
      </tbody>
    </table>
    </div>`}
  </div>

  ${S.totalCount>PAGE_SIZE?`
  <div style="display:flex;justify-content:space-between;align-items:center;margin-top:16px;flex-wrap:wrap;gap:10px">
    <span style="font-size:13px;color:#64748b">Showing ${((S.page-1)*PAGE_SIZE)+1}–${Math.min(S.page*PAGE_SIZE,S.totalCount)} of ${S.totalCount.toLocaleString()}</span>
    <div style="display:flex;gap:8px;align-items:center">
      <button data-action="pg-prev" ${S.page===1?'disabled':''} style="${BASE.ghostBtn};opacity:${S.page===1?0.4:1}">← Prev</button>
      <span style="font-size:13px;color:#64748b">Page ${S.page} / ${totalPages}</span>
      <button data-action="pg-next" ${S.page>=totalPages?'disabled':''} style="${BASE.ghostBtn};opacity:${S.page>=totalPages?0.4:1}">Next →</button>
    </div>
  </div>`:''}`:''}
`
}

