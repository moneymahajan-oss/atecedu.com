function escH(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')
}

// ─── Render ───────────────────────────────────────────────────────────────────
function render() {
  const root = document.getElementById('sa-root')
  if (!root) return
  root.innerHTML = buildUI()
  attachEvents()
}

// ─── Event delegation ─────────────────────────────────────────────────────────
function attachEvents() {
  const root = document.getElementById('sa-root')
  if (!root) return

  // Tab buttons
  root.querySelectorAll('[data-tab]').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab
      setState({ tab })
      if (tab==='audit') loadAudit(S.auditPage, S.auditFilter)
    })
  })

  // CSV file input
  const csvInput = root.querySelector('#csv-file-inp')
  if (csvInput) {
    csvInput.addEventListener('change', e => {
      if (e.target.files[0]) handleCSVFile(e.target.files[0])
    })
  }

  // Select all checkbox
  const selAll = root.querySelector('#select-all')
  if (selAll) {
    selAll.addEventListener('change', () => {
      const s = new Set(selAll.checked ? S.certs.map(c=>c.id) : [])
      setState({ selected: s })
    })
  }

  // Action buttons (event delegation on root)
  root.addEventListener('click', async e => {
    const target = e.target.closest('[data-action]')
    if (!target) return
    const action = target.dataset.action

    if (action==='search') {
      const q=root.querySelector('#sa-search')?.value||''
      setState({ search:q, page:1 })
      loadCerts(1, q)
    }
    if (action==='clear-search') { setState({ search:'', page:1 }); loadCerts(1,'') }
    if (action==='add-new') setState({ tab:'add', editId:null, form:emptyForm(), formError:'', formSuccess:'' })
    if (action==='pg-prev') { const p=S.page-1; setState({page:p}); loadCerts(p,S.search) }
    if (action==='pg-next') { const p=S.page+1; setState({page:p}); loadCerts(p,S.search) }

    if (action==='toggle-sel') {
      const id=target.dataset.id
      const s=new Set(S.selected)
      if(s.has(id)) s.delete(id); else s.add(id)
      setState({ selected:s })
    }
    if (action==='open-bulk-del') setState({ bulkDelModal:true, bulkDelPwd:'', bulkDelWord:'', bulkDelError:'' })
    if (action==='cancel-bulk-del') setState({ bulkDelModal:false })
    if (action==='confirm-bulk-del') {
      setState({
        bulkDelPwd: root.querySelector('#bulk-del-pwd-inp')?.value||'',
        bulkDelWord: root.querySelector('#bulk-del-word-inp')?.value||'',
      })
      await doBulkDelete()
    }

    if (action==='edit-cert') {
      const cert=S.certs.find(c=>c.id===target.dataset.id)
      if(cert) {
        setState({
          editId:cert.id, tab:'add', formError:'', formSuccess:'',
          form:{
            certificate_no:cert.certificate_no||'', batch_id:cert.batch_id||'',
            student_name:cert.student_name||'', father_name:cert.father_name||'',
            mother_name:cert.mother_name||'', course_name:cert.course_name||'',
            course_duration:cert.course_duration||'', grade:cert.grade||'',
            marks_obtained:cert.marks_obtained??'', total_marks:cert.total_marks??'',
            from_date:cert.from_date?cert.from_date.slice(0,10):'',
            issue_date:cert.issue_date?cert.issue_date.slice(0,10):'',
            center_name:cert.center_name||'ATEC Gurdaspur', is_active:cert.is_active,
          },
        })
        window.scrollTo({top:0,behavior:'smooth'})
      }
    }

    if (action==='form-field') {
      const k=target.dataset.field
      const v=target.type==='checkbox'?target.checked:target.value
      setState({ form:{...S.form,[k]:v} })
    }
    if (action==='save-form') await saveForm()
    if (action==='cancel-form') setState({ form:emptyForm(), editId:null, tab:'list', formError:'', formSuccess:'' })

    if (action==='open-dl-all') setState({ dlModal:'all', dlPwd:'', dlError:'' })
    if (action==='open-dl-single') {
      const cert=S.certs.find(c=>c.id===target.dataset.id)
      if(cert) setState({ dlModal:cert, dlPwd:'', dlError:'' })
    }
    if (action==='confirm-download') {
      setState({ dlPwd: root.querySelector('#dl-pwd-inp')?.value||'' })
      await doDownload()
    }
    if (action==='cancel-dl') setState({ dlModal:null, dlPwd:'', dlError:'' })

    if (action==='open-del') {
      const cert=S.certs.find(c=>c.id===target.dataset.id)
      if(cert) setState({ delModal:cert, delPwd:'', delWord:'', delError:'' })
    }
    if (action==='confirm-delete') {
      setState({
        delPwd: root.querySelector('#del-pwd-inp')?.value||'',
        delWord: root.querySelector('#del-word-inp')?.value||'',
      })
      await doDelete()
    }
    if (action==='cancel-del') setState({ delModal:null, delPwd:'', delWord:'', delError:'' })

    if (action==='upload-csv') await uploadCSV()
    if (action==='cancel-csv') setState({ csvRows:[], csvPreview:false, csvError:'', csvDuplicates:[] })
    if (action==='skip-dupes') skipDuplicates()

    if (action==='refresh-audit') loadAudit(S.auditPage, S.auditFilter)
    if (action==='audit-filter') {
      const f=root.querySelector('#audit-filter-inp')?.value||''
      setState({ auditFilter:f, auditPage:1 }); loadAudit(1,f)
    }
    if (action==='audit-clear-filter') { setState({ auditFilter:'', auditPage:1 }); loadAudit(1,'') }
    if (action==='audit-pg-prev') { const p=S.auditPage-1; setState({auditPage:p}); loadAudit(p,S.auditFilter) }
    if (action==='audit-pg-next') { const p=S.auditPage+1; setState({auditPage:p}); loadAudit(p,S.auditFilter) }
    if (action==='export-audit') {
      const { data } = await sb.from('certificate_audit_log').select('*').order('performed_at',{ascending:false}).limit(10000)
      const rows=data||[]
      const cols=['id','action','certificate_no','student_name','records_count','performed_by','notes','performed_at']
      const csv=[cols.join(','),...rows.map(r=>cols.map(c=>{
        const v=r[c]??''; const s=String(v)
        return s.includes(',')||s.includes('"')?`"${s.replace(/"/g,'""')}"`:s
      }).join(','))].join('\n')
      const blob=new Blob([csv],{type:'text/csv'})
      const url=URL.createObjectURL(blob)
      const a=document.createElement('a'); a.href=url; a.download=`ATEC_Audit_Log_${new Date().toISOString().slice(0,10)}.csv`; a.click()
      URL.revokeObjectURL(url)
      await logAudit('AUDIT_EXPORT','Audit export','superadmin',null,null,rows.length,'Audit log exported to CSV')
    }
  })
}

// ─── Initial load ─────────────────────────────────────────────────────────────
loadCerts(1, '')
render()

} // end mountApp
</script>
