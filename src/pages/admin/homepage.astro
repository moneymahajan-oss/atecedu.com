            lbl('Sub Heading / Tagline'),
            h('textarea', {defaultValue:hero.subheading||'',onBlur:(e:any)=>setHero((p:any)=>({...p,subheading:e.target.value})),rows:2,style:{...s,height:'auto',resize:'vertical'},placeholder:'Online, hybrid & classroom courses...'})
          ),
          h('div', {},
            lbl(`Heading Font Size: ${hero.heading_font_size||4}rem`),
            h('input', {type:'range',min:'2',max:'6',step:'0.25',value:hero.heading_font_size||'4',
              onChange:(e:any)=>setHero((p:any)=>({...p,heading_font_size:e.target.value})),
              style:{...s,padding:'0',height:'8px'}})
          ),
          // ── NEW VIDEO PICKER — replaces old youtube_video_id field ──────
          h(VideoPicker, {}),
          // ────────────────────────────────────────────────────────────────
          h('div', {style:{gridColumn:'1/-1',marginTop:'8px',padding:'14px',background:'#f8fafc',borderRadius:'10px',border:'1px solid #e2e8f0'}},
            h('div', {style:{fontSize:'13px',fontWeight:'700',marginBottom:'12px',color:'#1c3d7a'}}, '🎯 Primary Call-to-Action Button'),
            h('div', {style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'12px'}},
              h('div', {},
                lbl('Button Text'),
                h('input', {type:'text',defaultValue:hero.cta_text||'',onBlur:(e:any)=>setHero((p:any)=>({...p,cta_text:e.target.value})),style:s,placeholder:'Explore Courses'})
              ),
              h('div', {},
                lbl('Button Link'),
                h('input', {type:'text',defaultValue:hero.cta_link||'',onBlur:(e:any)=>setHero((p:any)=>({...p,cta_link:e.target.value})),style:s,placeholder:'/courses or https://wa.me/...'})
              )
            )
          ),
          h('div', {style:{gridColumn:'1/-1',padding:'14px',background:'#f0fdf4',borderRadius:'10px',border:'1px solid #bbf7d0'}},
            h('div', {style:{fontSize:'13px',fontWeight:'700',marginBottom:'12px',color:'#166534'}}, '💬 Secondary Button (WhatsApp recommended)'),
            h('div', {style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'12px'}},
              h('div', {},
                lbl('Button Text'),
                h('input', {type:'text',defaultValue:hero.cta2_text||'',onBlur:(e:any)=>setHero((p:any)=>({...p,cta2_text:e.target.value})),style:s,placeholder:'Chat on WhatsApp'})
              ),
              h('div', {},
                lbl('WhatsApp URL'),
                h('input', {type:'text',defaultValue:hero.cta2_link||'',onBlur:(e:any)=>setHero((p:any)=>({...p,cta2_link:e.target.value})),style:s,placeholder:'https://wa.me/917009933289?text=Hi'})
              )
            ),
            h('div', {style:{fontSize:'11px',color:'#166534',marginTop:'8px'}}, '💡 WhatsApp link format: https://wa.me/917009933289?text=Hi%20I%20want%20to%20enroll')
          ),

          // ── Hero Text Colors ────────────────────────────────────
          h('div', {style:{borderTop:'1px solid #f1f5f9',paddingTop:'20px',marginTop:'8px'}},
            h('div', {style:{fontSize:'13px',fontWeight:'700',color:'#1e293b',marginBottom:'16px',display:'flex',alignItems:'center',gap:'8px'}},
              '🎨 Hero Text Colors',
              h('span', {style:{fontSize:'11px',color:'#94a3b8',fontWeight:'500'}}, '— changes update live without rebuild')
            ),
            h('div', {style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'16px'}},

              // Heading color
              h('div', {},
                lbl('Heading Color  ("Learn ONLINE" text)'),
                h('div', {style:{display:'flex',gap:'8px',alignItems:'center',marginBottom:'8px'}},
                  h('div', {style:{width:'40px',height:'40px',background:hero.hero_text_color||'#0b1525',border:'2px solid #e2e8f0',borderRadius:'8px',flexShrink:0}}),
                  h('input', {type:'text',value:hero.hero_text_color||'',
                    onChange:(e:any)=>{let val=e.target.value.toLowerCase().trim();if(val&&!val.startsWith('#'))val='#'+val;setHero((p:any)=>({...p,hero_text_color:val}))},
                    style:{...s,fontFamily:'monospace'},placeholder:'#0b1525'})
                ),
                h('div', {style:{display:'flex',gap:'4px',flexWrap:'wrap'}},
                  ...['#0b1525','#1c1c1c','#ffffff','#1a3460','#d4f01a','#f9fafb','#374151','#1e293b','#f59e0b','#ef4444'].map((color:string) =>
                    h('button', {key:color,type:'button',
                      onMouseDown:(e:any)=>e.preventDefault(),
                      onClick:()=>setHero((p:any)=>({...p,hero_text_color:color})),
                      title:color,
                      style:{width:'28px',height:'28px',background:color,
                        border:(hero.hero_text_color||'').toLowerCase()===color.toLowerCase()?'3px solid #1c3d7a':'1px solid #e2e8f0',
                        borderRadius:'6px',cursor:'pointer',padding:0}
                    })
                  )
                )
              ),

              // Subtitle color
              h('div', {},
