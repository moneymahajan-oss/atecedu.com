<script>
import { createClient } from '@supabase/supabase-js'
import { createElement as h, useState, useEffect } from 'react'
import { createRoot } from 'react-dom/client'

const sb = createClient(window.__SB_URL, window.__SB_KEY)

// ── OLD: only YouTube. NEW: detects YouTube / Instagram / Facebook / Vimeo / direct MP4
function extractYTId(input: string): string {
  let v = (input||'').trim()
  const short = v.match(/youtu\.be\/([a-zA-Z0-9_-]{11})/)
  const long  = v.match(/(?:v=|\/embed\/|\/shorts\/|\/v\/)([a-zA-Z0-9_-]{11})/)
  if (short) return short[1]
  if (long) return long[1]
  return v
}

// ── Detect video type from any URL ──────────────────────────────────────────
// Returns { type, embedUrl, displayId, platform }
function detectVideo(raw: string): {
  type: 'youtube' | 'instagram' | 'facebook' | 'vimeo' | 'direct' | 'unknown'
  embedUrl: string
  displayId: string
  platform: string
  error?: string
} {
  const url = (raw || '').trim()
  if (!url) return { type: 'unknown', embedUrl: '', displayId: '', platform: '' }

  // ── YouTube ──────────────────────────────────────────────────────────────
  const ytShort = url.match(/youtu\.be\/([A-Za-z0-9_-]{11})/)
  const ytLong  = url.match(/(?:v=|\/embed\/|\/shorts\/|\/v\/)([A-Za-z0-9_-]{11})/)
  const ytId    = ytShort?.[1] || ytLong?.[1] || (/^[A-Za-z0-9_-]{11}$/.test(url) ? url : '')
  if (ytId) return {
    type: 'youtube',
    embedUrl: `https://www.youtube.com/embed/${ytId}?autoplay=1&mute=1&loop=1&playlist=${ytId}&controls=1&rel=0&modestbranding=1`,
    displayId: ytId,
    platform: 'YouTube',
  }

  // ── Instagram Reel / Post ────────────────────────────────────────────────
  const igMatch = url.match(/instagram\.com\/(?:reel|p)\/([A-Za-z0-9_-]+)/)
  if (igMatch) return {
    type: 'instagram',
    embedUrl: `https://www.instagram.com/reel/${igMatch[1]}/embed/`,
    displayId: igMatch[1],
    platform: 'Instagram Reel',
  }

  // ── Facebook Video ───────────────────────────────────────────────────────
  const fbMatch = url.match(/facebook\.com\/.*\/videos\/(\d+)/) ||
                  url.match(/fb\.watch\/([A-Za-z0-9_-]+)/)
  if (fbMatch || url.includes('facebook.com/watch') || url.includes('fb.watch')) {
    const encoded = encodeURIComponent(url)
    return {
      type: 'facebook',
      embedUrl: `https://www.facebook.com/plugins/video.php?href=${encoded}&show_text=false&autoplay=true`,
      displayId: fbMatch?.[1] || 'Facebook Video',
      platform: 'Facebook Video',
    }
  }

  // ── Vimeo ────────────────────────────────────────────────────────────────
  const vimeoMatch = url.match(/vimeo\.com\/(\d+)/)
  if (vimeoMatch) return {
    type: 'vimeo',
    embedUrl: `https://player.vimeo.com/video/${vimeoMatch[1]}?autoplay=1&muted=1&loop=1`,
    displayId: vimeoMatch[1],
    platform: 'Vimeo',
  }

  // ── Direct MP4 / WebM ────────────────────────────────────────────────────
  if (/\.(mp4|webm|ogg|mov)(\?.*)?$/i.test(url)) return {
    type: 'direct',
    embedUrl: url,
    displayId: url.split('/').pop()?.split('?')[0] || 'video file',
    platform: 'Direct Video File',
  }

  // ── Unknown ──────────────────────────────────────────────────────────────
  return {
    type: 'unknown',
    embedUrl: '',
    displayId: '',
    platform: '',
    error: 'Paste a YouTube, Instagram Reel, Facebook, Vimeo URL — or a direct .mp4 link',
  }
}

// Check if URL is a direct image (not a page on Imgur/PostImg/etc)
function isDirectImageUrl(url: string): { ok: boolean; error?: string; fix?: string } {
  if (!url || !url.trim()) return { ok: true }
  const u = url.trim()
  if (u.match(/^https?:\/\/postimg\.cc\/[a-zA-Z0-9]+\/?$/)) {
    return { ok: false, error: '❌ This is a PostImg page link, not the image itself', fix: 'Go to that page → right-click the image → "Copy image address" → it should look like https://i.postimg.cc/xxx/image.jpg' }
  }
  if (u.match(/^https?:\/\/imgur\.com\/[a-zA-Z0-9]+\/?$/) || u.match(/^https?:\/\/imgur\.com\/a\//)) {
    return { ok: false, error: '❌ This is an Imgur page link, not the image itself', fix: 'Right-click the image on Imgur → "Copy image address" → it should look like https://i.imgur.com/xxx.jpg' }
  }
  if (u.match(/^https?:\/\/drive\.google\.com\//)) {
    return { ok: false, error: '❌ Google Drive links don\'t work directly as images', fix: 'Use a public CDN like PostImg, Imgur, or your Supabase Storage instead' }
  }
  const isImage = /\.(jpg|jpeg|png|gif|webp|svg|avif)(\?.*)?$/i.test(u)
  const isDirectCDN = /^https?:\/\/(i\.postimg\.cc|i\.imgur\.com|.*\.supabase\.co\/storage|res\.cloudinary\.com|.*\.cloudfront\.net)\//i.test(u)
  if (!isImage && !isDirectCDN) {
    return { ok: false, error: '⚠️ This URL doesn\'t look like a direct image link', fix: 'Make sure your URL ends with .jpg, .png, .webp etc.' }
  }
  return { ok: true }
}

function Mgr() {
  const [tab, setTab] = useState('hero')
  const [hero, setHero] = useState<any>({
    heading: 'Turning Students Into Professionals Since 2000',
    subheading: 'Online, hybrid & classroom courses in hardware, networking, web design and more.',
    youtube_video_id: '',   // kept for backward compat when reading old saved data
    video_url: '',          // NEW: universal video URL field
    video_type: 'youtube',  // NEW: detected automatically
    heading_font_size: '4',
    cta_text: 'Explore Courses',
    cta_link: '/courses',
    cta2_text: 'Chat on WhatsApp',
    cta2_link: 'https://wa.me/917009933289',
    hero_text_color: '#0b1525',
    hero_sub_color: '#555555',
  })
  const [strip, setStrip] = useState<any>({ text:'',link:'',link_text:'',is_active:true,bg_color:'#0f2347',text_color:'#ffffff',show_timer:false,ends_at:'' })
  const [stories, setStories] = useState<any[]>([])
  const [storyForm, setStoryForm] = useState<any>({ student_name:'', course:'', company_placed:'', review:'', rating:5, photo_url:'', video_url:'', video_type:'youtube', is_active:true, sort_order:0 })
  const [editingStory, setEditingStory] = useState<string|null>(null)
  const [storyMsg, setStoryMsg] = useState('')
  const [branding, setBranding] = useState<any>({ logo_url:'',logo_size:38,show_text:true,brand_name:'ATEC',brand_tagline:'Educational Society' })
  const [nav, setNav] = useState<any>({ links:[{label:'Home',href:'/'}], cta_text:'Enroll Now', cta_link:'https://wa.me/917009933289', cta_style:'lemon', show_login:true })
  const [theme, setTheme] = useState<any>({ primary:'#1c3d7a', accent:'#d4f01a', navy_dark:'#0f2347', off_white:'#f8fafc' })
  const [saving, setSaving] = useState('')
  const [saved, setSaved] = useState('')

  useEffect(() => { load() }, [])
  async function load() {
    const { data } = await sb.from('site_settings').select('key,value').in('key', ['hero','announcement_strip','branding','navigation','theme'])
    data?.forEach((d: any) => {
      if (d.key==='hero') {
        setHero((p: any) => {
          const merged = { ...p, ...d.value }
          // Back-compat: if old data only has youtube_video_id, populate video_url from it
          if (!merged.video_url && merged.youtube_video_id) {
            merged.video_url = merged.youtube_video_id
            merged.video_type = 'youtube'
          }
          return merged
        })
      }
      if (d.key==='announcement_strip') setStrip((p:any) => ({...p, ...d.value}))
      if (d.key==='branding')           setBranding((p:any) => ({...p, ...d.value}))
      if (d.key==='navigation')         setNav((p:any) => ({...p, ...d.value, links: d.value?.links ?? p.links}))
      if (d.key==='theme')              setTheme((p:any) => ({...p, ...d.value}))
    })
    // Load student stories
    const { data: stData } = await sb.from('testimonials').select('*').order('sort_order', {ascending:true})
    if (stData) setStories(stData)
  }

  async function saveKey(key: string, value: any) {
    setSaving(key)
    await sb.from('site_settings').upsert({ key, value }, { onConflict: 'key' })
    setSaving('')
    setSaved(key)
    setTimeout(() => setSaved(''), 2000)
  }

  const s: any = {width:'100%',padding:'10px 14px',border:'1px solid #e2e8f0',borderRadius:'8px',fontSize:'13px',outline:'none',boxSizing:'border-box',fontFamily:'Inter,sans-serif'}
  const lbl = (t: string) => h('label', {style:{fontSize:'12px',fontWeight:'600',color:'#475569',display:'block',marginBottom:'6px'}}, t)

  const Card = ({ title, emoji, saveKeyName, children, onSave }: any) =>
    h('div', {style:{background:'#fff',borderRadius:'16px',border:'1px solid #e2e8f0',padding:'28px',marginBottom:'20px'}},
      h('div', {style:{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:'20px',borderBottom:'1px solid #f1f5f9',paddingBottom:'14px'}},
        h('h2', {style:{fontFamily:'Sora,sans-serif',fontWeight:'700',fontSize:'17px'}}, `${emoji} ${title}`),
        h('button', {onClick:onSave, disabled:saving===saveKeyName,
          style:{padding:'9px 22px',background:saved===saveKeyName?'#166534':saving===saveKeyName?'#94a3b8':'#1c3d7a',color:'#fff',border:'none',borderRadius:'8px',fontWeight:'700',fontSize:'13px',cursor:saving===saveKeyName?'not-allowed':'pointer'}},
          saved===saveKeyName?'✅ Saved!':saving===saveKeyName?'Saving...':'💾 Save'
        )
      ),
      ...children
    )

  const TabBtn = ({ id, label, icon }: any) =>
    h('button', {onClick:()=>setTab(id),
      style:{padding:'10px 18px',border:'none',borderRadius:'10px',fontSize:'13px',fontWeight:'600',cursor:'pointer',
        background: tab===id ? '#1c3d7a' : 'transparent',
        color: tab===id ? '#fff' : '#475569',
        transition: 'all 0.15s'}
    }, `${icon} ${label}`)

  // ── Video picker component (replaces the old youtube_video_id field) ────
  const VideoPicker = () => {
    const rawUrl   = hero.video_url || hero.youtube_video_id || ''
    const detected = detectVideo(rawUrl)

    const platformColors: Record<string, string> = {
      youtube:   '#ff0000',
      instagram: '#e1306c',
      facebook:  '#1877f2',
      vimeo:     '#1ab7ea',
      direct:    '#16a34a',
      unknown:   '#94a3b8',
    }
    const platformIcons: Record<string, string> = {
      youtube:   '▶️',
      instagram: '📸',
      facebook:  '👥',
      vimeo:     '🎬',
      direct:    '📁',
      unknown:   '❓',
    }

    return h('div', {style:{gridColumn:'1/-1'}},
      lbl('Hero Video (YouTube, Instagram Reel, Facebook, Vimeo, or direct .mp4 URL)'),

      // Input field
      h('input', {
        type: 'text',
        value: rawUrl,
        onChange: (e: any) => {
          const val = e.target.value
          const d = detectVideo(val)
          setHero((p: any) => ({
            ...p,
            video_url:  val,
            video_type: d.type === 'unknown' ? 'youtube' : d.type,
            // keep youtube_video_id in sync for backward compat
            youtube_video_id: d.type === 'youtube' ? d.displayId : p.youtube_video_id,
          }))
        },
        style: { ...s, marginBottom: '10px' },
        placeholder: 'Paste any video URL — YouTube, Instagram, Facebook, Vimeo, .mp4...',
      }),

      // Detection result badge
      rawUrl && h('div', {style:{
        display: 'flex', alignItems: 'flex-start', gap: '10px',
        padding: '12px 14px',
        background: detected.error ? '#fef2f2' : '#f0fdf4',
        border: `1px solid ${detected.error ? '#fecaca' : '#bbf7d0'}`,
        borderRadius: '10px',
        marginBottom: '10px',
      }},
        // Platform badge
        !detected.error && h('span', {style:{
          padding: '2px 10px', borderRadius: '20px', fontSize: '11px', fontWeight: '800',
          background: platformColors[detected.type] || '#94a3b8',
          color: '#fff', flexShrink: 0, marginTop: '1px',
        }}, `${platformIcons[detected.type]} ${detected.platform}`),

        detected.error
          ? h('div', {},
              h('div', {style:{color:'#991b1b',fontWeight:'700',fontSize:'13px'}}, '❌ Unrecognised URL'),
              h('div', {style:{color:'#7f1d1d',fontSize:'12px',marginTop:'4px'}}, detected.error)
            )
          : h('div', {},
              h('div', {style:{color:'#166534',fontWeight:'700',fontSize:'13px'}}, '✅ Video detected'),
              h('div', {style:{color:'#15803d',fontSize:'11px',fontFamily:'monospace',marginTop:'2px',wordBreak:'break-all'}},
                `ID / Code: ${detected.displayId}`
              )
            )
      ),

      // Supported sources info box
      !rawUrl && h('div', {style:{
        padding: '12px 14px',
        background: '#f8fafc',
        border: '1px solid #e2e8f0',
        borderRadius: '10px',
        fontSize: '12px',
        color: '#64748b',
      }},
        h('div', {style:{fontWeight:'700',marginBottom:'8px',color:'#1c3d7a'}}, '📹 Supported video sources:'),
        h('div', {style:{display:'flex',flexDirection:'column',gap:'5px'}},
          ...([
            ['▶️ YouTube',       'https://youtu.be/VIDEO_ID  or  youtube.com/watch?v=VIDEO_ID'],
            ['📸 Instagram Reel','https://www.instagram.com/reel/CODE/'],
            ['👥 Facebook Video','https://www.facebook.com/watch?v=VIDEO_ID'],
            ['🎬 Vimeo',         'https://vimeo.com/VIDEO_ID'],
            ['📁 Direct MP4',    'https://yoursite.com/video.mp4'],
          ] as [string, string][]).map(([icon, example]) =>
            h('div', {key:icon, style:{display:'flex',gap:'8px',alignItems:'flex-start'}},
              h('span', {style:{fontWeight:'700',minWidth:'130px',flexShrink:0}}, icon),
              h('span', {style:{color:'#94a3b8',fontFamily:'monospace',fontSize:'11px',wordBreak:'break-all'}}, example)
            )
          )
        )
      ),

      // Live mini preview (YouTube only — others can't be embedded cross-origin in small iframes)
      detected.type === 'youtube' && detected.displayId && h('div', {style:{marginTop:'10px'}},
        h('div', {style:{fontSize:'11px',fontWeight:'700',color:'#94a3b8',marginBottom:'6px',textTransform:'uppercase'}}, 'Thumbnail Preview'),
        h('img', {
          src: `https://img.youtube.com/vi/${detected.displayId}/maxresdefault.jpg`,
          onError: (e: any) => { e.target.src = `https://img.youtube.com/vi/${detected.displayId}/hqdefault.jpg` },
          alt: 'YouTube thumbnail',
          style: { width: '100%', maxWidth: '320px', borderRadius: '8px', border: '2px solid #e2e8f0', display: 'block' },
        })
      ),

      // Instagram: show a note that preview can't be shown but it will work
      detected.type === 'instagram' && h('div', {style:{
        marginTop:'8px', padding:'10px 12px',
        background:'#fdf4ff', border:'1px solid #e9d5ff', borderRadius:'8px',
        fontSize:'12px', color:'#7c3aed',
      }},
        '📸 Instagram Reel detected. No thumbnail preview here, but it will play correctly in the hero video card on the website.'
      ),

      // Facebook note
      detected.type === 'facebook' && h('div', {style:{
        marginTop:'8px', padding:'10px 12px',
        background:'#eff6ff', border:'1px solid #bfdbfe', borderRadius:'8px',
        fontSize:'12px', color:'#1d4ed8',
      }},
        '👥 Facebook Video detected. Make sure the video is Public — private/friends-only videos will not play on the website.'
      ),

      // Direct MP4 note
      detected.type === 'direct' && h('div', {style:{
        marginTop:'8px', padding:'10px 12px',
        background:'#f0fdf4', border:'1px solid #bbf7d0', borderRadius:'8px',
        fontSize:'12px', color:'#15803d',
      }},
        '📁 Direct video file detected. Make sure it is publicly accessible and hosted on a server that allows cross-origin (CORS) access.'
      ),
    )
  }

  return h('div', {style:{display:'flex',flexDirection:'column',gap:'20px'}},
    // Header
    h('div', {},
      h('h1', {style:{fontFamily:'Sora,sans-serif',fontSize:'1.6rem',fontWeight:'800',marginBottom:'4px'}}, '🏠 Homepage Manager'),
      h('p', {style:{fontSize:'13px',color:'#64748b'}}, 'All changes save to Supabase and appear live on the website — no rebuild needed.')
    ),

    // Tabs
    h('div', {style:{display:'flex',gap:'4px',background:'#f1f5f9',padding:'4px',borderRadius:'12px',flexWrap:'wrap'}},
      h(TabBtn, {id:'hero',     label:'Hero Section',      icon:'🦸'}),
      h(TabBtn, {id:'branding', label:'Logo & Branding',   icon:'🎨'}),
      h(TabBtn, {id:'nav',      label:'Navigation',        icon:'🧭'}),
      h(TabBtn, {id:'theme',    label:'Theme Colors',      icon:'🌈'}),
      h(TabBtn, {id:'strip',    label:'Announcement Strip', icon:'📢'}),
      h(TabBtn, {id:'stories',  label:'Student Stories',   icon:'🎬'}),
    ),

    // ─ HERO TAB ────────────────────────────────────────
    tab==='hero' && h(Card, {
      title:'Hero Section', emoji:'🦸', saveKeyName:'hero',
      onSave: () => saveKey('hero', hero),
      children: [
        h('div', {style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'16px'}},
          h('div', {style:{gridColumn:'1/-1'}},
            lbl('Main Heading (use | to highlight middle word: "Turning Students Into|Professionals|Since 2000")'),
            h('input', {type:'text',defaultValue:hero.heading||'',onBlur:(e:any)=>setHero((p:any)=>({...p,heading:e.target.value})),style:s,placeholder:'Use | for gradient highlight'}),
            h('div', {style:{fontSize:'11px',color:'#94a3b8',marginTop:'4px'}}, '💡 Tip: Put your most important word between pipes — it gets the rainbow gradient effect')
