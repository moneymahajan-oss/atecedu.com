---
// src/pages/admin/contact-sections.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="Contact Sections" activeSection="contact-sections">

<style>
  /* ── Layout ── */
  .wrap { max-width:860px }
  .pg-title { font-family:'Sora',sans-serif; font-size:20px; font-weight:900; color:#0b1a2e; margin:0 0 2px }
  .pg-sub   { font-size:13px; color:#94a3b8; margin:0 0 24px }

  /* ── Section accordion ── */
  .sec { background:#fff; border-radius:14px; border:1px solid #e2e8f0; margin-bottom:16px; overflow:hidden }
  .sec-head {
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 20px; cursor:pointer; user-select:none; gap:12px;
  }
  .sec-head:hover { background:#fafbfc }
  .sec-left  { display:flex; align-items:center; gap:10px; flex:1; min-width:0 }
  .sec-icon  { width:34px; height:34px; border-radius:9px; background:#eff6ff; display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0 }
  .sec-title { font-size:14px; font-weight:700; color:#0b1a2e; margin:0 }
  .sec-desc  { font-size:12px; color:#94a3b8; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis }
  .sec-right { display:flex; align-items:center; gap:8px; flex-shrink:0 }
  .chev { font-size:12px; color:#94a3b8; transition:transform 0.2s }
  .chev.open { transform:rotate(180deg) }
  .sec-body { padding:20px; border-top:1px solid #f1f5f9; display:none }
  .sec-body.open { display:block }

  /* ── Inline field row ── */
  .f2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px }
  .f3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px }
  @media(max-width:600px){ .f2,.f3 { grid-template-columns:1fr } }
  .field { display:flex; flex-direction:column; gap:4px }
  .lbl { font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.04em }
  input[type=text],input[type=url],input[type=number],select,textarea,.inp {
    padding:8px 11px; border:1.5px solid #e2e8f0; border-radius:8px;
    font-size:13px; color:#1e293b; outline:none; font-family:'Inter',sans-serif;
    width:100%; box-sizing:border-box; background:#fff; transition:border-color 0.15s
  }
  input:focus,select:focus,textarea:focus { border-color:#0b1a2e }
  textarea { resize:vertical }

  /* ── Platform row (compact single-line card) ── */
  .plat-row {
    display:grid; grid-template-columns:32px 130px 1fr 1fr auto; gap:8px;
    align-items:center; padding:10px 12px; border:1px solid #e8edf2;
    border-radius:9px; margin-bottom:6px; background:#fafbfc;
  }
  .plat-row:hover { border-color:#0b1a2e; background:#fff }
  @media(max-width:680px){ .plat-row { grid-template-columns:1fr 1fr; grid-template-rows:auto auto; } }
  .plat-num { width:28px; height:28px; border-radius:7px; background:#0b1a2e; color:#d4f01a; font-size:11px; font-weight:900; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-family:'Sora',sans-serif }
  .plat-del { background:#fee2e2; border:none; color:#dc2626; border-radius:6px; padding:5px 10px; font-size:12px; font-weight:700; cursor:pointer; white-space:nowrap }
  .plat-del:hover { background:#fca5a5 }

  /* QR row - optional, shown below only if needed */
  .plat-qr { display:grid; grid-template-columns:32px 1fr auto; gap:8px; align-items:center; padding:6px 12px 10px; margin-top:-4px; margin-bottom:6px }
  .plat-qr-label { font-size:11px; color:#94a3b8; text-align:center }

  /* ── FAQ row ── */
  .faq-row { border:1px solid #e8edf2; border-radius:9px; margin-bottom:6px; overflow:hidden; background:#fafbfc }
  .faq-row:hover { border-color:#0b1a2e }
  .faq-top { display:flex; align-items:center; gap:8px; padding:10px 12px; cursor:pointer }
  .faq-top:hover { background:#f8fafc }
  .faq-num { width:24px; height:24px; border-radius:6px; background:#0b1a2e; color:#d4f01a; font-size:10px; font-weight:900; display:flex; align-items:center; justify-content:center; flex-shrink:0 }
  .faq-q-preview { flex:1; font-size:13px; font-weight:600; color:#1e293b; overflow:hidden; text-overflow:ellipsis; white-space:nowrap }
  .faq-actions { display:flex; gap:4px; align-items:center; flex-shrink:0 }
  .faq-body { padding:0 12px 12px; display:none }
  .faq-body.open { display:block }

  /* ── Resource row ── */
  .res-row { border:1px solid #e8edf2; border-radius:9px; margin-bottom:6px; background:#fafbfc }
  .res-row:hover { border-color:#0b1a2e }
  .res-top { display:grid; grid-template-columns:auto 1fr 1fr auto; gap:8px; align-items:center; padding:10px 12px }
  @media(max-width:600px){ .res-top { grid-template-columns:1fr 1fr } }
  .res-bottom { padding:0 12px 10px; display:grid; grid-template-columns:1fr 1fr; gap:8px }
  @media(max-width:600px){ .res-bottom { grid-template-columns:1fr } }

  /* ── Buttons ── */
  .save-btn { display:inline-flex; align-items:center; gap:7px; background:#0b1a2e; color:#d4f01a; border:none; border-radius:9px; padding:10px 20px; font-size:13px; font-weight:800; cursor:pointer; font-family:'Inter',sans-serif; transition:background 0.15s }
  .save-btn:hover { background:#1a3460 }
  .save-btn:disabled { background:#94a3b8; cursor:not-allowed; color:#fff }
  .add-btn { display:flex; align-items:center; gap:6px; padding:8px 14px; background:#f0f9ff; border:1.5px dashed #93c5fd; color:#0b1a2e; border-radius:8px; font-size:12px; font-weight:700; cursor:pointer; font-family:'Inter',sans-serif; transition:all 0.15s }
  .add-btn:hover { background:#dbeafe; border-color:#3b82f6 }
  .btn-sm { background:#f1f5f9; border:none; color:#475569; border-radius:6px; padding:5px 10px; font-size:11px; font-weight:700; cursor:pointer; font-family:'Inter',sans-serif }
  .btn-sm:hover { background:#e2e8f0 }
  .btn-sm.red { background:#fee2e2; color:#dc2626 }
  .btn-sm.red:hover { background:#fca5a5 }

  /* ── Status ── */
  .status { font-size:12px; font-weight:600; padding:8px 14px; border-radius:8px; display:none; margin-top:10px }
  .status.ok  { background:#dcfce7; color:#166534; display:block }
  .status.err { background:#fee2e2; color:#991b1b; display:block }

  /* ── Toggle chip ── */
  .toggle-chip { display:flex; align-items:center; gap:6px; padding:4px 10px; border-radius:20px; border:1px solid #e2e8f0; font-size:12px; font-weight:600; cursor:pointer; user-select:none; background:#fff; color:#64748b }
  .toggle-chip.on { background:#dcfce7; color:#15803d; border-color:#bbf7d0 }

  /* ── Section footer ── */
  .sec-footer { display:flex; align-items:center; justify-content:space-between; margin-top:16px; padding-top:14px; border-top:1px solid #f1f5f9; flex-wrap:wrap; gap:10px }
</style>

<div class="wrap">
  <h1 class="pg-title">📞 Contact Sections</h1>
  <p class="pg-sub">Social platforms, contact info, FAQ, and download resources — saves instantly, no rebuild needed.</p>

  <!-- ══════════════ 1. CONNECT WITH US ══════════════ -->
  <div class="sec">
    <div class="sec-head" onclick="toggleSec('connect')">
      <div class="sec-left">
        <div class="sec-icon">🔗</div>
        <div>
          <div class="sec-title">Connect With Us</div>
          <div class="sec-desc">Social platforms shown as QR cards on the homepage</div>
        </div>
      </div>
      <div class="sec-right">
        <button class="save-btn" id="con-save-btn" onclick="event.stopPropagation();saveCon()" style="padding:7px 14px;font-size:12px;">💾 Save</button>
        <span class="chev open" id="chev-connect">▼</span>
      </div>
    </div>
    <div class="sec-body open" id="body-connect">
      <div class="f2" style="margin-bottom:14px;">
        <div class="field"><label class="lbl">Section Title</label><input type="text" id="con-title" value="Connect With Us"></div>
        <div class="field"><label class="lbl">Subtitle</label><input type="text" id="con-sub" value="Stay updated with latest courses & events"></div>
      </div>

      <div style="font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px;">Platforms</div>
      <!-- Header row -->
      <div style="display:grid;grid-template-columns:32px 130px 1fr 1fr auto;gap:8px;padding:0 12px 6px;font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;">
        <div></div><div>Type</div><div>Name</div><div>URL</div><div></div>
      </div>
      <div id="con-platforms-list"></div>
      <button class="add-btn" id="con-add-btn" style="width:100%;justify-content:center;margin-top:4px;">+ Add Platform</button>
      <div class="status" id="con-status"></div>
    </div>
  </div>

  <!-- ══════════════ 2. GET IN TOUCH ══════════════ -->
  <div class="sec">
    <div class="sec-head" onclick="toggleSec('contact')">
      <div class="sec-left">
        <div class="sec-icon">📍</div>
        <div>
          <div class="sec-title">Get In Touch</div>
          <div class="sec-desc">Address, phone, email, hours, map embed</div>
        </div>
      </div>
      <div class="sec-right">
        <button class="save-btn" id="ct-save-btn" onclick="event.stopPropagation();saveCt()" style="padding:7px 14px;font-size:12px;">💾 Save</button>
        <span class="chev open" id="chev-contact">▼</span>
      </div>
    </div>
    <div class="sec-body open" id="body-contact">
      <div class="f2" style="margin-bottom:12px;">
        <div class="field"><label class="lbl">Section Title</label><input type="text" id="ct-title" value="Get in Touch"></div>
        <div class="field"><label class="lbl">Subtitle</label><input type="text" id="ct-sub" value="We're here to help you choose the right course"></div>
      </div>
      <div class="field" style="margin-bottom:12px;"><label class="lbl">Full Address</label><input type="text" id="ct-address" value="1st Floor, ATEC Avenue, Hardo Channi Road, Gurdaspur, Punjab – 143521"></div>
      <div class="f3" style="margin-bottom:12px;">
        <div class="field"><label class="lbl">Phone 1</label><input type="text" id="ct-phone1" value="+91 9878505706"></div>
        <div class="field"><label class="lbl">Phone 2 (optional)</label><input type="text" id="ct-phone2" value="+91 7009933289"></div>
        <div class="field"><label class="lbl">Hours</label><input type="text" id="ct-hours" placeholder="Mon–Sat, 9am–6pm"></div>
      </div>
      <div class="f2" style="margin-bottom:12px;">
        <div class="field"><label class="lbl">Email 1</label><input type="text" id="ct-email1" value="atecgsp@gmail.com"></div>
        <div class="field"><label class="lbl">Email 2 (optional)</label><input type="text" id="ct-email2" placeholder="support@atecedu.com"></div>
      </div>
      <div class="field" style="margin-bottom:12px;"><label class="lbl">Google Maps Embed URL</label><input type="text" id="ct-map" placeholder="https://www.google.com/maps/embed?pb=..."></div>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;padding:10px 12px;border:1px solid #e8edf2;border-radius:8px;background:#fafbfc;">
        <input type="checkbox" id="ct-show-form" checked style="width:15px;height:15px;accent-color:#0b1a2e;cursor:pointer;flex-shrink:0;">
        <label for="ct-show-form" style="font-size:13px;font-weight:600;color:#374151;cursor:pointer;flex:1;">Show enquiry form on homepage</label>
        <div class="f2" style="margin:0;flex:2;">
          <div class="field"><input type="text" id="ct-form-title" placeholder="Form title" style="font-size:12px;padding:6px 10px;"></div>
          <div class="field"><input type="text" id="ct-form-sub" placeholder="Form subtitle" style="font-size:12px;padding:6px 10px;"></div>
        </div>
      </div>
      <div class="status" id="ct-status"></div>
    </div>
  </div>

  <!-- ══════════════ 3. FAQ ══════════════ -->
  <div class="sec">
    <div class="sec-head" onclick="toggleSec('faq')">
      <div class="sec-left">
        <div class="sec-icon">❓</div>
        <div>
          <div class="sec-title">FAQ</div>
          <div class="sec-desc">Frequently asked questions shown on homepage</div>
        </div>
      </div>
      <div class="sec-right">
        <button class="save-btn" id="fq-save-btn" onclick="event.stopPropagation();saveFaq()" style="padding:7px 14px;font-size:12px;">💾 Save</button>
        <span class="chev open" id="chev-faq">▼</span>
      </div>
    </div>
    <div class="sec-body open" id="body-faq">
      <div class="f2" style="margin-bottom:14px;">
        <div class="field"><label class="lbl">Section Title</label><input type="text" id="fq-title" value="Frequently Asked Questions"></div>
        <div class="field"><label class="lbl">Subtitle</label><input type="text" id="fq-sub" value="Everything you need to know about ATEC courses"></div>
      </div>
      <div id="faq-admin-list"></div>
      <button class="add-btn" id="fq-add-btn" style="width:100%;justify-content:center;margin-top:4px;">+ Add Question</button>
      <div class="status" id="fq-status"></div>
    </div>
  </div>

  <!-- ══════════════ 4. DOWNLOAD RESOURCES ══════════════ -->
  <div class="sec">
    <div class="sec-head" onclick="toggleSec('dl')">
      <div class="sec-left">
        <div class="sec-icon">📥</div>
        <div>
          <div class="sec-title">Download Resources</div>
          <div class="sec-desc">Brochures, syllabus PDFs, study materials</div>
        </div>
      </div>
      <div class="sec-right">
        <button class="save-btn" id="dl-save-btn" onclick="event.stopPropagation();saveDl()" style="padding:7px 14px;font-size:12px;">💾 Save</button>
        <span class="chev open" id="chev-dl">▼</span>
      </div>
    </div>
    <div class="sec-body open" id="body-dl">
      <div class="f2" style="margin-bottom:14px;">
        <div class="field"><label class="lbl">Section Title</label><input type="text" id="dl-title" value="Download Resources"></div>
        <div class="field"><label class="lbl">Subtitle</label><input type="text" id="dl-sub" value="Free course brochures, syllabus PDFs, and study materials"></div>
      </div>
      <div id="dl-admin-list"></div>
      <button class="add-btn" id="dl-add-btn" style="width:100%;justify-content:center;margin-top:4px;">+ Add Resource</button>
      <div class="status" id="dl-status"></div>
    </div>
  </div>

</div>

<script>
const SB_URL = (window as any).__SB_URL as string
const SB_KEY = (window as any).__SB_KEY as string

function v(id: string)  { return ((document.getElementById(id) as HTMLInputElement)?.value||'').trim() }
function sv(id: string, val: string) { const el=document.getElementById(id) as HTMLInputElement; if(el) el.value=val||'' }
function chk(id: string) { return !!(document.getElementById(id) as HTMLInputElement)?.checked }
function schk(id: string, val: boolean) { const el=document.getElementById(id) as HTMLInputElement; if(el) el.checked=!!val }

async function sbGet(key: string) {
  if(!SB_URL||!SB_KEY) return null
  const r = await fetch(`${SB_URL}/rest/v1/site_settings?key=eq.${key}&select=value`,
    { headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}` } })
  const d = await r.json()
  return d?.[0]?.value??null
}
async function sbSet(key: string, value: any) {
  if(!SB_URL||!SB_KEY) throw new Error('No Supabase')
  await fetch(`${SB_URL}/rest/v1/site_settings`,{
    method:'POST',
    headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}`, 'Content-Type':'application/json', Prefer:'resolution=merge-duplicates,return=minimal' },
    body:JSON.stringify({key,value})
  })
}
function showStatus(id: string, ok: boolean, msg: string) {
  const el=document.getElementById(id)
  if(!el) return
  el.textContent=msg; el.className='status '+(ok?'ok':'err')
  setTimeout(()=>{ el.className='status' },3000)
}
function esc(s: string) { return String(s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;') }

;(window as any).toggleSec = function(id: string) {
  document.getElementById(`body-${id}`)?.classList.toggle('open')
  document.getElementById(`chev-${id}`)?.classList.toggle('open')
}

// ══════════════════════════════════════════════════
// 1. CONNECT WITH US
// ══════════════════════════════════════════════════
const PLATFORM_OPTIONS = ['whatsapp','instagram','facebook','youtube','google','twitter','linkedin','telegram','other']
const PLATFORM_EMOJI: any = { whatsapp:'💬', instagram:'📸', facebook:'👥', youtube:'▶️', google:'⭐', twitter:'🐦', linkedin:'💼', telegram:'✈️', other:'🔗' }

let conPlatforms: any[] = [
  { name:'WhatsApp', url:'https://wa.me/917009933289', platform:'whatsapp', qr_url:'', is_active:true },
  { name:'Instagram', url:'https://www.instagram.com/ateceducation/', platform:'instagram', qr_url:'', is_active:true },
  { name:'Facebook', url:'https://www.facebook.com/ateceducation', platform:'facebook', qr_url:'', is_active:true },
  { name:'YouTube', url:'https://www.youtube.com/@ATECEducationalSociety', platform:'youtube', qr_url:'', is_active:true },
  { name:'Google Reviews', url:'https://g.page/r/atec-gurdaspur', platform:'google', qr_url:'', is_active:true },
]

function renderConPlatforms() {
  const list = document.getElementById('con-platforms-list')!
  list.innerHTML = ''
  conPlatforms.forEach((p, i) => {
    const wrap = document.createElement('div')
    wrap.style.cssText = 'margin-bottom:4px'
    wrap.innerHTML = `
      <div class="plat-row">
        <div class="plat-num">${PLATFORM_EMOJI[p.platform]||'🔗'}</div>
        <select id="cp-platform-${i}" onchange="updatePlatEmoji(${i})" style="padding:6px 8px;font-size:12px;">
          ${PLATFORM_OPTIONS.map(o=>`<option value="${o}"${p.platform===o?' selected':''}>${o.charAt(0).toUpperCase()+o.slice(1)}</option>`).join('')}
        </select>
        <input type="text" id="cp-name-${i}" value="${esc(p.name||'')}" placeholder="Display name" style="font-size:13px;padding:7px 10px;">
        <input type="url" id="cp-url-${i}" value="${esc(p.url||'')}" placeholder="https://..." style="font-size:12px;padding:7px 10px;">
        <div style="display:flex;gap:4px;align-items:center;flex-shrink:0;">
          <label style="display:flex;align-items:center;gap:4px;cursor:pointer;font-size:12px;color:#64748b;white-space:nowrap;">
            <input type="checkbox" id="cp-active-${i}" ${p.is_active!==false?'checked':''} style="width:14px;height:14px;accent-color:#0b1a2e;">
          </label>
          <button class="plat-del" onclick="conDel(${i})">✕</button>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;padding:0 12px 6px;margin-top:-2px;">
        <span style="font-size:10px;color:#94a3b8;white-space:nowrap;min-width:80px;">QR Code URL</span>
        <input type="url" id="cp-qr-${i}" value="${esc(p.qr_url||'')}" placeholder="optional — paste QR image URL" style="font-size:12px;padding:5px 10px;border-color:#f1f5f9;background:#f8fafc;color:#94a3b8;">
      </div>`
    list.appendChild(wrap)
  })
}

;(window as any).updatePlatEmoji = function(i: number) {
  const sel = (document.getElementById(`cp-platform-${i}`) as HTMLSelectElement)?.value
  const numEl = document.querySelectorAll('.plat-num')[i] as HTMLElement
  if (numEl) numEl.textContent = PLATFORM_EMOJI[sel] || '🔗'
}
;(window as any).conDel = (i: number) => { conPlatforms.splice(i,1); renderConPlatforms() }

document.getElementById('con-add-btn')?.addEventListener('click', () => {
  conPlatforms.push({ name:'', url:'', platform:'other', qr_url:'', is_active:true })
  renderConPlatforms()
  document.getElementById(`cp-name-${conPlatforms.length-1}`)?.focus()
})

;(window as any).saveCon = async function() {
  const btn = document.getElementById('con-save-btn') as HTMLButtonElement
  btn.disabled=true; btn.textContent='⏳'
  const saved = conPlatforms.map((_,i)=>({
    name:      v(`cp-name-${i}`),
    url:       v(`cp-url-${i}`),
    platform:  (document.getElementById(`cp-platform-${i}`) as HTMLSelectElement)?.value||'other',
    qr_url:    v(`cp-qr-${i}`),
    is_active: chk(`cp-active-${i}`),
  }))
  const payload = { title:v('con-title'), subtitle:v('con-sub'), platforms:saved }
  try { await sbSet('social_connect', payload); showStatus('con-status',true,'✅ Saved!') }
  catch { showStatus('con-status',false,'❌ Save failed') }
  btn.disabled=false; btn.textContent='💾 Save'
}

// ══════════════════════════════════════════════════
// 2. GET IN TOUCH
// ══════════════════════════════════════════════════
;(window as any).saveCt = async function() {
  const btn = document.getElementById('ct-save-btn') as HTMLButtonElement
  btn.disabled=true; btn.textContent='⏳'
  const payload = {
    title:v('ct-title'), subtitle:v('ct-sub'), address:v('ct-address'),
    phone1:v('ct-phone1'), phone2:v('ct-phone2'), email1:v('ct-email1'), email2:v('ct-email2'),
    hours:v('ct-hours'), map_embed_url:v('ct-map'),
    show_form:chk('ct-show-form'), form_title:v('ct-form-title'), form_subtitle:v('ct-form-sub'),
  }
  try { await sbSet('contact_info', payload); showStatus('ct-status',true,'✅ Saved!') }
  catch { showStatus('ct-status',false,'❌ Save failed') }
  btn.disabled=false; btn.textContent='💾 Save'
}

// ══════════════════════════════════════════════════
// 3. FAQ
// ══════════════════════════════════════════════════
let faqItems: any[] = [
  { q:'What courses does ATEC Gurdaspur offer?', a:'ATEC offers 20+ courses including GEN AI, MERN Stack, Tally Prime, Hardware & Networking, Python, Digital Marketing, and more.', is_active:true },
  { q:'Where is ATEC located?', a:'1st Floor, ATEC Avenue, Hardo Channi Road, Gurdaspur, Punjab – 143521.', is_active:true },
  { q:'What are the course fees?', a:'Course fees range from ₹1,499 to ₹6,999. Flexible payment plans and frequent discounts available.', is_active:true },
  { q:'Does ATEC provide certificates?', a:'Yes. All courses provide an ISO-verified certificate. Verify online at atecedu.com/verification.', is_active:true },
  { q:'What is the placement support like?', a:'ATEC has a dedicated placement cell with 500+ hiring partners. 100% placement assistance for eligible students.', is_active:true },
  { q:'Are online courses available?', a:'Yes. Most courses are available online, hybrid, and classroom modes with live sessions.', is_active:true },
  { q:'How do I enroll?', a:'Click "Enroll Now" to WhatsApp us, or call +91 7009933289. New batches start every month.', is_active:true },
]
let faqOpenIdx: number|null = null

function renderFaqAdmin() {
  const list = document.getElementById('faq-admin-list')!
  list.innerHTML = ''
  faqItems.forEach((f, i) => {
    const isOpen = faqOpenIdx === i
    const div = document.createElement('div')
    div.className = 'faq-row'
    div.innerHTML = `
      <div class="faq-top" onclick="toggleFaqRow(${i})">
        <div class="faq-num">${i+1}</div>
        <div class="faq-q-preview">${esc(f.q||'New question…')}</div>
        <div class="faq-actions" onclick="event.stopPropagation()">
          <button class="btn-sm" onclick="faqMove(${i},-1)" title="Move up">↑</button>
          <button class="btn-sm" onclick="faqMove(${i},1)" title="Move down">↓</button>
          <label style="display:flex;align-items:center;gap:4px;cursor:pointer;font-size:12px;color:#64748b;padding:0 4px;">
            <input type="checkbox" id="fq-active-${i}" ${f.is_active!==false?'checked':''} style="width:13px;height:13px;accent-color:#0b1a2e;">
            <span>Show</span>
          </label>
          <button class="btn-sm red" onclick="faqDel(${i})">✕</button>
        </div>
        <span style="font-size:11px;color:#94a3b8;margin-left:4px;">${isOpen?'▲':'▼'}</span>
      </div>
      <div class="faq-body ${isOpen?'open':''}" id="faq-body-${i}">
        <div class="field" style="margin-bottom:8px;">
          <label class="lbl">Question</label>
          <input type="text" id="fq-q-${i}" value="${esc(f.q||'')}" placeholder="Type the question…" oninput="updateFaqPreview(${i})">
        </div>
        <div class="field">
          <label class="lbl">Answer</label>
          <textarea id="fq-a-${i}" rows="2" placeholder="Type the answer…">${esc(f.a||'')}</textarea>
        </div>
      </div>`
    list.appendChild(div)
  })
}

;(window as any).toggleFaqRow = function(i: number) {
  faqOpenIdx = faqOpenIdx === i ? null : i
  renderFaqAdmin()
}
;(window as any).updateFaqPreview = function(i: number) {
  const q = v(`fq-q-${i}`)
  const preview = document.querySelectorAll('.faq-q-preview')[i] as HTMLElement
  if (preview) preview.textContent = q || 'New question…'
}
;(window as any).faqDel = (i: number) => { faqItems.splice(i,1); faqOpenIdx=null; renderFaqAdmin() }
;(window as any).faqMove = (i: number, d: number) => {
  const j=i+d; if(j<0||j>=faqItems.length) return
  ;[faqItems[i],faqItems[j]]=[faqItems[j],faqItems[i]]
  faqOpenIdx=j; renderFaqAdmin()
}

document.getElementById('fq-add-btn')?.addEventListener('click', () => {
  faqItems.push({ q:'', a:'', is_active:true })
  faqOpenIdx = faqItems.length - 1
  renderFaqAdmin()
  setTimeout(() => document.getElementById(`fq-q-${faqOpenIdx}`)?.focus(), 50)
})

;(window as any).saveFaq = async function() {
  const btn = document.getElementById('fq-save-btn') as HTMLButtonElement
  btn.disabled=true; btn.textContent='⏳'
  const saved = faqItems.map((_,i)=>({
    q:         v(`fq-q-${i}`),
    a:         (document.getElementById(`fq-a-${i}`) as HTMLTextAreaElement)?.value?.trim()||'',
    is_active: chk(`fq-active-${i}`),
  }))
  const payload = { title:v('fq-title'), subtitle:v('fq-sub'), faqs:saved }
  try { await sbSet('faq_items', payload); showStatus('fq-status',true,'✅ Saved!') }
  catch { showStatus('fq-status',false,'❌ Save failed') }
  btn.disabled=false; btn.textContent='💾 Save'
}

// ══════════════════════════════════════════════════
// 4. DOWNLOAD RESOURCES
// ══════════════════════════════════════════════════
let dlItems: any[] = [
  { title:'ATEC Course Brochure 2026', description:'Full catalogue of all courses with fees, duration, and syllabus overview.', file_url:'', category:'Brochure', thumbnail_url:'', is_active:true },
  { title:'Hardware & Networking Syllabus', description:'Detailed week-by-week syllabus for the Hardware & Networking course.', file_url:'', category:'Syllabus', thumbnail_url:'', is_active:true },
  { title:'Tally Prime Study Guide', description:'Comprehensive Tally Prime notes covering GST, payroll, and advanced features.', file_url:'', category:'Study Material', thumbnail_url:'', is_active:true },
]

function renderDlAdmin() {
  const list = document.getElementById('dl-admin-list')!
  list.innerHTML = ''
  dlItems.forEach((r, i) => {
    const div = document.createElement('div')
    div.className = 'res-row'
    div.innerHTML = `
      <div class="res-top">
        <div class="plat-num" style="width:26px;height:26px;font-size:10px;">📄</div>
        <input type="text" id="dl-t-${i}" value="${esc(r.title||'')}" placeholder="Resource title" style="font-size:13px;padding:6px 10px;">
        <input type="text" id="dl-cat-${i}" value="${esc(r.category||'')}" placeholder="Category" style="font-size:12px;padding:6px 10px;">
        <div style="display:flex;gap:6px;align-items:center;justify-content:flex-end;">
          <label style="display:flex;align-items:center;gap:4px;cursor:pointer;font-size:12px;color:#64748b;">
            <input type="checkbox" id="dl-active-${i}" ${r.is_active!==false?'checked':''} style="width:13px;height:13px;accent-color:#0b1a2e;">
            Show
          </label>
          <button class="btn-sm red" onclick="dlDel(${i})">✕</button>
        </div>
      </div>
      <div class="res-bottom">
        <input type="text" id="dl-desc-${i}" value="${esc(r.description||'')}" placeholder="Short description" style="font-size:12px;padding:6px 10px;border-color:#f1f5f9;">
        <input type="url" id="dl-url-${i}" value="${esc(r.file_url||'')}" placeholder="File URL (PDF/DOCX)" style="font-size:12px;padding:6px 10px;border-color:#f1f5f9;">
      </div>`
    list.appendChild(div)
  })
}

;(window as any).dlDel = (i: number) => { dlItems.splice(i,1); renderDlAdmin() }

document.getElementById('dl-add-btn')?.addEventListener('click', () => {
  dlItems.push({ title:'', description:'', file_url:'', category:'Brochure', thumbnail_url:'', is_active:true })
  renderDlAdmin()
  setTimeout(() => document.getElementById(`dl-t-${dlItems.length-1}`)?.focus(), 50)
})

;(window as any).saveDl = async function() {
  const btn = document.getElementById('dl-save-btn') as HTMLButtonElement
  btn.disabled=true; btn.textContent='⏳'
  const saved = dlItems.map((_,i)=>({
    title:         v(`dl-t-${i}`),
    description:   v(`dl-desc-${i}`),
    file_url:      v(`dl-url-${i}`),
    category:      v(`dl-cat-${i}`),
    thumbnail_url: '',
    is_active:     chk(`dl-active-${i}`),
  }))
  const payload = { title:v('dl-title'), subtitle:v('dl-sub'), resources:saved }
  try { await sbSet('download_resources', payload); showStatus('dl-status',true,'✅ Saved!') }
  catch { showStatus('dl-status',false,'❌ Save failed') }
  btn.disabled=false; btn.textContent='💾 Save'
}

// ══════════════════════════════════════════════════
// PRELOAD
// ══════════════════════════════════════════════════
async function preload() {
  try {
    const [conCfg, ctCfg, fqCfg, dlCfg] = await Promise.all([
      sbGet('social_connect'), sbGet('contact_info'), sbGet('faq_items'), sbGet('download_resources')
    ])
    if (conCfg) {
      sv('con-title', conCfg.title); sv('con-sub', conCfg.subtitle)
      if(Array.isArray(conCfg.platforms)&&conCfg.platforms.length) conPlatforms=conCfg.platforms
    }
    if (ctCfg) {
      sv('ct-title',ctCfg.title); sv('ct-sub',ctCfg.subtitle); sv('ct-address',ctCfg.address)
      sv('ct-phone1',ctCfg.phone1); sv('ct-phone2',ctCfg.phone2)
      sv('ct-email1',ctCfg.email1); sv('ct-email2',ctCfg.email2)
      sv('ct-hours',ctCfg.hours); sv('ct-map',ctCfg.map_embed_url)
      schk('ct-show-form',ctCfg.show_form!==false)
      sv('ct-form-title',ctCfg.form_title); sv('ct-form-sub',ctCfg.form_subtitle)
    }
    if (fqCfg) {
      sv('fq-title',fqCfg.title); sv('fq-sub',fqCfg.subtitle)
      if(Array.isArray(fqCfg.faqs)&&fqCfg.faqs.length) faqItems=fqCfg.faqs
    }
    if (dlCfg) {
      sv('dl-title',dlCfg.title); sv('dl-sub',dlCfg.subtitle)
      if(Array.isArray(dlCfg.resources)&&dlCfg.resources.length) dlItems=dlCfg.resources
    }
  } catch(e) { console.warn('Preload error:',e) }
  renderConPlatforms(); renderFaqAdmin(); renderDlAdmin()
}

renderConPlatforms(); renderFaqAdmin(); renderDlAdmin()
preload()
</script>
</AdminLayout>
