---
// src/pages/admin/zoom.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="Zoom / Live Class Links" activeSection="zoom">

<style>
  .wrap { max-width:820px }
  .pg-title { font-family:'Sora',sans-serif; font-size:20px; font-weight:900; color:#0b1a2e; margin:0 0 2px }
  .pg-sub { font-size:13px; color:#94a3b8; margin:0 0 20px }
  .panel { background:#fff; border-radius:14px; border:1px solid #e2e8f0; padding:22px; margin-bottom:16px }
  .panel-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:18px; gap:12px }
  .panel-title { font-size:15px; font-weight:700; color:#0b1a2e; margin:0 }
  .panel-desc { font-size:12px; color:#94a3b8; margin:3px 0 0 }
  .f2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px }
  @media(max-width:580px){ .f2 { grid-template-columns:1fr } }
  .field { display:flex; flex-direction:column; gap:4px; margin-bottom:12px }
  .lbl { font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.04em }
  .hint { font-size:11px; color:#94a3b8; margin-top:3px }
  input[type=text],input[type=url],input[type=datetime-local],input[type=number],select,textarea {
    padding:8px 11px; border:1.5px solid #e2e8f0; border-radius:8px;
    font-size:13px; color:#1e293b; outline:none; font-family:'Inter',sans-serif;
    width:100%; box-sizing:border-box; background:#fff; transition:border-color 0.15s
  }
  input:focus,select:focus,textarea:focus { border-color:#0b1a2e }

  /* Session card */
  .session-card { border:1px solid #e8edf2; border-radius:10px; margin-bottom:8px; overflow:hidden; background:#fafbfc }
  .session-card:hover { border-color:#0b1a2e }
  .session-head { display:flex; align-items:center; gap:10px; padding:11px 14px; cursor:pointer }
  .session-head:hover { background:#f8fafc }
  .session-icon { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0 }
  .session-title { font-size:13px; font-weight:700; color:#1e293b; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap }
  .session-meta { font-size:11px; color:#94a3b8; white-space:nowrap }
  .session-body { display:none; padding:14px; border-top:1px solid #f1f5f9 }
  .session-body.open { display:block }
  .chev { font-size:10px; color:#94a3b8; transition:transform 0.2s; flex-shrink:0 }
  .chev.open { transform:rotate(180deg) }

  /* Platform badge */
  .plat-badge { display:inline-flex; align-items:center; gap:5px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700 }
  .plat-zoom { background:#2D8CFF; color:#fff }
  .plat-meet { background:#34A853; color:#fff }
  .plat-teams { background:#6264A7; color:#fff }
  .plat-other { background:#64748b; color:#fff }

  /* Status badge */
  .status-live   { background:#dcfce7; color:#15803d; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700 }
  .status-sched  { background:#fef3c7; color:#92400e; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700 }
  .status-ended  { background:#f1f5f9; color:#94a3b8;  padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700 }

  /* Buttons */
  .save-btn { display:inline-flex; align-items:center; gap:7px; background:#0b1a2e; color:#d4f01a; border:none; border-radius:9px; padding:10px 20px; font-size:13px; font-weight:800; cursor:pointer; font-family:'Inter',sans-serif; transition:background 0.15s; white-space:nowrap }
  .save-btn:hover { background:#1a3460 }
  .save-btn:disabled { background:#94a3b8; cursor:not-allowed; color:#fff }
  .add-btn { display:flex; align-items:center; gap:6px; padding:8px 14px; background:#f0f9ff; border:1.5px dashed #93c5fd; color:#0b1a2e; border-radius:8px; font-size:12px; font-weight:700; cursor:pointer; font-family:'Inter',sans-serif; transition:all 0.15s; justify-content:center; width:100%; margin-top:4px }
  .add-btn:hover { background:#dbeafe }
  .btn-sm { padding:4px 10px; border-radius:6px; font-size:11px; font-weight:600; cursor:pointer; border:none; font-family:'Inter',sans-serif }
  .btn-del { background:#fee2e2; color:#dc2626 }
  .btn-del:hover { background:#fca5a5 }
  .status { font-size:12px; font-weight:600; padding:8px 14px; border-radius:8px; margin-top:10px }
  .status.ok  { background:#dcfce7; color:#166534 }
  .status.err { background:#fee2e2; color:#991b1b }

  /* Info box */
  .info-box { background:#eff6ff; border:1px solid #bfdbfe; border-radius:10px; padding:14px 16px; margin-bottom:16px; font-size:13px; color:#1d4ed8; line-height:1.6 }
</style>

<div class="wrap">
  <h1 class="pg-title">🎥 Live Class Links</h1>
  <p class="pg-sub">Manage Zoom, Google Meet, and Teams links for live classes. Students see these on their course pages.</p>

  <div class="info-box">
    <strong>Supported platforms:</strong> Zoom, Google Meet, Microsoft Teams, and any other meeting link. You can paste the full join URL — students click it to join directly without needing a meeting ID or password separately.
  </div>

  <!-- ── Default / Always-On Links ── -->
  <div class="panel">
    <div class="panel-head">
      <div>
        <div class="panel-title">📌 Default Classroom Links</div>
        <div class="panel-desc">Permanent links shown to all enrolled students as the primary entry point for live classes</div>
      </div>
      <button class="save-btn" id="default-save-btn" onclick="saveDefaults()">💾 Save</button>
    </div>
    <div class="f2">
      <div class="field">
        <label class="lbl">Primary Meeting Platform</label>
        <select id="def-platform">
          <option value="zoom">Zoom</option>
          <option value="meet">Google Meet</option>
          <option value="teams">Microsoft Teams</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="field">
        <label class="lbl">Join Link (full URL)</label>
        <input type="url" id="def-link" placeholder="https://zoom.us/j/... or https://meet.google.com/...">
        <div class="hint">Paste the full invite link. Students click this to join.</div>
      </div>
      <div class="field">
        <label class="lbl">Meeting ID (optional)</label>
        <input type="text" id="def-meeting-id" placeholder="123 456 7890">
      </div>
      <div class="field">
        <label class="lbl">Passcode (optional)</label>
        <input type="text" id="def-passcode" placeholder="abc123">
      </div>
    </div>
    <div class="field">
      <label class="lbl">Schedule / Timing Info</label>
      <input type="text" id="def-schedule" placeholder="Mon–Fri, 7:00 PM – 9:00 PM IST">
    </div>
    <div class="field">
      <label class="lbl">Additional Notes</label>
      <textarea id="def-notes" rows="2" placeholder="Any notes for students, e.g. 'Keep mic muted on entry'"></textarea>
    </div>
    <div id="default-status" class="status" style="display:none"></div>
  </div>

  <!-- ── Per-Course / Scheduled Sessions ── -->
  <div class="panel">
    <div class="panel-head">
      <div>
        <div class="panel-title">📅 Scheduled Sessions</div>
        <div class="panel-desc">One-time or recurring sessions with specific links per course or batch</div>
      </div>
      <button class="save-btn" id="sessions-save-btn" onclick="saveSessions()">💾 Save Sessions</button>
    </div>

    <div id="sessions-list"></div>
    <button class="add-btn" id="session-add-btn">+ Add Session</button>
    <div id="sessions-status" class="status" style="display:none"></div>
  </div>

  <!-- ── Recording Links ── -->
  <div class="panel">
    <div class="panel-head">
      <div>
        <div class="panel-title">🎬 Class Recordings</div>
        <div class="panel-desc">Links to recorded sessions for students who missed a class or want to revise</div>
      </div>
      <button class="save-btn" id="rec-save-btn" onclick="saveRecordings()">💾 Save</button>
    </div>
    <div id="recordings-list"></div>
    <button class="add-btn" id="rec-add-btn">+ Add Recording</button>
    <div id="rec-status" class="status" style="display:none"></div>
  </div>
</div>

<script>
const SB_URL = (window as any).__SB_URL as string
const SB_KEY = (window as any).__SB_KEY as string

function v(id: string) { return ((document.getElementById(id) as HTMLInputElement)?.value||'').trim() }
function sv(id: string, val: string) { const el=document.getElementById(id) as HTMLInputElement; if(el) el.value=val||'' }
function svs(id: string, val: string) { const el=document.getElementById(id) as HTMLSelectElement; if(el) el.value=val||'' }
function chk(id: string) { return !!(document.getElementById(id) as HTMLInputElement)?.checked }
function esc(s: string) { return String(s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;') }

async function sbGet(key: string) {
  if(!SB_URL||!SB_KEY) return null
  const r = await fetch(`${SB_URL}/rest/v1/site_settings?key=eq.${key}&select=value`, { headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}` } })
  return (await r.json())?.[0]?.value ?? null
}
async function sbSet(key: string, value: any) {
  await fetch(`${SB_URL}/rest/v1/site_settings`, {
    method:'POST',
    headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}`, 'Content-Type':'application/json', Prefer:'resolution=merge-duplicates,return=minimal' },
    body:JSON.stringify({key,value})
  })
}
function showStatus(id: string, ok: boolean, msg: string) {
  const el=document.getElementById(id)!
  el.textContent=msg; el.className='status '+(ok?'ok':'err'); el.style.display='block'
  setTimeout(()=>el.style.display='none', 3000)
}

const PLAT_ICON: any = { zoom:'🔵', meet:'🟢', teams:'🟣', other:'🎥' }
const PLAT_LABEL: any = { zoom:'Zoom', meet:'Google Meet', teams:'Teams', other:'Other' }
const PLAT_CLASS: any = { zoom:'plat-zoom', meet:'plat-meet', teams:'plat-teams', other:'plat-other' }

// ── Default links ───────────────────────────────────────────
;(window as any).saveDefaults = async function() {
  const btn = document.getElementById('default-save-btn') as HTMLButtonElement
  btn.disabled=true; btn.textContent='⏳'
  try {
    const plat = (document.getElementById('def-platform') as HTMLSelectElement)?.value || 'zoom'
    await sbSet('zoom_defaults', {
      platform:   plat,
      join_link:  v('def-link'),
      meeting_id: v('def-meeting-id'),
      passcode:   v('def-passcode'),
      schedule:   v('def-schedule'),
      notes:      v('def-notes'),
    })
    showStatus('default-status', true, '✅ Saved! Default classroom links updated.')
  } catch(e:any) { showStatus('default-status', false, '❌ ' + (e.message||'Save failed')) }
  btn.disabled=false; btn.textContent='💾 Save'
}

// ── Sessions ────────────────────────────────────────────────
let sessions: any[] = [
  { title:'MERN Stack — Batch S-241129 Live Class', platform:'zoom', link:'', course:'MERN Stack', date:'', time:'7:00 PM', status:'scheduled', is_active:true },
  { title:'GEN AI Workshop — All Batches', platform:'meet', link:'', course:'GEN AI', date:'', time:'6:00 PM', status:'scheduled', is_active:true },
]
let openSession: number|null = null

function renderSessions() {
  const list = document.getElementById('sessions-list')!
  list.innerHTML = ''
  sessions.forEach((s, i) => {
    const meta = PLAT_LABEL[s.platform] || 'Other'
    const platClass = PLAT_CLASS[s.platform] || 'plat-other'
    const statusBadge = s.status === 'live' ? '<span class="status-live">🔴 Live Now</span>'
      : s.status === 'ended' ? '<span class="status-ended">✓ Ended</span>'
      : '<span class="status-sched">📅 Scheduled</span>'
    const isOpen = openSession === i
    const div = document.createElement('div')
    div.className = 'session-card'
    div.innerHTML = `
      <div class="session-head" onclick="toggleSession(${i})">
        <div class="session-icon" style="background:${s.platform==='zoom'?'#e8f4ff':s.platform==='meet'?'#e8f5e9':'#ede7f6'}">${PLAT_ICON[s.platform]||'🎥'}</div>
        <div class="session-title">${esc(s.title||'New Session')}</div>
        <div class="session-meta">${statusBadge}</div>
        <div style="display:flex;gap:4px;align-items:center;" onclick="event.stopPropagation()">
          <button class="btn-sm btn-del" onclick="delSession(${i})">✕</button>
        </div>
        <span class="chev ${isOpen?'open':''}">▼</span>
      </div>
      <div class="session-body ${isOpen?'open':''}">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
          <div class="field" style="margin-bottom:0">
            <label class="lbl">Session Title</label>
            <input type="text" id="ss-title-${i}" value="${esc(s.title||'')}" placeholder="Course name — Batch X Live Class">
          </div>
          <div class="field" style="margin-bottom:0">
            <label class="lbl">Course / Batch</label>
            <input type="text" id="ss-course-${i}" value="${esc(s.course||'')}" placeholder="MERN Stack, Tally Prime...">
          </div>
          <div class="field" style="margin-bottom:0">
            <label class="lbl">Platform</label>
            <select id="ss-plat-${i}">
              <option value="zoom"${s.platform==='zoom'?' selected':''}>🔵 Zoom</option>
              <option value="meet"${s.platform==='meet'?' selected':''}>🟢 Google Meet</option>
              <option value="teams"${s.platform==='teams'?' selected':''}>🟣 Microsoft Teams</option>
              <option value="other"${s.platform==='other'?' selected':''}>🎥 Other</option>
            </select>
          </div>
          <div class="field" style="margin-bottom:0">
            <label class="lbl">Status</label>
            <select id="ss-status-${i}">
              <option value="scheduled"${s.status==='scheduled'?' selected':''}>📅 Scheduled</option>
              <option value="live"${s.status==='live'?' selected':''}>🔴 Live Now</option>
              <option value="ended"${s.status==='ended'?' selected':''}>✓ Ended</option>
            </select>
          </div>
          <div class="field" style="margin-bottom:0">
            <label class="lbl">Date</label>
            <input type="date" id="ss-date-${i}" value="${esc(s.date||'')}">
          </div>
          <div class="field" style="margin-bottom:0">
            <label class="lbl">Time</label>
            <input type="text" id="ss-time-${i}" value="${esc(s.time||'')}" placeholder="7:00 PM IST">
          </div>
        </div>
        <div class="field" style="margin-bottom:0">
          <label class="lbl">Join Link (full URL)</label>
          <input type="url" id="ss-link-${i}" value="${esc(s.link||'')}" placeholder="https://zoom.us/j/... or https://meet.google.com/...">
        </div>
      </div>`
    list.appendChild(div)
  })
}

;(window as any).toggleSession = function(i: number) {
  openSession = openSession === i ? null : i
  renderSessions()
}
;(window as any).delSession = function(i: number) {
  collectSessions(); sessions.splice(i,1); openSession=null; renderSessions()
}
document.getElementById('session-add-btn')?.addEventListener('click', () => {
  collectSessions()
  sessions.push({ title:'', platform:'zoom', link:'', course:'', date:'', time:'7:00 PM', status:'scheduled', is_active:true })
  openSession = sessions.length - 1
  renderSessions()
})

function collectSessions() {
  sessions = sessions.map((_,i) => ({
    title:    v(`ss-title-${i}`),
    course:   v(`ss-course-${i}`),
    platform: (document.getElementById(`ss-plat-${i}`) as HTMLSelectElement)?.value || 'zoom',
    status:   (document.getElementById(`ss-status-${i}`) as HTMLSelectElement)?.value || 'scheduled',
    date:     v(`ss-date-${i}`),
    time:     v(`ss-time-${i}`),
    link:     v(`ss-link-${i}`),
    is_active: true,
  }))
}

;(window as any).saveSessions = async function() {
  const btn = document.getElementById('sessions-save-btn') as HTMLButtonElement
  btn.disabled=true; btn.textContent='⏳'
  collectSessions()
  try {
    await sbSet('zoom_sessions', sessions)
    showStatus('sessions-status', true, '✅ Saved! Sessions updated for students.')
  } catch(e:any) { showStatus('sessions-status', false, '❌ ' + (e.message||'Save failed')) }
  btn.disabled=false; btn.textContent='💾 Save Sessions'
}

// ── Recordings ──────────────────────────────────────────────
let recordings: any[] = [
  { title:'MERN Stack — Week 1 Recording', course:'MERN Stack', url:'', date:'', duration:'2h 15min', is_active:true },
]

function renderRecordings() {
  const list = document.getElementById('recordings-list')!
  list.innerHTML = ''
  recordings.forEach((r, i) => {
    const div = document.createElement('div')
    div.style.cssText = 'display:grid;grid-template-columns:1fr 1fr 1fr 120px auto;gap:8px;align-items:center;padding:8px 12px;border:1px solid #e8edf2;border-radius:8px;margin-bottom:6px;background:#fafbfc;'
    div.innerHTML = `
      <input type="text" id="rc-title-${i}" value="${esc(r.title||'')}" placeholder="Session title" style="font-size:12px;padding:6px 9px;">
      <input type="text" id="rc-course-${i}" value="${esc(r.course||'')}" placeholder="Course name" style="font-size:12px;padding:6px 9px;">
      <input type="url" id="rc-url-${i}" value="${esc(r.url||'')}" placeholder="Recording URL" style="font-size:12px;padding:6px 9px;">
      <input type="text" id="rc-dur-${i}" value="${esc(r.duration||'')}" placeholder="2h 15min" style="font-size:12px;padding:6px 9px;">
      <button class="btn-sm btn-del" onclick="delRec(${i})">✕</button>`
    list.appendChild(div)
  })
}

;(window as any).delRec = function(i: number) { collectRecs(); recordings.splice(i,1); renderRecordings() }
document.getElementById('rec-add-btn')?.addEventListener('click', () => {
  collectRecs()
  recordings.push({ title:'', course:'', url:'', date:'', duration:'', is_active:true })
  renderRecordings()
})
function collectRecs() {
  recordings = recordings.map((_,i) => ({
    title:    v(`rc-title-${i}`),
    course:   v(`rc-course-${i}`),
    url:      v(`rc-url-${i}`),
    duration: v(`rc-dur-${i}`),
    is_active:true,
  }))
}
;(window as any).saveRecordings = async function() {
  const btn = document.getElementById('rec-save-btn') as HTMLButtonElement
  btn.disabled=true; btn.textContent='⏳'
  collectRecs()
  try {
    await sbSet('zoom_recordings', recordings)
    showStatus('rec-status', true, '✅ Saved!')
  } catch(e:any) { showStatus('rec-status', false, '❌ ' + (e.message||'Save failed')) }
  btn.disabled=false; btn.textContent='💾 Save'
}

// ── Preload ────────────────────────────────────────────────
async function preload() {
  try {
    const [defs, sess, recs] = await Promise.all([sbGet('zoom_defaults'), sbGet('zoom_sessions'), sbGet('zoom_recordings')])
    if (defs) {
      svs('def-platform', defs.platform)
      sv('def-link', defs.join_link); sv('def-meeting-id', defs.meeting_id)
      sv('def-passcode', defs.passcode); sv('def-schedule', defs.schedule)
      sv('def-notes', defs.notes)
    }
    if (Array.isArray(sess) && sess.length) sessions = sess
    if (Array.isArray(recs) && recs.length) recordings = recs
  } catch(e) {}
  renderSessions(); renderRecordings()
}
renderSessions(); renderRecordings()
preload()
</script>
</AdminLayout>
