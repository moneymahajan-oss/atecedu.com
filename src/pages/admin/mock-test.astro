    <!-- Messages -->
    <div class="form-grid" style="margin-bottom:20px;">
      <div class="field">
        <label>Pass Message (shown on result screen when score ≥ 75%)</label>
        <input type="text" id="cfg-pass-msg" placeholder="You qualify for a course discount!">
      </div>
      <div class="field">
        <label>Fail Message (shown when score &lt; 75%)</label>
        <input type="text" id="cfg-fail-msg" placeholder="Score 75%+ to unlock a discount.">
      </div>
    </div>

    <!-- Toggles -->
    <div style="background:#f8fafc;border-radius:12px;padding:16px;margin-bottom:20px;">
      <h4 style="font-size:14px;font-weight:700;color:#0b1525;margin:0 0 12px;">Feature Toggles</h4>
      <div class="toggle-row">
