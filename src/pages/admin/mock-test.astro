---
// src/pages/admin/mock-test.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---

<AdminLayout title="Mock Test Manager" activeSection="mock-test">

<style>
/* ── Tabs ── */
.mt-tabs { display:flex; gap:4px; margin-bottom:24px; background:#f0f4f8; border-radius:12px; padding:4px; flex-wrap:wrap; }
.mt-tab { padding:8px 18px; border-radius:9px; border:none; background:transparent; font-size:13px; font-weight:600; color:#64748b; cursor:pointer; font-family:'Inter',sans-serif; transition:all 0.15s; white-space:nowrap; }
.mt-tab.active { background:#fff; color:#0b1525; box-shadow:0 1px 4px rgba(0,0,0,0.1); }

/* ── Cards ── */
.panel { background:#fff; border-radius:14px; padding:24px; margin-bottom:20px; border:1px solid #e8edf2; }
.panel-title { font-size:16px; font-weight:700; color:#0b1525; margin:0 0 18px; display:flex; align-items:center; gap:8px; }
.panel-title span { font-size:18px; }

/* ── Stats row ── */
.stats-row { display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:12px; margin-bottom:20px; }
.stat-card { background:#fff; border-radius:12px; padding:16px; border:1px solid #e8edf2; text-align:center; }
.stat-num { font-family:'Sora',sans-serif; font-size:2rem; font-weight:900; color:#0b1525; line-height:1; }
.stat-lbl { font-size:11px; color:#94a3b8; font-weight:600; margin-top:4px; text-transform:uppercase; letter-spacing:0.05em; }

/* ── Form controls ── */
.form-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
@media(max-width:640px){ .form-grid { grid-template-columns:1fr; } }
.form-grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:14px; }
@media(max-width:640px){ .form-grid-3 { grid-template-columns:1fr; } }

.field { display:flex; flex-direction:column; gap:5px; }
.field label { font-size:12px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.05em; }
.field input, .field select, .field textarea {
  padding:9px 12px; border:1.5px solid #e2e8f0; border-radius:8px;
  font-size:14px; color:#1e293b; font-family:'Inter',sans-serif;
  outline:none; transition:border-color 0.15s; background:#fff;
}
.field input:focus, .field select:focus, .field textarea:focus { border-color:#0b1525; }
.field textarea { resize:vertical; min-height:70px; }
.field-full { grid-column:1/-1; }

/* ── Correct answers checkboxes ── */
.options-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.opt-row { display:flex; align-items:center; gap:8px; }
.opt-row label { font-size:13px; color:#374151; font-weight:500; }
.opt-row input[type=checkbox] { width:16px; height:16px; accent-color:#0b1525; cursor:pointer; }
.opt-row input[type=text] { flex:1; padding:7px 10px; border:1.5px solid #e2e8f0; border-radius:7px; font-size:13px; font-family:'Inter',sans-serif; }
.opt-row input[type=text]:focus { border-color:#0b1525; outline:none; }

/* ── Buttons ── */
.btn { padding:9px 18px; border-radius:8px; border:none; font-size:13px; font-weight:700; cursor:pointer; font-family:'Inter',sans-serif; transition:all 0.15s; display:inline-flex; align-items:center; gap:6px; }
.btn-primary { background:#0b1525; color:#d4f01a; }
.btn-primary:hover { background:#1a3460; }
.btn-primary:disabled { background:#94a3b8; color:#fff; cursor:not-allowed; }
.btn-secondary { background:#f1f5f9; color:#374151; }
.btn-secondary:hover { background:#e2e8f0; }
.btn-danger { background:#fee2e2; color:#dc2626; }
.btn-danger:hover { background:#fecaca; }
.btn-success { background:#dcfce7; color:#15803d; }
.btn-success:hover { background:#bbf7d0; }
.btn-sm { padding:5px 12px; font-size:12px; border-radius:6px; }
.btn-row { display:flex; gap:8px; flex-wrap:wrap; margin-top:16px; }

/* ── Table ── */
.tbl-wrap { overflow-x:auto; border-radius:12px; border:1px solid #e8edf2; }
table { width:100%; border-collapse:collapse; font-size:13px; }
thead tr { background:#f8fafc; }
th { padding:10px 14px; text-align:left; font-size:11px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:0.05em; white-space:nowrap; border-bottom:1px solid #e8edf2; }
td { padding:10px 14px; border-bottom:1px solid #f1f5f9; vertical-align:middle; }
tr:last-child td { border-bottom:none; }
tr:hover td { background:#f8fafc; }
.badge { display:inline-flex; align-items:center; padding:2px 8px; border-radius:20px; font-size:11px; font-weight:700; }
.badge-green { background:#dcfce7; color:#15803d; }
.badge-gray { background:#f1f5f9; color:#64748b; }
.badge-blue { background:#dbeafe; color:#1d4ed8; }
.badge-orange { background:#fed7aa; color:#c2410c; }
.badge-purple { background:#e9d5ff; color:#7c3aed; }

/* ── Msg ── */
.msg { padding:10px 14px; border-radius:8px; font-size:13px; font-weight:600; margin-bottom:14px; display:none; }
.msg.show { display:block; }
.msg.ok { background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0; }
.msg.err { background:#fef2f2; color:#dc2626; border:1px solid #fecaca; }

/* ── Question list item ── */
.q-item { border:1px solid #e8edf2; border-radius:10px; padding:14px 16px; margin-bottom:8px; background:#fff; }
.q-item:hover { border-color:#0b1525; }
.q-item-top { display:flex; align-items:flex-start; gap:10px; }
.q-item-num { width:28px; height:28px; border-radius:8px; background:#0b1525; color:#d4f01a; font-size:12px; font-weight:900; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-family:'Sora',sans-serif; }
.q-item-body { flex:1; min-width:0; }
.q-item-text { font-size:14px; font-weight:600; color:#1e293b; margin:0 0 6px; line-height:1.4; }
.q-item-meta { display:flex; gap:6px; flex-wrap:wrap; }
.q-item-actions { display:flex; gap:6px; align-items:flex-start; flex-shrink:0; }

/* ── Attempt row ── */
.attempt-score { font-family:'Sora',sans-serif; font-size:1.3rem; font-weight:900; }
.score-pass { color:#15803d; }
.score-fail { color:#dc2626; }

/* ── Config range ── */
.range-row { display:flex; align-items:center; gap:12px; }
.range-row input[type=range] { flex:1; accent-color:#0b1525; }
.range-val { font-family:'Sora',sans-serif; font-size:1.1rem; font-weight:900; color:#0b1525; min-width:48px; text-align:center; }

/* ── Discount tiers ── */
.tier-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; margin-bottom:16px; }
.tier-card { border:2px solid #e2e8f0; border-radius:12px; padding:16px; text-align:center; }
.tier-card.tier-bronze { border-color:#cd7f32; background:#fdf8f0; }
.tier-card.tier-silver { border-color:#94a3b8; background:#f8fafc; }
.tier-card.tier-gold   { border-color:#fbbf24; background:#fffbeb; }
.tier-pct { font-family:'Sora',sans-serif; font-size:1.8rem; font-weight:900; color:#0b1525; }
.tier-label { font-size:11px; font-weight:700; color:#94a3b8; text-transform:uppercase; margin-bottom:10px; }
.tier-input { width:70px; padding:6px 8px; border:1.5px solid #e2e8f0; border-radius:8px; font-size:18px; font-weight:800; text-align:center; font-family:'Sora',sans-serif; color:#0b1525; }

/* ── Category filter ── */
.cat-filter { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:16px; }
.cat-btn { padding:5px 14px; border-radius:20px; border:1.5px solid #e2e8f0; background:#fff; font-size:12px; font-weight:600; color:#64748b; cursor:pointer; transition:all 0.12s; font-family:'Inter',sans-serif; }
.cat-btn:hover { border-color:#0b1525; color:#0b1525; }
.cat-btn.active { background:#0b1525; color:#d4f01a; border-color:#0b1525; }

/* ── Bulk import ── */
.import-area { border:2px dashed #e2e8f0; border-radius:12px; padding:24px; text-align:center; background:#f8fafc; cursor:pointer; transition:border-color 0.15s; }
.import-area:hover { border-color:#0b1525; }
.import-area textarea { width:100%; border:none; background:transparent; font-family:'Inter',sans-serif; font-size:13px; color:#374151; resize:vertical; min-height:160px; outline:none; }

/* ── Toggle ── */
.toggle-row { display:flex; align-items:center; justify-content:space-between; padding:12px 0; border-bottom:1px solid #f1f5f9; }
.toggle-row:last-child { border-bottom:none; }
.toggle-info h4 { font-size:14px; font-weight:700; color:#1e293b; margin:0 0 2px; }
.toggle-info p { font-size:12px; color:#94a3b8; margin:0; }
.toggle { position:relative; width:44px; height:24px; flex-shrink:0; }
.toggle input { opacity:0; width:0; height:0; }
.toggle-slider { position:absolute; inset:0; background:#e2e8f0; border-radius:24px; cursor:pointer; transition:0.2s; }
.toggle-slider:before { content:''; position:absolute; width:18px; height:18px; left:3px; top:3px; background:#fff; border-radius:50%; transition:0.2s; }
.toggle input:checked + .toggle-slider { background:#0b1525; }
.toggle input:checked + .toggle-slider:before { transform:translateX(20px); }

/* ── Section hidden ── */
.tab-section { display:none; }
.tab-section.active { display:block; }

/* ── Course mapping ── */
.course-map-item { display:flex; align-items:center; gap:12px; padding:10px 14px; border:1px solid #e8edf2; border-radius:8px; margin-bottom:8px; background:#fff; }
.course-map-name { font-weight:700; color:#0b1525; flex:1; }
.course-map-count { font-size:13px; color:#64748b; }
</style>

<!-- Page header -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
  <div>
    <h1 style="font-family:'Sora',sans-serif;font-size:22px;font-weight:900;color:#0b1525;margin:0;">🎯 Mock Test Manager</h1>
    <p style="font-size:13px;color:#64748b;margin:4px 0 0;">Manage questions, scholarship discounts, and test results</p>
  </div>
  <a href="/mock-test" target="_blank" class="btn btn-secondary">🔗 View Public Test</a>
</div>

<!-- Stats -->
<div class="stats-row" id="stats-row">
  <div class="stat-card"><div class="stat-num" id="st-total-q">—</div><div class="stat-lbl">Total Questions</div></div>
  <div class="stat-card"><div class="stat-num" id="st-active-q">—</div><div class="stat-lbl">Active Questions</div></div>
  <div class="stat-card"><div class="stat-num" id="st-attempts">—</div><div class="stat-lbl">Test Attempts</div></div>
  <div class="stat-card"><div class="stat-num" id="st-pass-rate">—</div><div class="stat-lbl">Pass Rate (75%+)</div></div>
  <div class="stat-card"><div class="stat-num" id="st-discount-given">—</div><div class="stat-lbl">Discounts Given</div></div>
  <div class="stat-card"><div class="stat-num" id="st-categories">—</div><div class="stat-lbl">Categories</div></div>
</div>

<!-- Tabs -->
<div class="mt-tabs">
  <button class="mt-tab active" onclick="switchTab('questions')">📝 Questions Bank</button>
  <button class="mt-tab" onclick="switchTab('add')">➕ Add Question</button>
  <button class="mt-tab" onclick="switchTab('bulk')">📥 Bulk Import</button>
  <button class="mt-tab" onclick="switchTab('attempts')">📊 Student Attempts</button>
  <button class="mt-tab" onclick="switchTab('config')">⚙️ Test Settings</button>
  <button class="mt-tab" onclick="switchTab('courses')">📚 Course Mapping</button>
</div>

<!-- ═══════════════════════════ QUESTIONS BANK ═══════════════════════════ -->
<div class="tab-section active" id="tab-questions">
  <div class="panel">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px;">
      <div class="panel-title"><span>📝</span> Questions Bank</div>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <input id="q-search" type="text" placeholder="Search questions…" oninput="filterQuestions()" style="padding:7px 12px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:13px;font-family:'Inter',sans-serif;width:220px;">
        <select id="q-cat-filter" onchange="filterQuestions()" style="padding:7px 12px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:13px;font-family:'Inter',sans-serif;">
          <option value="">All Categories</option>
        </select>
        <select id="q-status-filter" onchange="filterQuestions()" style="padding:7px 12px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:13px;font-family:'Inter',sans-serif;">
          <option value="">All Status</option>
          <option value="active">Active only</option>
          <option value="inactive">Inactive only</option>
        </select>
      </div>
    </div>
    <div id="q-msg" class="msg"></div>
    <div id="q-list">
      <div style="text-align:center;padding:40px;color:#94a3b8;">Loading questions…</div>
    </div>
    <div id="q-count" style="font-size:12px;color:#94a3b8;margin-top:12px;text-align:right;"></div>
  </div>

  <!-- Inline Edit Panel (hidden by default) -->
  <div class="panel" id="edit-panel" style="display:none;border:2px solid #0b1525;">
    <div class="panel-title"><span>✏️</span> Edit Question <button onclick="closeEdit()" class="btn btn-secondary btn-sm" style="margin-left:auto;">✕ Cancel</button></div>
    <div id="edit-msg" class="msg"></div>
    <div id="edit-form-body"></div>
  </div>
</div>

<!-- ═══════════════════════════ ADD QUESTION ═══════════════════════════ -->
<div class="tab-section" id="tab-add">
  <div class="panel">
    <div class="panel-title"><span>➕</span> Add New Question</div>
    <div id="add-msg" class="msg"></div>

    <div class="field field-full" style="margin-bottom:14px;">
      <label>Question Text *</label>
      <textarea id="add-question" placeholder="Type the question here…" rows="3"></textarea>
    </div>

    <div style="margin-bottom:16px;">
      <label style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:10px;">Options — tick ALL correct answers (supports multiple correct)</label>
      <div class="options-grid">
        <div class="opt-row"><input type="checkbox" id="add-c-a"><strong style="min-width:18px;color:#0b1525">A</strong><input type="text" id="add-opt-a" placeholder="Option A text"></div>
        <div class="opt-row"><input type="checkbox" id="add-c-b"><strong style="min-width:18px;color:#0b1525">B</strong><input type="text" id="add-opt-b" placeholder="Option B text"></div>
        <div class="opt-row"><input type="checkbox" id="add-c-c"><strong style="min-width:18px;color:#0b1525">C</strong><input type="text" id="add-opt-c" placeholder="Option C text"></div>
        <div class="opt-row"><input type="checkbox" id="add-c-d"><strong style="min-width:18px;color:#0b1525">D</strong><input type="text" id="add-opt-d" placeholder="Option D text"></div>
        <div class="opt-row"><input type="checkbox" id="add-c-e"><strong style="min-width:18px;color:#0b1525">E</strong><input type="text" id="add-opt-e" placeholder="Option E (optional)"></div>
      </div>
      <p style="font-size:12px;color:#94a3b8;margin-top:8px;">✅ Tick the checkbox(es) next to the correct answer(s). Multiple correct answers are supported.</p>
    </div>

    <div class="form-grid" style="margin-bottom:14px;">
      <div class="field">
        <label>Category / Course *</label>
        <input type="text" id="add-category" placeholder="e.g. Hardware, MERN Stack, Tally, GEN AI, General IT" list="cat-suggestions">
        <datalist id="cat-suggestions"></datalist>
      </div>
      <div class="field">
        <label>Explanation (shown after test)</label>
        <input type="text" id="add-explanation" placeholder="Brief explanation of the correct answer">
      </div>
      <div class="field">
        <label>Sort Order</label>
        <input type="number" id="add-sort" value="0" min="0">
      </div>
      <div class="field" style="justify-content:flex-end;padding-bottom:2px;">
        <label>&nbsp;</label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:14px;font-weight:500;color:#374151;text-transform:none;letter-spacing:0;">
          <input type="checkbox" id="add-active" checked style="width:16px;height:16px;accent-color:#0b1525;">
          Active (included in tests)
        </label>
      </div>
    </div>

    <div class="btn-row">
      <button class="btn btn-primary" id="add-btn" onclick="addQuestion()">➕ Add Question</button>
      <button class="btn btn-secondary" onclick="clearAddForm()">🗑️ Clear</button>
      <button class="btn btn-secondary" onclick="switchTab('questions')">← Back to List</button>
    </div>
  </div>
</div>

<!-- ═══════════════════════════ BULK IMPORT ═══════════════════════════ -->
<div class="tab-section" id="tab-bulk">
  <div class="panel">
    <div class="panel-title"><span>📥</span> Bulk Import Questions</div>
    <p style="font-size:13px;color:#64748b;margin:0 0 16px;">Paste questions in the format below. One question per block, separated by a blank line.</p>

    <div style="background:#f8fafc;border:1px solid #e8edf2;border-radius:10px;padding:16px;margin-bottom:16px;font-size:12px;color:#374151;font-family:monospace;line-height:1.8;">
      Q: What does CPU stand for?<br>
      A: Central Processing Unit<br>
      B: Computer Program Unit<br>
      C: Core Processing Unit<br>
      D: Control Panel Utility<br>
      CORRECT: A<br>
      CATEGORY: Hardware<br>
      EXPLAIN: CPU is the brain of a computer.<br>
      <br>
      Q: Which of these are programming languages? (select all)<br>
      A: Python<br>
      B: Excel<br>
      C: JavaScript<br>
      D: HTML<br>
      CORRECT: A,C<br>
      CATEGORY: MERN Stack<br>
    </div>

    <div id="bulk-msg" class="msg"></div>

    <div class="field" style="margin-bottom:14px;">
      <label>Default Category (used if no CATEGORY line in block)</label>
      <input type="text" id="bulk-default-cat" placeholder="General IT" value="General IT">
    </div>

    <textarea id="bulk-text" placeholder="Paste your questions here in the format shown above…"
      style="width:100%;min-height:300px;padding:14px;border:1.5px solid #e2e8f0;border-radius:10px;font-family:monospace;font-size:13px;color:#374151;resize:vertical;outline:none;box-sizing:border-box;"></textarea>

    <div class="btn-row">
      <button class="btn btn-primary" id="bulk-parse-btn" onclick="parseBulk()">🔍 Preview Import</button>
    </div>

    <div id="bulk-preview" style="display:none;margin-top:20px;">
      <div style="font-size:14px;font-weight:700;color:#0b1525;margin-bottom:12px;">Preview — <span id="bulk-count">0</span> questions found:</div>
      <div id="bulk-preview-list" style="max-height:360px;overflow-y:auto;"></div>
      <div class="btn-row" style="margin-top:16px;">
        <button class="btn btn-primary" id="bulk-save-btn" onclick="saveBulk()">💾 Save All Questions</button>
        <button class="btn btn-secondary" onclick="document.getElementById('bulk-preview').style.display='none'">Cancel Preview</button>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════ STUDENT ATTEMPTS ═══════════════════════════ -->
<div class="tab-section" id="tab-attempts">
  <div class="panel">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px;">
      <div class="panel-title"><span>📊</span> Student Attempts</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <select id="att-filter" onchange="loadAttempts()" style="padding:7px 12px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:13px;font-family:'Inter',sans-serif;">
          <option value="">All attempts</option>
          <option value="pass">Passed (75%+)</option>
          <option value="fail">Failed (&lt;75%)</option>
          <option value="discount">Got discount</option>
        </select>
        <button class="btn btn-secondary btn-sm" onclick="exportCSV()">📥 Export CSV</button>
      </div>
    </div>
    <div id="att-msg" class="msg"></div>
    <div class="tbl-wrap">
      <table>
        <thead>
          <tr>
            <th>Student</th>
            <th>Email / Phone</th>
            <th>Course Interest</th>
            <th>Score</th>
            <th>%</th>
            <th>Discount</th>
            <th>Time</th>
            <th>Date</th>
            <th>Report</th>
          </tr>
        </thead>
        <tbody id="att-tbody">
          <tr><td colspan="9" style="text-align:center;padding:30px;color:#94a3b8;">Loading…</td></tr>
        </tbody>
      </table>
    </div>
    <div id="att-count" style="font-size:12px;color:#94a3b8;margin-top:10px;"></div>
  </div>
</div>

<!-- ═══════════════════════════ CONFIG / SETTINGS ═══════════════════════════ -->
<div class="tab-section" id="tab-config">
  <div class="panel">
    <div class="panel-title"><span>⚙️</span> Test Settings</div>
    <div id="cfg-msg" class="msg"></div>

    <!-- Basic config -->
    <div class="form-grid" style="margin-bottom:20px;">
      <div class="field">
        <label>Test Title</label>
        <input type="text" id="cfg-title" placeholder="ATEC Computer Knowledge Test">
      </div>
      <div class="field">
        <label>Subtitle</label>
        <input type="text" id="cfg-subtitle" placeholder="Test your IT knowledge and earn a discount!">
      </div>
      <div class="field">
        <label>Instructions Line</label>
        <input type="text" id="cfg-instructions" placeholder="50 questions | 20 minutes | Multiple correct answers possible">
      </div>
    </div>

    <!-- Timer & questions count -->
    <div style="background:#f8fafc;border-radius:12px;padding:20px;margin-bottom:20px;">
      <h4 style="font-size:14px;font-weight:700;color:#0b1525;margin:0 0 16px;">⏱️ Timer & Question Count</h4>
      <div style="margin-bottom:16px;">
        <label style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:8px;">Timer (minutes)</label>
        <div class="range-row">
