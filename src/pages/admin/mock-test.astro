<!-- ═══════════════════════════ SCRIPTS ═══════════════════════════ -->
<script is:inline>
;(function() {

const SB_URL = window.__SB_URL
const SB_KEY = window.__SB_KEY

let allQuestions  = []
let allAttempts   = []
let bulkParsed    = []
let currentEditId = null
let cfg           = {}

// ── Init ──────────────────────────────────────────────────────────────
async function init() {
  await Promise.all([loadQuestions(), loadAttempts(), loadConfig()])
  updateStats()
}

// ── Tab switching ──────────────────────────────────────────────────────
window.switchTab = function(tab) {
  document.querySelectorAll('.tab-section').forEach(s => s.classList.remove('active'))
  document.querySelectorAll('.mt-tab').forEach(b => b.classList.remove('active'))
  document.getElementById('tab-' + tab).classList.add('active')
  const tabs = ['questions','add','bulk','attempts','config','courses']
  const idx = tabs.indexOf(tab)
  document.querySelectorAll('.mt-tab')[idx]?.classList.add('active')
}

// ── Supabase helpers ──────────────────────────────────────────────────
async function sbGet(table, params = '') {
  const r = await fetch(`${SB_URL}/rest/v1/${table}${params ? '?' + params : ''}`, {
    headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}`, Accept: 'application/json' }
  })
  return r.json()
}
async function sbPost(table, body) {
  return fetch(`${SB_URL}/rest/v1/${table}`, {
    method: 'POST',
    headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}`, 'Content-Type': 'application/json', Prefer: 'return=representation' },
    body: JSON.stringify(body)
  })
}
async function sbPatch(table, id, body) {
  return fetch(`${SB_URL}/rest/v1/${table}?id=eq.${id}`, {
    method: 'PATCH',
    headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}`, 'Content-Type': 'application/json', Prefer: 'return=minimal' },
    body: JSON.stringify(body)
  })
}
async function sbDelete(table, id) {
  return fetch(`${SB_URL}/rest/v1/${table}?id=eq.${id}`, {
    method: 'DELETE',
    headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` }
  })
}
function showMsg(id, text, isErr = false) {
  const el = document.getElementById(id)
  if (!el) return
  el.textContent = text
  el.className = 'msg show ' + (isErr ? 'err' : 'ok')
  if (!isErr) setTimeout(() => el.classList.remove('show'), 4000)
}

// ── Load Questions ────────────────────────────────────────────────────
async function loadQuestions() {
  try {
    const data = await sbGet('mock_test_questions', 'order=sort_order.asc,created_at.asc&select=*')
    allQuestions = Array.isArray(data) ? data : []
    renderQuestionList(allQuestions)
    populateCategoryFilter()
    populateCatSuggestions()
  } catch(e) {
    document.getElementById('q-list').innerHTML = '<p style="color:#dc2626;padding:20px;">Failed to load questions. Check Supabase connection.</p>'
  }
}

function renderQuestionList(list) {
  const el = document.getElementById('q-list')
  if (!list.length) { el.innerHTML = '<div style="text-align:center;padding:40px;color:#94a3b8;">No questions found. Add some above!</div>'; return }
  el.innerHTML = list.map((q, i) => {
    const correct = Array.isArray(q.correct) ? q.correct : [q.correct]
    const isMulti = correct.length > 1
    return `<div class="q-item">
      <div class="q-item-top">
        <div class="q-item-num">${i + 1}</div>
        <div class="q-item-body">
          <div class="q-item-text">${escHtml(q.question)}</div>
          <div class="q-item-meta">
            <span class="badge badge-blue">${escHtml(q.category || 'General')}</span>
            ${isMulti ? '<span class="badge badge-purple">Multiple correct</span>' : ''}
            ${q.is_active ? '<span class="badge badge-green">Active</span>' : '<span class="badge badge-gray">Hidden</span>'}
            <span class="badge badge-gray">Ans: ${correct.map(c=>c.toUpperCase()).join(', ')}</span>
          </div>
        </div>
        <div class="q-item-actions">
          <button class="btn btn-secondary btn-sm" onclick="editQuestion('${q.id}')">✏️ Edit</button>
          <button class="btn btn-sm" style="background:${q.is_active ? '#fef9c3' : '#dcfce7'};color:${q.is_active ? '#854d0e' : '#15803d'};" onclick="toggleQ('${q.id}', ${q.is_active})">${q.is_active ? 'Hide' : 'Show'}</button>
          <button class="btn btn-danger btn-sm" onclick="deleteQ('${q.id}')">🗑️</button>
        </div>
      </div>
    </div>`
  }).join('')
  document.getElementById('q-count').textContent = `Showing ${list.length} of ${allQuestions.length} questions`
}

function populateCategoryFilter() {
  const cats = [...new Set(allQuestions.map(q => q.category).filter(Boolean))].sort()
  const sel = document.getElementById('q-cat-filter')
  const cur = sel.value
  sel.innerHTML = '<option value="">All Categories</option>' + cats.map(c => `<option value="${escHtml(c)}" ${c === cur ? 'selected' : ''}>${escHtml(c)}</option>`).join('')
}

function populateCatSuggestions() {
  const cats = [...new Set(allQuestions.map(q => q.category).filter(Boolean))].sort()
  const dl = document.getElementById('cat-suggestions')
  if (dl) dl.innerHTML = cats.map(c => `<option value="${escHtml(c)}">`).join('')
}

window.filterQuestions = function() {
  const search = document.getElementById('q-search').value.toLowerCase()
  const cat    = document.getElementById('q-cat-filter').value
  const status = document.getElementById('q-status-filter').value
  let list = allQuestions
  if (search) list = list.filter(q => (q.question || '').toLowerCase().includes(search))
  if (cat)    list = list.filter(q => q.category === cat)
  if (status === 'active')   list = list.filter(q => q.is_active)
  if (status === 'inactive') list = list.filter(q => !q.is_active)
  renderQuestionList(list)
}

// ── Toggle / Delete ───────────────────────────────────────────────────
window.toggleQ = async function(id, currentActive) {
  await sbPatch('mock_test_questions', id, { is_active: !currentActive })
  allQuestions = allQuestions.map(q => q.id === id ? { ...q, is_active: !currentActive } : q)
  filterQuestions()
  updateStats()
}

window.deleteQ = async function(id) {
  if (!confirm('Delete this question permanently?')) return
  await sbDelete('mock_test_questions', id)
  allQuestions = allQuestions.filter(q => q.id !== id)
  filterQuestions()
  updateStats()
  populateCategoryFilter()
  renderCourseMap()
}

// ── Edit Question ─────────────────────────────────────────────────────
window.editQuestion = function(id) {
  const q = allQuestions.find(x => x.id === id)
  if (!q) return
  currentEditId = id
  const correct = Array.isArray(q.correct) ? q.correct : [q.correct]
  const opts = ['a','b','c','d','e']
  document.getElementById('edit-form-body').innerHTML = `
    <div class="field field-full" style="margin-bottom:14px;">
      <label>Question Text *</label>
      <textarea id="eq-question" rows="3">${escHtml(q.question || '')}</textarea>
    </div>
    <div style="margin-bottom:16px;">
      <label style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:10px;">Options — tick ALL correct answers</label>
      <div class="options-grid">
        ${opts.map(k => `
          <div class="opt-row">
            <input type="checkbox" id="eq-c-${k}" ${correct.includes(k) ? 'checked' : ''}>
            <strong style="min-width:18px;color:#0b1525">${k.toUpperCase()}</strong>
            <input type="text" id="eq-opt-${k}" placeholder="Option ${k.toUpperCase()} text" value="${escHtml(q['option_' + k] || '')}">
          </div>`).join('')}
      </div>
    </div>
    <div class="form-grid" style="margin-bottom:14px;">
      <div class="field">
        <label>Category *</label>
        <input type="text" id="eq-category" value="${escHtml(q.category || '')}" list="cat-suggestions">
      </div>
      <div class="field">
        <label>Explanation</label>
        <input type="text" id="eq-explanation" value="${escHtml(q.explanation || '')}">
      </div>
      <div class="field">
        <label>Sort Order</label>
        <input type="number" id="eq-sort" value="${q.sort_order || 0}">
      </div>
      <div class="field" style="justify-content:flex-end;padding-bottom:2px;">
        <label>&nbsp;</label>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:14px;font-weight:500;color:#374151;text-transform:none;letter-spacing:0;">
          <input type="checkbox" id="eq-active" ${q.is_active ? 'checked' : ''} style="width:16px;height:16px;accent-color:#0b1525;"> Active
        </label>
      </div>
    </div>
    <div class="btn-row">
      <button class="btn btn-primary" id="eq-save-btn" onclick="saveEdit()">💾 Save Changes</button>
    </div>
  `
  document.getElementById('edit-panel').style.display = 'block'
  document.getElementById('edit-panel').scrollIntoView({ behavior: 'smooth', block: 'start' })
}

window.closeEdit = function() {
  document.getElementById('edit-panel').style.display = 'none'
  currentEditId = null
}

window.saveEdit = async function() {
  const btn = document.getElementById('eq-save-btn')
  btn.disabled = true; btn.textContent = 'Saving…'
  try {
    const q = buildQuestionFromForm('eq')
    if (!q) { btn.disabled = false; btn.textContent = '💾 Save Changes'; return }
    await sbPatch('mock_test_questions', currentEditId, q)
    allQuestions = allQuestions.map(x => x.id === currentEditId ? { ...x, ...q } : x)
    showMsg('edit-msg', '✅ Question updated!')
    filterQuestions()
    updateStats()
    populateCategoryFilter()
    renderCourseMap()
    setTimeout(closeEdit, 1200)
  } catch(e) {
    showMsg('edit-msg', '❌ ' + (e.message || 'Save failed'), true)
  }
  btn.disabled = false; btn.textContent = '💾 Save Changes'
}

// ── Add Question ──────────────────────────────────────────────────────
window.addQuestion = async function() {
  const btn = document.getElementById('add-btn')
  btn.disabled = true; btn.textContent = 'Adding…'
  try {
    const q = buildQuestionFromForm('add')
    if (!q) { btn.disabled = false; btn.textContent = '➕ Add Question'; return }
    const r = await sbPost('mock_test_questions', { ...q, sort_order: q.sort_order || allQuestions.length })
    const saved = await r.json()
    if (saved && saved[0]) {
      allQuestions.push(saved[0])
      filterQuestions()
      updateStats()
      populateCategoryFilter()
      populateCatSuggestions()
      renderCourseMap()
      showMsg('add-msg', '✅ Question added! Add another or go to Questions Bank.')
      clearAddForm()
    } else {
      showMsg('add-msg', '❌ Failed to save. Check Supabase RLS policies.', true)
    }
  } catch(e) {
    showMsg('add-msg', '❌ ' + (e.message || 'Error'), true)
  }
  btn.disabled = false; btn.textContent = '➕ Add Question'
}

function buildQuestionFromForm(prefix) {
  const question = document.getElementById(prefix + '-question')?.value.trim()
  if (!question) { showMsg(prefix + '-msg', '❌ Question text is required.', true); return null }
  const opts = ['a','b','c','d','e']
  const correct = opts.filter(k => document.getElementById(prefix + '-c-' + k)?.checked)
  if (!correct.length) { showMsg(prefix + '-msg', '❌ Please tick at least one correct answer.', true); return null }
  const category = document.getElementById(prefix + '-category')?.value.trim() || 'General IT'
  return {
    question,
    option_a: document.getElementById(prefix + '-opt-a')?.value.trim() || null,
    option_b: document.getElementById(prefix + '-opt-b')?.value.trim() || null,
    option_c: document.getElementById(prefix + '-opt-c')?.value.trim() || null,
    option_d: document.getElementById(prefix + '-opt-d')?.value.trim() || null,
    option_e: document.getElementById(prefix + '-opt-e')?.value.trim() || null,
    correct,
    correct_count: correct.length,
    category,
    explanation: document.getElementById(prefix + '-explanation')?.value.trim() || null,
    sort_order: parseInt(document.getElementById(prefix + '-sort')?.value || '0') || 0,
    is_active: document.getElementById(prefix + '-active')?.checked ?? true,
  }
}

window.clearAddForm = function() {
  ['question','opt-a','opt-b','opt-c','opt-d','opt-e','category','explanation'].forEach(k => {
    const el = document.getElementById('add-' + k)
    if (el) el.value = ''
  })
  ;['a','b','c','d','e'].forEach(k => {
    const cb = document.getElementById('add-c-' + k)
    if (cb) cb.checked = false
  })
  document.getElementById('add-active').checked = true
  document.getElementById('add-sort').value = '0'
}

// ── Bulk Import ───────────────────────────────────────────────────────
window.parseBulk = function() {
  const text = document.getElementById('bulk-text').value.trim()
  const defCat = document.getElementById('bulk-default-cat').value.trim() || 'General IT'
  if (!text) { showMsg('bulk-msg', '❌ Please paste some questions first.', true); return }

  bulkParsed = []
  const blocks = text.split(/\n\s*\n/).filter(b => b.trim())

  blocks.forEach((block, bi) => {
    const lines = block.trim().split('\n').map(l => l.trim()).filter(Boolean)
    let q = { question:'', option_a:'', option_b:'', option_c:'', option_d:'', option_e:'', correct:[], category: defCat, explanation:'' }
    lines.forEach(line => {
      if (/^Q:/i.test(line))         q.question    = line.replace(/^Q:\s*/i,'').trim()
      else if (/^A:/i.test(line))    q.option_a    = line.replace(/^A:\s*/i,'').trim()
      else if (/^B:/i.test(line))    q.option_b    = line.replace(/^B:\s*/i,'').trim()
      else if (/^C:/i.test(line))    q.option_c    = line.replace(/^C:\s*/i,'').trim()
      else if (/^D:/i.test(line))    q.option_d    = line.replace(/^D:\s*/i,'').trim()
      else if (/^E:/i.test(line))    q.option_e    = line.replace(/^E:\s*/i,'').trim()
      else if (/^CORRECT:/i.test(line)) q.correct  = line.replace(/^CORRECT:\s*/i,'').split(',').map(s=>s.trim().toLowerCase()).filter(Boolean)
      else if (/^CATEGORY:/i.test(line)) q.category = line.replace(/^CATEGORY:\s*/i,'').trim()
      else if (/^EXPLAIN:/i.test(line))  q.explanation = line.replace(/^EXPLAIN:\s*/i,'').trim()
    })
    if (q.question && q.correct.length) {
      q.correct_count = q.correct.length
      q.is_active = true
      q.sort_order = allQuestions.length + bi
      bulkParsed.push(q)
    }
  })

  if (!bulkParsed.length) { showMsg('bulk-msg', '❌ No valid questions found. Check the format.', true); return }

  document.getElementById('bulk-count').textContent = bulkParsed.length
  const previewEl = document.getElementById('bulk-preview-list')
  previewEl.innerHTML = bulkParsed.map((q, i) => `
    <div style="padding:12px;border:1px solid #e8edf2;border-radius:8px;margin-bottom:8px;background:#fff;">
      <div style="font-weight:700;font-size:13px;color:#0b1525;margin-bottom:4px;">${i+1}. ${escHtml(q.question)}</div>
      <div style="font-size:12px;color:#64748b;">${['a','b','c','d','e'].filter(k=>q['option_'+k]).map(k=>`<strong>${k.toUpperCase()}</strong>: ${escHtml(q['option_'+k])}`).join(' · ')}
      <br>✅ Correct: ${q.correct.map(c=>c.toUpperCase()).join(', ')} · 📂 ${escHtml(q.category)}</div>
    </div>`).join('')
  document.getElementById('bulk-preview').style.display = 'block'
}

window.saveBulk = async function() {
  if (!bulkParsed.length) return
  const btn = document.getElementById('bulk-save-btn')
  btn.disabled = true; btn.textContent = '⏳ Saving…'
  try {
    const r = await sbPost('mock_test_questions', bulkParsed)
    const saved = await r.json()
    if (Array.isArray(saved)) {
      allQuestions = [...allQuestions, ...saved]
      filterQuestions()
      updateStats()
      populateCategoryFilter()
      populateCatSuggestions()
      renderCourseMap()
      document.getElementById('bulk-text').value = ''
      document.getElementById('bulk-preview').style.display = 'none'
      bulkParsed = []
      showMsg('bulk-msg', `✅ ${saved.length} questions saved successfully!`)
    } else {
      showMsg('bulk-msg', '❌ Save failed. Check Supabase RLS policies for mock_test_questions table.', true)
    }
  } catch(e) {
    showMsg('bulk-msg', '❌ ' + (e.message || 'Error'), true)
  }
  btn.disabled = false; btn.textContent = '💾 Save All Questions'
}

// ── Load Attempts ─────────────────────────────────────────────────────
async function loadAttempts() {
  try {
    const data = await sbGet('mock_test_attempts', 'order=created_at.desc&limit=200&select=*')
    allAttempts = Array.isArray(data) ? data : []
    renderAttempts(allAttempts)
  } catch(e) {}
}

window.loadAttempts = function() {
  const f = document.getElementById('att-filter').value
  let list = allAttempts
  if (f === 'pass')     list = list.filter(a => a.percentage >= 75)
  if (f === 'fail')     list = list.filter(a => a.percentage < 75)
  if (f === 'discount') list = list.filter(a => a.discount > 0)
  renderAttempts(list)
}

function renderAttempts(list) {
  const tbody = document.getElementById('att-tbody')
  if (!list.length) { tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:30px;color:#94a3b8;">No attempts found.</td></tr>'; return }
  tbody.innerHTML = list.map(a => {
    const pct = a.percentage ?? 0
    const passed = pct >= 75
    const discBadge = a.discount > 0
      ? `<span class="badge" style="background:#fef9c3;color:#854d0e;">${a.discount}% OFF</span>`
      : '<span class="badge badge-gray">None</span>'
    const mins = Math.floor((a.time_taken || 0) / 60)
    const secs = (a.time_taken || 0) % 60
    return `<tr>
      <td><span style="font-weight:700;color:#0b1525;">${escHtml(a.name || '—')}</span></td>
      <td><div style="font-size:12px;">${escHtml(a.email || '—')}</div><div style="font-size:11px;color:#94a3b8;">${escHtml(a.phone || '')}</div></td>
      <td><span style="font-size:12px;color:#64748b;">${escHtml(a.course || '—')}</span></td>
      <td style="font-weight:700;">${a.score ?? '?'}/${a.total ?? '?'}</td>
      <td><span class="attempt-score ${passed ? 'score-pass' : 'score-fail'}">${pct}%</span></td>
      <td>${discBadge}</td>
      <td style="font-size:12px;color:#64748b;">${mins}m ${secs}s</td>
      <td style="font-size:12px;color:#94a3b8;">${a.created_at ? new Date(a.created_at).toLocaleDateString('en-IN') : '—'}</td>
      <td>${a.report_sent ? '<span class="badge badge-green">Sent</span>' : '<span class="badge badge-gray">—</span>'}</td>
    </tr>`
  }).join('')
  document.getElementById('att-count').textContent = `Showing ${list.length} of ${allAttempts.length} attempts`
}

window.exportCSV = function() {
  const headers = ['Name','Email','Phone','Course','Score','Total','Percentage','Discount','Time(s)','Date','Report Sent']
  const rows = allAttempts.map(a => [
    a.name, a.email, a.phone, a.course, a.score, a.total, a.percentage,
    a.discount, a.time_taken, a.created_at?.slice(0,10), a.report_sent ? 'Yes' : 'No'
  ])
  const csv = [headers, ...rows].map(r => r.map(v => `"${(v??'').toString().replace(/"/g,'""')}"`).join(',')).join('\n')
  const blob = new Blob([csv], { type: 'text/csv' })
  const url  = URL.createObjectURL(blob)
  const a    = document.createElement('a')
  a.href = url; a.download = 'atec_mock_test_attempts.csv'; a.click()
  URL.revokeObjectURL(url)
}

// ── Config ────────────────────────────────────────────────────────────
async function loadConfig() {
  try {
    const data = await sbGet('site_settings', 'key=eq.mock_test_config&select=value')
    if (data?.[0]?.value) {
      cfg = data[0].value
      const c = cfg
      setVal('cfg-title', c.title)
      setVal('cfg-subtitle', c.subtitle)
      setVal('cfg-instructions', c.instructions)
      setVal('cfg-timer', c.timer_minutes || 20)
      document.getElementById('cfg-timer-val').textContent = (c.timer_minutes || 20) + ' min'
      setVal('cfg-qcount', c.questions_count || 50)
      document.getElementById('cfg-qcount-val').textContent = (c.questions_count || 50) + ' questions'
      setVal('cfg-d75', c.discount_75 || 10)
      setVal('cfg-d85', c.discount_85 || 20)
      setVal('cfg-d95', c.discount_95 || 25)
      setVal('cfg-pass-msg', c.pass_message)
      setVal('cfg-fail-msg', c.fail_message)
      setCheck('cfg-otp', c.otp_enabled !== false)
      setCheck('cfg-shuffle', c.shuffle !== false)
      setCheck('cfg-explain', c.show_explanations !== false)
      setCheck('cfg-autoadvance', c.auto_advance !== false)
      setVal('cfg-ejs-service', c.emailjs_service)
      setVal('cfg-ejs-template', c.emailjs_template)
      setVal('cfg-ejs-pubkey', c.emailjs_pubkey)
    }
  } catch(e) {}
}

window.saveConfig = async function() {
  const btn = document.getElementById('cfg-save-btn')
  btn.disabled = true; btn.textContent = '⏳ Saving…'
  try {
    const newCfg = {
      title:          getVal('cfg-title') || 'ATEC Computer Knowledge Test',
      subtitle:       getVal('cfg-subtitle'),
      instructions:   getVal('cfg-instructions'),
      timer_minutes:  parseInt(getVal('cfg-timer')) || 20,
      questions_count:parseInt(getVal('cfg-qcount')) || 50,
      discount_75:    parseInt(getVal('cfg-d75')) || 10,
      discount_85:    parseInt(getVal('cfg-d85')) || 20,
      discount_95:    parseInt(getVal('cfg-d95')) || 25,
      pass_message:   getVal('cfg-pass-msg'),
      fail_message:   getVal('cfg-fail-msg'),
      otp_enabled:    getCheck('cfg-otp'),
      shuffle:        getCheck('cfg-shuffle'),
      show_explanations: getCheck('cfg-explain'),
      auto_advance:   getCheck('cfg-autoadvance'),
      emailjs_service:  getVal('cfg-ejs-service'),
      emailjs_template: getVal('cfg-ejs-template'),
      emailjs_pubkey:   getVal('cfg-ejs-pubkey'),
    }
    await fetch(`${SB_URL}/rest/v1/site_settings`, {
      method: 'POST',
      headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}`, 'Content-Type': 'application/json', Prefer: 'resolution=merge-duplicates,return=minimal' },
      body: JSON.stringify({ key: 'mock_test_config', value: newCfg })
    })
    showMsg('cfg-msg', '✅ Settings saved! Changes apply immediately to the live test.')
    cfg = newCfg
  } catch(e) {
    showMsg('cfg-msg', '❌ ' + (e.message || 'Save failed'), true)
  }
  btn.disabled = false; btn.textContent = '💾 Save All Settings'
}

// ── Stats ─────────────────────────────────────────────────────────────
function updateStats() {
  const active = allQuestions.filter(q => q.is_active).length
  const cats   = new Set(allQuestions.map(q => q.category).filter(Boolean)).size
  const passed = allAttempts.filter(a => (a.percentage ?? 0) >= 75).length
  const withDiscount = allAttempts.filter(a => a.discount > 0).length
  const passRate = allAttempts.length ? Math.round((passed / allAttempts.length) * 100) : 0

  setText('st-total-q', allQuestions.length)
  setText('st-active-q', active)
  setText('st-attempts', allAttempts.length)
  setText('st-pass-rate', passRate + '%')
  setText('st-discount-given', withDiscount)
  setText('st-categories', cats)

  renderCourseMap()
}

// ── Course Map ────────────────────────────────────────────────────────
function renderCourseMap() {
  const map = {}
  allQuestions.forEach(q => {
    const cat = q.category || 'Uncategorized'
    if (!map[cat]) map[cat] = { total: 0, active: 0 }
    map[cat].total++
    if (q.is_active) map[cat].active++
  })
  const el = document.getElementById('course-map-list')
  if (!el) return
  const entries = Object.entries(map).sort((a, b) => b[1].total - a[1].total)
  if (!entries.length) { el.innerHTML = '<p style="color:#94a3b8;font-size:14px;">No questions yet. Add questions with category tags to see mapping.</p>'; return }
  el.innerHTML = entries.map(([cat, counts]) => `
    <div class="course-map-item">
      <span class="badge badge-blue" style="font-size:13px;padding:4px 12px;">${escHtml(cat)}</span>
      <span class="course-map-name"></span>
      <span class="course-map-count">${counts.active} active / ${counts.total} total questions</span>
      <div style="width:120px;background:#e8edf2;border-radius:20px;height:8px;overflow:hidden;">
        <div style="width:${Math.round((counts.active/counts.total)*100)}%;height:100%;background:#0b1525;border-radius:20px;"></div>
      </div>
    </div>`).join('')
}

// ── Helpers ───────────────────────────────────────────────────────────
function setText(id, val) { const el = document.getElementById(id); if (el) el.textContent = val }
function setVal(id, val)  { const el = document.getElementById(id); if (el && val != null) el.value = val }
function getVal(id)       { return document.getElementById(id)?.value ?? '' }
function setCheck(id, v)  { const el = document.getElementById(id); if (el) el.checked = !!v }
function getCheck(id)     { return document.getElementById(id)?.checked ?? false }
function escHtml(str)     { return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;') }

// ── Boot ──────────────────────────────────────────────────────────────
if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init)
else init()

})()
</script>

</AdminLayout>
