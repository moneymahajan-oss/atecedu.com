---
// src/pages/admin/students.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="Students" activeSection="students">
  <div id="root"></div>
</AdminLayout>
<script>
import { createClient } from '@supabase/supabase-js'
import { createElement as h, useState, useEffect } from 'react'
import { createRoot } from 'react-dom/client'
const sb = createClient(window.__SB_URL, window.__SB_KEY)

function Mgr() {
  const [rows, setRows] = useState([])
  const [loading, setLoading] = useState(true)
  const [search, setSearch] = useState('')

  useEffect(() => { load() }, [])
  async function load() {
    const { data } = await sb.from('student_profiles').select('*').order('created_at', { ascending: false }).limit(200)
    setRows(data ?? []); setLoading(false)
  }

  const filtered = rows.filter(r => {
    const q = search.toLowerCase()
    return !q || r.full_name?.toLowerCase().includes(q) || r.phone?.includes(q) || r.city?.toLowerCase().includes(q)
  })

  return h('div',{style:{display:'flex',flexDirection:'column',gap:'20px'}},
    h('div',{style:{display:'flex',justifyContent:'space-between',alignItems:'center',flexWrap:'wrap',gap:'12px'}},
      h('div',{},
        h('h1',{style:{fontFamily:'Sora,sans-serif',fontSize:'1.5rem',fontWeight:'800'}},'👥 All Students'),
        h('p',{style:{fontSize:'13px',color:'#64748b',marginTop:'4px'}},`${rows.length} registered students`)
      ),
      h('button',{onClick:load,style:{padding:'8px 16px',background:'#f8fafc',border:'1px solid #e2e8f0',borderRadius:'8px',fontWeight:'600',fontSize:'13px',cursor:'pointer'}},'🔄 Refresh')
    ),
    h('input',{type:'text',placeholder:'🔍 Search by name, phone, city...',value:search,onChange:e=>setSearch(e.target.value),
      style:{padding:'10px 16px',border:'1px solid #e2e8f0',borderRadius:'10px',fontSize:'14px',outline:'none',width:'100%',boxSizing:'border-box'}}),
    h('div',{style:{background:'#fff',borderRadius:'14px',border:'1px solid #e2e8f0',overflow:'hidden'}},
      loading
        ? h('div',{style:{padding:'40px',textAlign:'center',color:'#94a3b8'}},'Loading...')
        : filtered.length===0
          ? h('div',{style:{padding:'40px',textAlign:'center',color:'#94a3b8'}},'No students found.')
          : h('div',{style:{overflowX:'auto'}},
              h('table',{style:{width:'100%',borderCollapse:'collapse',fontSize:'13px'}},
                h('thead',{},h('tr',{style:{background:'#f8fafc',borderBottom:'1px solid #e2e8f0'}},
                  ...['Student','Phone','City','State','Joined'].map(col =>
                    h('th',{key:col,style:{padding:'12px 16px',textAlign:'left',fontWeight:'700',color:'#475569',fontSize:'12px',textTransform:'uppercase',letterSpacing:'0.5px'}},col)
                  )
                )),
                h('tbody',{},...filtered.map(r =>
                  h('tr',{key:r.id,style:{borderBottom:'1px solid #f1f5f9'},
                    onMouseEnter:e=>{e.currentTarget.style.background='#f8fafc'},
                    onMouseLeave:e=>{e.currentTarget.style.background='#fff'}},
                    h('td',{style:{padding:'12px 16px'}},
                      h('div',{style:{display:'flex',alignItems:'center',gap:'10px'}},
                        h('div',{style:{width:'36px',height:'36px',borderRadius:'50%',background:'#1c3d7a',color:'#d4f01a',display:'flex',alignItems:'center',justifyContent:'center',fontWeight:'700',fontSize:'14px',flexShrink:0}},
                          r.full_name?.[0]||'?'
                        ),
                        h('span',{style:{fontWeight:'600'}},r.full_name||'—')
                      )
                    ),
                    h('td',{style:{padding:'12px 16px'}},
                      r.phone ? h('a',{href:`tel:${r.phone}`,style:{color:'#1c3d7a',fontWeight:'600'}},r.phone) : '—'
                    ),
                    h('td',{style:{padding:'12px 16px',color:'#64748b'}},r.city||'—'),
                    h('td',{style:{padding:'12px 16px',color:'#64748b'}},r.state||'Punjab'),
                    h('td',{style:{padding:'12px 16px',color:'#94a3b8',fontSize:'12px'}},
                      new Date(r.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'})
                    )
                  )
                ))
              )
            )
    )
  )
}
createRoot(document.getElementById('root')).render(h(Mgr,null))
</script>
