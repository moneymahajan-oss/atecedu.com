---
// src/pages/admin/seo.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="SEO Settings" activeSection="seo">

<style>
  .wrap { max-width:820px }
  .pg-title { font-family:'Sora',sans-serif; font-size:20px; font-weight:900; color:#0b1a2e; margin:0 0 2px }
  .pg-sub { font-size:13px; color:#94a3b8; margin:0 0 20px }
  .panel { background:#fff; border-radius:14px; border:1px solid #e2e8f0; padding:22px; margin-bottom:16px }
  .panel-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:18px; gap:12px }
  .panel-title { font-size:15px; font-weight:700; color:#0b1a2e; margin:0 }
  .panel-desc { font-size:12px; color:#94a3b8; margin:3px 0 0 }
  .f2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px }
  @media(max-width:580px){ .f2 { grid-template-columns:1fr } }
  .field { display:flex; flex-direction:column; gap:4px; margin-bottom:12px }
  .field-full { margin-bottom:12px }
  .lbl { font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.04em }
  .hint { font-size:11px; color:#94a3b8; margin-top:3px }
  .char-count { font-size:11px; color:#94a3b8; text-align:right; margin-top:2px }
  .char-count.warn { color:#f59e0b }
  .char-count.over { color:#dc2626 }
  input[type=text],input[type=url],input[type=number],textarea,select {
    padding:8px 11px; border:1.5px solid #e2e8f0; border-radius:8px;
    font-size:13px; color:#1e293b; outline:none; font-family:'Inter',sans-serif;
    width:100%; box-sizing:border-box; background:#fff; transition:border-color 0.15s
  }
  input:focus,textarea:focus,select:focus { border-color:#0b1a2e }
  textarea { resize:vertical }
  .save-btn { display:inline-flex; align-items:center; gap:7px; background:#0b1a2e; color:#d4f01a; border:none; border-radius:9px; padding:10px 20px; font-size:13px; font-weight:800; cursor:pointer; font-family:'Inter',sans-serif; transition:background 0.15s; white-space:nowrap }
  .save-btn:hover { background:#1a3460 }
  .save-btn:disabled { background:#94a3b8; cursor:not-allowed; color:#fff }
  .status { font-size:12px; font-weight:600; padding:8px 14px; border-radius:8px; margin-top:10px }
  .status.ok  { background:#dcfce7; color:#166534 }
  .status.err { background:#fee2e2; color:#991b1b }

  /* Google preview */
  .goog-preview { border:1px solid #e2e8f0; border-radius:10px; padding:16px; background:#fff; margin-top:14px }
  .goog-preview-url { font-size:13px; color:#186f28; margin-bottom:2px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap }
  .goog-preview-title { font-size:18px; color:#1a0dab; font-weight:400; margin-bottom:4px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap }
  .goog-preview-desc { font-size:13px; color:#4d5156; line-height:1.5; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical }

  /* OG preview */
  .og-preview { border:1px solid #e2e8f0; border-radius:10px; overflow:hidden; max-width:400px; margin-top:14px }
  .og-preview-img { width:100%; height:160px; object-fit:cover; background:#f1f5f9; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:13px }
  .og-preview-body { padding:10px 14px; background:#fff }
  .og-preview-domain { font-size:11px; color:#94a3b8; text-transform:uppercase; margin-bottom:3px }
  .og-preview-title { font-size:14px; font-weight:700; color:#1e293b; margin-bottom:3px }
  .og-preview-desc { font-size:12px; color:#64748b }

  /* Badge row */
  .badge-row { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:12px }
  .badge { padding:4px 10px; border-radius:20px; font-size:11px; font-weight:600; border:1.5px solid #e2e8f0; background:#fff; cursor:pointer; font-family:'Inter',sans-serif }
  .badge:hover { border-color:#0b1a2e; background:#f8fafc }
  .sec-divider { border:none; border-top:1px solid #f1f5f9; margin:16px 0 }
</style>

<div class="wrap">
  <h1 class="pg-title">🔍 SEO Settings</h1>
  <p class="pg-sub">Control how atecedu.com appears in Google search results and on social media shares.</p>

  <!-- ── Homepage SEO ── -->
  <div class="panel">
    <div class="panel-head">
      <div>
        <div class="panel-title">🏠 Homepage SEO</div>
        <div class="panel-desc">Meta title and description for the main page — what Google shows in search results</div>
      </div>
      <button class="save-btn" id="seo-save-btn" onclick="saveSEO()">💾 Save</button>
    </div>

    <div class="field-full">
      <label class="lbl">Page Title <span style="color:#94a3b8;font-weight:400;text-transform:none;">(50–60 characters ideal)</span></label>
      <input type="text" id="seo-title" value="ATEC Gurdaspur — Computer Courses Online | GEN AI, MERN Stack, Tally" oninput="updatePreview()" maxlength="100">
      <div class="char-count" id="title-count">0 / 60</div>
      <div class="hint">Appears as the clickable blue link in Google. Include your main keyword early.</div>
    </div>

    <div class="field-full">
      <label class="lbl">Meta Description <span style="color:#94a3b8;font-weight:400;text-transform:none;">(140–160 characters ideal)</span></label>
      <textarea id="seo-desc" rows="3" oninput="updatePreview()" maxlength="300">ATEC Gurdaspur offers ISO-certified online computer courses — GEN AI, MERN Stack, Tally Prime, Hardware & Networking. 25+ years. 100% placement. Enroll now.</textarea>
      <div class="char-count" id="desc-count">0 / 160</div>
      <div class="hint">The 2-line description below the title in search results. Include a call to action.</div>
    </div>

    <div class="field-full">
      <label class="lbl">Focus Keywords <span style="color:#94a3b8;font-weight:400;text-transform:none;">(comma separated)</span></label>
      <input type="text" id="seo-keywords" value="computer courses gurdaspur, online computer course punjab, GEN AI course, MERN Stack course, Tally Prime, ATEC Gurdaspur" placeholder="keyword1, keyword2, keyword3">
      <div class="hint">Not directly used by Google, but helps you stay on-brand. Separate with commas.</div>
    </div>

    <!-- Quick keyword suggestions -->
    <div style="font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;margin-bottom:6px;">Quick add keywords</div>
    <div class="badge-row">
      <button class="badge" onclick="addKw('computer courses Gurdaspur')">+ computer courses Gurdaspur</button>
      <button class="badge" onclick="addKw('online computer course Punjab')">+ online computer course Punjab</button>
      <button class="badge" onclick="addKw('GEN AI course online')">+ GEN AI course online</button>
      <button class="badge" onclick="addKw('MERN Stack course')">+ MERN Stack course</button>
      <button class="badge" onclick="addKw('Tally Prime GST course')">+ Tally Prime GST</button>
      <button class="badge" onclick="addKw('hardware networking course')">+ hardware networking</button>
      <button class="badge" onclick="addKw('ISO certified institute Gurdaspur')">+ ISO certified institute</button>
    </div>

    <hr class="sec-divider">

    <!-- Google preview -->
    <div style="font-size:12px;font-weight:700;color:#64748b;margin-bottom:8px;">📊 Google Search Preview</div>
    <div class="goog-preview">
      <div class="goog-preview-url" id="prev-url">atecedu.com</div>
      <div class="goog-preview-title" id="prev-title">ATEC Gurdaspur — Computer Courses Online</div>
      <div class="goog-preview-desc" id="prev-desc">ATEC Gurdaspur offers ISO-certified online computer courses…</div>
    </div>

    <div id="seo-status" class="status" style="display:none"></div>
  </div>

  <!-- ── Open Graph (Social Sharing) ── -->
  <div class="panel">
    <div class="panel-head">
      <div>
        <div class="panel-title">📲 Social Sharing (Open Graph)</div>
        <div class="panel-desc">How the site looks when shared on WhatsApp, Facebook, Twitter, LinkedIn</div>
      </div>
      <button class="save-btn" id="og-save-btn" onclick="saveOG()">💾 Save</button>
    </div>

    <div class="f2">
      <div class="field">
        <label class="lbl">OG Title</label>
        <input type="text" id="og-title" value="ATEC Gurdaspur — Learn Online" oninput="updateOGPreview()">
      </div>
      <div class="field">
        <label class="lbl">OG Description</label>
        <input type="text" id="og-desc" value="ISO-certified computer courses online. GEN AI, MERN, Tally. 25+ years. Enroll now!" oninput="updateOGPreview()">
      </div>
    </div>
    <div class="field-full">
      <label class="lbl">OG Image URL <span style="color:#94a3b8;font-weight:400;text-transform:none;">(recommended: 1200×630px)</span></label>
      <input type="url" id="og-image" placeholder="https://atecedu.com/og-image.jpg" oninput="updateOGPreview()">
      <div class="hint">Upload a 1200×630px image to Supabase Storage → paste public URL here. Shows when someone shares your site on WhatsApp or Facebook.</div>
    </div>
    <div class="field-full">
      <label class="lbl">Canonical URL</label>
      <input type="url" id="og-canonical" value="https://atecedu.com" placeholder="https://atecedu.com">
      <div class="hint">Usually just your homepage URL. Tells Google which URL is the "real" one if there are duplicates.</div>
    </div>

    <!-- OG preview card -->
    <div style="font-size:12px;font-weight:700;color:#64748b;margin-bottom:8px;">📱 WhatsApp / Facebook Share Preview</div>
    <div class="og-preview">
      <div id="og-prev-img-wrap" style="height:160px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;">
        <span style="color:#94a3b8;font-size:13px;">No image set — paste an OG Image URL above</span>
      </div>
      <div class="og-preview-body">
        <div class="og-preview-domain">atecedu.com</div>
        <div class="og-preview-title" id="og-prev-title">ATEC Gurdaspur — Learn Online</div>
        <div class="og-preview-desc" id="og-prev-desc">ISO-certified computer courses online.</div>
      </div>
    </div>

    <div id="og-status" class="status" style="display:none"></div>
  </div>

  <!-- ── Structured Data ── -->
  <div class="panel" style="background:#f8fafc;">
    <div class="panel-title" style="margin-bottom:10px;">🏢 Business Info (Schema / Google Knowledge Panel)</div>
    <div class="panel-head" style="margin-bottom:14px;">
      <div class="panel-desc">Helps Google understand your business for local SEO and knowledge panel</div>
      <button class="save-btn" id="schema-save-btn" onclick="saveSchema()">💾 Save</button>
    </div>
    <div class="f2">
      <div class="field"><label class="lbl">Business Name</label><input type="text" id="sc-biz-name" value="ATEC Gurdaspur" placeholder="ATEC Gurdaspur"></div>
      <div class="field"><label class="lbl">Business Type</label>
        <select id="sc-biz-type">
          <option value="EducationalOrganization" selected>Educational Organization</option>
          <option value="LocalBusiness">Local Business</option>
          <option value="CollegeOrUniversity">College or University</option>
          <option value="School">School</option>
        </select>
      </div>
      <div class="field"><label class="lbl">Phone</label><input type="text" id="sc-phone" value="+91 7009933289"></div>
      <div class="field"><label class="lbl">Email</label><input type="text" id="sc-email" value="atecgsp@gmail.com"></div>
      <div class="field"><label class="lbl">City</label><input type="text" id="sc-city" value="Gurdaspur"></div>
      <div class="field"><label class="lbl">State</label><input type="text" id="sc-state" value="Punjab"></div>
    </div>
    <div class="field-full">
      <label class="lbl">Full Address</label>
      <input type="text" id="sc-address" value="1st Floor, ATEC Avenue, Hardo Channi Road, Gurdaspur, Punjab – 143521">
    </div>
    <div class="f2">
      <div class="field"><label class="lbl">Founded Year</label><input type="number" id="sc-founded" value="2000" min="1900" max="2030"></div>
      <div class="field"><label class="lbl">Google Maps URL</label><input type="url" id="sc-maps" placeholder="https://maps.google.com/..."></div>
    </div>
    <div id="schema-status" class="status" style="display:none"></div>
  </div>
</div>

<script>
const SB_URL = (window as any).__SB_URL as string
const SB_KEY = (window as any).__SB_KEY as string

function v(id: string) { return ((document.getElementById(id) as HTMLInputElement)?.value||'').trim() }
function sv(id: string, val: string) { const el=document.getElementById(id) as HTMLInputElement; if(el) el.value=val||'' }
function svs(id: string, val: string) { const el=document.getElementById(id) as HTMLSelectElement; if(el) el.value=val||'' }

async function sbGet(key: string) {
  if(!SB_URL||!SB_KEY) return null
  const r = await fetch(`${SB_URL}/rest/v1/site_settings?key=eq.${key}&select=value`, { headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}` } })
  return (await r.json())?.[0]?.value ?? null
}
async function sbSet(key: string, value: any) {
  await fetch(`${SB_URL}/rest/v1/site_settings`, {
    method:'POST',
    headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}`, 'Content-Type':'application/json', Prefer:'resolution=merge-duplicates,return=minimal' },
    body:JSON.stringify({key,value})
  })
}
function showStatus(id: string, ok: boolean, msg: string) {
  const el=document.getElementById(id)!
  el.textContent=msg; el.className='status '+(ok?'ok':'err'); el.style.display='block'
  setTimeout(()=>el.style.display='none', 3000)
}

// ── Preview ──────────────────────────────────────────────────
function countChars(val: string, max: number, countId: string) {
  const el = document.getElementById(countId)
  if (!el) return
  el.textContent = `${val.length} / ${max}`
  el.className = 'char-count' + (val.length > max ? ' over' : val.length > max * 0.85 ? ' warn' : '')
}
;(window as any).updatePreview = function() {
  const title = v('seo-title')
  const desc  = v('seo-desc')
  countChars(title, 60, 'title-count')
  countChars(desc, 160, 'desc-count')
  const pt = document.getElementById('prev-title'); if(pt) pt.textContent = title || 'Page Title'
  const pd = document.getElementById('prev-desc');  if(pd) pd.textContent = desc  || 'Page description...'
}
;(window as any).updateOGPreview = function() {
  const t  = v('og-title'); const d = v('og-desc'); const img = v('og-image')
  const pt = document.getElementById('og-prev-title'); if(pt) pt.textContent = t || 'OG Title'
  const pd = document.getElementById('og-prev-desc');  if(pd) pd.textContent = d || 'OG description'
  const wrap = document.getElementById('og-prev-img-wrap')!
  if (img) wrap.innerHTML = `<img src="${img}" style="width:100%;height:160px;object-fit:cover;" onerror="this.parentNode.innerHTML='<span style=color:#dc2626;font-size:12px;padding:10px;>Image failed to load — check URL</span>'">`
  else wrap.innerHTML = `<span style="color:#94a3b8;font-size:13px;">No image set</span>`
}
;(window as any).addKw = function(kw: string) {
  const el = document.getElementById('seo-keywords') as HTMLInputElement
  if (!el) return
  const cur = el.value.trim()
  el.value = cur ? cur + ', ' + kw : kw
}

// ── Save ────────────────────────────────────────────────────
;(window as any).saveSEO = async function() {
  const btn = document.getElementById('seo-save-btn') as HTMLButtonElement
  btn.disabled=true; btn.textContent='⏳'
  try {
    await sbSet('seo_settings', { title:v('seo-title'), description:v('seo-desc'), keywords:v('seo-keywords') })
    showStatus('seo-status', true, '✅ Saved! Note: SEO changes require the page meta tags to read from DB — ask Claude to wire up dynamic meta in BaseLayout if not done yet.')
  } catch(e:any) { showStatus('seo-status', false, '❌ ' + (e.message||'Save failed')) }
  btn.disabled=false; btn.textContent='💾 Save'
}
;(window as any).saveOG = async function() {
  const btn = document.getElementById('og-save-btn') as HTMLButtonElement
  btn.disabled=true; btn.textContent='⏳'
  try {
    await sbSet('og_settings', { title:v('og-title'), description:v('og-desc'), image:v('og-image'), canonical:v('og-canonical') })
    showStatus('og-status', true, '✅ Saved!')
  } catch(e:any) { showStatus('og-status', false, '❌ ' + (e.message||'Save failed')) }
  btn.disabled=false; btn.textContent='💾 Save'
}
;(window as any).saveSchema = async function() {
  const btn = document.getElementById('schema-save-btn') as HTMLButtonElement
  btn.disabled=true; btn.textContent='⏳'
  try {
    await sbSet('schema_settings', {
      name:v('sc-biz-name'), type:v('sc-biz-type'), phone:v('sc-phone'), email:v('sc-email'),
      city:v('sc-city'), state:v('sc-state'), address:v('sc-address'),
      founded:v('sc-founded'), maps_url:v('sc-maps'),
    })
    showStatus('schema-status', true, '✅ Saved!')
  } catch(e:any) { showStatus('schema-status', false, '❌ ' + (e.message||'Save failed')) }
  btn.disabled=false; btn.textContent='💾 Save'
}

// ── Preload ──────────────────────────────────────────────────
async function preload() {
  try {
    const [seo, og, sc] = await Promise.all([sbGet('seo_settings'), sbGet('og_settings'), sbGet('schema_settings')])
    if (seo) { sv('seo-title', seo.title); sv('seo-desc', seo.description); sv('seo-keywords', seo.keywords) }
    if (og)  { sv('og-title', og.title); sv('og-desc', og.description); sv('og-image', og.image); sv('og-canonical', og.canonical) }
    if (sc)  {
      sv('sc-biz-name', sc.name); svs('sc-biz-type', sc.type); sv('sc-phone', sc.phone); sv('sc-email', sc.email)
      sv('sc-city', sc.city); sv('sc-state', sc.state); sv('sc-address', sc.address)
      sv('sc-founded', sc.founded); sv('sc-maps', sc.maps_url)
    }
  } catch(e) {}
  updatePreview(); updateOGPreview()
}
preload()
</script>
</AdminLayout>
