---
// src/pages/admin/payments.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="Payments" activeSection="payments">
  <div id="root"></div>
</AdminLayout>
<script>
import { createClient } from '@supabase/supabase-js'
import { createElement as h, useState, useEffect } from 'react'
import { createRoot } from 'react-dom/client'
const sb = createClient(window.__SB_URL, window.__SB_KEY)

function Mgr() {
  const [rows, setRows] = useState([])
  const [loading, setLoading] = useState(true)
  const [search, setSearch] = useState('')
  const [filter, setFilter] = useState('all')

  useEffect(() => { load() }, [])
  async function load() {
    const { data } = await sb.from('payments')
      .select('*, student_profiles(full_name, phone), courses(title)')
      .order('created_at', { ascending: false })
      .limit(200)
    setRows(data ?? []); setLoading(false)
  }

  const filtered = rows.filter(r => {
    const matchFilter = filter==='all' || r.status===filter
    const q = search.toLowerCase()
    const matchSearch = !q || r.student_profiles?.full_name?.toLowerCase().includes(q) || r.razorpay_payment_id?.includes(q) || r.courses?.title?.toLowerCase().includes(q)
    return matchFilter && matchSearch
  })

  const totalCaptured = rows.filter(r=>r.status==='captured').reduce((a,r)=>a+(r.amount_paise||0),0)/100

  const statusColor = { captured:'#dcfce7', failed:'#fee2e2', pending:'#fef9c3', refunded:'#f3f4f6' }
  const statusText = { captured:'#166534', failed:'#991b1b', pending:'#713f12', refunded:'#374151' }

  return h('div',{style:{display:'flex',flexDirection:'column',gap:'20px'}},
    h('div',{style:{display:'flex',justifyContent:'space-between',alignItems:'center',flexWrap:'wrap',gap:'12px'}},
      h('div',{},
        h('h1',{style:{fontFamily:'Sora,sans-serif',fontSize:'1.5rem',fontWeight:'800'}},'💳 Payments'),
        h('p',{style:{fontSize:'13px',color:'#64748b',marginTop:'4px'}},`Total collected: ₹${totalCaptured.toLocaleString('en-IN')}`)
      ),
      h('button',{onClick:load,style:{padding:'8px 16px',background:'#f8fafc',border:'1px solid #e2e8f0',borderRadius:'8px',fontWeight:'600',fontSize:'13px',cursor:'pointer'}},'🔄 Refresh')
    ),
    h('div',{style:{display:'flex',gap:'10px',flexWrap:'wrap',alignItems:'center'}},
      h('input',{type:'text',placeholder:'🔍 Search student, payment ID, course...',value:search,onChange:e=>setSearch(e.target.value),
        style:{flex:1,minWidth:'200px',padding:'9px 14px',border:'1px solid #e2e8f0',borderRadius:'10px',fontSize:'14px',outline:'none'}}),
      ...['all','captured','pending','failed','refunded'].map(f =>
        h('button',{key:f,onClick:()=>setFilter(f),
          style:{padding:'7px 14px',borderRadius:'24px',border:'1.5px solid',fontSize:'12px',fontWeight:'500',cursor:'pointer',
            background:filter===f?'#1c3d7a':'#fff',color:filter===f?'#fff':'#64748b',borderColor:filter===f?'#1c3d7a':'#e2e8f0'}
        }, f.charAt(0).toUpperCase()+f.slice(1))
      )
    ),
    h('div',{style:{background:'#fff',borderRadius:'14px',border:'1px solid #e2e8f0',overflow:'hidden'}},
      loading
        ? h('div',{style:{padding:'40px',textAlign:'center',color:'#94a3b8'}},'Loading...')
        : filtered.length===0
          ? h('div',{style:{padding:'40px',textAlign:'center',color:'#94a3b8'}},'No payments found.')
          : h('div',{style:{overflowX:'auto'}},
              h('table',{style:{width:'100%',borderCollapse:'collapse',fontSize:'13px'}},
                h('thead',{},h('tr',{style:{background:'#f8fafc',borderBottom:'1px solid #e2e8f0'}},
                  ...['Student','Course','Amount','Payment ID','Status','Date'].map(col =>
                    h('th',{key:col,style:{padding:'12px 16px',textAlign:'left',fontWeight:'700',color:'#475569',fontSize:'12px',textTransform:'uppercase',whiteSpace:'nowrap'}},col)
                  )
                )),
                h('tbody',{},...filtered.map(r =>
                  h('tr',{key:r.id,style:{borderBottom:'1px solid #f1f5f9'},
                    onMouseEnter:e=>{e.currentTarget.style.background='#f8fafc'},
                    onMouseLeave:e=>{e.currentTarget.style.background='#fff'}},
                    h('td',{style:{padding:'12px 16px',fontWeight:'600'}},r.student_profiles?.full_name||'—'),
                    h('td',{style:{padding:'12px 16px',color:'#64748b'}},r.courses?.title||'—'),
                    h('td',{style:{padding:'12px 16px',fontWeight:'700',color:'#1c3d7a'}},`₹${((r.amount_paise||0)/100).toLocaleString('en-IN')}`),
                    h('td',{style:{padding:'12px 16px',fontFamily:'monospace',fontSize:'11px',color:'#94a3b8'}},r.razorpay_payment_id||'—'),
                    h('td',{style:{padding:'12px 16px'}},
                      h('span',{style:{background:statusColor[r.status]||'#f3f4f6',color:statusText[r.status]||'#374151',fontSize:'11px',fontWeight:'700',padding:'3px 10px',borderRadius:'12px',textTransform:'capitalize'}},
                        r.status||'—'
                      )
                    ),
                    h('td',{style:{padding:'12px 16px',color:'#94a3b8',fontSize:'12px',whiteSpace:'nowrap'}},
                      new Date(r.created_at).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'})
                    )
                  )
                ))
              )
            )
    )
  )
}
createRoot(document.getElementById('root')).render(h(Mgr,null))
</script>
