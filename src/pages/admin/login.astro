---
// src/pages/admin/login.astro
// FIXED: Checks user_roles table in DB instead of hardcoded email list
// Any email in user_roles with is_active=true can log in
// Fallback: atecgsp@gmail.com always allowed (superadmin safety net)
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL || ''
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || ''
---

<!DOCTYPE html>
<html lang="en-IN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login — ATEC</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@700;800&family=Inter:wght@400;500;600&display=swap" />
  <link rel="icon" type="image/png" href="/favicon.png" />

  <script define:vars={{ SUPABASE_URL, SUPABASE_KEY }}>
    window.__SB_URL = SUPABASE_URL
    window.__SB_KEY = SUPABASE_KEY
  </script>

  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;background:linear-gradient(135deg,#0b1f3f 0%,#1c3d7a 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}
    #checking{display:flex;flex-direction:column;align-items:center;gap:16px;color:rgba(255,255,255,0.6);font-size:14px}
    .spinner{width:36px;height:36px;border:3px solid rgba(255,255,255,0.2);border-top-color:#d4f01a;border-radius:50%;animation:spin 0.8s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}
    #page{display:none;width:100%;max-width:400px;flex-direction:column;align-items:center;gap:24px}
    .logo{display:inline-flex;align-items:center;gap:10px;text-decoration:none}
    .logo-mark{width:44px;height:44px;border-radius:12px;background:#d4f01a;display:flex;align-items:center;justify-content:center;font-family:'Sora',sans-serif;font-weight:800;font-size:20px;color:#0f2347}
    .logo-name{font-family:'Sora',sans-serif;font-weight:800;font-size:18px;color:#fff;line-height:1.1}
    .logo-sub{font-size:11px;color:rgba(255,255,255,0.5)}
    .card{width:100%;background:#fff;border-radius:20px;padding:36px 32px;box-shadow:0 24px 60px rgba(0,0,0,0.3)}
    .badge{display:inline-flex;align-items:center;gap:6px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:6px;padding:4px 10px;font-size:11px;font-weight:700;color:#1e40af;margin-bottom:14px}
    h1{font-family:'Sora',sans-serif;font-size:1.5rem;font-weight:800;color:#0f1724;margin-bottom:4px}
    .sub{font-size:14px;color:#6b7280;margin-bottom:24px}
    .field{margin-bottom:14px}
    label{display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:5px}
    .pw{position:relative}
    .eye{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:16px;color:#9ca3af;padding:4px;line-height:1}
    input[type=email],input[type=password]{width:100%;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:15px;font-family:'Inter',sans-serif;outline:none;transition:border-color 0.2s}
    input:focus{border-color:#1c3d7a}
    .err{background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:10px 14px;font-size:13px;color:#991b1b;margin-bottom:14px;display:none}
    .err.show{display:block}
    #login-btn{width:100%;padding:14px;background:#1c3d7a;color:#fff;border:none;border-radius:10px;font-family:'Sora',sans-serif;font-weight:800;font-size:15px;cursor:pointer}
    #login-btn:hover{background:#0f2347}
    #login-btn:disabled{background:#9ca3af;cursor:not-allowed}
    .back{display:block;text-align:center;margin-top:16px;font-size:13px;color:#9ca3af;text-decoration:none}
    .back:hover{color:#1c3d7a}
  </style>
</head>
<body>

  <div id="checking">
    <div class="spinner"></div>
    <span>Checking session...</span>
  </div>

  <div id="page">
    <a href="/" class="logo">
      <div class="logo-mark">A</div>
      <div><div class="logo-name">ATEC</div><div class="logo-sub">Educational Society</div></div>
    </a>
    <div class="card">
      <div class="badge">🔐 Admin Access Only</div>
      <h1>Admin Login</h1>
      <p class="sub">Sign in to manage your website</p>

      <div id="err" class="err"></div>

      <div class="field">
        <label for="em">Admin Email</label>
        <input type="email" id="em" placeholder="your-admin@email.com" autocomplete="username" />
      </div>

      <div class="field">
        <label for="pw">Password</label>
        <div class="pw">
          <input type="password" id="pw" placeholder="Enter your password" autocomplete="current-password" />
          <button type="button" class="eye" id="eye-btn">👁️</button>
        </div>
      </div>

      <button type="button" id="login-btn">Login to Admin Panel</button>
      <a href="/" class="back">← Back to website</a>
    </div>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js'

    const supabase = createClient(window.__SB_URL, window.__SB_KEY)

    // Superadmin safety net — always allowed even if DB is down
    const SUPERADMIN = 'atecgsp@gmail.com'

    // Check if user has admin role in DB
    async function hasAdminRole(userId: string, email: string): Promise<boolean> {
      // Superadmin always passes
      if (email === SUPERADMIN) return true
      try {
        const { data } = await supabase
          .from('user_roles')
          .select('role, is_active')
          .eq('user_id', userId)
          .single()
        return !!(data?.is_active && data?.role)
      } catch {
        return false
      }
    }

    // Session check on load
    supabase.auth.getSession().then(async ({ data: { session } }) => {
      if (session?.user) {
        const allowed = await hasAdminRole(session.user.id, session.user.email ?? '')
        if (allowed) {
          window.location.replace('/admin')
          return
        }
      }
      document.getElementById('checking')!.style.display = 'none'
      document.getElementById('page')!.style.display = 'flex'
    }).catch(() => {
      document.getElementById('checking')!.style.display = 'none'
      document.getElementById('page')!.style.display = 'flex'
    })

    // Eye toggle
    document.getElementById('eye-btn')?.addEventListener('click', function() {
      const pw = document.getElementById('pw') as HTMLInputElement
      pw.type = pw.type === 'password' ? 'text' : 'password'
    })

    // Enter key
    document.getElementById('em')?.addEventListener('keydown', (e: any) => { if (e.key === 'Enter') doLogin() })
    document.getElementById('pw')?.addEventListener('keydown', (e: any) => { if (e.key === 'Enter') doLogin() })
    document.getElementById('login-btn')?.addEventListener('click', doLogin)

    async function doLogin() {
      const errEl = document.getElementById('err') as HTMLElement
      const btn   = document.getElementById('login-btn') as HTMLButtonElement
      errEl.classList.remove('show')

      const email    = (document.getElementById('em') as HTMLInputElement).value.trim()
      const password = (document.getElementById('pw') as HTMLInputElement).value

      if (!email || !password) {
        errEl.textContent = '⚠️ Please enter your email and password'
        errEl.classList.add('show')
        return
      }

      btn.disabled    = true
      btn.textContent = 'Checking credentials...'

      // Sign in first
      const { data, error } = await supabase.auth.signInWithPassword({ email, password })

      if (error) {
        errEl.textContent = '⚠️ ' + (
          error.message === 'Invalid login credentials'
            ? 'Incorrect email or password.'
            : error.message
        )
        errEl.classList.add('show')
        btn.disabled    = false
        btn.textContent = 'Login to Admin Panel'
        return
      }

      // Now check if this user has an admin role
      btn.textContent = 'Verifying admin access...'
      const allowed = await hasAdminRole(data.user.id, data.user.email ?? '')

      if (!allowed) {
        // Sign them back out — they're not an admin
        await supabase.auth.signOut()
        errEl.textContent = '⚠️ Access denied. This account does not have admin privileges.'
        errEl.classList.add('show')
        btn.disabled    = false
        btn.textContent = 'Login to Admin Panel'
        return
      }

      btn.textContent = '✅ Redirecting...'
      window.location.replace('/admin')
    }
  </script>
</body>
</html>
