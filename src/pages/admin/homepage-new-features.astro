document.getElementById('popup-save-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('popup-save-btn') as HTMLButtonElement
  btn.disabled = true; btn.textContent = '⏳ Saving…'
  const cfg = {
    enabled:               chk('popup-enabled'),
    delay_seconds:         parseInt(v('popup-delay')) || 15,
    show_once_per_session: chk('popup-once'),
    title:                 v('popup-title'),
    subtitle:              v('popup-subtitle'),
  }
  try {
    await sbSet('popup_settings', cfg)
    showStatus('popup-status', true, '✅ Saved!')
  } catch { showStatus('popup-status', false, '❌ Save failed.') }
  btn.disabled = false; btn.textContent = '💾 Save Popup Settings'
})

// ═══════════════════════════════════════════════════════════
// PRELOAD from DB
// ═══════════════════════════════════════════════════════════
// ── setColor: updates input, preview dot, and live card preview ─────
function setColor(id, val) {
  if (!val) return
  const inp = document.getElementById(id)
  if (inp && inp.value !== val) inp.value = val
  const prev = document.getElementById(id + '-preview')
  if (prev) prev.style.background = val
  // Update live card preview
  const previewMap = {
    'card-bg-color':    ['prev-thumb', 'bg'],
    'card-body-bg':     ['prev-body',  'bg'],
    'card-title-color': ['prev-title', 'color'],
    'card-desc-color':  ['prev-desc',  'color'],
    'card-fee-color':   ['prev-fee',   'color'],
    'btn1-bg':          ['prev-btn1',  'bg'],
    'btn1-color':       ['prev-btn1',  'color'],
    'btn2-bg':          ['prev-btn2',  'bg'],
    'btn2-color':       ['prev-btn2',  'color'],
  }
  const mapping = previewMap[id]
  if (!mapping) return
  const target = document.getElementById(mapping[0])
  if (!target) return
  if (mapping[1] === 'color') target.style.color = val
  else target.style.background = val
}
window.setColor = setColor

async function preload() {
  try {
    const slData = await sbGet('hero_sliders')
    if (Array.isArray(slData) && slData.length) slides = slData
  } catch {}
  renderSlides()

  try {
    const wData = await sbGet('why_features')
    if (Array.isArray(wData) && wData.length) {
      whyCards = wData.slice(0, 5)
      if ((wData as any).section_title) sv('why-title', (wData as any).section_title)
      if ((wData as any).section_sub)   sv('why-sub',   (wData as any).section_sub)
    }
  } catch {}
  renderWhyCards()

  try {
    const catCfg = await sbGet('course_categories')
    if (catCfg?.categories?.length) {
      cats = catCfg.categories
      if (catCfg.section_title) sv('cat-section-title', catCfg.section_title)
      if (catCfg.section_sub)   sv('cat-section-sub',   catCfg.section_sub)
      schk('cat-show-fee', catCfg.show_fee !== false)
      const colorFields = [
        ['card-bg-color',    catCfg.card_bg_color],
        ['card-body-bg',     catCfg.card_body_bg],
        ['card-title-color', catCfg.card_title_color],
        ['card-desc-color',  catCfg.card_desc_color],
        ['card-fee-color',   catCfg.card_fee_color],
        ['btn1-bg',          catCfg.btn1_bg],
        ['btn1-color',       catCfg.btn1_color],
        ['btn2-bg',          catCfg.btn2_bg],
        ['btn2-color',       catCfg.btn2_color],
      ]
      colorFields.forEach(([id, val]) => {
        if (!val) return
        sv(id, val)
        const prev = document.getElementById(id + '-preview')
        if (prev) prev.style.background = val
        setColor(id, val)
      })
    }
  } catch {}
  renderCatAdmin()

  try {
    const popCfg = await sbGet('popup_settings')
    if (popCfg) {
      schk('popup-enabled', popCfg.enabled !== false)
      if (typeof popCfg.delay_seconds === 'number') sv('popup-delay', String(popCfg.delay_seconds))
      schk('popup-once', popCfg.show_once_per_session !== false)
      if (popCfg.title)    sv('popup-title', popCfg.title)
      if (popCfg.subtitle) sv('popup-subtitle', popCfg.subtitle)
    }
  } catch {}
}

// Render defaults immediately then load from DB
renderSlides()
renderWhyCards()
renderCatAdmin()
preload()
</script>
