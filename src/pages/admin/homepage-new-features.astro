            <div class="field">
              <label class="lbl">Category Name</label>
              <input type="text" id="ca-name-${ci}" value="${(cat.name||'').replace(/"/g,'&quot;')}" placeholder="AI & Machine Learning" />
            </div>
            <div class="field">
              <label class="lbl">Label Color</label>
              <div class="color-row">
                <input type="color" id="ca-color-${ci}" value="${color}" oninput="document.getElementById('ca-color-hex-${ci}').value=this.value" />
                <input type="text" id="ca-color-hex-${ci}" value="${color}" maxlength="9" style="width:90px" oninput="document.getElementById('ca-color-${ci}').value=this.value" />
              </div>
            </div>
            <div class="field">
              <label class="lbl">Row Background</label>
              <div class="color-row">
                <input type="color" id="ca-bg-${ci}" value="${bg}" oninput="document.getElementById('ca-bg-hex-${ci}').value=this.value" />
                <input type="text" id="ca-bg-hex-${ci}" value="${bg}" maxlength="9" style="width:90px" oninput="document.getElementById('ca-bg-${ci}').value=this.value" />
              </div>
            </div>
          </div>
          <div style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:8px">Courses in this row</div>
          <div style="border:1px solid #f1f5f9;border-radius:8px;overflow:hidden">
            <div style="font-size:11px;font-weight:700;color:#64748b;padding:6px 12px;background:#f1f5f9;border-radius:6px;margin-bottom:6px">
              Click any course below to expand and edit all fields
            </div>
            <div id="cc-list-${ci}">${courseRows}</div>
          </div>
          <button class="add-btn" style="margin-top:8px" onclick="catAddCourse(${ci})">+ Add Course</button>
        </div>
      </div>`
    list.appendChild(div)
  })
  if (cats.length <= 3) {
    cats.forEach((_: any, ci: number) => {
      const b = document.getElementById(`ca-body-${ci}`)
      if (b) b.style.display = 'block'
    })
  }
}

;(window as any).catToggle = (ci: number) => {
  const b = document.getElementById(`ca-body-${ci}`)
  if (b) b.style.display = b.style.display === 'none' ? 'block' : 'none'
}
;(window as any).catDel = (ci: number) => { collectCats(); cats.splice(ci, 1); renderCatAdmin() }
;(window as any).catMove = (ci: number, d: number) => {
  collectCats(); const j = ci+d
  if (j >= 0 && j < cats.length) { [cats[ci],cats[j]] = [cats[j],cats[ci]]; renderCatAdmin() }
}
;(window as any).catDelCourse = (ci: number, ri: number) => { collectCats(); cats[ci].courses.splice(ri,1); renderCatAdmin() }
;(window as any).catAddCourse = (ci: number) => {
  collectCats()
  cats[ci].courses.push({ title:'New Course', slug:'new-course', short_description:'', mode:'hybrid', fee_inr:2999, original_fee_inr:5999, thumbnail_url:'' })
  renderCatAdmin()
  const b = document.getElementById(`ca-body-${ci}`)
  if (b) b.style.display = 'block'
}

document.getElementById('cat-add-btn')?.addEventListener('click', () => {
  collectCats()
  cats.push({ name:'New Category', color:'#0f2a5c', bg_color:'#f8fafc', courses:[
    { title:'Course 1', slug:'course-1', short_description:'', mode:'hybrid', fee_inr:2999, original_fee_inr:5999, thumbnail_url:'' }
  ]})
  renderCatAdmin()
  const b = document.getElementById(`ca-body-${cats.length-1}`)
  if (b) b.style.display = 'block'
})

document.getElementById('cat-save-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('cat-save-btn') as HTMLButtonElement
  btn.disabled = true; btn.textContent = '⏳ Saving…'
  collectCats()
  const payload = {
    section_title:      gcv('cat-section-title') || 'Courses by Category',
    section_sub:        gcv('cat-section-sub')   || 'What We Offer',
    show_fee:           gcChk('cat-show-fee'),
    font_name:          "'Sora',sans-serif",
    card_bg_color:      gcv('card-bg-color')     || '#0b1525',
    card_body_bg:       gcv('card-body-bg')      || '#ffffff',
    card_title_color:   gcv('card-title-color')  || '#1c1c1c',
    card_desc_color:    gcv('card-desc-color')   || '#475569',
    card_fee_color:     gcv('card-fee-color')    || '#0b1525',
    btn1_bg:            gcv('btn1-bg')           || '#ea580c',
    btn1_color:         gcv('btn1-color')        || '#ffffff',
    btn2_bg:            gcv('btn2-bg')           || '#0b1525',
    btn2_color:         gcv('btn2-color')        || '#ffffff',
    categories:         cats,
  }
  try {
    await sbSet('course_categories', payload)
    showStatus('cat-status', true, '✅ Saved! Reload homepage to see changes.')
  } catch { showStatus('cat-status', false, '❌ Save failed.') }
  btn.disabled = false; btn.textContent = '💾 Save Categories'
})

// ═══════════════════════════════════════════════════════════
// POPUP
// ═══════════════════════════════════════════════════════════
document.getElementById('popup-save-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('popup-save-btn') as HTMLButtonElement
  btn.disabled = true; btn.textContent = '⏳ Saving…'
  const cfg = {
    enabled:               chk('popup-enabled'),
    delay_seconds:         parseInt(v('popup-delay')) || 15,
    show_once_per_session: chk('popup-once'),
    title:                 v('popup-title'),
    subtitle:              v('popup-subtitle'),
  }
  try {
    await sbSet('popup_settings', cfg)
    showStatus('popup-status', true, '✅ Saved!')
  } catch { showStatus('popup-status', false, '❌ Save failed.') }
  btn.disabled = false; btn.textContent = '💾 Save Popup Settings'
})

// ═══════════════════════════════════════════════════════════
// PRELOAD from DB
// ═══════════════════════════════════════════════════════════
// ── setColor: updates input, preview dot, and live card preview ─────
function setColor(id, val) {
  if (!val) return
  const inp = document.getElementById(id)
  if (inp && inp.value !== val) inp.value = val
  const prev = document.getElementById(id + '-preview')
  if (prev) prev.style.background = val
  // Update live card preview
  const previewMap = {
    'card-bg-color':    ['prev-thumb', 'bg'],
    'card-body-bg':     ['prev-body',  'bg'],
    'card-title-color': ['prev-title', 'color'],
    'card-desc-color':  ['prev-desc',  'color'],
    'card-fee-color':   ['prev-fee',   'color'],
    'btn1-bg':          ['prev-btn1',  'bg'],
    'btn1-color':       ['prev-btn1',  'color'],
    'btn2-bg':          ['prev-btn2',  'bg'],
    'btn2-color':       ['prev-btn2',  'color'],
  }
  const mapping = previewMap[id]
  if (!mapping) return
  const target = document.getElementById(mapping[0])
  if (!target) return
  if (mapping[1] === 'color') target.style.color = val
  else target.style.background = val
}
window.setColor = setColor

async function preload() {
  try {
    const slData = await sbGet('hero_sliders')
    if (Array.isArray(slData) && slData.length) slides = slData
  } catch {}
  renderSlides()

  try {
    const wData = await sbGet('why_features')
    if (Array.isArray(wData) && wData.length) {
      whyCards = wData.slice(0, 5)
      if ((wData as any).section_title) sv('why-title', (wData as any).section_title)
      if ((wData as any).section_sub)   sv('why-sub',   (wData as any).section_sub)
    }
  } catch {}
  renderWhyCards()

  try {
    const catCfg = await sbGet('course_categories')
    if (catCfg?.categories?.length) {
      cats = catCfg.categories
      if (catCfg.section_title) sv('cat-section-title', catCfg.section_title)
      if (catCfg.section_sub)   sv('cat-section-sub',   catCfg.section_sub)
      schk('cat-show-fee', catCfg.show_fee !== false)
      const colorFields = [
        ['card-bg-color',    catCfg.card_bg_color],
        ['card-body-bg',     catCfg.card_body_bg],
        ['card-title-color', catCfg.card_title_color],
        ['card-desc-color',  catCfg.card_desc_color],
        ['card-fee-color',   catCfg.card_fee_color],
        ['btn1-bg',          catCfg.btn1_bg],
        ['btn1-color',       catCfg.btn1_color],
        ['btn2-bg',          catCfg.btn2_bg],
        ['btn2-color',       catCfg.btn2_color],
      ]
      colorFields.forEach(([id, val]) => {
        if (!val) return
        sv(id, val)
        const prev = document.getElementById(id + '-preview')
        if (prev) prev.style.background = val
        setColor(id, val)
      })
    }
  } catch {}
  renderCatAdmin()

  try {
    const popCfg = await sbGet('popup_settings')
    if (popCfg) {
      schk('popup-enabled', popCfg.enabled !== false)
      if (typeof popCfg.delay_seconds === 'number') sv('popup-delay', String(popCfg.delay_seconds))
      schk('popup-once', popCfg.show_once_per_session !== false)
      if (popCfg.title)    sv('popup-title', popCfg.title)
      if (popCfg.subtitle) sv('popup-subtitle', popCfg.subtitle)
    }
  } catch {}
}

// Render defaults immediately then load from DB
renderSlides()
renderWhyCards()
renderCatAdmin()
preload()
</script>
