}

;(window as any).catToggle = (ci: number) => {
  const b = document.getElementById(`ca-body-${ci}`)
  if (b) b.style.display = b.style.display === 'none' ? 'block' : 'none'
}
;(window as any).catDel = (ci: number) => { collectCats(); cats.splice(ci, 1); renderCatAdmin() }
;(window as any).catMove = (ci: number, d: number) => {
  collectCats(); const j = ci+d
  if (j >= 0 && j < cats.length) { [cats[ci],cats[j]] = [cats[j],cats[ci]]; renderCatAdmin() }
}
;(window as any).catDelCourse = (ci: number, ri: number) => { collectCats(); cats[ci].courses.splice(ri,1); renderCatAdmin() }
;(window as any).catAddCourse = (ci: number) => {
  collectCats()
  cats[ci].courses.push({ title:'New Course', slug:'new-course', short_description:'', mode:'hybrid', fee_inr:2999, original_fee_inr:5999, thumbnail_url:'' })
  renderCatAdmin()
  const b = document.getElementById(`ca-body-${ci}`)
  if (b) b.style.display = 'block'
}

document.getElementById('cat-add-btn')?.addEventListener('click', () => {
  collectCats()
  cats.push({ name:'New Category', color:'#0f2a5c', bg_color:'#f8fafc', courses:[
    { title:'Course 1', slug:'course-1', short_description:'', mode:'hybrid', fee_inr:2999, original_fee_inr:5999, thumbnail_url:'' }
  ]})
  renderCatAdmin()
  const b = document.getElementById(`ca-body-${cats.length-1}`)
  if (b) b.style.display = 'block'
})

document.getElementById('cat-save-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('cat-save-btn') as HTMLButtonElement
  btn.disabled = true; btn.textContent = '⏳ Saving…'
  collectCats()
  const payload = {
    section_title:      gcv('cat-section-title') || 'Courses by Category',
    section_sub:        gcv('cat-section-sub')   || 'What We Offer',
    show_fee:           gcChk('cat-show-fee'),
    font_name:          "'Sora',sans-serif",
    card_bg_color:      gcv('card-bg-color')     || '#0b1525',
    card_body_bg:       gcv('card-body-bg')      || '#ffffff',
    card_title_color:   gcv('card-title-color')  || '#1c1c1c',
    card_desc_color:    gcv('card-desc-color')   || '#475569',
    card_fee_color:     gcv('card-fee-color')    || '#0b1525',
    btn1_bg:            gcv('btn1-bg')           || '#ea580c',
    btn1_color:         gcv('btn1-color')        || '#ffffff',
    btn2_bg:            gcv('btn2-bg')           || '#0b1525',
    btn2_color:         gcv('btn2-color')        || '#ffffff',
    categories:         cats,
  }
  try {
    await sbSet('course_categories', payload)
    showStatus('cat-status', true, '✅ Saved! Reload homepage to see changes.')
  } catch { showStatus('cat-status', false, '❌ Save failed.') }
  btn.disabled = false; btn.textContent = '💾 Save Categories'
})

