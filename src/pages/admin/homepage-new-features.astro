// ─── SECTION COLORS ───────────────────────────────────────────────────
const COLOR_KEYS = ['why_atec','slider','courses','instructors','stories','cta']

document.getElementById('colors-save-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('colors-save-btn') as HTMLButtonElement
  btn.disabled = true; btn.textContent = '⏳ Saving...'
  const cfg: any = { primary_color: val('color-primary-hex') || val('color-primary') }
  COLOR_KEYS.forEach(k => {
    const hex  = val(`color-${k}-hex`)
    const grad = val(`grad-${k}`)
    if (hex)  cfg[`${k}_bg`]       = hex
    if (grad) cfg[`${k}_gradient`] = grad
  })
  try {
    await sbSet('section_colors', cfg)
    showStatus('colors-status', true, '✅ Colors saved! Reload homepage to see changes.')
  } catch(e) {
    showStatus('colors-status', false, '❌ Save failed. Check Supabase connection.')
  }
  btn.disabled = false; btn.textContent = '💾 Save Section Colors'
})

// ─── PRELOAD from DB ──────────────────────────────────────────────────
async function preload() {
  // Why ATEC
  try {
    const wData = await sbGet('why_features')
    if (Array.isArray(wData) && wData.length) {
      whyCards = wData.slice(0,5)
      if ((wData as any).section_title) setVal('why-title', (wData as any).section_title)
      if ((wData as any).section_sub)   setVal('why-sub',   (wData as any).section_sub)
    }
  } catch(_) {}
  renderWhyCards()

  // Slider
  try {
    const slData = await sbGet('hero_sliders')
    if (Array.isArray(slData) && slData.length) slides = slData
  } catch(_) {}
  renderSlides()

  // Popup
  try {
    const popCfg = await sbGet('popup_settings')
    if (popCfg) {
      setChecked('popup-enabled', popCfg.enabled !== false)
      if (typeof popCfg.delay_seconds === 'number') setVal('popup-delay', String(popCfg.delay_seconds))
      setChecked('popup-once', popCfg.show_once_per_session !== false)
      if (popCfg.title)    setVal('popup-title',    popCfg.title)
      if (popCfg.subtitle) setVal('popup-subtitle', popCfg.subtitle)
    }
  } catch(_) {}

  // Section colors
  try {
    const colCfg = await sbGet('section_colors')
    if (colCfg) {
      if (colCfg.primary_color) {
        setVal('color-primary', colCfg.primary_color)
        setVal('color-primary-hex', colCfg.primary_color)
      }
      COLOR_KEYS.forEach(k => {
        if (colCfg[`${k}_bg`]) {
          setVal(`color-${k}`, colCfg[`${k}_bg`])
          setVal(`color-${k}-hex`, colCfg[`${k}_bg`])
        }
        if (colCfg[`${k}_gradient`]) {
          setVal(`grad-${k}`, colCfg[`${k}_gradient`])
        }
        ;(window as any).updateGradientPreview(k)
      })
    }
  } catch(_) {}

  // Course categories
  try {
    const catCfg = await sbGet('course_categories')
    if (catCfg?.categories?.length) {
      cats = catCfg.categories
      if (catCfg.section_title) setVal('cat-section-title', catCfg.section_title)
      if (catCfg.section_sub)   setVal('cat-section-sub',   catCfg.section_sub)
      if (catCfg.marquee_speed) setVal('cat-speed', String(catCfg.marquee_speed))
      setChecked('cat-show-fee', catCfg.show_fee !== false)
    }
  } catch(_) {}
  renderCatAdmin()
}

