---
// src/pages/admin/homepage-new-features.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="Slider · Cards · Popup" activeSection="new-features">

<style>
  .wrap { max-width:960px; }
  .page-title { font-family:'Sora',sans-serif; font-size:22px; font-weight:900; color:#1e293b; margin:0 0 4px }
  .page-sub { font-size:13px; color:#94a3b8; margin:0 0 28px }

  /* Tabs */
  .tabs { display:flex; gap:4px; background:#e8edf2; padding:4px; border-radius:12px; flex-wrap:wrap; margin-bottom:28px }
  .tab { padding:9px 18px; border:none; border-radius:9px; font-size:13px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; transition:all 0.15s; background:transparent; color:#64748b }
  .tab.active { background:#fff; color:#1a3460; box-shadow:0 1px 4px rgba(0,0,0,0.1) }

  /* Section card */
  .section-card { background:#fff; border-radius:16px; border:1px solid #e2e8f0; padding:28px; margin-bottom:24px }
  .section-title { font-family:'Sora',sans-serif; font-size:16px; font-weight:800; color:#1e293b; margin:0 0 4px }
  .section-desc { font-size:13px; color:#94a3b8; margin:0 0 24px }

  /* Fields */
  .field { display:flex; flex-direction:column; gap:5px; margin-bottom:16px }
  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:16px }
  .field-row.three { grid-template-columns:1fr 1fr 1fr }
  @media(max-width:600px){ .field-row,.field-row.three { grid-template-columns:1fr } }
  label.lbl { font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.05em }
  input[type=text],.inp,input[type=number],input[type=datetime-local],select,textarea {
    padding:9px 13px; border:1.5px solid #e2e8f0; border-radius:9px;
    font-size:14px; color:#1e293b; outline:none; background:#fff;
    width:100%; box-sizing:border-box; font-family:'Inter',sans-serif;
    transition:border-color 0.15s;
  }
  input:focus,.inp:focus,select:focus,textarea:focus { border-color:#1a3460 }
  textarea { resize:vertical }

  /* Slide card */
  .slide-card { border:1.5px solid #e2e8f0; border-radius:12px; margin-bottom:12px; overflow:hidden; background:#fafbfc }
  .slide-header { display:flex; align-items:center; gap:10px; padding:12px 16px; cursor:pointer; user-select:none; background:#f7f9fc }
  .slide-num { width:24px; height:24px; border-radius:50%; background:#1a3460; color:#d4f01a; font-size:11px; font-weight:800; display:flex; align-items:center; justify-content:center; flex-shrink:0 }
  .slide-header-title { font-size:13px; font-weight:700; color:#1e293b; flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap }
  .slide-actions { display:flex; gap:6px; flex-shrink:0 }
  .btn-sm { padding:4px 10px; border-radius:6px; font-size:12px; font-weight:600; cursor:pointer; border:1px solid #e2e8f0; background:#fff; color:#4a5568; font-family:'Inter',sans-serif }
  .btn-sm:hover { background:#f1f5f9 }
  .btn-sm.del { background:#fee2e2; border-color:#fecaca; color:#dc2626 }
  .btn-sm.del:hover { background:#fca5a5 }
  .slide-chevron { font-size:11px; color:#94a3b8; transition:transform 0.2s; flex-shrink:0 }
  .slide-chevron.open { transform:rotate(180deg) }
  .slide-body { display:none; padding:20px }
  .slide-body.open { display:block }

  /* Mini preview */
  .preview-box { height:120px; border-radius:10px; overflow:hidden; position:relative; margin-bottom:12px; background:#0f2a5c }
  .preview-box img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover }
  .preview-box .ov { position:absolute; inset:0; background:rgba(0,0,0,0.4) }
  .preview-box .ct { position:absolute; bottom:10px; left:12px; right:12px }
  .preview-box .pb { font-size:8px; font-weight:800; color:#d4f01a; text-transform:uppercase; margin-bottom:3px }
  .preview-box .ph { font-size:12px; font-weight:900; color:#fff; line-height:1.2; margin-bottom:5px }
  .preview-box .pc { display:inline-block; background:#d4f01a; color:#0f2a5c; font-size:9px; font-weight:800; padding:2px 8px; border-radius:4px }

  /* Why card */
  .why-card { border:1.5px solid #e2e8f0; border-radius:10px; padding:16px; margin-bottom:10px; background:#fafbfc }
  .why-card-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:12px }
  .why-card-label { font-size:12px; font-weight:700; color:#1a3460 }

  /* Save button */
  .save-btn { display:inline-flex; align-items:center; gap:8px; background:#1a3460; color:#d4f01a; border:none; border-radius:10px; padding:11px 24px; font-size:14px; font-weight:800; cursor:pointer; font-family:'Inter',sans-serif; transition:background 0.15s }
  .save-btn:hover { background:#0f2347 }
  .save-btn:disabled { background:#94a3b8; cursor:not-allowed }

  /* Status message */
  .status { font-size:13px; font-weight:600; padding:9px 16px; border-radius:9px; display:none; margin-top:12px }
  .status.ok { background:#dcfce7; color:#166534 }
  .status.err { background:#fee2e2; color:#991b1b }

  /* Color picker row */
  .color-row { display:flex; align-items:center; gap:8px }
  .color-row input[type=color] { width:36px; height:32px; border:1px solid #e2e8f0; border-radius:7px; cursor:pointer; padding:2px; flex-shrink:0 }
  .color-row input[type=text] { width:100px }

  /* Toggle */
  .toggle-row { display:flex; align-items:center; gap:10px; margin-bottom:14px }
  .toggle-row input[type=checkbox] { width:16px; height:16px; accent-color:#1a3460; cursor:pointer }
  .toggle-row label { font-size:14px; font-weight:500; color:#374151; cursor:pointer }

  /* Add course row */
  .add-btn { display:flex; align-items:center; gap:6px; padding:9px 16px; background:#eff6ff; border:2px dashed #93c5fd; color:#1d4ed8; border-radius:9px; font-size:13px; font-weight:700; cursor:pointer; width:100%; justify-content:center; font-family:'Inter',sans-serif }
  .add-btn:hover { background:#dbeafe }
  .tip { font-size:12px; color:#94a3b8; margin-top:4px; line-height:1.4 }

  /* Cat course row */
  .course-row { display:grid; grid-template-columns:1fr 1fr 90px 90px 30px; gap:6px; align-items:center; padding:7px 10px; border-bottom:1px solid #f1f5f9; background:#fff }
  .course-row:nth-child(even) { background:#f8fafc }
  .course-inp { padding:5px 8px; border:1px solid #e2e8f0; border-radius:5px; font-size:12px; outline:none; background:transparent; width:100%; box-sizing:border-box }
  .course-inp:focus { border-color:#1a3460; background:#fff }
  .course-hdr { display:grid; grid-template-columns:1fr 1fr 90px 90px 30px; gap:6px; padding:6px 10px; background:#f1f5f9 }
  .course-hdr span { font-size:10px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.04em }
</style>

<div class="wrap">
  <h1 class="page-title">🎠 Slider · Cards · Popup</h1>
  <p class="page-sub">Hero slider, Why ATEC cards, Drop Query popup, and Course Categories — all update live, no rebuild needed.</p>

  <!-- Tabs -->
  <div class="tabs">
    <button class="tab active" data-tab="slider"     onclick="switchTab('slider')">🎠 Hero Slider</button>
    <button class="tab"        data-tab="why"        onclick="switchTab('why')">✅ Why ATEC</button>
    <button class="tab"        data-tab="categories" onclick="switchTab('categories')">📚 Course Cards</button>
    <button class="tab"        data-tab="popup"      onclick="switchTab('popup')">💬 Query Popup</button>
  </div>

  <!-- ═══════════════════ HERO SLIDER ═══════════════════ -->
  <div id="tab-slider">
    <div class="section-card">
      <h2 class="section-title">🎠 Hero Slider</h2>
      <p class="section-desc">Slides appear below the main hero. Each shows a badge, heading, subheading, CTA button, and optional background image. Add up to 6 slides.</p>

      <div id="slider-list"></div>

      <button class="add-btn" id="slider-add-btn">+ Add New Slide</button>
      <br><br>
      <button class="save-btn" id="slider-save-btn">💾 Save Slides</button>
      <div class="status" id="slider-status"></div>
    </div>
  </div>

  <!-- ═══════════════════ WHY ATEC ═══════════════════ -->
  <div id="tab-why" style="display:none">
    <div class="section-card">
      <h2 class="section-title">✅ Why Choose ATEC — 5 Reason Cards</h2>
      <p class="section-desc">Shown on the homepage in the dark navy section. Add up to 5 cards with emoji, title, and description.</p>

      <div class="field-row">
        <div class="field">
          <label class="lbl">Section Title</label>
          <input type="text" id="why-title" value="Why Choose ATEC?" placeholder="Why Choose ATEC?" />
        </div>
        <div class="field">
          <label class="lbl">Section Subtitle</label>
          <input type="text" id="why-sub" placeholder="25+ years of excellence..." />
        </div>
      </div>

      <div id="why-cards-list"></div>
      <button class="add-btn" id="why-add-btn">+ Add Card (max 5)</button>
      <br><br>
      <button class="save-btn" id="why-save-btn">💾 Save Why Cards</button>
      <div class="status" id="why-status"></div>
    </div>
  </div>

  <!-- ═══════════════════ COURSE CATEGORIES ═══════════════════ -->
  <div id="tab-categories" style="display:none">
    <div class="section-card">
      <h2 class="section-title">📚 Course Category Cards</h2>
      <p class="section-desc">Each category row shows 4 course cards with title, description, fee, and mode badge. Add short descriptions to show below the course title on cards.</p>

      <div class="field-row three" style="margin-bottom:16px">
        <div class="field">
          <label class="lbl">Section Title</label>
          <input type="text" id="cat-section-title" value="Courses by Category" />
        </div>
        <div class="field">
          <label class="lbl">Label Above Title</label>
          <input type="text" id="cat-section-sub" value="What We Offer" />
        </div>
        <div class="field" style="display:flex;align-items:flex-end;gap:10px;padding-bottom:2px">
          <input type="checkbox" id="cat-show-fee" checked style="width:16px;height:16px;accent-color:#1a3460;cursor:pointer" />
          <label for="cat-show-fee" style="font-size:13px;font-weight:600;color:#374151;cursor:pointer">Show ₹ price on cards</label>
        </div>
      </div>

      <!-- Card Color Scheme — redesigned full panel -->
      <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:14px;padding:20px;margin-bottom:20px;">
        <div style="font-size:14px;font-weight:800;color:#1e293b;margin-bottom:4px;">🎨 Card Color Scheme</div>
        <div style="font-size:12px;color:#94a3b8;margin-bottom:18px;">All changes apply instantly on homepage after Save. Use colour picker or type a hex code.</div>

        <!-- Row 1: Card backgrounds -->
        <div style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid #e2e8f0;">Card Backgrounds</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px">
          
          <div>
            <div style="font-size:11px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px">Thumbnail BG (no image)</div>
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">
              <div id="card-bg-color-preview" style="width:28px;height:28px;border-radius:6px;border:1.5px solid #e2e8f0;background:#0b1525;flex-shrink:0"></div>
              <input type="text" id="card-bg-color" value="#0b1525" maxlength="9"
                style="font-family:monospace;padding:6px 9px;border:1.5px solid #e2e8f0;border-radius:7px;font-size:13px;color:#1e293b;width:100%;outline:none;box-sizing:border-box"
                oninput="setColor('card-bg-color',this.value)" />
            </div>
            <div style="display:flex;gap:3px;flex-wrap:wrap"><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-bg-color','#0b1525')" style="width:22px;height:22px;background:#0b1525;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-bg-color','#111827')" style="width:22px;height:22px;background:#111827;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-bg-color','#1e293b')" style="width:22px;height:22px;background:#1e293b;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-bg-color','#1a1a2e')" style="width:22px;height:22px;background:#1a1a2e;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-bg-color','#374151')" style="width:22px;height:22px;background:#374151;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-bg-color','#0f172a')" style="width:22px;height:22px;background:#0f172a;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-bg-color','#1c1c1c')" style="width:22px;height:22px;background:#1c1c1c;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-bg-color','#000')" style="width:22px;height:22px;background:#000;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button></div>
          </div>
          
          <div>
            <div style="font-size:11px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px">Card Body Background</div>
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">
              <div id="card-body-bg-preview" style="width:28px;height:28px;border-radius:6px;border:1.5px solid #e2e8f0;background:#ffffff;flex-shrink:0"></div>
              <input type="text" id="card-body-bg" value="#ffffff" maxlength="9"
                style="font-family:monospace;padding:6px 9px;border:1.5px solid #e2e8f0;border-radius:7px;font-size:13px;color:#1e293b;width:100%;outline:none;box-sizing:border-box"
                oninput="setColor('card-body-bg',this.value)" />
            </div>
            <div style="display:flex;gap:3px;flex-wrap:wrap"><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-body-bg','#ffffff')" style="width:22px;height:22px;background:#ffffff;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-body-bg','#f9fafb')" style="width:22px;height:22px;background:#f9fafb;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-body-bg','#f1f5f9')" style="width:22px;height:22px;background:#f1f5f9;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-body-bg','#fff7ed')" style="width:22px;height:22px;background:#fff7ed;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-body-bg','#fef3c7')" style="width:22px;height:22px;background:#fef3c7;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-body-bg','#f0fdf4')" style="width:22px;height:22px;background:#f0fdf4;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-body-bg','#eff6ff')" style="width:22px;height:22px;background:#eff6ff;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-body-bg','#fdf4ff')" style="width:22px;height:22px;background:#fdf4ff;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button></div>
          </div>
        </div>

        <!-- Row 2: Text colors -->
        <div style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid #e2e8f0;">Text Colors</div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:18px">
          
          <div>
            <div style="font-size:11px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px">Course Title</div>
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">
              <div id="card-title-color-preview" style="width:28px;height:28px;border-radius:6px;border:1.5px solid #e2e8f0;background:#1c1c1c;flex-shrink:0"></div>
              <input type="text" id="card-title-color" value="#1c1c1c" maxlength="9"
                style="font-family:monospace;padding:6px 9px;border:1.5px solid #e2e8f0;border-radius:7px;font-size:13px;color:#1e293b;width:100%;outline:none;box-sizing:border-box"
                oninput="setColor('card-title-color',this.value)" />
            </div>
            <div style="display:flex;gap:3px;flex-wrap:wrap"><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-title-color','#1c1c1c')" style="width:22px;height:22px;background:#1c1c1c;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-title-color','#111827')" style="width:22px;height:22px;background:#111827;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-title-color','#374151')" style="width:22px;height:22px;background:#374151;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-title-color','#475569')" style="width:22px;height:22px;background:#475569;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-title-color','#0b1525')" style="width:22px;height:22px;background:#0b1525;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-title-color','#ffffff')" style="width:22px;height:22px;background:#ffffff;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-title-color','#d4f01a')" style="width:22px;height:22px;background:#d4f01a;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button><button type="button" onmousedown="event.preventDefault()" onclick="setColor('card-title-color','#f59e0b')" style="width:22px;height:22px;background:#f59e0b;border:1.5px solid #e2e8f0;border-radius:4px;cursor:pointer;padding:0;flex-shrink:0"></button></div>
          </div>
          
          <div>
            <div style="font-size:11px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px">Description</div>
            <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">
              <div id="card-desc-color-preview" style="width:28px;height:28px;border-radius:6px;border:1.5px solid #e2e8f0;background:#475569;flex-shrink:0"></div>
              <input type="text" id="card-desc-color" value="#475569" maxlength="9"
                style="font-family:monospace;padding:6px 9px;border:1.5px solid #e2e8f0;border-radius:7px;font-size:13px;color:#1e293b;width:100%;outline:none;box-sizing:border-box"
