  ]},
]
let cats: any[] = JSON.parse(JSON.stringify(DEFAULT_CATS))

function gcv(id:string):string { return ((document.getElementById(id) as HTMLInputElement)?.value||'').trim() }
function gcChk(id:string):boolean { return !!(document.getElementById(id) as HTMLInputElement)?.checked }

function collectCats() {
  cats = cats.map((_:any,ci:number) => {
    const courses:any[] = []
    let ri = 0
    while (document.getElementById(`cc-title-${ci}-${ri}`)) {
      courses.push({
        title:        gcv(`cc-title-${ci}-${ri}`),
        slug:         gcv(`cc-slug-${ci}-${ri}`),
        mode:         (document.getElementById(`cc-mode-${ci}-${ri}`) as HTMLSelectElement)?.value || 'hybrid',
        fee_inr:      parseInt(gcv(`cc-fee-${ci}-${ri}`)) || 0,
        original_fee_inr: parseInt(gcv(`cc-ofee-${ci}-${ri}`)) || 0,
        thumbnail_url:'',
      })
      ri++
    }
    return {
      name:     gcv(`ca-name-${ci}`),
      color:    gcv(`ca-color-hex-${ci}`) || '#0f2a5c',
      bg_color: gcv(`ca-bg-hex-${ci}`) || '#ffffff',
      courses,
    }
  })
}

function renderCatAdmin() {
  const list = document.getElementById('cat-admin-list')
  if (!list) return
  list.innerHTML = ''
  cats.forEach((cat:any, ci:number) => {
    const div = document.createElement('div')
    div.className = 'cat-admin-row'
    const color = cat.color || '#0f2a5c'
    const bg    = cat.bg_color || '#ffffff'
    const courseRows = (cat.courses||[]).map((c:any, ri:number) => `
      <div class="cat-course-row" id="cc-row-${ci}-${ri}">
        <input class="cat-course-inp" id="cc-title-${ci}-${ri}" value="${(c.title||'').replace(/"/g,'&quot;')}" placeholder="Course title" />
        <input class="cat-course-inp" id="cc-slug-${ci}-${ri}" value="${(c.slug||'').replace(/"/g,'&quot;')}" placeholder="url-slug" />
        <select class="cat-course-inp" id="cc-mode-${ci}-${ri}">
          <option value="online"${c.mode==='online'?' selected':''}>Online</option>
          <option value="hybrid"${c.mode==='hybrid'?' selected':''}>Hybrid</option>
          <option value="offline"${c.mode==='offline'?' selected':''}>Offline</option>
        </select>
        <input class="cat-course-inp" id="cc-fee-${ci}-${ri}" type="number" value="${c.fee_inr||''}" placeholder="Fee ₹" />
        <button class="mini-del" onclick="catDelCourse(${ci},${ri})">✕</button>
      </div>`).join('')

    div.innerHTML = `
      <div class="cat-admin-hdr" onclick="catToggle(${ci})">
        <div class="cat-admin-hdr-num" style="background:${color};">${ci+1}</div>
        <span class="cat-admin-hdr-title">${cat.name||'Category'}</span>
        <span class="cat-admin-hdr-count">${(cat.courses||[]).length} courses</span>
        <div class="cat-admin-hdr-btns">
          <button class="mini-move" onclick="event.stopPropagation();catMove(${ci},-1)">↑</button>
          <button class="mini-move" onclick="event.stopPropagation();catMove(${ci},1)">↓</button>
          <button class="mini-del" onclick="event.stopPropagation();catDel(${ci})">✕</button>
        </div>
      </div>
      <div class="cat-admin-body" id="ca-body-${ci}">
        <div class="cat-meta-row">
          <div class="cat-field">
            <label class="cat-lbl">Category Name</label>
            <input class="cat-inp" id="ca-name-${ci}" value="${(cat.name||'').replace(/"/g,'&quot;')}" placeholder="AI & Machine Learning" />
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div class="cat-field">
              <label class="cat-lbl">Label Color</label>
              <div class="cat-color-row">
                <input type="color" id="ca-color-${ci}" value="${color}" oninput="document.getElementById('ca-color-hex-${ci}').value=this.value" />
                <input class="cat-inp" id="ca-color-hex-${ci}" value="${color}" maxlength="9" style="width:80px;" oninput="document.getElementById('ca-color-${ci}').value=this.value" />
              </div>
            </div>
            <div class="cat-field">
              <label class="cat-lbl">Row Background</label>
              <div class="cat-color-row">
                <input type="color" id="ca-bg-${ci}" value="${bg}" oninput="document.getElementById('ca-bg-hex-${ci}').value=this.value" />
                <input class="cat-inp" id="ca-bg-hex-${ci}" value="${bg}" maxlength="9" style="width:80px;" oninput="document.getElementById('ca-bg-${ci}').value=this.value" />
              </div>
            </div>
          </div>
          <div style="font-size:11px;color:#94a3b8;padding-top:18px;">Row ${ci+1}: scrolls ${ci%2===0?'→ left':'← right'}</div>
        </div>

        <div style="font-size:11px;font-weight:700;color:#475569;text-transform:uppercase;margin-bottom:6px;">Courses in this category</div>
        <div class="cat-course-list" id="cc-list-${ci}">
          <div class="cat-course-hdr">
            <span>Title</span><span>URL Slug</span><span>Mode</span><span>Fee ₹</span><span></span>
          </div>
          ${courseRows}
        </div>
        <button class="cat-add-course" onclick="catAddCourse(${ci})">+ Add Course</button>
      </div>`
    list.appendChild(div)
  })
  if (cats.length <= 3) {
    cats.forEach((_:any,ci:number) => document.getElementById(`ca-body-${ci}`)?.classList.add('open'))
  }
}

;(window as any).catToggle = (ci:number) => document.getElementById(`ca-body-${ci}`)?.classList.toggle('open')
;(window as any).catDel = (ci:number) => { collectCats(); cats.splice(ci,1); renderCatAdmin() }
;(window as any).catMove = (ci:number,dir:number) => {
  collectCats(); const j=ci+dir
  if(j<0||j>=cats.length) return
  ;[cats[ci],cats[j]]=[cats[j],cats[ci]]; renderCatAdmin()
}
;(window as any).catDelCourse = (ci:number,ri:number) => {
  collectCats(); cats[ci].courses.splice(ri,1); renderCatAdmin()
}
;(window as any).catAddCourse = (ci:number) => {
  collectCats()
  cats[ci].courses.push({ title:'New Course', slug:'new-course', mode:'hybrid', fee_inr:2999, original_fee_inr:5999, thumbnail_url:'' })
  renderCatAdmin()
  document.getElementById(`ca-body-${ci}`)?.classList.add('open')
}

document.getElementById('cat-add-btn')?.addEventListener('click', () => {
  collectCats()
  cats.push({ name:'New Category', color:'#0f2a5c', bg_color:'#f8fafc', courses:[
    { title:'Course 1', slug:'course-1', mode:'hybrid', fee_inr:2999, original_fee_inr:5999, thumbnail_url:'' }
  ]})
  renderCatAdmin()
  document.getElementById(`ca-body-${cats.length-1}`)?.classList.add('open')
})

document.getElementById('cat-save-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('cat-save-btn') as HTMLButtonElement
  btn.disabled=true; btn.textContent='⏳ Saving...'
  collectCats()
  const payload = {
    section_title: gcv('cat-section-title') || 'Courses by Category',
    section_sub:   gcv('cat-section-sub')   || 'What We Offer',
    marquee_speed: parseInt(gcv('cat-speed')) || 32,
    show_fee:      gcChk('cat-show-fee'),
    categories:    cats,
  }
  try {
    await sbSet('course_categories', payload)
    showStatus('cat-status', true, '✅ Saved! Reload homepage to see category marquee.')
  } catch(e) {
    showStatus('cat-status', false, '❌ Save failed. Check Supabase connection.')
  }
  btn.disabled=false; btn.textContent='💾 Save Category Marquee'
})

// Initialize with defaults immediately
renderSlides()
renderCatAdmin()
renderWhyCards()

preload()
</script>
