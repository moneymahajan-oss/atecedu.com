            <div style="flex:1">
              <div style="font-size:10px;font-weight:700;color:#0b1525;text-transform:uppercase;margin-bottom:4px">🖼️ Course Thumbnail Image URL</div>
              <input class="course-inp" id="cc-thumb-${ci}-${ri}"
