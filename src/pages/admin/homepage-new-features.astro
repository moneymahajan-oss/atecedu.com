        </div>
      </div>`).join('')

    const div = document.createElement('div')
    div.innerHTML = `
      <div style="border:1.5px solid #e2e8f0;border-radius:12px;margin-bottom:12px;overflow:hidden;background:#fafbfc">
        <div style="display:flex;align-items:center;gap:10px;padding:11px 16px;background:#f7f9fc;cursor:pointer" onclick="catToggle(${ci})">
          <div style="width:22px;height:22px;border-radius:50%;background:${color};color:#fff;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0">${ci+1}</div>
          <span style="font-size:13px;font-weight:700;color:#1e293b;flex:1">${cat.name||'Category'}</span>
          <span style="font-size:11px;color:#94a3b8">${(cat.courses||[]).length} courses</span>
          <div style="display:flex;gap:5px">
            <button class="btn-sm" onclick="event.stopPropagation();catMove(${ci},-1)">↑</button>
            <button class="btn-sm" onclick="event.stopPropagation();catMove(${ci},1)">↓</button>
            <button class="btn-sm del" onclick="event.stopPropagation();catDel(${ci})">✕</button>
          </div>
          <span style="font-size:11px;color:#94a3b8" id="cat-chev-${ci}">▼</span>
        </div>
        <div id="ca-body-${ci}" style="display:none;padding:14px">
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:14px">
            <div class="field">
              <label class="lbl">Category Name</label>
              <input type="text" id="ca-name-${ci}" value="${(cat.name||'').replace(/"/g,'&quot;')}" placeholder="AI & Machine Learning" />
            </div>
            <div class="field">
              <label class="lbl">Label Color</label>
              <div class="color-row">
                <input type="color" id="ca-color-${ci}" value="${color}" oninput="document.getElementById('ca-color-hex-${ci}').value=this.value" />
                <input type="text" id="ca-color-hex-${ci}" value="${color}" maxlength="9" style="width:90px" oninput="document.getElementById('ca-color-${ci}').value=this.value" />
              </div>
            </div>
            <div class="field">
              <label class="lbl">Row Background</label>
              <div class="color-row">
                <input type="color" id="ca-bg-${ci}" value="${bg}" oninput="document.getElementById('ca-bg-hex-${ci}').value=this.value" />
                <input type="text" id="ca-bg-hex-${ci}" value="${bg}" maxlength="9" style="width:90px" oninput="document.getElementById('ca-bg-${ci}').value=this.value" />
              </div>
            </div>
          </div>
          <div style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:8px">Courses in this row</div>
          <div style="border:1px solid #f1f5f9;border-radius:8px;overflow:hidden">
            <div style="font-size:11px;font-weight:700;color:#64748b;padding:6px 12px;background:#f1f5f9;border-radius:6px;margin-bottom:6px">
              Click any course below to expand and edit all fields
            </div>
            <div id="cc-list-${ci}">${courseRows}</div>
          </div>
          <button class="add-btn" style="margin-top:8px" onclick="catAddCourse(${ci})">+ Add Course</button>
        </div>
      </div>`
    list.appendChild(div)
  })
  if (cats.length <= 3) {
    cats.forEach((_: any, ci: number) => {
      const b = document.getElementById(`ca-body-${ci}`)
      if (b) b.style.display = 'block'
    })
