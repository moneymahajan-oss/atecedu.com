---
// src/pages/admin/homepage-new-features.astro
// ══════════════════════════════════════════════════════════════════════
// Admin panel for NEW homepage features:
//   1. Why Choose ATEC cards (5 cards, DB-driven)
//   2. Hero Slider (below hero section)
//   3. Drop Us a Query popup (timer + content)
//   4. Section Colors (per-section bg + gradient)
// All changes apply live — no rebuild needed.
// ══════════════════════════════════════════════════════════════════════
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="New Features Manager" activeSection="new-features">

<style>
  .nf-wrap { max-width:920px; margin:0 auto; padding:32px 24px 100px; }
  .nf-section { background:#fff; border-radius:16px; border:1px solid #e2e8f0; padding:28px; margin:0 0 28px; }
  .nf-section h2 { font-family:'Sora',sans-serif; font-size:18px; font-weight:800; color:#1e293b; margin:0 0 4px; }
  .nf-section .nf-desc { font-size:13px; color:#94a3b8; margin:0 0 22px; }
  .nf-label { font-size:12px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:5px; display:block; }
  .nf-input { width:100%; padding:9px 13px; border:1.5px solid #e2e8f0; border-radius:9px; font-size:14px; color:#1e293b; outline:none; transition:border-color 0.15s; box-sizing:border-box; }
  .nf-input:focus { border-color:#0f2a5c; }
  .nf-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px; }
  .nf-row.triple { grid-template-columns:1fr 1fr 1fr; }
  @media(max-width:640px){ .nf-row, .nf-row.triple { grid-template-columns:1fr; } }
  .nf-field { display:flex; flex-direction:column; gap:5px; }
  .nf-color-row { display:flex; align-items:center; gap:10px; }
  .nf-color-row input[type=color] { width:44px; height:36px; border:1px solid #e2e8f0; border-radius:8px; cursor:pointer; padding:2px; background:#fff; }
  .nf-color-row input[type=text] { width:110px; padding:7px 10px; border:1.5px solid #e2e8f0; border-radius:8px; font-size:13px; font-family:monospace; color:#334155; }
  .nf-card { background:#f8fafc; border:1.5px solid #e2e8f0; border-radius:12px; padding:18px; margin-bottom:14px; position:relative; }
  .nf-card-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
  .nf-card-label { font-family:'Sora',sans-serif; font-weight:700; font-size:14px; color:#0f2a5c; }
  .nf-del-btn { background:#fee2e2; border:none; color:#dc2626; border-radius:7px; padding:4px 12px; font-size:12px; font-weight:700; cursor:pointer; }
  .nf-del-btn:hover { background:#fca5a5; }
  .nf-add-btn { display:flex; align-items:center; gap:7px; background:#eff6ff; border:2px dashed #93c5fd; color:#1d4ed8; border-radius:10px; padding:10px 20px; font-size:14px; font-weight:700; cursor:pointer; width:100%; justify-content:center; margin-top:4px; }
  .nf-add-btn:hover { background:#dbeafe; }
  .save-btn { display:inline-flex; align-items:center; gap:8px; background:#0f2a5c; color:#d4f01a; border:none; border-radius:10px; padding:11px 24px; font-size:14px; font-weight:800; cursor:pointer; transition:background 0.15s; }
  .save-btn:hover { background:#163264; }
  .save-btn:disabled { background:#94a3b8; cursor:not-allowed; }
  .nf-status { font-size:13px; font-weight:600; padding:8px 14px; border-radius:8px; display:none; margin-top:10px; }
  .nf-status.ok { background:#dcfce7; color:#166534; }
  .nf-status.err { background:#fee2e2; color:#991b1b; }
  .nf-toggle { display:flex; align-items:center; gap:10px; margin-bottom:14px; }
  .nf-toggle input[type=checkbox] { width:18px; height:18px; cursor:pointer; accent-color:#0f2a5c; }
  .nf-toggle label { font-size:14px; font-weight:600; color:#334155; cursor:pointer; }
  .gradient-row { display:flex; flex-direction:column; gap:5px; margin-bottom:14px; }
  .gradient-preview { height:36px; border-radius:8px; border:1px solid #e2e8f0; margin-top:6px; transition:background 0.3s; }
</style>

<div class="nf-wrap">
  <h1 style="font-family:'Sora',sans-serif;font-size:24px;font-weight:900;color:#1e293b;margin:0 0 6px;">🚀 New Features Manager</h1>
  <p style="font-size:14px;color:#94a3b8;margin:0 0 32px;">Why ATEC cards, Hero Slider, Popup, and Section Colors — all live, no rebuild needed.</p>

  <!-- ════════════════════════════════════════════════
       1. WHY CHOOSE ATEC — 5 Cards
  ════════════════════════════════════════════════ -->
  <div class="nf-section" id="sec-why">
    <h2>✅ Why Choose ATEC — 5 Cards</h2>
    <p class="nf-desc">Manage the 5 cards shown in the "Why Choose ATEC?" section. Exactly 5 cards will show.</p>

    <div class="nf-row">
      <div class="nf-field">
        <label class="nf-label">Section Title</label>
        <input class="nf-input" id="why-title" placeholder="Why Choose ATEC?" value="Why Choose ATEC?" />
      </div>
      <div class="nf-field">
        <label class="nf-label">Section Subtitle</label>
        <input class="nf-input" id="why-sub" placeholder="25+ years of excellence..." />
      </div>
    </div>

    <div id="why-cards-list"></div>

    <button class="nf-add-btn" id="why-add-btn">+ Add Card (max 5)</button>

    <br><br>
    <button class="save-btn" id="why-save-btn">💾 Save Why ATEC Cards</button>
    <div class="nf-status" id="why-status"></div>
  </div>

  <!-- ════════════════════════════════════════════════
       2. HERO SLIDER
  ════════════════════════════════════════════════ -->
  <style>
    .sc { background:#fff; border:1.5px solid #e2e8f0; border-radius:14px; margin-bottom:12px; overflow:hidden; }
    .sc-hdr { display:flex; align-items:center; justify-content:space-between; padding:12px 16px; background:#f8fafc; border-bottom:1px solid #e2e8f0; cursor:pointer; user-select:none; gap:10px; }
    .sc-num { width:24px; height:24px; border-radius:50%; background:#0f2a5c; color:#d4f01a; font-size:11px; font-weight:800; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .sc-hdr-title { font-size:13px; font-weight:700; color:#1e293b; flex:1; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .sc-hdr-badge { font-size:11px; color:#94a3b8; margin-left:8px; flex-shrink:0; }
    .sc-hdr-actions { display:flex; align-items:center; gap:6px; flex-shrink:0; }
    .sc-btn { background:#f1f5f9; border:none; color:#475569; border-radius:5px; padding:3px 8px; font-size:12px; cursor:pointer; height:28px; }
    .sc-btn:hover { background:#e2e8f0; }
    .sc-del { background:#fee2e2; color:#dc2626; }
    .sc-del:hover { background:#fca5a5; }
    .sc-chevron { font-size:12px; color:#94a3b8; transition:transform 0.2s; }
    .sc-chevron.open { transform:rotate(180deg); }
    .sc-body { display:none; padding:0; }
    .sc-body.open { display:block; }

    /* Two-panel layout inside each slide */
    .sc-inner { display:grid; grid-template-columns:1fr 300px; gap:0; }
    @media(max-width:700px){ .sc-inner { grid-template-columns:1fr; } }
    .sc-fields { padding:16px; border-right:1px solid #f1f5f9; display:flex; flex-direction:column; gap:12px; }
    .sc-preview-panel { padding:16px; background:#f8fafc; display:flex; flex-direction:column; gap:12px; }

    /* Field styles */
    .sc-field { display:flex; flex-direction:column; gap:4px; }
    .sc-field-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
    .sc-lbl { font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.04em; }
    .sc-inp { padding:8px 10px; border:1.5px solid #e2e8f0; border-radius:7px; font-size:13px; color:#1e293b; outline:none; background:#fff; width:100%; box-sizing:border-box; }
    .sc-inp:focus { border-color:#0f2a5c; }
    .sc-color-wrap { display:flex; align-items:center; gap:6px; }
    .sc-color-wrap input[type=color] { width:34px; height:32px; border:1px solid #e2e8f0; border-radius:6px; cursor:pointer; padding:2px; flex-shrink:0; }

    /* Live preview */
    .sc-prev { border-radius:10px; overflow:hidden; background:#0f2a5c; height:140px; position:relative; }
    .sc-prev-img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
    .sc-prev-overlay { position:absolute; inset:0; background:linear-gradient(135deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.1) 100%); }
    .sc-prev-content { position:absolute; bottom:10px; left:12px; right:12px; }
    .sc-prev-badge { font-size:9px; font-weight:800; color:#d4f01a; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:3px; }
    .sc-prev-title { font-size:13px; font-weight:900; color:#fff; line-height:1.2; margin-bottom:5px; }
    .sc-prev-cta { display:inline-block; background:#d4f01a; color:#0f2a5c; font-size:10px; font-weight:800; padding:2px 8px; border-radius:4px; }

    .sc-img-preview { border-radius:8px; overflow:hidden; background:#e2e8f0; }
    .sc-img-preview img { width:100%; display:block; max-height:100px; object-fit:cover; }
    .sc-img-placeholder { padding:16px; text-align:center; color:#94a3b8; font-size:12px; }
    .sc-divider { border:none; border-top:1px solid #e2e8f0; margin:4px 0; }
  </style>

  <div class="nf-section" id="sec-slider">
    <h2>🎠 Hero Slider</h2>
    <p class="nf-desc">Each slide shows text on the left, image/video on the right. Click a slide to expand. Changes save only when you click Save.</p>
    <div id="slider-list"></div>
    <button class="nf-add-btn" id="slider-add-btn">+ Add New Slide</button>
    <br><br>
    <button class="save-btn" id="slider-save-btn">💾 Save All Slides</button>
    <div class="nf-status" id="slider-status"></div>
  </div>

  <!-- ════════════════════════════════════════════════
       3. DROP US A QUERY POPUP  <!-- ════════════════════════════════════════════════
       3. DROP US A QUERY POPUP
  ════════════════════════════════════════════════ -->
  <div class="nf-section" id="sec-popup">
    <h2>💬 Drop Us a Query Popup</h2>
    <p class="nf-desc">Configure the enquiry popup that appears to visitors. Set timing, content, and behavior.</p>

    <div class="nf-toggle">
      <input type="checkbox" id="popup-enabled" checked />
      <label for="popup-enabled">Popup is enabled (show to visitors)</label>
    </div>

    <div class="nf-row">
      <div class="nf-field">
        <label class="nf-label">Show After (seconds)</label>
        <input class="nf-input" type="number" id="popup-delay" value="15" min="5" max="120" />
        <span style="font-size:12px;color:#94a3b8;margin-top:3px;">Default: 15 seconds. Visitor must be on page this long before popup appears.</span>
      </div>
      <div class="nf-field">
        <label class="nf-label">Show Once Per Session?</label>
        <div class="nf-toggle" style="margin:8px 0 0;">
          <input type="checkbox" id="popup-once" checked />
          <label for="popup-once">Yes — don't show again if dismissed</label>
        </div>
      </div>
    </div>

    <div class="nf-row">
      <div class="nf-field">
        <label class="nf-label">Popup Title</label>
        <input class="nf-input" id="popup-title" value="Drop Us a Query" />
      </div>
      <div class="nf-field">
        <label class="nf-label">Subtitle / Tagline</label>
        <input class="nf-input" id="popup-subtitle" value="We'll call you back within 30 minutes" />
      </div>
    </div>

    <button class="save-btn" id="popup-save-btn">💾 Save Popup Settings</button>
    <div class="nf-status" id="popup-status"></div>
  </div>

  <!-- ════════════════════════════════════════════════
       4. SECTION COLORS
  ════════════════════════════════════════════════ -->
  <!-- ════════════════════════════════════════════════
       5. COURSE CATEGORIES MARQUEE
  ════════════════════════════════════════════════ -->
  <style>
    .cat-admin-row { border:1.5px solid #e2e8f0; border-radius:12px; margin-bottom:12px; overflow:hidden; background:#fff; }
    .cat-admin-hdr { display:flex; align-items:center; gap:10px; padding:12px 16px; background:#f8fafc; border-bottom:1px solid #e2e8f0; cursor:pointer; user-select:none; }
    .cat-admin-hdr-num { width:22px; height:22px; border-radius:50%; background:#0f2a5c; color:#d4f01a; font-size:11px; font-weight:800; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .cat-admin-hdr-title { font-size:13px; font-weight:700; color:#1e293b; flex:1; }
    .cat-admin-hdr-count { font-size:11px; color:#94a3b8; }
    .cat-admin-hdr-btns { display:flex; gap:6px; }
    .cat-admin-body { display:none; padding:14px; }
    .cat-admin-body.open { display:block; }
    .cat-meta-row { display:grid; grid-template-columns:1fr 1fr 80px; gap:10px; margin-bottom:12px; }
    .cat-field { display:flex; flex-direction:column; gap:3px; }
    .cat-lbl { font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.04em; }
    .cat-inp { padding:7px 10px; border:1.5px solid #e2e8f0; border-radius:7px; font-size:13px; color:#1e293b; outline:none; background:#fff; width:100%; box-sizing:border-box; }
    .cat-inp:focus { border-color:#0f2a5c; }
    .cat-color-row { display:flex; align-items:center; gap:6px; }
    .cat-color-row input[type=color] { width:32px; height:30px; border:1px solid #e2e8f0; border-radius:5px; cursor:pointer; padding:2px; flex-shrink:0; }
    /* course rows inside category */
    .cat-course-list { border:1px solid #f1f5f9; border-radius:8px; overflow:hidden; margin-top:8px; }
    .cat-course-row { display:grid; grid-template-columns:1fr 1fr 80px 80px 32px; gap:6px; align-items:center; padding:8px 10px; border-bottom:1px solid #f1f5f9; background:#fff; }
    .cat-course-row:last-child { border-bottom:none; }
    .cat-course-row:nth-child(even) { background:#f8fafc; }
    .cat-course-inp { padding:5px 8px; border:1px solid #e2e8f0; border-radius:5px; font-size:12px; color:#1e293b; outline:none; background:transparent; width:100%; box-sizing:border-box; }
    .cat-course-inp:focus { border-color:#0f2a5c; background:#fff; }
    .cat-course-hdr { display:grid; grid-template-columns:1fr 1fr 80px 80px 32px; gap:6px; padding:6px 10px; background:#f1f5f9; }
    .cat-course-hdr span { font-size:10px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.04em; }
    .cat-add-course { display:flex; align-items:center; gap:6px; padding:8px 10px; font-size:12px; font-weight:700; color:#0f2a5c; cursor:pointer; background:none; border:none; width:100%; }
    .cat-add-course:hover { background:#eff6ff; }
    .mini-del { background:#fee2e2; border:none; color:#dc2626; border-radius:4px; width:26px; height:26px; cursor:pointer; font-size:13px; display:flex; align-items:center; justify-content:center; }
    .mini-del:hover { background:#fca5a5; }
    .mini-move { background:#f1f5f9; border:none; color:#475569; border-radius:4px; width:22px; height:22px; cursor:pointer; font-size:11px; }
  </style>
  <div class="nf-section" id="sec-categories">
    <h2>📚 Course Categories Marquee</h2>
    <p class="nf-desc">Replace the courses grid with alternating marquee rows by category. Each row scrolls in opposite directions. Odd rows → left, even rows → right.</p>

    <!-- Global settings -->
    <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:16px;margin-bottom:20px;">
      <div style="font-size:12px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:12px;">Global Settings</div>
      <div style="display:grid;grid-template-columns:1fr 1fr 120px 1fr;gap:12px;align-items:end;">
        <div class="cat-field">
          <label class="cat-lbl">Section Title</label>
          <input class="cat-inp" id="cat-section-title" value="Courses by Category" placeholder="Courses by Category" />
        </div>
        <div class="cat-field">
          <label class="cat-lbl">Section Subtitle Label</label>
          <input class="cat-inp" id="cat-section-sub" value="What We Offer" placeholder="What We Offer" />
        </div>
        <div class="cat-field">
          <label class="cat-lbl">Scroll Speed (s)</label>
          <input class="cat-inp" type="number" id="cat-speed" value="32" min="8" max="120" />
        </div>
        <div class="cat-field">
          <label class="cat-lbl">Show Course Price?</label>
          <div style="display:flex;align-items:center;gap:8px;padding:8px 0;">
            <input type="checkbox" id="cat-show-fee" checked style="width:16px;height:16px;accent-color:#0f2a5c;" />
            <label for="cat-show-fee" style="font-size:13px;color:#334155;cursor:pointer;">Yes — show ₹ price on cards</label>
          </div>
        </div>
      </div>
    </div>

    <div id="cat-admin-list"></div>
    <button class="nf-add-btn" id="cat-add-btn">+ Add Category Row</button>

    <br><br>
    <button class="save-btn" id="cat-save-btn">💾 Save Category Marquee</button>
    <div class="nf-status" id="cat-status"></div>
  </div>

    <div class="nf-section" id="sec-colors">
    <h2>🎨 Section Colors</h2>
    <p class="nf-desc">Override the background color of each section. Use a gradient (CSS) for advanced styling. Leave blank to use the default color.</p>

    <!-- Primary Color -->
    <div class="nf-field" style="margin-bottom:20px;">
      <label class="nf-label">🎯 Primary Dark Blue (all buttons, badges, navbars)</label>
      <div class="nf-color-row">
        <input type="color" id="color-primary" value="#0f2a5c" oninput="document.getElementById('color-primary-hex').value=this.value" />
        <input type="text" id="color-primary-hex" value="#0f2a5c" maxlength="7" oninput="document.getElementById('color-primary').value=this.value" />
        <span style="font-size:13px;color:#64748b;">Default: #0f2a5c (dark navy)</span>
      </div>
    </div>

    <div style="border-top:1px solid #f1f5f9;margin:20px 0;"></div>
    <p style="font-size:13px;font-weight:700;color:#475569;margin:0 0 16px;">Per-Section Backgrounds:</p>

    <!-- Each section -->
    {[
      { key:'why_atec', label:'Why Choose ATEC', default:'#0f2a5c' },
      { key:'slider', label:'Hero Slider area', default:'(matches slide bg)' },
      { key:'courses', label:'Popular Courses section', default:'#ffffff' },
      { key:'instructors', label:'Instructors Marquee', default:'#f8f4ef' },
      { key:'stories', label:'Student Stories (2-row marquee)', default:'#0b1525' },
      { key:'cta', label:'Bottom CTA section', default:'#f8f4ef' },
    ].map(s => (
      <div style="margin-bottom:22px;">
        <label class="nf-label">{s.label} <span style="color:#94a3b8;font-weight:400;text-transform:none;">(default: {s.default})</span></label>
        <div class="nf-color-row" style="margin-bottom:8px;">
          <input type="color" id={`color-${s.key}`} value="#0f2a5c"
            oninput={`document.getElementById('color-${s.key}-hex').value=this.value;updateGradientPreview('${s.key}')`} />
          <input type="text" id={`color-${s.key}-hex`} value="" maxlength="7" placeholder="Solid color (leave blank = default)"
            oninput={`document.getElementById('color-${s.key}').value=this.value||'#000000';updateGradientPreview('${s.key}')`} />
        </div>
        <div class="gradient-row">
          <label class="nf-label">Gradient (CSS) — overrides solid color</label>
          <input class="nf-input" id={`grad-${s.key}`} placeholder="e.g. linear-gradient(135deg,#0f2a5c 0%,#1e3a8a 100%)"
            oninput={`updateGradientPreview('${s.key}')`} />
          <div class="gradient-preview" id={`grad-preview-${s.key}`} style="background:#f1f5f9;"></div>
        </div>
      </div>
    ))}

    <button class="save-btn" id="colors-save-btn">💾 Save Section Colors</button>
    <div class="nf-status" id="colors-status"></div>
  </div>
</div>

</AdminLayout>

<script>
const sb_url = (window as any).__SB_URL as string
const sb_key = (window as any).__SB_KEY as string

async function sbGet(key: string) {
  if (!sb_url || !sb_key) return null
  const r = await fetch(`${sb_url}/rest/v1/site_settings?key=eq.${key}&select=value`,
    { headers:{ apikey:sb_key, Authorization:`Bearer ${sb_key}` } })
  const d = await r.json()
  return d?.[0]?.value ?? null
}

async function sbSet(key: string, value: any) {
  if (!sb_url || !sb_key) throw new Error('Supabase not connected')
  await fetch(`${sb_url}/rest/v1/site_settings`, {
    method: 'POST',
    headers: {
      apikey: sb_key, Authorization: `Bearer ${sb_key}`,
      'Content-Type':'application/json', Prefer:'resolution=merge-duplicates,return=minimal'
    },
    body: JSON.stringify({ key, value })
  })
}

function showStatus(id: string, ok: boolean, msg: string) {
  const el = document.getElementById(id)
  if (!el) return
  el.textContent = msg
  el.className   = `nf-status ${ok?'ok':'err'}`
  el.style.display = 'block'
  setTimeout(() => { el.style.display='none' }, 3500)
}

function val(id: string): string {
  return (document.getElementById(id) as HTMLInputElement)?.value?.trim() || ''
}
function checked(id: string): boolean {
  return !!(document.getElementById(id) as HTMLInputElement)?.checked
}
function setVal(id: string, v: string) {
  const el = document.getElementById(id) as HTMLInputElement
  if (el) el.value = v
}
function setChecked(id: string, v: boolean) {
  const el = document.getElementById(id) as HTMLInputElement
  if (el) el.checked = v
}

// ─── GRADIENT PREVIEW ─────────────────────────────────────────────────
(window as any).updateGradientPreview = function(key: string) {
  const grad = (document.getElementById(`grad-${key}`) as HTMLInputElement)?.value?.trim()
  const hex  = (document.getElementById(`color-${key}-hex`) as HTMLInputElement)?.value?.trim()
  const prev = document.getElementById(`grad-preview-${key}`)
  if (!prev) return
  if (grad) prev.style.background = grad
  else if (hex) prev.style.background = hex
  else prev.style.background = '#f1f5f9'
}

// ─── WHY ATEC CARDS ───────────────────────────────────────────────────
const DEFAULT_WHY = [
  { icon:'🎓', title:'Expert Faculty',          desc:'Industry-certified trainers with 10+ years of experience' },
  { icon:'🏆', title:'ISO Certified',            desc:'ISO 9001:2015 certified institute since 2000' },
  { icon:'💼', title:'100% Placement',           desc:'Dedicated placement cell with 500+ hiring partners' },
  { icon:'🌐', title:'Online + Hybrid',          desc:'Learn from anywhere or attend in-person at our centres' },
  { icon:'📜', title:'Recognized Certificates',  desc:'Government & industry-recognised certifications' },
]

let whyCards: any[] = [...DEFAULT_WHY]

function renderWhyCards() {
  const list = document.getElementById('why-cards-list')
  if (!list) return
  list.innerHTML = ''
  whyCards.forEach((c, i) => {
    const card = document.createElement('div')
    card.className = 'nf-card'
    card.innerHTML = `
      <div class="nf-card-header">
        <span class="nf-card-label">Card ${i+1}</span>
        <button class="nf-del-btn" onclick="deleteWhyCard(${i})">✕ Remove</button>
      </div>
      <div class="nf-row triple">
        <div class="nf-field">
          <label class="nf-label">Icon (emoji)</label>
          <input class="nf-input" id="why-icon-${i}" value="${c.icon||''}" placeholder="🎓" />
        </div>
        <div class="nf-field" style="grid-column:span 2;">
          <label class="nf-label">Title</label>
          <input class="nf-input" id="why-title-${i}" value="${c.title||''}" placeholder="Card Title" />
        </div>
      </div>
      <div class="nf-field">
        <label class="nf-label">Description</label>
        <input class="nf-input" id="why-desc-${i}" value="${c.desc||''}" placeholder="Short description..." />
      </div>`
    list.appendChild(card)
  })
  const addBtn = document.getElementById('why-add-btn')
  if (addBtn) addBtn.style.display = whyCards.length >= 5 ? 'none' : 'flex'
}

;(window as any).deleteWhyCard = function(i: number) {
  whyCards.splice(i, 1)
  renderWhyCards()
}

document.getElementById('why-add-btn')?.addEventListener('click', () => {
  if (whyCards.length >= 5) return
  whyCards.push({ icon:'⭐', title:'New Feature', desc:'Describe this feature...' })
  renderWhyCards()
})

document.getElementById('why-save-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('why-save-btn') as HTMLButtonElement
  btn.disabled = true; btn.textContent = '⏳ Saving...'
  // Collect current values
  const saved = whyCards.map((_,i) => ({
    icon:  val(`why-icon-${i}`),
    title: val(`why-title-${i}`),
    desc:  val(`why-desc-${i}`),
  }))
  // Also store title/sub
  ;(saved as any).section_title = val('why-title')
  ;(saved as any).section_sub   = val('why-sub')
  try {
    await sbSet('why_features', saved)
    showStatus('why-status', true, '✅ Saved! Cards will update on next page load.')
  } catch(e) {
    showStatus('why-status', false, '❌ Save failed. Check Supabase connection.')
  }
  btn.disabled = false; btn.textContent = '💾 Save Why ATEC Cards'
})

// ─── HERO SLIDER ──────────────────────────────────────────────────────
const DEFAULT_SLIDES = [
  { badge:'🔥 New Batch June 2026', heading:'Industrial Training for Real World Jobs', subheading:'GEN AI | MERN Stack | ML | Python | Ethical Hacking', cta_text:'Register Now', cta_link:'/courses', video_link:'', bg_color:'#0f2a5c', image_url:'' },
  { badge:'🌐 Online & Hybrid', heading:'Learn From Anywhere in India', subheading:'Live classes · Recorded sessions · Doubt clearing', cta_text:'Explore Courses', cta_link:'/courses', video_link:'', bg_color:'#1a1a2e', image_url:'' },
]
let slides: any[] = [...DEFAULT_SLIDES]

function gv(id: string): string {
  return ((document.getElementById(id) as HTMLInputElement)?.value || '').trim()
}

function collectSlides() {
  slides = slides.map((_:any, i:number) => ({
    badge:      gv(`sc-badge-${i}`),
    heading:    gv(`sc-heading-${i}`),
    subheading: gv(`sc-sub-${i}`),
    cta_text:   gv(`sc-cta-text-${i}`),
    cta_link:   gv(`sc-cta-link-${i}`) || '/courses',
    video_link: gv(`sc-video-${i}`),
    image_url:  gv(`sc-img-${i}`),
    bg_color:   gv(`sc-bg-hex-${i}`) || '#0f2a5c',
  }))
}

;(window as any).refreshPreview = function(i: number) {
  const bg    = gv(`sc-bg-hex-${i}`) || '#0f2a5c'
  const head  = gv(`sc-heading-${i}`) || 'Slide Heading'
  const badge = gv(`sc-badge-${i}`) || ''
  const cta   = gv(`sc-cta-text-${i}`) || 'CTA'
  const img   = gv(`sc-img-${i}`)

  const prevBox = document.getElementById(`sc-prev-${i}`)
  if (prevBox) prevBox.style.background = bg

  const prevImg = document.getElementById(`sc-prev-img-${i}`) as HTMLImageElement|null
  if (prevImg) { prevImg.src = img || ''; prevImg.style.display = img ? 'block' : 'none' }

  const badgeEl = document.getElementById(`sc-prev-badge-${i}`)
  if (badgeEl) badgeEl.textContent = badge

  const titleEl = document.getElementById(`sc-prev-title-${i}`)
  if (titleEl) titleEl.textContent = head.replace(/<[^>]*>/g, '')

  const ctaEl = document.getElementById(`sc-prev-cta-${i}`)
  if (ctaEl) ctaEl.textContent = cta

  const hdrTitle = document.getElementById(`sc-hdr-title-${i}`)
  if (hdrTitle) hdrTitle.textContent = head.replace(/<[^>]*>/g, '') || `Slide ${i+1}`

  // Update image thumbnail preview
  const imgPrev = document.getElementById(`sc-img-prev-${i}`)
  if (imgPrev) {
    imgPrev.innerHTML = img
      ? `<img src="${img}" onerror="this.style.opacity=0.3" />`
      : `<div class="sc-img-placeholder">📷 No image set<br><span style="font-size:10px;">Paste an image URL above</span></div>`
  }
}

