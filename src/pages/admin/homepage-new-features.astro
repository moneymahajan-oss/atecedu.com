            <input class="course-inp" id="cc-title-${ci}-${ri}" value="${(c.title||'').replace(/"/g,'&quot;')}" placeholder="e.g. GEN AI for Everyone" style="width:100%" />
          </div>
          <div>
            <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;margin-bottom:3px">Short Description</div>
            <input class="course-inp" id="cc-desc-${ci}-${ri}" value="${(c.short_description||'').replace(/"/g,'&quot;')}" placeholder="Shows below title on card" style="width:100%" />
