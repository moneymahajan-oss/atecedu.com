            <input class="course-inp" id="cc-syllabus-${ci}-${ri}" value="${(c.syllabus_url||'').replace(/"/g,'&quot;')}" placeholder="/courses/gen-ai or PDF link" style="width:100%" />
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px">
            <div>
              <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;margin-bottom:3px">Fee ₹</div>
              <input class="course-inp" id="cc-fee-${ci}-${ri}" type="number" value="${c.fee_inr||''}" placeholder="4999" style="width:100%" />
            </div>
            <div>
              <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;margin-bottom:3px">Orig ₹</div>
