    { title:'React.js', slug:'react', short_description:'Component-based UI development', mode:'online', fee_inr:4499, original_fee_inr:8999 },
  ]},
  { name:'Commerce & Accounting', color:'#065f46', bg_color:'#ecfdf5', courses:[
    { title:'Tally Prime + GST', slug:'tally-prime', short_description:'Accounting, GST filing & payroll', mode:'hybrid', fee_inr:2999, original_fee_inr:5999 },
  ]},
  { name:'Hardware & Networking', color:'#be123c', bg_color:'#fff1f2', courses:[
    { title:'Hardware + Networking', slug:'hardware-networking', short_description:'Chip-level repair + CCNA networking', mode:'hybrid', fee_inr:3999, original_fee_inr:7999 },
  ]},
]
let cats: any[] = JSON.parse(JSON.stringify(DEFAULT_CATS))

function gcv(id: string): string { return ((document.getElementById(id) as HTMLInputElement)?.value || '').trim() }
function gcChk(id: string): boolean { return !!(document.getElementById(id) as HTMLInputElement)?.checked }

function collectCats() {
  cats = cats.map((_: any, ci: number) => {
    const courses: any[] = []
    let ri = 0
    while (document.getElementById(`cc-title-${ci}-${ri}`)) {
      courses.push({
        title:             gcv(`cc-title-${ci}-${ri}`),
        slug:              gcv(`cc-slug-${ci}-${ri}`),
        short_description: gcv(`cc-desc-${ci}-${ri}`),
        syllabus_url:      gcv(`cc-syllabus-${ci}-${ri}`),
        thumbnail_url:     gcv(`cc-thumb-${ci}-${ri}`),
        mode:              (document.getElementById(`cc-mode-${ci}-${ri}`) as HTMLSelectElement)?.value || 'hybrid',
        level:             (document.getElementById(`cc-level-${ci}-${ri}`) as HTMLSelectElement)?.value || '',
        fee_inr:           parseInt(gcv(`cc-fee-${ci}-${ri}`)) || 0,
        original_fee_inr:  parseInt(gcv(`cc-ofee-${ci}-${ri}`)) || 0,
        duration_weeks:    parseInt(gcv(`cc-weeks-${ci}-${ri}`)) || 0,
      })
      ri++
    }
    return { name: gcv(`ca-name-${ci}`), color: gcv(`ca-color-hex-${ci}`) || '#0f2a5c', bg_color: gcv(`ca-bg-hex-${ci}`) || '#fff', courses }
  })
}

function renderCatAdmin() {
  const list = document.getElementById('cat-admin-list')
  if (!list) return
  list.innerHTML = ''
  cats.forEach((cat: any, ci: number) => {
    const color = cat.color || '#0f2a5c'
    const bg    = cat.bg_color || '#ffffff'
    const courseRows = (cat.courses||[]).map((c: any, ri: number) => `
      <div style="border:1px solid #e2e8f0;border-radius:10px;margin-bottom:8px;overflow:hidden;background:#fafbfc">
