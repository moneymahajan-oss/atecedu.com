;(window as any).toggleSlide = function(i: number) {
  document.getElementById(`sc-body-${i}`)?.classList.toggle('open')
  document.getElementById(`sc-chev-${i}`)?.classList.toggle('open')
}
;(window as any).scDelete = function(i: number) {
  collectSlides(); slides.splice(i,1); renderSlides()
}
;(window as any).scMove = function(i: number, dir: number) {
  collectSlides()
  const j = i + dir
  if (j < 0 || j >= slides.length) return
  ;[slides[i], slides[j]] = [slides[j], slides[i]]
  renderSlides()
}

document.getElementById('slider-add-btn')?.addEventListener('click', () => {
  collectSlides()
  slides.push({ badge:'🔥 New Slide', heading:'Slide Heading', subheading:'Add description here', cta_text:'Learn More', cta_link:'/courses', video_link:'', bg_color:'#0f2a5c', image_url:'' })
  renderSlides()
  const ni = slides.length - 1
  document.getElementById(`sc-body-${ni}`)?.classList.add('open')
  document.getElementById(`sc-chev-${ni}`)?.classList.add('open')
})

document.getElementById('slider-add-btn')?.addEventListener('click', () => {
  collectSlides()
  slides.push({ badge:'🔥 New Slide', heading:'Slide Heading', subheading:'Add your description here', cta_text:'Learn More', cta_link:'/courses', video_link:'', bg_color:'#0f2a5c', text_color:'#ffffff', image_url:'' })
  renderSlides()
  // Expand the new slide
  const newIdx = slides.length - 1
  const body = document.getElementById(`sl-body-${newIdx}`)
  const chev = document.getElementById(`sl-chevron-${newIdx}`)
  if (body) body.classList.add('open')
  if (chev) chev.classList.add('open')
})

