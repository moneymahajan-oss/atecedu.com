---
// src/pages/admin/homepage-new-features.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="Slider · Cards · Popup" activeSection="new-features">

<style>
  .wrap { max-width:920px }
  .pg-title { font-family:'Sora',sans-serif; font-size:20px; font-weight:900; color:#0b1a2e; margin:0 0 2px }
  .pg-sub   { font-size:13px; color:#94a3b8; margin:0 0 20px }

  /* Tabs */
  .tabs { display:flex; gap:3px; background:#eef1f5; padding:4px; border-radius:11px; flex-wrap:wrap; margin-bottom:20px }
  .tab  { padding:8px 16px; border:none; border-radius:8px; font-size:13px; font-weight:600; cursor:pointer; font-family:'Inter',sans-serif; transition:all 0.15s; background:transparent; color:#64748b }
  .tab.active { background:#fff; color:#0b1a2e; box-shadow:0 1px 4px rgba(0,0,0,0.1) }

  /* Panel */
  .panel { background:#fff; border-radius:14px; border:1px solid #e2e8f0; padding:22px; margin-bottom:18px }
  .panel-head { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:16px; gap:12px }
  .panel-title { font-size:15px; font-weight:700; color:#0b1a2e; margin:0 }
  .panel-desc  { font-size:12px; color:#94a3b8; margin:4px 0 0 }

  /* Fields */
  .f2  { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px }
  .f3  { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:12px }
  .f4  { display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:10px; margin-bottom:12px }
  @media(max-width:620px){ .f2,.f3,.f4 { grid-template-columns:1fr } }
  .field { display:flex; flex-direction:column; gap:4px }
  .lbl  { font-size:11px; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:0.04em }
  input[type=text],.inp,input[type=number],input[type=datetime-local],select,textarea {
    padding:8px 11px; border:1.5px solid #e2e8f0; border-radius:8px;
    font-size:13px; color:#1e293b; outline:none; background:#fff;
    width:100%; box-sizing:border-box; font-family:'Inter',sans-serif; transition:border-color 0.15s
  }
  input:focus,.inp:focus,select:focus,textarea:focus { border-color:#0b1a2e }
  textarea { resize:vertical }

  /* Slide card */
  .slide-card { border:1px solid #e8edf2; border-radius:11px; margin-bottom:8px; overflow:hidden; background:#fafbfc }
  .slide-card:hover { border-color:#0b1a2e }
  .slide-header { display:flex; align-items:center; gap:10px; padding:11px 14px; cursor:pointer; user-select:none }
  .slide-num { width:26px; height:26px; border-radius:7px; background:#0b1a2e; color:#d4f01a; font-size:11px; font-weight:900; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-family:'Sora',sans-serif }
  .slide-header-title { font-size:13px; font-weight:700; color:#1e293b; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap }
  .slide-actions { display:flex; gap:5px; flex-shrink:0 }
  .btn-sm { padding:4px 9px; border-radius:6px; font-size:11px; font-weight:600; cursor:pointer; border:1px solid #e2e8f0; background:#fff; color:#475569; font-family:'Inter',sans-serif }
  .btn-sm:hover { background:#f1f5f9 }
  .btn-sm.del { background:#fee2e2; border-color:#fecaca; color:#dc2626 }
  .btn-sm.del:hover { background:#fca5a5 }
  .slide-chevron { font-size:10px; color:#94a3b8; transition:transform 0.2s; flex-shrink:0 }
  .slide-chevron.open { transform:rotate(180deg) }
  .slide-body { display:none; padding:16px; border-top:1px solid #f1f5f9 }
  .slide-body.open { display:block }

  /* Mini preview */
  .preview-box { height:110px; border-radius:9px; overflow:hidden; position:relative; background:#0f2a5c }
  .preview-box img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover }
  .preview-box .ov { position:absolute; inset:0; background:rgba(0,0,0,0.4) }
  .preview-box .ct { position:absolute; bottom:8px; left:10px; right:10px }
  .preview-box .pb { font-size:7px; font-weight:800; color:#d4f01a; text-transform:uppercase; margin-bottom:2px }
  .preview-box .ph { font-size:11px; font-weight:900; color:#fff; line-height:1.2; margin-bottom:4px }
  .preview-box .pc { display:inline-block; background:#d4f01a; color:#0f2a5c; font-size:8px; font-weight:800; padding:2px 7px; border-radius:3px }

  /* Why card — compact single row */
  .why-card { display:grid; grid-template-columns:50px 1fr 2fr auto; gap:8px; align-items:center; padding:9px 12px; border:1px solid #e8edf2; border-radius:9px; margin-bottom:6px; background:#fafbfc }
  .why-card:hover { border-color:#0b1a2e }
  .why-card-num { width:26px; height:26px; border-radius:7px; background:#0b1a2e; color:#d4f01a; font-size:10px; font-weight:900; display:flex; align-items:center; justify-content:center; font-family:'Sora',sans-serif }
  .why-card-label { font-size:12px; font-weight:700; color:#0b1a2e }

  /* Buttons */
  .save-btn { display:inline-flex; align-items:center; gap:7px; background:#0b1a2e; color:#d4f01a; border:none; border-radius:9px; padding:10px 20px; font-size:13px; font-weight:800; cursor:pointer; font-family:'Inter',sans-serif; transition:background 0.15s }
  .save-btn:hover { background:#1a3460 }
  .save-btn:disabled { background:#94a3b8; cursor:not-allowed; color:#fff }
  .add-btn { display:flex; align-items:center; gap:6px; padding:8px 14px; background:#f0f9ff; border:1.5px dashed #93c5fd; color:#0b1a2e; border-radius:8px; font-size:12px; font-weight:700; cursor:pointer; font-family:'Inter',sans-serif; transition:all 0.15s; justify-content:center }
  .add-btn:hover { background:#dbeafe }

  /* Status */
  .status { font-size:12px; font-weight:600; padding:8px 14px; border-radius:8px; display:none; margin-top:10px }
  .status.ok  { background:#dcfce7; color:#166534; display:block }
  .status.err { background:#fee2e2; color:#991b1b; display:block }

  /* Toggle row */
  .toggle-row { display:flex; align-items:center; gap:8px; margin-bottom:12px }
  .toggle-row input[type=checkbox] { width:15px; height:15px; accent-color:#0b1a2e; cursor:pointer }
  .toggle-row label { font-size:13px; font-weight:500; color:#374151; cursor:pointer }

  /* Color row (picker + hex) */
  .color-row { display:flex; align-items:center; gap:6px }
  .color-row input[type=color] { width:32px; height:28px; border:1px solid #e2e8f0; border-radius:6px; cursor:pointer; padding:2px; flex-shrink:0 }
  .color-row input[type=text] { width:88px; font-family:monospace; font-size:12px }

  /* tip text */
  .tip { font-size:11px; color:#94a3b8; display:block; margin-top:3px }

  /* field row */
  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px }
  .field-row.three { grid-template-columns:80px 1fr 2fr }
</style>

<div class="wrap">
  <h1 class="pg-title">🎠 Slider · Why ATEC · Popup</h1>
  <p class="pg-sub">Hero slider, Why ATEC cards, Query popup — all save live, no rebuild needed.</p>

  <div class="tabs">
    <button class="tab active" data-tab="slider"     onclick="switchTab('slider')">🎠 Hero Slider</button>
    <button class="tab"        data-tab="why"         onclick="switchTab('why')">✅ Why ATEC</button>
    <button class="tab"        data-tab="categories"  onclick="switchTab('categories')">📚 Course Cards</button>
    <button class="tab"        data-tab="popup"       onclick="switchTab('popup')">💬 Query Popup</button>
  </div>

  <!-- ══════════ HERO SLIDER ══════════ -->
  <div id="tab-slider">
    <div class="panel">
      <div class="panel-head">
        <div>
          <div class="panel-title">🎠 Hero Slider</div>
          <div class="panel-desc">Slides below the main hero. Each has badge, heading, subheading, CTA button, background image/color. Max 6.</div>
        </div>
        <button class="save-btn" id="slider-save-btn">💾 Save Slides</button>
      </div>
      <div id="slider-list"></div>
      <button class="add-btn" id="slider-add-btn" style="width:100%;margin-top:4px;">+ Add Slide</button>
      <div class="status" id="slider-status"></div>
    </div>
  </div>

  <!-- ══════════ WHY ATEC ══════════ -->
  <div id="tab-why" style="display:none">
    <div class="panel">
      <div class="panel-head">
        <div>
          <div class="panel-title">✅ Why Choose ATEC</div>
          <div class="panel-desc">5 reason cards shown in dark navy section on homepage.</div>
        </div>
        <button class="save-btn" id="why-save-btn">💾 Save</button>
      </div>
      <div class="f2" style="margin-bottom:14px;">
        <div class="field"><label class="lbl">Section Title</label><input type="text" id="why-title" value="Why Choose ATEC?" placeholder="Why Choose ATEC?"></div>
        <div class="field"><label class="lbl">Subtitle</label><input type="text" id="why-sub" placeholder="25+ years of excellence..."></div>
      </div>
      <!-- Header -->
      <div style="display:grid;grid-template-columns:50px 50px 1fr 2fr auto;gap:8px;padding:0 12px 6px;font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.04em;">
        <div></div><div>Icon</div><div>Title</div><div>Description</div><div></div>
      </div>
      <div id="why-cards-list"></div>
      <button class="add-btn" id="why-add-btn" style="width:100%;margin-top:4px;">+ Add Card (max 5)</button>
      <div class="status" id="why-status"></div>
    </div>
  </div>

  <!-- ══════════ COURSE CARDS (MOVED) ══════════ -->
  <div id="tab-categories" style="display:none">
    <div class="panel">
      <div style="text-align:center;padding:40px 20px;">
        <div style="font-size:48px;margin-bottom:16px;">📚</div>
        <h2 style="font-family:'Sora',sans-serif;font-size:18px;font-weight:800;color:#0b1a2e;margin:0 0 10px;">Course Cards Moved to Courses Manager</h2>
        <p style="font-size:14px;color:#64748b;margin:0 0 8px;max-width:480px;margin-left:auto;margin-right:auto;line-height:1.7;">
          The homepage course cards now read <strong>directly from the Courses table</strong> — no more duplicate data entry.
          Add or edit any course in <strong>Courses Manager</strong> and it appears live on the homepage automatically.
        </p>
        <p style="font-size:13px;color:#94a3b8;margin:0 0 28px;max-width:420px;margin-left:auto;margin-right:auto;line-height:1.6;">
          To control <em>category colors and row backgrounds</em>, go to Courses Manager → <strong>🎨 Category Styles</strong> tab.
        </p>
        <a href="/admin/courses" style="display:inline-flex;align-items:center;gap:10px;padding:13px 28px;background:#1c3d7a;color:#fff;border-radius:12px;font-weight:700;font-size:14px;text-decoration:none;font-family:'Sora',sans-serif;">
          → Go to Courses Manager
        </a>
        <div style="margin-top:20px;padding:14px;background:#f0fdf4;border-radius:10px;border:1px solid #bbf7d0;font-size:12px;color:#166534;max-width:480px;margin-left:auto;margin-right:auto;">
          ✅ <strong>All your existing course data is safe.</strong> Courses entered in Courses Manager now show on the homepage grouped by their <em>Category</em> field.
          Set each course's Category field (e.g. <code>AI</code>, <code>web</code>, <code>hardware</code>) to control which row it appears in.
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════ POPUP ══════════ -->
  <div id="tab-popup" style="display:none">
    <div class="panel">
      <div class="panel-head">
        <div>
          <div class="panel-title">💬 Drop Us a Query Popup</div>
          <div class="panel-desc">Appears to visitors after a set delay. Configurable timing and content.</div>
        </div>
        <button class="save-btn" id="popup-save-btn">💾 Save</button>
      </div>
      <div class="toggle-row"><input type="checkbox" id="popup-enabled" checked><label for="popup-enabled">Popup enabled (show to visitors)</label></div>
      <div class="toggle-row"><input type="checkbox" id="popup-once" checked><label for="popup-once">Show only once per session (don't repeat on refresh)</label></div>
      <div class="f2" style="margin-bottom:12px;">
        <div class="field"><label class="lbl">Show After (seconds)</label><input type="number" id="popup-delay" value="15" min="5" max="300"></div>
        <div></div>
      </div>
      <div class="f2">
        <div class="field"><label class="lbl">Popup Title</label><input type="text" id="popup-title" value="Drop Us a Query"></div>
        <div class="field"><label class="lbl">Subtitle</label><input type="text" id="popup-subtitle" value="We'll call you back within 30 minutes"></div>
      </div>
      <div class="status" id="popup-status"></div>
    </div>
  </div>

</div>

<script>
const SB_URL = (window as any).__SB_URL as string
const SB_KEY = (window as any).__SB_KEY as string

// ── Helpers ────────────────────────────────────────────────────────────
function v(id: string): string { return ((document.getElementById(id) as HTMLInputElement)?.value || '').trim() }
function sv(id: string, val: string) { const el = document.getElementById(id) as HTMLInputElement; if (el) el.value = val }
function chk(id: string): boolean { return !!(document.getElementById(id) as HTMLInputElement)?.checked }
function schk(id: string, val: boolean) { const el = document.getElementById(id) as HTMLInputElement; if (el) el.checked = val }

async function sbGet(key: string): Promise<any> {
  if (!SB_URL || !SB_KEY) return null
  const r = await fetch(`${SB_URL}/rest/v1/site_settings?key=eq.${key}&select=value`,
    { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } })
  const d = await r.json()
  return d?.[0]?.value ?? null
}
async function sbSet(key: string, value: any) {
  if (!SB_URL || !SB_KEY) throw new Error('No Supabase connection')
  await fetch(`${SB_URL}/rest/v1/site_settings`, {
    method: 'POST',
    headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}`, 'Content-Type': 'application/json', Prefer: 'resolution=merge-duplicates,return=minimal' },
    body: JSON.stringify({ key, value })
  })
}
function showStatus(id: string, ok: boolean, msg: string) {
  const el = document.getElementById(id)
  if (!el) return
  el.textContent = msg
  el.className = 'status ' + (ok ? 'ok' : 'err')
  el.style.display = 'block'
  setTimeout(() => { el.style.display = 'none' }, 3500)
}

// ── Tab switching ──────────────────────────────────────────────────────
;(window as any).switchTab = function(tab: string) {
  document.querySelectorAll('[data-tab]').forEach(btn => btn.classList.toggle('active', (btn as HTMLElement).dataset.tab === tab))
  ;['slider','why','categories','popup'].forEach(t => {
    const el = document.getElementById(`tab-${t}`)
    if (el) el.style.display = t === tab ? '' : 'none'
  })
}

// ═══════════════════════════════════════════════════════════
// HERO SLIDER
// ═══════════════════════════════════════════════════════════
const DEFAULT_SLIDES: any[] = [
  { badge:'🔥 New Batch June 2026', heading:'Industrial Training for Real World Jobs', subheading:'GEN AI | MERN Stack | Machine Learning | Python | Ethical Hacking', cta_text:'Register Now', cta_link:'/courses', image_url:'', bg_color:'#0f2a5c', text_color:'#ffffff' },
  { badge:'🌐 Online & Hybrid', heading:'Learn From Anywhere in India', subheading:'Live classes, recorded sessions, doubt clearing — all from home', cta_text:'Explore Courses', cta_link:'/courses', image_url:'', bg_color:'#1a1a2e', text_color:'#ffffff' },
]
let slides: any[] = [...DEFAULT_SLIDES]

function collectSlides() {
  slides = slides.map((_: any, i: number) => ({
    badge:      v(`sl-badge-${i}`),
    heading:    v(`sl-heading-${i}`),
    subheading: v(`sl-sub-${i}`),
    cta_text:   v(`sl-cta-${i}`),
    cta_link:   v(`sl-link-${i}`) || '/courses',
    image_url:  v(`sl-img-${i}`),
    bg_color:   v(`sl-bg-hex-${i}`) || '#0f2a5c',
    text_color: v(`sl-tc-hex-${i}`) || '#ffffff',
  }))
}

function renderSlides() {
  const list = document.getElementById('slider-list')
  if (!list) return
  list.innerHTML = ''
  slides.forEach((s: any, i: number) => {
    const card = document.createElement('div')
    card.className = 'slide-card'
    const bg = s.bg_color || '#0f2a5c'
    const tc = s.text_color || '#fff'
    card.innerHTML = `
      <div class="slide-header" onclick="toggleSlide(${i})">
        <div class="slide-num">${i+1}</div>
        <span class="slide-header-title" id="sl-htitle-${i}">${s.heading || 'New Slide'}</span>
        <div class="slide-actions">
          <button class="btn-sm" onclick="event.stopPropagation();slMove(${i},-1)">↑</button>
          <button class="btn-sm" onclick="event.stopPropagation();slMove(${i},1)">↓</button>
          <button class="btn-sm del" onclick="event.stopPropagation();slDelete(${i})">✕ Remove</button>
        </div>
        <span class="slide-chevron ${i < 2 ? 'open' : ''}" id="sl-chev-${i}">▼</span>
      </div>
      <div class="slide-body ${i < 2 ? 'open' : ''}" id="sl-body-${i}">
        <div style="display:grid;grid-template-columns:1fr 260px;gap:20px">
          <div>
            <div class="field-row">
              <div class="field">
                <label class="lbl">🏷️ Badge Text</label>
                <input type="text" id="sl-badge-${i}" value="${(s.badge||'').replace(/"/g,'&quot;')}" placeholder="🔥 New Batch June 2026" oninput="slPreview(${i})" />
              </div>
              <div class="field">
                <label class="lbl">💡 Hint</label>
                <span class="tip" style="padding-top:8px">Badge shows as a small pill above the heading. Use emoji for visual interest.</span>
              </div>
            </div>
            <div class="field" style="margin-bottom:10px">
              <label class="lbl">📝 Heading</label>
              <input type="text" id="sl-heading-${i}" value="${(s.heading||'').replace(/"/g,'&quot;')}" placeholder="Industrial Training for Real World Jobs" oninput="slPreview(${i})" />
            </div>
            <div class="field" style="margin-bottom:10px">
              <label class="lbl">📄 Subheading / Description</label>
              <input type="text" id="sl-sub-${i}" value="${(s.subheading||'').replace(/"/g,'&quot;')}" placeholder="Short line below the heading" />
            </div>
            <div class="field-row">
              <div class="field">
                <label class="lbl">🔘 Button Text</label>
                <input type="text" id="sl-cta-${i}" value="${(s.cta_text||'').replace(/"/g,'&quot;')}" placeholder="Register Now" oninput="slPreview(${i})" />
              </div>
              <div class="field">
                <label class="lbl">🔗 Button Link</label>
                <input type="text" id="sl-link-${i}" value="${(s.cta_link||'/courses').replace(/"/g,'&quot;')}" placeholder="/courses" />
              </div>
            </div>
            <div class="field" style="margin-bottom:10px">
              <label class="lbl">🖼️ Background Image URL (optional)</label>
              <input type="text" id="sl-img-${i}" value="${(s.image_url||'').replace(/"/g,'&quot;')}" placeholder="https://... direct image URL (.jpg .png .webp)" oninput="slPreview(${i})" />
              <span class="tip">Paste a direct https:// image URL. Leave blank to use solid background colour.</span>
            </div>
            <div class="field-row">
              <div class="field">
                <label class="lbl">🎨 Background Color</label>
                <div class="color-row">
                  <input type="color" id="sl-bg-${i}" value="${bg}" oninput="document.getElementById('sl-bg-hex-${i}').value=this.value;slPreview(${i})" />
                  <input type="text" id="sl-bg-hex-${i}" value="${bg}" maxlength="9" oninput="document.getElementById('sl-bg-${i}').value=this.value||'#000';slPreview(${i})" />
                </div>
              </div>
              <div class="field">
                <label class="lbl">🔤 Text Color</label>
                <div class="color-row">
                  <input type="color" id="sl-tc-${i}" value="${tc}" oninput="document.getElementById('sl-tc-hex-${i}').value=this.value;slPreview(${i})" />
                  <input type="text" id="sl-tc-hex-${i}" value="${tc}" maxlength="9" oninput="document.getElementById('sl-tc-${i}').value=this.value||'#fff';slPreview(${i})" />
                </div>
              </div>
            </div>
          </div>
          <!-- Live mini preview -->
          <div>
            <label class="lbl" style="display:block;margin-bottom:8px">Live Preview</label>
            <div class="preview-box" id="sl-prev-${i}" style="background:${bg}">
              ${s.image_url ? `<img src="${s.image_url}" onerror="this.style.display='none'" />` : ''}
              <div class="ov"></div>
              <div class="ct">
                <div class="pb" id="sl-pb-${i}">${s.badge||'Badge'}</div>
                <div class="ph" id="sl-ph-${i}" style="color:${tc}">${s.heading||'Heading'}</div>
                <span class="pc" id="sl-pc-${i}">${s.cta_text||'CTA'}</span>
              </div>
            </div>
            <span class="tip">Adjust fields on the left to see changes here.</span>
          </div>
        </div>
      </div>`
    list.appendChild(card)
  })
}

;(window as any).toggleSlide = (i: number) => {
  document.getElementById(`sl-body-${i}`)?.classList.toggle('open')
  document.getElementById(`sl-chev-${i}`)?.classList.toggle('open')
}
;(window as any).slDelete = (i: number) => { collectSlides(); slides.splice(i, 1); renderSlides() }
;(window as any).slMove = (i: number, d: number) => {
  collectSlides(); const j = i+d
  if (j >= 0 && j < slides.length) { [slides[i],slides[j]] = [slides[j],slides[i]]; renderSlides() }
}
;(window as any).slPreview = (i: number) => {
  const bg = v(`sl-bg-hex-${i}`) || '#0f2a5c'
  const tc = v(`sl-tc-hex-${i}`) || '#fff'
  const img = v(`sl-img-${i}`)
  const prevBox = document.getElementById(`sl-prev-${i}`)
  if (prevBox) prevBox.style.background = bg
  const htitleEl = document.getElementById(`sl-htitle-${i}`)
  if (htitleEl) htitleEl.textContent = v(`sl-heading-${i}`) || `Slide ${i+1}`
  const pbEl = document.getElementById(`sl-pb-${i}`)
  if (pbEl) pbEl.textContent = v(`sl-badge-${i}`) || 'Badge'
  const phEl = document.getElementById(`sl-ph-${i}`)
  if (phEl) { phEl.textContent = v(`sl-heading-${i}`) || 'Heading'; phEl.style.color = tc }
  const pcEl = document.getElementById(`sl-pc-${i}`)
  if (pcEl) pcEl.textContent = v(`sl-cta-${i}`) || 'CTA'
  const prevImg = prevBox?.querySelector('img') as HTMLImageElement | null
  if (img) {
    if (prevImg) { prevImg.src = img; prevImg.style.display = '' }
    else if (prevBox) {
      const im = document.createElement('img'); im.src = img
      im.onerror = () => { im.style.display='none' }
      prevBox.insertBefore(im, prevBox.firstChild)
    }
  } else if (prevImg) prevImg.style.display = 'none'
}

document.getElementById('slider-add-btn')?.addEventListener('click', () => {
  collectSlides()
  if (slides.length >= 6) { alert('Maximum 6 slides allowed.'); return }
  slides.push({ badge:'🎯 New Slide', heading:'Slide Heading', subheading:'Add your message here', cta_text:'Learn More', cta_link:'/courses', image_url:'', bg_color:'#0f2a5c', text_color:'#ffffff' })
  renderSlides()
  const ni = slides.length - 1
  document.getElementById(`sl-body-${ni}`)?.classList.add('open')
  document.getElementById(`sl-chev-${ni}`)?.classList.add('open')
})

document.getElementById('slider-save-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('slider-save-btn') as HTMLButtonElement
  btn.disabled = true; btn.textContent = '⏳ Saving…'
  collectSlides()
  try {
    await sbSet('hero_sliders', slides)
    showStatus('slider-status', true, '✅ Saved! Reload homepage to see changes.')
  } catch { showStatus('slider-status', false, '❌ Save failed. Check connection.') }
  btn.disabled = false; btn.textContent = '💾 Save Slides'
})

// ═══════════════════════════════════════════════════════════
// WHY ATEC CARDS
// ═══════════════════════════════════════════════════════════
const DEFAULT_WHY = [
  { icon:'🎓', title:'Expert Faculty',         desc:'Industry-certified trainers with 10+ years experience' },
  { icon:'🏆', title:'ISO 9001:2015 Certified', desc:'Certified institute since 2000 — quality guaranteed' },
  { icon:'💼', title:'100% Placement',          desc:'Dedicated placement cell with 500+ hiring partners' },
  { icon:'🌐', title:'Online + Hybrid',         desc:'Learn from anywhere or attend in-person' },
  { icon:'📜', title:'Govt. Recognised Certs',  desc:'Industry-recognised certifications on completion' },
]
let whyCards: any[] = [...DEFAULT_WHY]

function renderWhyCards() {
  const list = document.getElementById('why-cards-list')
  if (!list) return
  list.innerHTML = ''
  whyCards.forEach((c, i) => {
    const card = document.createElement('div')
    card.className = 'why-card'
    card.innerHTML = `
      <div class="why-card-num">${i+1}</div>
      <input type="text" id="wc-icon-${i}" value="${c.icon||''}" placeholder="🎓" style="font-size:20px;text-align:center;width:44px;padding:4px" />
      <input type="text" id="wc-title-${i}" value="${(c.title||'').replace(/"/g,'&quot;')}" placeholder="Expert Faculty" />
      <input type="text" id="wc-desc-${i}" value="${(c.desc||'').replace(/"/g,'&quot;')}" placeholder="Short description..." />
      <button class="btn-sm del" onclick="delWhyCard(${i})">✕</button>`
    list.appendChild(card)
  })
  const addBtn = document.getElementById('why-add-btn')
  if (addBtn) addBtn.style.display = whyCards.length >= 5 ? 'none' : 'flex'
}
;(window as any).delWhyCard = (i: number) => { whyCards.splice(i, 1); renderWhyCards() }

document.getElementById('why-add-btn')?.addEventListener('click', () => {
  if (whyCards.length >= 5) return
  whyCards.push({ icon:'⭐', title:'New Feature', desc:'Describe this benefit...' })
  renderWhyCards()
})
document.getElementById('why-save-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('why-save-btn') as HTMLButtonElement
  btn.disabled = true; btn.textContent = '⏳ Saving…'
  const saved = whyCards.map((_,i) => ({ icon: v(`wc-icon-${i}`), title: v(`wc-title-${i}`), desc: v(`wc-desc-${i}`) }))
  ;(saved as any).section_title = v('why-title')
  ;(saved as any).section_sub   = v('why-sub')
  try {
    await sbSet('why_features', saved)
    showStatus('why-status', true, '✅ Saved! Cards update live on homepage.')
  } catch { showStatus('why-status', false, '❌ Save failed.') }
  btn.disabled = false; btn.textContent = '💾 Save Why Cards'
})

// ═══════════════════════════════════════════════════════════
// POPUP
// ═══════════════════════════════════════════════════════════
document.getElementById('popup-save-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('popup-save-btn') as HTMLButtonElement
  btn.disabled = true; btn.textContent = '⏳ Saving…'
  const cfg = {
    enabled:               chk('popup-enabled'),
    delay_seconds:         parseInt(v('popup-delay')) || 15,
    show_once_per_session: chk('popup-once'),
    title:                 v('popup-title'),
    subtitle:              v('popup-subtitle'),
  }
  try {
    await sbSet('popup_settings', cfg)
    showStatus('popup-status', true, '✅ Saved!')
  } catch { showStatus('popup-status', false, '❌ Save failed.') }
  btn.disabled = false; btn.textContent = '💾 Save Popup Settings'
})

// ═══════════════════════════════════════════════════════════
// PRELOAD from DB
// ═══════════════════════════════════════════════════════════
async function preload() {
  try {
    const slData = await sbGet('hero_sliders')
    if (Array.isArray(slData) && slData.length) slides = slData
  } catch {}
  renderSlides()

  try {
    const wData = await sbGet('why_features')
    if (Array.isArray(wData) && wData.length) {
      whyCards = wData.slice(0, 5)
      if ((wData as any).section_title) sv('why-title', (wData as any).section_title)
      if ((wData as any).section_sub)   sv('why-sub',   (wData as any).section_sub)
    }
  } catch {}
  renderWhyCards()

  try {
    const popCfg = await sbGet('popup_settings')
    if (popCfg) {
      schk('popup-enabled', popCfg.enabled !== false)
      if (typeof popCfg.delay_seconds === 'number') sv('popup-delay', String(popCfg.delay_seconds))
      schk('popup-once', popCfg.show_once_per_session !== false)
      if (popCfg.title)    sv('popup-title', popCfg.title)
      if (popCfg.subtitle) sv('popup-subtitle', popCfg.subtitle)
    }
  } catch {}
}

// Render defaults immediately then load from DB
renderSlides()
renderWhyCards()
preload()
</script>

</AdminLayout>
