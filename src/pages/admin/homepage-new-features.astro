              <input class="course-inp" id="cc-weeks-${ci}-${ri}" type="number" value="${c.duration_weeks||''}" placeholder="8" style="width:100%" />
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">
            <div>
              <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;margin-bottom:3px">Mode</div>
              <select class="course-inp" id="cc-mode-${ci}-${ri}" style="width:100%">
                <option value="online"${c.mode==='online'?' selected':''}>Online</option>
