          <div style="display:flex;gap:12px;align-items:flex-start;margin-bottom:10px;padding:10px;background:#f8fafc;border-radius:8px;border:1px solid #e2e8f0">
            <div id="cc-thumb-preview-${ci}-${ri}" style="width:80px;height:56px;border-radius:6px;background:#0b1525;flex-shrink:0;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:10px;color:rgba(255,255,255,0.4);border:1px solid #e2e8f0">
              ${c.thumbnail_url ? '<img src="' + (c.thumbnail_url||'').replace(/"/g,'&quot;') + '" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display=\'none\'" />' : '🖼️'}
