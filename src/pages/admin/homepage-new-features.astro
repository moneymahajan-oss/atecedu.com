            </div>

            <div class="sc-field">
              <label class="sc-lbl">📄 Subheading</label>
              <input class="sc-inp" id="sc-sub-${i}" value="${(s.subheading||'').replace(/"/g,'&quot;')}"
                placeholder="GEN AI | Python | React | Batch starts Monday" />
            </div>

            <div class="sc-field-row">
              <div class="sc-field">
                <label class="sc-lbl">🔘 Button Text</label>
