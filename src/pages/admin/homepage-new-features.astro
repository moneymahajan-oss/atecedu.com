<script>
const SB_URL = (window as any).__SB_URL as string
const SB_KEY = (window as any).__SB_KEY as string

// ── Helpers ────────────────────────────────────────────────────────────
function v(id: string): string { return ((document.getElementById(id) as HTMLInputElement)?.value || '').trim() }
function sv(id: string, val: string) { const el = document.getElementById(id) as HTMLInputElement; if (el) el.value = val }
function chk(id: string): boolean { return !!(document.getElementById(id) as HTMLInputElement)?.checked }
function schk(id: string, val: boolean) { const el = document.getElementById(id) as HTMLInputElement; if (el) el.checked = val }

async function sbGet(key: string): Promise<any> {
  if (!SB_URL || !SB_KEY) return null
  const r = await fetch(`${SB_URL}/rest/v1/site_settings?key=eq.${key}&select=value`,
    { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } })
  const d = await r.json()
  return d?.[0]?.value ?? null
}
async function sbSet(key: string, value: any) {
  if (!SB_URL || !SB_KEY) throw new Error('No Supabase connection')
  await fetch(`${SB_URL}/rest/v1/site_settings`, {
    method: 'POST',
    headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}`, 'Content-Type': 'application/json', Prefer: 'resolution=merge-duplicates,return=minimal' },
    body: JSON.stringify({ key, value })
  })
}
function showStatus(id: string, ok: boolean, msg: string) {
  const el = document.getElementById(id)
  if (!el) return
  el.textContent = msg
  el.className = 'status ' + (ok ? 'ok' : 'err')
  el.style.display = 'block'
  setTimeout(() => { el.style.display = 'none' }, 3500)
}

// ── Tab switching ──────────────────────────────────────────────────────
;(window as any).switchTab = function(tab: string) {
  document.querySelectorAll('[data-tab]').forEach(btn => btn.classList.toggle('active', (btn as HTMLElement).dataset.tab === tab))
  ;['slider','why','categories','popup'].forEach(t => {
    const el = document.getElementById(`tab-${t}`)
    if (el) el.style.display = t === tab ? '' : 'none'
  })
}

// ═══════════════════════════════════════════════════════════
// HERO SLIDER
// ═══════════════════════════════════════════════════════════
const DEFAULT_SLIDES: any[] = [
  { badge:'🔥 New Batch June 2026', heading:'Industrial Training for Real World Jobs', subheading:'GEN AI | MERN Stack | Machine Learning | Python | Ethical Hacking', cta_text:'Register Now', cta_link:'/courses', image_url:'', bg_color:'#0f2a5c', text_color:'#ffffff' },
  { badge:'🌐 Online & Hybrid', heading:'Learn From Anywhere in India', subheading:'Live classes, recorded sessions, doubt clearing — all from home', cta_text:'Explore Courses', cta_link:'/courses', image_url:'', bg_color:'#1a1a2e', text_color:'#ffffff' },
]
let slides: any[] = [...DEFAULT_SLIDES]

function collectSlides() {
  slides = slides.map((_: any, i: number) => ({
    badge:      v(`sl-badge-${i}`),
    heading:    v(`sl-heading-${i}`),
    subheading: v(`sl-sub-${i}`),
    cta_text:   v(`sl-cta-${i}`),
    cta_link:   v(`sl-link-${i}`) || '/courses',
    image_url:  v(`sl-img-${i}`),
    bg_color:   v(`sl-bg-hex-${i}`) || '#0f2a5c',
    text_color: v(`sl-tc-hex-${i}`) || '#ffffff',
  }))
}

function renderSlides() {
  const list = document.getElementById('slider-list')
  if (!list) return
  list.innerHTML = ''
  slides.forEach((s: any, i: number) => {
    const card = document.createElement('div')
    card.className = 'slide-card'
    const bg = s.bg_color || '#0f2a5c'
    const tc = s.text_color || '#fff'
    card.innerHTML = `
      <div class="slide-header" onclick="toggleSlide(${i})">
        <div class="slide-num">${i+1}</div>
        <span class="slide-header-title" id="sl-htitle-${i}">${s.heading || 'New Slide'}</span>
        <div class="slide-actions">
          <button class="btn-sm" onclick="event.stopPropagation();slMove(${i},-1)">↑</button>
          <button class="btn-sm" onclick="event.stopPropagation();slMove(${i},1)">↓</button>
          <button class="btn-sm del" onclick="event.stopPropagation();slDelete(${i})">✕ Remove</button>
        </div>
        <span class="slide-chevron ${i < 2 ? 'open' : ''}" id="sl-chev-${i}">▼</span>
      </div>
      <div class="slide-body ${i < 2 ? 'open' : ''}" id="sl-body-${i}">
        <div style="display:grid;grid-template-columns:1fr 260px;gap:20px">
          <div>
            <!-- Badge + heading -->
            <div class="field-row">
              <div class="field">
                <label class="lbl">🏷️ Badge Text</label>
                <input type="text" id="sl-badge-${i}" value="${(s.badge||'').replace(/"/g,'&quot;')}" placeholder="🔥 New Batch June 2026" oninput="slPreview(${i})" />
              </div>
              <div class="field">
                <label class="lbl">💡 Hint</label>
                <span class="tip" style="padding-top:8px">Badge shows as a small pill above the heading. Use emoji for visual interest.</span>
              </div>
            </div>
            <div class="field">
              <label class="lbl">📝 Heading</label>
              <input type="text" id="sl-heading-${i}" value="${(s.heading||'').replace(/"/g,'&quot;')}" placeholder="Industrial Training for Real World Jobs" oninput="slPreview(${i})" />
            </div>
            <div class="field">
              <label class="lbl">📄 Subheading / Description</label>
              <input type="text" id="sl-sub-${i}" value="${(s.subheading||'').replace(/"/g,'&quot;')}" placeholder="Short line below the heading" />
            </div>
            <!-- CTA -->
            <div class="field-row">
              <div class="field">
                <label class="lbl">🔘 Button Text</label>
                <input type="text" id="sl-cta-${i}" value="${(s.cta_text||'').replace(/"/g,'&quot;')}" placeholder="Register Now" oninput="slPreview(${i})" />
              </div>
              <div class="field">
                <label class="lbl">🔗 Button Link</label>
                <input type="text" id="sl-link-${i}" value="${(s.cta_link||'/courses').replace(/"/g,'&quot;')}" placeholder="/courses" />
              </div>
            </div>
            <!-- Background image -->
            <div class="field">
              <label class="lbl">🖼️ Background Image URL (optional)</label>
              <input type="text" id="sl-img-${i}" value="${(s.image_url||'').replace(/"/g,'&quot;')}" placeholder="https://... direct image URL (.jpg .png .webp)" oninput="slPreview(${i})" />
              <span class="tip">Paste a direct https:// image URL. Leave blank to use solid background colour.</span>
            </div>
            <!-- Colors -->
            <div class="field-row">
              <div class="field">
                <label class="lbl">🎨 Background Color</label>
                <div class="color-row">
                  <input type="color" id="sl-bg-${i}" value="${bg}" oninput="document.getElementById('sl-bg-hex-${i}').value=this.value;slPreview(${i})" />
                  <input type="text" id="sl-bg-hex-${i}" value="${bg}" maxlength="9" oninput="document.getElementById('sl-bg-${i}').value=this.value||'#000';slPreview(${i})" />
                </div>
              </div>
              <div class="field">
                <label class="lbl">🔤 Text Color</label>
                <div class="color-row">
                  <input type="color" id="sl-tc-${i}" value="${tc}" oninput="document.getElementById('sl-tc-hex-${i}').value=this.value;slPreview(${i})" />
                  <input type="text" id="sl-tc-hex-${i}" value="${tc}" maxlength="9" oninput="document.getElementById('sl-tc-${i}').value=this.value||'#fff';slPreview(${i})" />
                </div>
              </div>
            </div>
          </div>

          <!-- Live mini preview -->
          <div>
            <label class="lbl" style="display:block;margin-bottom:8px">Live Preview</label>
            <div class="preview-box" id="sl-prev-${i}" style="background:${bg}">
              ${s.image_url ? `<img src="${s.image_url}" onerror="this.style.display='none'" />` : ''}
              <div class="ov"></div>
              <div class="ct">
                <div class="pb" id="sl-pb-${i}">${s.badge||'Badge'}</div>
                <div class="ph" id="sl-ph-${i}" style="color:${tc}">${s.heading||'Heading'}</div>
                <span class="pc" id="sl-pc-${i}">${s.cta_text||'CTA'}</span>
              </div>
            </div>
            <span class="tip">Adjust fields on the left to see changes here.</span>
          </div>
        </div>
      </div>`
    list.appendChild(card)
  })
}

;(window as any).toggleSlide = (i: number) => {
  document.getElementById(`sl-body-${i}`)?.classList.toggle('open')
  document.getElementById(`sl-chev-${i}`)?.classList.toggle('open')
}
;(window as any).slDelete = (i: number) => { collectSlides(); slides.splice(i, 1); renderSlides() }
;(window as any).slMove = (i: number, d: number) => {
  collectSlides(); const j = i+d
  if (j >= 0 && j < slides.length) { [slides[i],slides[j]] = [slides[j],slides[i]]; renderSlides() }
}
;(window as any).slPreview = (i: number) => {
  const bg = v(`sl-bg-hex-${i}`) || '#0f2a5c'
  const tc = v(`sl-tc-hex-${i}`) || '#fff'
  const img = v(`sl-img-${i}`)
  const prevBox = document.getElementById(`sl-prev-${i}`)
  if (prevBox) prevBox.style.background = bg
  const htitleEl = document.getElementById(`sl-htitle-${i}`)
  if (htitleEl) htitleEl.textContent = v(`sl-heading-${i}`) || `Slide ${i+1}`
  const pbEl = document.getElementById(`sl-pb-${i}`)
  if (pbEl) pbEl.textContent = v(`sl-badge-${i}`) || 'Badge'
  const phEl = document.getElementById(`sl-ph-${i}`)
  if (phEl) { phEl.textContent = v(`sl-heading-${i}`) || 'Heading'; phEl.style.color = tc }
  const pcEl = document.getElementById(`sl-pc-${i}`)
  if (pcEl) pcEl.textContent = v(`sl-cta-${i}`) || 'CTA'
  // Update image
  const prevImg = prevBox?.querySelector('img') as HTMLImageElement | null
  if (img) {
    if (prevImg) { prevImg.src = img; prevImg.style.display = '' }
    else if (prevBox) {
      const im = document.createElement('img'); im.src = img
      im.onerror = () => { im.style.display='none' }
      prevBox.insertBefore(im, prevBox.firstChild)
    }
  } else if (prevImg) prevImg.style.display = 'none'
}

document.getElementById('slider-add-btn')?.addEventListener('click', () => {
  collectSlides()
  if (slides.length >= 6) { alert('Maximum 6 slides allowed.'); return }
  slides.push({ badge:'🎯 New Slide', heading:'Slide Heading', subheading:'Add your message here', cta_text:'Learn More', cta_link:'/courses', image_url:'', bg_color:'#0f2a5c', text_color:'#ffffff' })
  renderSlides()
  const ni = slides.length - 1
  document.getElementById(`sl-body-${ni}`)?.classList.add('open')
  document.getElementById(`sl-chev-${ni}`)?.classList.add('open')
})

document.getElementById('slider-save-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('slider-save-btn') as HTMLButtonElement
  btn.disabled = true; btn.textContent = '⏳ Saving…'
  collectSlides()
  try {
    await sbSet('hero_sliders', slides)
    showStatus('slider-status', true, '✅ Saved! Reload homepage to see changes.')
  } catch { showStatus('slider-status', false, '❌ Save failed. Check connection.') }
  btn.disabled = false; btn.textContent = '💾 Save Slides'
})

