---
// src/pages/admin/youtube.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="YouTube Manager" activeSection="youtube">
  <div id="yt-root"></div>
</AdminLayout>

<script>
import { createClient } from '@supabase/supabase-js'
import { createElement as h, useState, useEffect } from 'react'
import { createRoot } from 'react-dom/client'

const supabase = createClient(window.__SB_URL, window.__SB_KEY)

interface Video {
  id: string; youtube_id: string; title: string; description: string | null
  category: string; is_active: boolean; is_featured: boolean
  duration: string | null; view_count: string | null; sort_order: number
  thumbnail_url: string | null
}

const EMPTY = { youtube_id: '', title: '', description: '', category: 'general', duration: '', view_count: '', is_active: true, is_featured: false, sort_order: 0, thumbnail_url: '' }

// Extracts the 11-char video ID from any YouTube URL format, or returns the raw value if already an ID
function extractId(input: string): string {
  const trimmed = input.trim()
  const m = trimmed.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|shorts\/|embed\/|v\/))([A-Za-z0-9_-]{11})/)
  if (m) return m[1]
  // If it looks like a bare 11-char ID already, return it
  if (/^[A-Za-z0-9_-]{11}$/.test(trimmed)) return trimmed
  return trimmed // return as-is, validation will catch it
}

function isValidId(id: string): boolean {
  return /^[A-Za-z0-9_-]{11}$/.test(id.trim())
}

function YTManager() {
  const [videos, setVideos]   = useState<Video[]>([])
  const [loading, setLoading] = useState(true)
  const [showForm, setShowForm] = useState(false)
  const [editId, setEditId]   = useState<string | null>(null)
  const [form, setForm]       = useState<typeof EMPTY>({ ...EMPTY })
  const [saving, setSaving]   = useState(false)
  const [msg, setMsg]         = useState('')
  const [urlInput, setUrlInput] = useState('') // raw input field — auto-extracts on blur

  useEffect(() => { load() }, [])

  async function load() {
    const { data, error } = await supabase.from('youtube_videos').select('*').order('sort_order').order('created_at', { ascending: false })
    if (error) setMsg('❌ Load error: ' + error.message)
    setVideos(data ?? [])
    setLoading(false)
  }

  function openAdd() {
    setForm({ ...EMPTY }); setEditId(null); setUrlInput(''); setShowForm(true); setMsg('')
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }
  function openEdit(v: Video) {
    setForm({ ...EMPTY, ...v }); setEditId(v.id); setUrlInput(v.youtube_id); setShowForm(true); setMsg('')
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }

  // When user types/pastes in the URL field, auto-extract the ID immediately
  function handleUrlChange(raw: string) {
    setUrlInput(raw)
    const extracted = extractId(raw)
    setForm((p: typeof EMPTY) => ({ ...p, youtube_id: extracted }))
  }

  const upd = (f: string, v: unknown) => setForm((p: typeof EMPTY) => ({ ...p, [f]: v }))

  async function save() {
    setMsg('')
    if (!form.title.trim()) { setMsg('❌ Title is required'); return }
    if (!isValidId(form.youtube_id)) { setMsg('❌ Invalid YouTube ID — paste the full video URL or the 11-character ID (e.g. dQw4w9WgXcQ)'); return }
    setSaving(true)
    try {
      const payload = {
        ...form,
        youtube_id: form.youtube_id.trim(),
        sort_order: parseInt(String(form.sort_order)) || 0,
        thumbnail_url: form.thumbnail_url || `https://img.youtube.com/vi/${form.youtube_id.trim()}/hqdefault.jpg`
      }
      if (editId) {
        const { error } = await supabase.from('youtube_videos').update(payload).eq('id', editId)
        if (error) throw error
      } else {
        const { error } = await supabase.from('youtube_videos').insert(payload)
        if (error) throw error
      }
      setMsg('✅ Saved!')
      setShowForm(false)
      load()
    } catch(e: any) {
      setMsg('❌ ' + e.message)
    } finally {
      setSaving(false)
    }
  }

  async function remove(id: string) {
    if (!confirm('Delete this video?')) return
    await supabase.from('youtube_videos').delete().eq('id', id)
    setVideos((p: Video[]) => p.filter(x => x.id !== id))
  }

  async function toggle(id: string, field: string, current: boolean) {
    await supabase.from('youtube_videos').update({ [field]: !current }).eq('id', id)
    setVideos((p: Video[]) => p.map((x: Video) => x.id === id ? { ...x, [field]: !current } : x))
  }

  const s = { width: '100%', padding: '9px 12px', border: '1px solid #e2e8f0', borderRadius: '8px', fontSize: '13px', outline: 'none', boxSizing: 'border-box' as const }
  const lbl = (text: string) => h('label', { style: { fontSize: '12px', fontWeight: '600', color: '#475569', display: 'block', marginBottom: '5px' } }, text)

  const extractedId = form.youtube_id.trim()
  const idValid = isValidId(extractedId)

  return h('div', { style: { display: 'flex', flexDirection: 'column', gap: '20px' } },

    // Header
    h('div', { style: { display: 'flex', justifyContent: 'space-between', alignItems: 'center', flexWrap: 'wrap', gap: '12px' } },
      h('div', {},
        h('h1', { style: { fontFamily: 'Sora, sans-serif', fontSize: '1.5rem', fontWeight: '800' } }, '📺 YouTube Videos'),
        h('p', { style: { fontSize: '13px', color: '#64748b', marginTop: '4px' } }, 'Paste any YouTube URL — ID is extracted automatically')
      ),
      h('button', { onClick: openAdd, style: { padding: '10px 22px', background: '#ff0000', color: '#fff', border: 'none', borderRadius: '10px', fontWeight: '700', fontSize: '14px', cursor: 'pointer' } }, '+ Add Video')
    ),

    // Global msg (outside form)
    !showForm && msg ? h('div', { style: { padding: '10px 14px', borderRadius: '8px', fontSize: '14px', fontWeight: 500, background: msg.startsWith('✅') ? '#f0fdf4' : '#fef2f2', color: msg.startsWith('✅') ? '#15803d' : '#dc2626', border: `1px solid ${msg.startsWith('✅') ? '#bbf7d0' : '#fca5a5'}` } }, msg) : null,

    // Form
    showForm && h('div', { style: { background: '#fff', borderRadius: '16px', border: '2px solid #ff0000', padding: '28px' } },
      h('div', { style: { display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '20px' } },
        h('h2', { style: { fontFamily: 'Sora, sans-serif', fontWeight: '700', fontSize: '16px' } }, editId ? '✏️ Edit Video' : '➕ Add Video'),
        h('button', { onClick: () => setShowForm(false), style: { background: 'none', border: 'none', fontSize: '20px', cursor: 'pointer', color: '#94a3b8' } }, '✕')
      ),

      // Form msg
      msg ? h('div', { style: { marginBottom: '16px', padding: '10px 14px', borderRadius: '8px', fontSize: '14px', fontWeight: 500, background: msg.startsWith('✅') ? '#f0fdf4' : '#fef2f2', color: msg.startsWith('✅') ? '#15803d' : '#dc2626', border: `1px solid ${msg.startsWith('✅') ? '#bbf7d0' : '#fca5a5'}` } }, msg) : null,

      h('div', { style: { display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '14px' } },

        // YouTube URL input (full row) — auto-extracts ID
        h('div', { style: { gridColumn: '1 / -1' } },
          lbl('YouTube URL or Video ID *'),
          h('input', {
            type: 'text',
            value: urlInput,
            onChange: (e: Event) => handleUrlChange((e.target as HTMLInputElement).value),
            placeholder: 'Paste full URL: https://www.youtube.com/watch?v=dQw4w9WgXcQ',
            style: { ...s, border: urlInput && !idValid ? '1px solid #f87171' : '1px solid #e2e8f0' }
          }),
          urlInput ? h('p', { style: { fontSize: '11px', marginTop: '4px', color: idValid ? '#16a34a' : '#dc2626' } },
            idValid ? `✓ Video ID: ${extractedId}` : '✗ Could not extract a valid YouTube ID from this input'
          ) : null
        ),

        // Title
        h('div', { style: { gridColumn: '1 / -1' } },
          lbl('Title *'),
          h('input', { type: 'text', value: form.title, onChange: (e: Event) => upd('title', (e.target as HTMLInputElement).value), placeholder: 'Hardware & Networking Demo Class', style: s })
        ),

        // Description
        h('div', { style: { gridColumn: '1 / -1' } },
          lbl('Description (optional)'),
          h('input', { type: 'text', value: form.description ?? '', onChange: (e: Event) => upd('description', (e.target as HTMLInputElement).value), placeholder: 'Short description', style: s })
        ),

        // Category + Sort Order
        h('div', {},
          lbl('Category'),
          h('input', { type: 'text', value: form.category, onChange: (e: Event) => upd('category', (e.target as HTMLInputElement).value), placeholder: 'hardware, web, general…', style: s })
        ),
        h('div', {},
          lbl('Sort Order'),
          h('input', { type: 'number', value: form.sort_order, onChange: (e: Event) => upd('sort_order', (e.target as HTMLInputElement).value), style: s })
        ),

        // Duration + View Count
        h('div', {},
          lbl('Duration (e.g. 12:45)'),
          h('input', { type: 'text', value: form.duration ?? '', onChange: (e: Event) => upd('duration', (e.target as HTMLInputElement).value), placeholder: '12:45', style: s })
        ),
        h('div', {},
          lbl('View Count (e.g. 1.2K)'),
          h('input', { type: 'text', value: form.view_count ?? '', onChange: (e: Event) => upd('view_count', (e.target as HTMLInputElement).value), placeholder: '1.2K', style: s })
        ),

        // Checkboxes
        h('div', { style: { display: 'flex', alignItems: 'center', gap: '10px' } },
          h('input', { type: 'checkbox', checked: form.is_active, onChange: (e: Event) => upd('is_active', (e.target as HTMLInputElement).checked), style: { width: '16px', height: '16px', accentColor: '#1c3d7a' } }),
          lbl('Active (show on website)')
        ),
        h('div', { style: { display: 'flex', alignItems: 'center', gap: '10px' } },
          h('input', { type: 'checkbox', checked: form.is_featured, onChange: (e: Event) => upd('is_featured', (e.target as HTMLInputElement).checked), style: { width: '16px', height: '16px', accentColor: '#1c3d7a' } }),
          lbl('Featured')
        ),

        // Live thumbnail preview
        idValid && h('div', { style: { gridColumn: '1 / -1' } },
          lbl('Thumbnail Preview'),
          h('img', {
            src: `https://img.youtube.com/vi/${extractedId}/hqdefault.jpg`,
            alt: 'Thumbnail preview',
            style: { width: '240px', borderRadius: '8px', border: '1px solid #e2e8f0', display: 'block' }
          })
        )
      ),

      // Save / Cancel
      h('div', { style: { display: 'flex', gap: '10px', marginTop: '20px' } },
        h('button', { onClick: save, disabled: saving, style: { flex: 1, padding: '12px', background: saving ? '#94a3b8' : '#ff0000', color: '#fff', border: 'none', borderRadius: '10px', fontWeight: '700', fontSize: '14px', cursor: saving ? 'not-allowed' : 'pointer' } },
          saving ? 'Saving...' : '✅ Save Video'
        ),
        h('button', { onClick: () => { setShowForm(false); setMsg('') }, style: { padding: '12px 20px', border: '1px solid #e2e8f0', borderRadius: '10px', background: '#fff', fontWeight: '600', fontSize: '14px', cursor: 'pointer' } }, 'Cancel')
      )
    ),

    // Video grid
    h('div', { style: { display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(280px,1fr))', gap: '16px' } },
      loading
        ? h('div', { style: { gridColumn: '1 / -1', padding: '40px', textAlign: 'center', color: '#94a3b8' } }, 'Loading...')
        : videos.length === 0
          ? h('div', { style: { gridColumn: '1 / -1', padding: '40px', textAlign: 'center', color: '#94a3b8' } }, 'No videos yet. Click + Add Video to get started.')
          : videos.map((v: Video) => {
              const thumb = v.thumbnail_url || (isValidId(v.youtube_id) ? `https://img.youtube.com/vi/${v.youtube_id}/hqdefault.jpg` : '')
              const badId = !isValidId(v.youtube_id)
              return h('div', { key: v.id, style: { background: '#fff', borderRadius: '12px', border: badId ? '2px solid #f87171' : '1px solid #e2e8f0', overflow: 'hidden', opacity: v.is_active ? 1 : 0.6 } },
                h('div', { style: { position: 'relative' } },
                  thumb
                    ? h('img', { src: thumb, alt: v.title, style: { width: '100%', height: '160px', objectFit: 'cover', display: 'block' } })
                    : h('div', { style: { width: '100%', height: '160px', background: '#1c1c1c', display: 'flex', alignItems: 'center', justifyContent: 'center' } },
                        h('span', { style: { color: '#94a3b8', fontSize: '12px' } }, 'No thumbnail')
                      ),
                  h('div', { style: { position: 'absolute', top: '8px', right: '8px', display: 'flex', gap: '4px', flexWrap: 'wrap' } },
                    badId && h('span', { style: { background: '#f87171', color: '#fff', fontSize: '10px', fontWeight: '700', padding: '2px 7px', borderRadius: '4px' } }, '⚠ Bad ID'),
                    v.is_featured && h('span', { style: { background: '#d4f01a', color: '#0f2347', fontSize: '10px', fontWeight: '700', padding: '2px 7px', borderRadius: '4px' } }, '⭐ Featured'),
                    h('span', { style: { background: v.is_active ? '#dcfce7' : '#fee2e2', color: v.is_active ? '#166534' : '#991b1b', fontSize: '10px', fontWeight: '700', padding: '2px 7px', borderRadius: '4px' } }, v.is_active ? 'Active' : 'Hidden')
                  )
                ),
                h('div', { style: { padding: '14px' } },
                  h('p', { style: { fontWeight: '700', fontSize: '13px', marginBottom: '4px', lineHeight: '1.3' } }, v.title),
                  h('p', { style: { fontSize: '11px', color: badId ? '#dc2626' : '#94a3b8', marginBottom: '10px' } }, `ID: ${v.youtube_id}`),
                  h('div', { style: { display: 'flex', gap: '6px', flexWrap: 'wrap' } },
                    h('button', { onClick: () => openEdit(v), style: { padding: '5px 10px', background: '#eff6ff', color: '#1c3d7a', border: 'none', borderRadius: '6px', fontSize: '11px', fontWeight: '600', cursor: 'pointer' } }, '✏️ Edit'),
                    h('button', { onClick: () => toggle(v.id, 'is_active', v.is_active), style: { padding: '5px 10px', background: v.is_active ? '#fee2e2' : '#dcfce7', color: v.is_active ? '#991b1b' : '#166534', border: 'none', borderRadius: '6px', fontSize: '11px', fontWeight: '600', cursor: 'pointer' } }, v.is_active ? 'Hide' : 'Show'),
                    h('button', { onClick: () => toggle(v.id, 'is_featured', v.is_featured), style: { padding: '5px 10px', background: v.is_featured ? '#fef9c3' : '#f8fafc', border: '1px solid #e2e8f0', borderRadius: '6px', fontSize: '11px', cursor: 'pointer' } }, v.is_featured ? '★ Unfeature' : '☆ Feature'),
                    isValidId(v.youtube_id) && h('a', { href: `https://youtube.com/watch?v=${v.youtube_id}`, target: '_blank', rel: 'noopener', style: { padding: '5px 10px', background: '#f8fafc', color: '#64748b', border: '1px solid #e2e8f0', borderRadius: '6px', fontSize: '11px', fontWeight: '600', textDecoration: 'none', display: 'inline-block' } }, '▶ Watch'),
                    h('button', { onClick: () => remove(v.id), style: { padding: '5px 10px', background: '#fee2e2', color: '#991b1b', border: 'none', borderRadius: '6px', fontSize: '11px', fontWeight: '600', cursor: 'pointer' } }, '🗑 Delete')
                  )
                )
              )
            })
    )
  )
}

const root = createRoot(document.getElementById('yt-root')!)
root.render(h(YTManager, null))
</script>
