---
// src/pages/cart.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import CartView from '../components/cart/CartView'
---

<BaseLayout
  title="My Cart — ATEC Educational Society"
  description="Review your selected courses and proceed to checkout."
  noIndex={true}
>
  <div class="cart-page">
    <div class="container">
      <div class="page-header-inner">
        <nav class="breadcrumb">
          <a href="/">Home</a>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          <span>My Cart</span>
        </nav>
        <h1>My Cart</h1>
      </div>
      <CartView client:load />
    </div>
  </div>
</BaseLayout>

<style>
.cart-page { padding: 48px 0 80px; background: var(--gray-50); min-height: 70vh; }
.page-header-inner { margin-bottom: 32px; }
.page-header-inner h1 { font-family: var(--font-display); font-size: 2rem; font-weight: 800; margin-top: 8px; }
</style>
