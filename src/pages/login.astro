---
// src/pages/login.astro
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL || ''
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || ''
---

<!DOCTYPE html>
<html lang="en-IN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Login — ATEC Educational Society</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@700;800&family=Inter:wght@400;500;600&display=swap" />
  <link rel="icon" type="image/png" href="/favicon.png" />

  <script define:vars={{ SUPABASE_URL, SUPABASE_KEY }}>
    window.__SB_URL = SUPABASE_URL
    window.__SB_KEY = SUPABASE_KEY
  </script>

  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;background:linear-gradient(135deg,#0b1f3f 0%,#1c3d7a 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px 16px}
    .wrap{width:100%;max-width:440px;display:flex;flex-direction:column;align-items:center;gap:24px}
    .logo{display:inline-flex;align-items:center;gap:10px;text-decoration:none}
    .logo-mark{width:44px;height:44px;border-radius:12px;background:#d4f01a;display:flex;align-items:center;justify-content:center;font-family:'Sora',sans-serif;font-weight:800;font-size:20px;color:#0f2347}
    .logo-name{font-family:'Sora',sans-serif;font-weight:800;font-size:18px;color:#fff;line-height:1.1}
    .logo-sub{font-size:11px;color:rgba(255,255,255,0.5)}
    .card{width:100%;background:#fff;border-radius:20px;padding:36px 32px;box-shadow:0 24px 60px rgba(0,0,0,0.3)}
    h1{font-family:'Sora',sans-serif;font-size:1.5rem;font-weight:800;color:#0f1724;margin-bottom:4px}
    .sub{font-size:14px;color:#6b7280;margin-bottom:28px}
    .google-btn{width:100%;display:flex;align-items:center;justify-content:center;gap:10px;padding:12px;border:1.5px solid #e5e7eb;border-radius:10px;background:#fff;cursor:pointer;font-size:14px;font-weight:600;color:#374151;font-family:'Inter',sans-serif;margin-bottom:18px}
    .google-btn:hover{border-color:#1c3d7a}
    .divider{display:flex;align-items:center;gap:12px;margin-bottom:18px}
    .div-line{flex:1;height:1px;background:#e5e7eb}
    .div-txt{font-size:12px;color:#9ca3af}
    .field{margin-bottom:14px}
    label{display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:5px}
    .row{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px}
    .row a{font-size:13px;color:#1c3d7a;font-weight:600;text-decoration:none}
    .pw{position:relative}
    .eye{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:16px;color:#9ca3af;padding:4px;line-height:1}
    input[type=email],input[type=password]{width:100%;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:15px;font-family:'Inter',sans-serif;outline:none;transition:border-color 0.2s}
    input:focus{border-color:#1c3d7a}
    .err{background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:10px 14px;font-size:13px;color:#991b1b;margin-bottom:14px;display:none}
    .err.show{display:block}
    #login-btn{width:100%;padding:14px;background:#1c3d7a;color:#fff;border:none;border-radius:10px;font-family:'Sora',sans-serif;font-weight:800;font-size:15px;cursor:pointer;margin-top:4px}
    #login-btn:hover{background:#0f2347}
    #login-btn:disabled{background:#9ca3af;cursor:not-allowed}
    .switch{text-align:center;font-size:14px;color:#6b7280;margin-top:20px}
    .switch a{color:#1c3d7a;font-weight:600;text-decoration:none}
    .foot{font-size:13px;color:rgba(255,255,255,0.4);text-align:center}
    .foot a{color:rgba(255,255,255,0.55);text-decoration:none}
  </style>
</head>
<body>
  <div class="wrap">
    <a href="/" class="logo">
      <div class="logo-mark">A</div>
      <div><div class="logo-name">ATEC</div><div class="logo-sub">Educational Society</div></div>
    </a>

    <div class="card">
      <h1>Welcome Back</h1>
      <p class="sub">Login to access your courses and dashboard</p>

      <button type="button" class="google-btn" id="google-btn">
        <svg width="18" height="18" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Continue with Google
      </button>

      <div class="divider">
        <div class="div-line"></div>
        <span class="div-txt">or login with email</span>
        <div class="div-line"></div>
      </div>

      <div id="err" class="err"></div>

      <div class="field">
        <label for="em">Email Address</label>
        <input type="email" id="em" placeholder="you@example.com" autocomplete="username" />
      </div>

      <div class="field">
        <div class="row">
          <label for="pw" style="margin:0">Password</label>
          <a href="/forgot-password">Forgot password?</a>
        </div>
        <div class="pw">
          <input type="password" id="pw" placeholder="Enter your password" autocomplete="current-password" />
          <button type="button" class="eye" id="eye-btn">👁️</button>
        </div>
      </div>

      <button type="button" id="login-btn">Login to My Account</button>
      <p class="switch">Don't have an account? <a href="/signup">Create one free</a></p>
    </div>

    <p class="foot">
      <a href="/verification">Verify certificate</a> ·
      <a href="/courses">Browse courses</a> ·
      <a href="/admin/login">Admin login</a>
    </p>
  </div>

  <!-- Uses Vite-bundled npm package — NOT CDN -->
  <script>
    import { createClient } from '@supabase/supabase-js'

    const supabase = createClient(window.__SB_URL, window.__SB_KEY)

    // Check session
    supabase.auth.getSession().then(({ data: { session } }) => {
      if (session) window.location.href = '/dashboard'
    })

    // Eye toggle
    document.getElementById('eye-btn').addEventListener('click', function () {
      var pw = document.getElementById('pw')
      pw.type = pw.type === 'password' ? 'text' : 'password'
    })

    // Enter key
    document.getElementById('em').addEventListener('keydown', function (e) { if (e.key === 'Enter') doLogin() })
    document.getElementById('pw').addEventListener('keydown', function (e) { if (e.key === 'Enter') doLogin() })

    // Google
    document.getElementById('google-btn').addEventListener('click', function () {
      supabase.auth.signInWithOAuth({
        provider: 'google',
        options: { redirectTo: window.location.origin + '/dashboard' }
      })
    })

    document.getElementById('login-btn').addEventListener('click', doLogin)

    async function doLogin() {
      var errEl = document.getElementById('err')
      var btn   = document.getElementById('login-btn')
      errEl.classList.remove('show')

      var email    = document.getElementById('em').value.trim()
      var password = document.getElementById('pw').value

      if (!email || !password) {
        errEl.textContent = '⚠️ Please enter your email and password'
        errEl.classList.add('show')
        return
      }

      btn.disabled    = true
      btn.textContent = 'Logging in...'

      const { error } = await supabase.auth.signInWithPassword({ email, password })

      if (error) {
        errEl.textContent = '⚠️ ' + (error.message === 'Invalid login credentials' ? 'Incorrect email or password.' : error.message)
        errEl.classList.add('show')
        btn.disabled    = false
        btn.textContent = 'Login to My Account'
        return
      }

      btn.textContent = '✅ Redirecting...'
      const params = new URLSearchParams(window.location.search)
      window.location.href = params.get('redirect') || '/dashboard'
    }
  </script>
</body>
</html>
