        <p style="font-size:13px;font-weight:700;color:#d4f01a;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 6px;background:#0b1525;display:inline-block;padding:3px 10px;border-radius:4px;">Contact</p>
        <h2 id="contact-title" style="font-family:'Sora',sans-serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:800;color:#1c1c1c;margin:8px 0 10px;">Get in Touch</h2>
        <p id="contact-sub" style="font-size:15px;color:#64748b;margin:0;">We're here to help you choose the right course</p>
      </div>
      <div class="contact-layout">
        <!-- Left: info cards + map -->
        <div id="contact-info-col">
          <div class="contact-info-card">
            <div class="contact-info-icon">📍</div>
            <div><div class="contact-info-label">Visit Us</div><div class="contact-info-val" id="ci-address">1st Floor, ATEC Avenue, Hardo Channi Road, Gurdaspur, Punjab – 143521</div></div>
          </div>
