    .contact-info-val { font-size:14px; color:#475569; line-height:1.6; margin:0; }
    .contact-info-val a { color:#0b1525; text-decoration:none; }
    .contact-info-val a:hover { text-decoration:underline; }
    .contact-map { border-radius:16px; overflow:hidden; border:1px solid #e2e8f0; height:220px; margin-top:14px; background:#f1f5f9; display:flex; align-items:center; justify-content:center; font-size:13px; color:#94a3b8; }
    .contact-map iframe { width:100%; height:100%; border:none; }
