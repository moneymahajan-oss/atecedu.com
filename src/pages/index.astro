    .stories-track          { display:flex; width:max-content; gap:14px; padding:6px 0; will-change:transform; }
    .stories-track.row-1    { animation:st-left  38s linear infinite; }
    .stories-track.row-2    { animation:st-right 46s linear infinite; }
    .stories-track:hover    { animation-play-state:paused; }

    /* ── Portrait card (Scaler size) ── */
    .story-card {
      flex-shrink:0;
      width:300px; height:200px;
      border-radius:14px; overflow:hidden;
      position:relative; cursor:pointer;
      background:#1c2a40;
      transition:transform 0.25s ease, box-shadow 0.25s ease;
      box-shadow:0 4px 20px rgba(0,0,0,0.4);
    }
