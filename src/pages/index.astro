<!-- ══════════════════════════════════════════════════════════════
     VIDEO OVERLAY + HERO LIVE SETTINGS + BOTTOM BAR
     ALL 5 FIXES IN THIS SCRIPT BLOCK ONLY
══════════════════════════════════════════════════════════════ -->
<script>
  ;(function() {
    // ── Config ─────────────────────────────────────────────────────────────
    const SB_URL   = (window as any).__SB_URL as string
    const SB_KEY   = (window as any).__SB_KEY as string
    const FALLBACK_YT = 'oEK34ybNFdQ'

    // FIX 5: track both video type and URL separately
    // videoType: 'youtube' | 'instagram'
    // activeId: YouTube 11-char ID (only for YouTube)
    // activeInstaUrl: full Instagram reel embed URL (only for Instagram)
    let videoType      = 'youtube'
    let activeId       = FALLBACK_YT
    let activeInstaUrl = ''

    let revealDone   = false
    let preloadEl: HTMLIFrameElement | null = null
    let tickTimer: ReturnType<typeof setInterval> | null = null
    let secs         = 3

    // ── Extract 11-char YouTube ID from any URL ──────────────────────────
    function ytId(raw: string): string {
      if (!raw?.trim()) return ''
      raw = raw.trim()
      let m: RegExpMatchArray | null
      if ((m = raw.match(/youtu\.be\/([A-Za-z0-9_-]{11})/)))  return m[1]
      if ((m = raw.match(/[?&]v=([A-Za-z0-9_-]{11})/)))       return m[1]
      if ((m = raw.match(/\/embed\/([A-Za-z0-9_-]{11})/)))     return m[1]
      if ((m = raw.match(/\/shorts\/([A-Za-z0-9_-]{11})/)))    return m[1]
      if (/^[A-Za-z0-9_-]{11}$/.test(raw))                    return raw
      return ''
    }

    // FIX 5: detect Instagram reel URL and return embed URL
    // Accepts: https://www.instagram.com/reel/ABC123/ or /p/ABC123/
    function instaEmbedUrl(raw: string): string {
      if (!raw?.trim()) return ''
      raw = raw.trim()
      // Match reel or post shortcode
      const m = raw.match(/instagram\.com\/(?:reel|p)\/([A-Za-z0-9_-]+)/)
      if (m) return `https://www.instagram.com/reel/${m[1]}/embed/`
      // Already an embed URL
      if (raw.includes('instagram.com') && raw.includes('/embed')) return raw
      return ''
    }

    // ── Build the correct src for the iframe ────────────────────────────
    // FIX 5: returns different URL depending on videoType
    function buildSrc(muted: boolean): string {
      if (videoType === 'instagram') {
        // Instagram embeds don't support autoplay params — they play on their own
        return activeInstaUrl
      }
      // YouTube
      const m = muted ? '&mute=1' : ''
      return `https://www.youtube.com/embed/${activeId}?autoplay=1${m}&loop=1&playlist=${activeId}&controls=1&rel=0&modestbranding=1`
    }

    // ── FIX 1: inject muted iframe directly into the card ────────────────
    // This IS the "video autoplaying in the card" — replaces the old thumbnail approach
    function injectCardIframe(id: string, type: string) {
      const card = document.getElementById('hero-thumb') as HTMLElement
      if (!card) return
      // Remove any existing card iframe
      const old = document.getElementById('card-iframe')
      if (old) old.remove()

      const f = document.createElement('iframe')
      f.id = 'card-iframe'

      if (type === 'instagram') {
        f.src = activeInstaUrl
        // Instagram: no autoplay control, but it autoplays in embed mode
      } else {
        f.src = `https://www.youtube.com/embed/${id}?autoplay=1&mute=1&loop=1&playlist=${id}&controls=0&rel=0&modestbranding=1&playsinline=1`
      }

      f.setAttribute('allow', 'autoplay; encrypted-media; fullscreen; picture-in-picture')
      f.setAttribute('allowfullscreen', '')
      f.setAttribute('frameborder', '0')
      // Inline styles — Astro scoping doesn't apply to JS-inserted elements
      f.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none;border-radius:14px;pointer-events:none;'
      // Insert BEFORE the overlay divs so it's behind them
      card.insertBefore(f, card.firstChild)
    }

    // ── Preload: attach tiny hidden iframe to body (YouTube only) ─────────
    // Instagram doesn't need preloading — we skip it for Instagram
    function startPreload(id: string) {
      if (videoType === 'instagram') return  // no preload needed for Instagram
      if (preloadEl) { preloadEl.remove(); preloadEl = null }
      const f = document.createElement('iframe')
      f.id  = 'yt-preload-iframe'
      f.src = `https://www.youtube.com/embed/${id}?autoplay=1&mute=1&loop=1&playlist=${id}&controls=1&rel=0&modestbranding=1`
      f.setAttribute('allow', 'autoplay; encrypted-media; fullscreen; picture-in-picture')
      f.setAttribute('allowfullscreen', '')
      f.style.cssText = [
        'position:fixed','bottom:2px','right:2px',
        'width:4px','height:4px','border:none',
        'z-index:1','opacity:0.01','pointer-events:none',
      ].join(';')
      document.body.appendChild(f)
      preloadEl = f
    }

    // ── Countdown ticker ─────────────────────────────────────────────────
    const cdEl = document.getElementById('reveal-countdown') as HTMLElement

    function startTick() {
      if (tickTimer) return
      tickTimer = setInterval(() => {
        secs--
        if (cdEl) cdEl.textContent = String(Math.max(secs, 0))
        if (secs <= 0) {
          clearInterval(tickTimer!); tickTimer = null
          const badge = document.getElementById('reveal-hint')
          if (badge) badge.style.display = 'none'
          doReveal()
        }
      }, 1000)
    }

    // ── doReveal: zoom the card out to full screen ────────────────────────
    function doReveal() {
      if (revealDone) return
      revealDone = true

      const ov   = document.getElementById('video-overlay')    as HTMLElement
      const wrap = document.getElementById('video-iframe-wrap') as HTMLElement
      const hc   = document.getElementById('hero-content')     as HTMLElement

      if (videoType === 'youtube' && preloadEl && wrap) {
        // Resize the already-playing preload iframe to full size
        preloadEl.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none;opacity:1;pointer-events:all;'
        wrap.innerHTML = ''
        wrap.appendChild(preloadEl)
        preloadEl = null
      } else {
        // Instagram or fallback: inject fresh iframe
        const f = document.createElement('iframe')
        f.src = buildSrc(true)
        f.setAttribute('allow', 'autoplay; encrypted-media; fullscreen; picture-in-picture')
        f.setAttribute('allowfullscreen', '')
        f.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none;'
        if (wrap) { wrap.innerHTML = ''; wrap.appendChild(f) }
      }

      // Show unmute hint
      const hint = document.getElementById('unmute-hint') as HTMLElement
      if (hint) hint.style.display = 'inline-flex'

      // FIX B: show bottom CTA bar only now (video is playing full-screen)
      if (localStorage.getItem('atec_bar_v2') !== 'dismissed') {
        const bar = document.getElementById('bottom-cta-bar') as HTMLElement
        if (bar) bar.style.transform = 'translateY(0)'
      }

      // Zoom-in animation
      ov.style.pointerEvents = 'all'
      requestAnimationFrame(() => {
        ov.style.transition   = 'transform 1s cubic-bezier(0.16,1,0.3,1), opacity 0.6s ease, border-radius 1s ease'
        ov.style.transform    = 'scale(1)'
        ov.style.opacity      = '1'
        ov.style.borderRadius = '0'
      })

      if (hc) {
        hc.style.transition    = 'opacity 0.6s ease'
        hc.style.opacity       = '0.08'
        hc.style.pointerEvents = 'none'
      }
    }

    // ── closeOverlay: shared by button + backdrop click ───────────────────
    function closeOverlay() {
      const ov   = document.getElementById('video-overlay') as HTMLElement
      const hc   = document.getElementById('hero-content')  as HTMLElement
      const hint = document.getElementById('unmute-hint')   as HTMLElement
      const bar  = document.getElementById('bottom-cta-bar') as HTMLElement

      ov.style.transition    = 'transform 0.5s ease, opacity 0.4s ease, border-radius 0.5s ease'
      ov.style.transform     = 'scale(0.07)'
      ov.style.opacity       = '0'
      ov.style.borderRadius  = '24px'
      ov.style.pointerEvents = 'none'
      if (hint) hint.style.display = 'none'
      if (hc)  { hc.style.opacity = '1'; hc.style.pointerEvents = 'all' }
      // FIX B: hide bottom bar when video closes
      if (bar) bar.style.transform = 'translateY(100%)'

      setTimeout(() => {
        const wrap = document.getElementById('video-iframe-wrap') as HTMLElement
        if (wrap) wrap.innerHTML = ''
        ov.style.transition = 'none'
        revealDone = false
        // Restart preload so next auto-reveal works
        if (videoType === 'youtube') startPreload(activeId)
      }, 520)
    }

    // FIX 3+4: close button + backdrop both call closeOverlay
    document.getElementById('video-close-btn')?.addEventListener('click', closeOverlay)
    document.getElementById('video-backdrop')?.addEventListener('click', closeOverlay)

    // ── Thumbnail click: skip countdown ─────────────────────────────────
    document.getElementById('hero-thumb')?.addEventListener('click', () => {
      if (revealDone) return
      if (tickTimer) { clearInterval(tickTimer); tickTimer = null }
      secs = 0
      const badge = document.getElementById('reveal-hint')
      if (badge) badge.style.display = 'none'
      doReveal()
    })

    // ── Load settings from Supabase ──────────────────────────────────────
    async function loadSettings() {
      if (!SB_URL || !SB_KEY) return
      try {
        const res  = await fetch(
          `${SB_URL}/rest/v1/site_settings?key=eq.hero&select=value`,
          { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
        )
        const rows = await res.json()
        const v    = rows?.[0]?.value || {}

        // Hero colours / text
        const sec = document.getElementById('hero-section') as HTMLElement
        if (v.hero_bg_color)    sec.style.background = v.hero_bg_color
        const h = document.getElementById('hero-heading') as HTMLElement
        if (v.heading)           h.innerHTML = v.heading
        if (v.hero_text_color)   h.style.color = v.hero_text_color
        const s = document.getElementById('hero-sub') as HTMLElement
        if (v.subheading)        s.textContent = v.subheading
        if (v.hero_sub_color)    s.style.color = v.hero_sub_color

        // Video bar
        const barEl  = document.getElementById('video-bar-text') as HTMLElement
        const topBar = document.getElementById('video-top-bar')  as HTMLElement
        if (v.video_bar_text)       barEl.textContent       = v.video_bar_text
        if (v.video_bar_bg)         topBar.style.background = v.video_bar_bg
        if (v.video_bar_text_color) barEl.style.color       = v.video_bar_text_color

        // Bottom bar
        const btText  = document.getElementById('bottom-bar-text')  as HTMLElement
        const btPhone = document.getElementById('bottom-bar-phone') as HTMLAnchorElement
        const btCTA   = document.getElementById('bottom-bar-cta')   as HTMLAnchorElement
        const btBar   = document.getElementById('bottom-cta-bar')   as HTMLElement
        if (v.bottom_bar_text  && btText)  btText.textContent = v.bottom_bar_text
        if (v.bottom_bar_phone && btPhone) { btPhone.textContent = v.bottom_bar_phone; btPhone.href = `tel:${v.bottom_bar_phone.replace(/\s/g,'')}` }
        if (v.bottom_bar_cta   && btCTA)   btCTA.textContent  = v.bottom_bar_cta + ' ↗'
        if (v.bottom_bar_link  && btCTA)   btCTA.href         = v.bottom_bar_link
        if (v.bottom_bar_bg    && btBar)   btBar.style.background = v.bottom_bar_bg

        // ── FIX 5: video type detection ───────────────────────────────────
        // Admin can set video_type = 'instagram' | 'youtube'
        // and video_url = any YouTube or Instagram reel URL
        const adminType = (v.video_type || 'youtube').toLowerCase()
        const adminUrl  = (v.video_url || v.youtube_video_id || '').trim()

        if (adminType === 'instagram') {
          const embedUrl = instaEmbedUrl(adminUrl)
          if (embedUrl) {
            // Switch to Instagram — completely replace card and preload
            videoType      = 'instagram'
            activeInstaUrl = embedUrl
            // Kill YouTube preload — no longer needed
            if (preloadEl) { preloadEl.remove(); preloadEl = null }
            // Replace card iframe with Instagram embed
            if (!revealDone) injectCardIframe('', 'instagram')
          }
        } else {
          // YouTube path
          const adminId = ytId(adminUrl)
          if (adminId && adminId !== activeId) {
            videoType = 'youtube'
            activeId  = adminId
            if (!revealDone) {
              injectCardIframe(adminId, 'youtube')
              startPreload(adminId)
            }
          }
        }

      } catch(e) {
        console.warn('[ATEC] Settings fetch failed, fallback active:', e)
      }
    }

    // ── Bottom bar slide-up after 2s ─────────────────────────────────────
    function showBottomBar() {
      if (localStorage.getItem('atec_bar_v2') === 'dismissed') return
      setTimeout(() => {
        const bar = document.getElementById('bottom-cta-bar') as HTMLElement
        if (bar) bar.style.transform = 'translateY(0)'
      }, 2000)
    }

    // ── Boot ─────────────────────────────────────────────────────────────
    function boot() {
      // FIX 1: inject muted iframe into the card immediately on boot
      injectCardIframe(FALLBACK_YT, 'youtube')
      // Preload the same video in background for smooth zoom-in
      startPreload(FALLBACK_YT)
      startTick()       // 3s countdown
      // NOTE: showBottomBar() removed from boot — bottom bar shows ONLY when video zooms in
      loadSettings()    // parallel — updates colours/text/video source
    }

    function waitAndBoot() {
      const sbUrl = (window as any).__SB_URL
      if (sbUrl) { boot(); return }
      let attempts = 0
      const poll = setInterval(() => {
        attempts++
        if ((window as any).__SB_URL || attempts >= 40) {
          clearInterval(poll)
          boot()
        }
      }, 50)
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', waitAndBoot)
    } else {
      waitAndBoot()
    }
  })()
</script>
