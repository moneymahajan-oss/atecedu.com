    .story-card.no-video      { cursor:default; }
    .story-card.no-video:hover{ transform:none; box-shadow:0 4px 20px rgba(0,0,0,0.4); }

    /* photo fills entire card */
    .story-photo { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:0; }
    /* video/iframe fills entire card — muted autoplay */
    .story-card-video {
      position:absolute; inset:0;
      width:100%; height:100%;
      border:none; pointer-events:none; z-index:0;
    }
    /* dark bottom-half gradient for text */
    .story-grad {
      position:absolute; inset:0; z-index:1;
      background:linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.28) 48%, rgba(0,0,0,0.04) 100%);
    }
    /* large initial when no photo */
