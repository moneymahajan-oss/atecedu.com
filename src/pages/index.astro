    .story-role   { font-size:11px; color:rgba(255,255,255,0.58); margin:0; }

    /* ── Fullscreen story overlay ── */
    #story-overlay {
      position:fixed; inset:0; z-index:10000;
      display:flex; flex-direction:column;
      background:#000;
      transform:scale(0.06); opacity:0;
