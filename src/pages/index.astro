---
// src/pages/index.astro
// Hero: cream-white background (admin-controlled)
// Video: full-width card, zooms in after 3s with smooth animation
// Announcement strip: text in box, no arrow, colors from admin
import BaseLayout from '../layouts/BaseLayout.astro'
import AnnouncementStrip from '../components/layout/AnnouncementStrip.astro'
import { supabase } from '../lib/supabase'

// Fetch static data at build time for SEO shell
let courses: any[] = []
let heroSettings: any = {}
let siteStats: any = {}

try {
  const [coursesRes, heroRes, statsRes] = await Promise.allSettled([
    supabase.from('courses').select('id,title,slug,short_description,thumbnail_url,mode,fee_inr,original_fee_inr,category,is_featured').eq('is_active', true).order('sort_order').limit(8),
    supabase.from('site_settings').select('value').eq('key', 'hero').single(),
    supabase.from('site_settings').select('value').eq('key', 'stats').single(),
  ])
  if (coursesRes.status === 'fulfilled') courses = coursesRes.value.data ?? []
  if (heroRes.status === 'fulfilled') heroSettings = heroRes.value.data?.value ?? {}
  if (statsRes.status === 'fulfilled') siteStats = statsRes.value.data?.value ?? {}
} catch (_) {}

const heroHeading = heroSettings.heading || 'Learn <span style="color:#d4f01a">ONLINE</span>'
const heroSub = heroSettings.subheading || 'GEN AI | MERN STACK | TALLY | KIDS PROGRAMS'
const heroBg = heroSettings.hero_bg_color || '#f8f4ef'
const heroTextColor = heroSettings.hero_text_color || '#1c1c1c'
const heroSubColor = heroSettings.hero_sub_color || '#444444'
const videoBarText = heroSettings.video_bar_text || 'For OFFLINE COURSES : www.ateceducation.in'
const videoBarBg = heroSettings.video_bar_bg || '#1c3d7a'
const videoBarTextColor = heroSettings.video_bar_text_color || '#ffffff'
---

<BaseLayout
  title="ATEC Educational Society — Learn Online | GEN AI, MERN Stack, Tally"
  description="India's trusted computer training institute. Online & hybrid courses in GEN AI, MERN Stack, Tally, Hardware Networking. 25+ years, 5000+ students placed."
>
  <!-- Announcement Strip -->
  <AnnouncementStrip />

  <!-- Navbar slot (Navbar.astro is included in BaseLayout) -->

  <!-- ═══════════════════════════════════════════════════════
       HERO SECTION — cream-white, admin-controlled background
  ═══════════════════════════════════════════════════════ -->
  <section id="hero-section" style={`background:${heroBg};position:relative;overflow:hidden;min-height:90vh;display:flex;align-items:center;`}>

    <!-- Hero content (left text + buttons) — visible before video card -->
    <div id="hero-content" style="
      width:100%;
      max-width:1200px;
      margin:0 auto;
      padding:80px 32px 60px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:40px;
      flex-wrap:wrap;
      position:relative;
      z-index:2;
    ">
      <!-- Left: Text -->
      <div style="flex:1;min-width:280px;max-width:520px;">
        <h1 id="hero-heading" style={`font-family:'Sora',sans-serif;font-size:clamp(2.4rem,5vw,3.8rem);font-weight:900;line-height:1.1;color:${heroTextColor};margin:0 0 18px;`}
          set:html={heroHeading}
        />
        <p id="hero-sub" style={`font-size:clamp(14px,2vw,18px);color:${heroSubColor};letter-spacing:0.04em;font-weight:500;margin:0 0 36px;`}>
          {heroSub}
        </p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <a href="/courses" style="
            display:inline-flex;align-items:center;gap:8px;
            background:#d4f01a;color:#1a1a1a;
            padding:14px 28px;border-radius:10px;
            font-weight:700;font-size:15px;
            text-decoration:none;
            transition:transform 0.2s,box-shadow 0.2s;
            box-shadow:0 4px 16px rgba(212,240,26,0.35);
          "
          onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 24px rgba(212,240,26,0.45)'"
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 16px rgba(212,240,26,0.35)'">
            Explore Courses →
          </a>
          <a href="https://wa.me/917009933289" target="_blank" rel="noopener" style="
            display:inline-flex;align-items:center;gap:8px;
            background:#25D366;color:#fff;
            padding:14px 28px;border-radius:10px;
            font-weight:700;font-size:15px;
            text-decoration:none;
            transition:transform 0.2s;
          "
          onmouseover="this.style.transform='translateY(-2px)'"
          onmouseout="this.style.transform='translateY(0)'">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Chat on WhatsApp
          </a>
        </div>
      </div>

      <!-- Right: placeholder (replaced by video card after 3s) -->
      <div id="hero-video-placeholder" style="
        flex:1;min-width:280px;max-width:560px;
        aspect-ratio:16/9;
        border-radius:18px;
        background:linear-gradient(135deg,#e8e0d5 0%,#d4c9b8 100%);
        display:flex;align-items:center;justify-content:center;
      ">
        <div style="text-align:center;color:#999;">
          <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polygon points="10,8 16,12 10,16" fill="currentColor" stroke="none"/></svg>
          <p style="margin:8px 0 0;font-size:13px;">Video loading...</p>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         FULL-WIDTH VIDEO CARD — zooms in after 3s, covers whole section
         Like Scaler.com hero video treatment
    ═══════════════════════════════════════════════════════ -->
    <div
      id="hero-video-card"
      style="
        position:absolute;
        inset:0;
        z-index:10;
        display:flex;
        flex-direction:column;
        background:#000;
        transform:scale(0.08);
        opacity:0;
        transform-origin:center center;
        border-radius:24px;
        overflow:hidden;
        pointer-events:none;
        transition:none;
      "
    >
      <!-- Address bar at top of card -->
      <div id="video-card-bar" style={`
        background:${videoBarBg};
        padding:10px 20px;
        display:flex;
        align-items:center;
        gap:12px;
        flex-shrink:0;
      `}>
        <div style="
          display:flex;
          align-items:center;
          gap:6px;
          background:rgba(255,255,255,0.12);
          border:1px solid rgba(255,255,255,0.2);
          border-radius:6px;
          padding:5px 14px;
          flex:1;
          max-width:420px;
        ">
          <svg width="14" height="14" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
          <span id="video-bar-text" style={`font-size:13px;color:${videoBarTextColor};font-weight:500;`}>{videoBarText}</span>
        </div>
        <!-- Close button -->
        <button
          id="video-card-close"
          onclick="document.getElementById('hero-video-card').style.cssText='position:absolute;inset:0;z-index:10;display:none;';document.getElementById('hero-content').style.opacity='1';"
          style="
            background:rgba(255,255,255,0.15);
            border:none;
            border-radius:6px;
            color:#fff;
            cursor:pointer;
            padding:5px 10px;
            font-size:13px;
            font-weight:600;
            margin-left:auto;
            transition:background 0.2s;
          "
          onmouseover="this.style.background='rgba(255,255,255,0.25)'"
          onmouseout="this.style.background='rgba(255,255,255,0.15)'"
        >✕ Close</button>
      </div>

      <!-- YouTube iframe fills rest of card -->
      <div id="video-card-iframe-wrap" style="flex:1;position:relative;min-height:0;">
        <!-- iframe injected by JS -->
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <div style="background:#1c3d7a;padding:20px 32px;">
    <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-around;flex-wrap:wrap;gap:20px;">
      {[
        { n: siteStats.years || '25+', label: 'Years of Excellence' },
        { n: siteStats.students || '5000+', label: 'Students Trained' },
        { n: siteStats.placement || '100%', label: 'Placement Support' },
        { n: siteStats.centres || '3+', label: 'ATEC Centres' },
      ].map(s => (
        <div style="text-align:center;">
          <div style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:#d4f01a;font-family:'Sora',sans-serif;">{s.n}</div>
          <div style="font-size:13px;color:rgba(255,255,255,0.75);margin-top:2px;">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Dynamic sections (courses, testimonials, etc.) loaded by React island -->
  <div id="homepage-dynamic-root"></div>

</BaseLayout>

<!-- ═══════════════════════════════════════════════════════
     LIVE HERO UPDATER + VIDEO CARD ZOOM-IN ANIMATION
═══════════════════════════════════════════════════════ -->
<script>
  declare const window: any

  const SUPABASE_URL: string = window.__SB_URL
  const SUPABASE_KEY: string = window.__SB_KEY

  // ─── 1. Pull live hero settings ───────────────────────────────────────────
  async function applyHeroSettings() {
    if (!SUPABASE_URL || !SUPABASE_KEY) return

    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/site_settings?key=eq.hero&select=value`,
        { headers: { apikey: SUPABASE_KEY, Authorization: `Bearer ${SUPABASE_KEY}` } }
      )
      const rows = await res.json()
      if (!rows?.length) return
      const v = rows[0].value

      // Background & text colors
      const section = document.getElementById('hero-section')!
      if (v.hero_bg_color && section) section.style.background = v.hero_bg_color

      const heading = document.getElementById('hero-heading')!
      if (v.heading && heading) heading.innerHTML = v.heading

      if (v.hero_text_color && heading) heading.style.color = v.hero_text_color

      const sub = document.getElementById('hero-sub')!
      if (v.subheading && sub) sub.textContent = v.subheading
      if (v.hero_sub_color && sub) sub.style.color = v.hero_sub_color

      // Address bar in video card
      const barText = document.getElementById('video-bar-text')
      const bar = document.getElementById('video-card-bar')
      if (v.video_bar_text && barText) barText.textContent = v.video_bar_text
      if (v.video_bar_bg && bar) bar.style.background = v.video_bar_bg
      if (v.video_bar_text_color && barText) barText.style.color = v.video_bar_text_color

      // ─── 2. Schedule video card zoom-in after 3 seconds ───────────────────
      const rawId: string = v.youtube_video_id || ''
      if (rawId) {
        // Extract real 11-char ID from any YouTube URL format
        let ytId = rawId.trim()
        const short = rawId.match(/youtu\.be\/([a-zA-Z0-9_-]{11})/)
        const long  = rawId.match(/[?&v=|\/embed\/|\/shorts\/|\/v\/]([a-zA-Z0-9_-]{11})/)
        if (short) ytId = short[1]
        else if (long) ytId = long[1]
        else if (ytId.length !== 11) ytId = ''

        if (ytId.length === 11) {
          scheduleVideoCardReveal(ytId)
        }
      }

    } catch (e) {
      console.warn('Hero settings load failed:', e)
    }
  }

  // ─── 3. Zoom-in animation: scale(0.08) → scale(1), starts at 3s ──────────
  function scheduleVideoCardReveal(ytId: string) {
    const card = document.getElementById('hero-video-card')!
    const iframeWrap = document.getElementById('video-card-iframe-wrap')!
    const heroContent = document.getElementById('hero-content')!

    // Pre-inject iframe (hidden) so it's ready
    iframeWrap.innerHTML = `
      <iframe
        src="https://www.youtube.com/embed/${ytId}?autoplay=1&mute=1&loop=1&playlist=${ytId}&controls=1&modestbranding=1&rel=0"
        allow="autoplay; encrypted-media"
        allowfullscreen
        style="position:absolute;inset:0;width:100%;height:100%;border:none;"
        loading="lazy"
      ></iframe>
    `

    setTimeout(() => {
      // Make card visible + pointer-events on
      card.style.pointerEvents = 'all'

      // Step 1: enable CSS transition
      card.style.transition = 'transform 0.9s cubic-bezier(0.22,1,0.36,1), opacity 0.6s ease, border-radius 0.9s ease'

      // Step 2: trigger zoom-in on next frame
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          card.style.transform = 'scale(1)'
          card.style.opacity = '1'
          card.style.borderRadius = '0'
        })
      })

      // Fade out hero content text as video expands
      heroContent.style.transition = 'opacity 0.5s ease'
      heroContent.style.opacity = '0.15'
      heroContent.style.pointerEvents = 'none'

    }, 3000) // 3 second delay
  }

  applyHeroSettings()
</script>
