  <!-- ══════════════════════════════════════════════════════════════
       GET IN TOUCH — Contact info + enquiry form
       Runtime loaded from site_settings key='contact_info'
       Fields: address, phone1, phone2, email1, email2, hours,
               map_embed_url, show_form, form_title, form_subtitle
  ══════════════════════════════════════════════════════════════ -->
  <style is:global>
