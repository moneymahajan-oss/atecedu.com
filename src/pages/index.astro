<script>
// Course filter
const filterBtns = document.querySelectorAll('.filter-btn')
const courseCards = document.querySelectorAll('#courses-grid .course-card')

filterBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    const mode = (btn as HTMLElement).dataset.mode ?? 'all'
    filterBtns.forEach(b => b.classList.remove('active'))
    btn.classList.add('active')

    courseCards.forEach(card => {
      const cardMode = (card.querySelector('.card-mode-badge') as HTMLElement)?.textContent?.trim().toLowerCase() ?? ''
      const el = card as HTMLElement
      if (mode === 'all' || cardMode === mode) {
        el.style.display = ''
      } else {
        el.style.display = 'none'
      }
    })
  })
})

// Student photo slider
const track = document.getElementById('student-track') as HTMLElement | null
const prevBtn = document.getElementById('student-prev')
const nextBtn = document.getElementById('student-next')
let slideIndex = 0
const slideWidth = 236

function moveSlider(dir: number) {
  if (!track) return
  const slides = track.querySelectorAll('.student-slide')
  const max = Math.max(0, slides.length - 3)
  slideIndex = Math.max(0, Math.min(slideIndex + dir, max))
  track.style.transform = `translateX(-${slideIndex * slideWidth}px)`
}

prevBtn?.addEventListener('click', () => moveSlider(-1))
nextBtn?.addEventListener('click', () => moveSlider(1))

// Auto-advance slider every 3 seconds
let autoSlide = setInterval(() => {
  if (!track) return
  const slides = track.querySelectorAll('.student-slide')
  const max = Math.max(0, slides.length - 3)
  if (slideIndex >= max) slideIndex = -1
  moveSlider(1)
}, 3000)

track?.parentElement?.addEventListener('mouseenter', () => clearInterval(autoSlide))
track?.parentElement?.addEventListener('mouseleave', () => {
  autoSlide = setInterval(() => {
    if (!track) return
    const slides = track.querySelectorAll('.student-slide')
    const max = Math.max(0, slides.length - 3)
    if (slideIndex >= max) slideIndex = -1
    moveSlider(1)
  }, 3000)
})
</script>
