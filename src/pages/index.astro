---
// src/pages/index.astro
// FIXES:
//  1. Video card uses position:fixed so it truly covers the FULL viewport
//  2. Hero bg color loaded live from Supabase (admin-controlled)
//  3. All homepage sections (courses, testimonials, instructors etc) rendered inline - NO missing HomepageDynamic
//  4. Placeholder has NO "Video loading..." text - silent until video zooms in
//  5. Scaler-style sticky bottom CTA bar added
import BaseLayout from '../layouts/BaseLayout.astro'
import AnnouncementStrip from '../components/layout/AnnouncementStrip.astro'
import { supabase } from '../lib/supabase'

// ── Fetch all data individually so one fail never crashes the whole page ──
let courses: any[]      = []
let testimonials: any[] = []
let instructors: any[]  = []
let newsItems: any[]    = []
let centresData: any[]  = []
let heroSettings: any   = {}
let siteStats: any      = {}

try { const { data } = await supabase.from('courses').select('id,title,slug,short_description,thumbnail_url,mode,fee_inr,original_fee_inr,category,is_featured').eq('is_active', true).order('sort_order').limit(8); courses = data ?? [] } catch(_) {}
try { const { data } = await supabase.from('testimonials').select('*').eq('is_active', true).limit(6); testimonials = data ?? [] } catch(_) {}
try { const { data } = await supabase.from('instructors').select('*').eq('is_active', true).order('sort_order').limit(12); instructors = data ?? [] } catch(_) {}
try { const { data } = await supabase.from('news_items').select('*').eq('is_active', true).order('sort_order').limit(4); newsItems = data ?? [] } catch(_) {}
try { const { data } = await supabase.from('centres').select('*').eq('is_active', true).order('sort_order'); centresData = data ?? [] } catch(_) {}
try { const { data } = await supabase.from('site_settings').select('value').eq('key', 'hero').single(); heroSettings = data?.value ?? {} } catch(_) {}
try { const { data } = await supabase.from('site_settings').select('value').eq('key', 'stats').single(); siteStats = data?.value ?? {} } catch(_) {}

// Fallback data
const heroHeading    = heroSettings.heading    || 'Learn <span style="color:#d4f01a">ONLINE</span>'
const heroSub        = heroSettings.subheading || 'GEN AI | MERN STACK | TALLY | KIDS PROGRAMS'
const heroBg         = heroSettings.hero_bg_color   || '#f8f4ef'
const heroTextColor  = heroSettings.hero_text_color || '#1c1c1c'
const heroSubColor   = heroSettings.hero_sub_color  || '#555555'
const videoBarText   = heroSettings.video_bar_text  || 'For OFFLINE COURSES : www.ateceducation.in'
const videoBarBg     = heroSettings.video_bar_bg    || '#1c3d7a'
const videoBarColor  = heroSettings.video_bar_text_color || '#ffffff'
const bottomBarText  = heroSettings.bottom_bar_text || 'Need help? Talk to us at'
const bottomBarPhone = heroSettings.bottom_bar_phone || '+91 7009933289'
const bottomBarCTA   = heroSettings.bottom_bar_cta  || 'Request a Call'
const bottomBarLink  = heroSettings.bottom_bar_link || '/contact'
const bottomBarBg    = heroSettings.bottom_bar_bg   || '#1c3d7a'

// Fallback courses
const fallbackCourses = courses.length > 0 ? courses : [
  { id:'1', title:'GEN AI', slug:'gen-ai', short_description:'Master AI tools, ChatGPT, image gen & automation', mode:'online', fee_inr:4999, original_fee_inr:9999, category:'ai', is_featured:true },
  { id:'2', title:'MERN Stack', slug:'mern-stack', short_description:'Full-stack web development with React, Node, MongoDB', mode:'online', fee_inr:5999, original_fee_inr:11999, category:'web', is_featured:true },
  { id:'3', title:'Tally Prime', slug:'tally-prime', short_description:'Complete accounting & GST with Tally Prime', mode:'hybrid', fee_inr:2999, original_fee_inr:5999, category:'accounting', is_featured:false },
  { id:'4', title:'Hardware & Networking', slug:'hardware-networking', short_description:'Chip-level repair, CCNA, server admin', mode:'hybrid', fee_inr:3999, original_fee_inr:7999, category:'hardware', is_featured:false },
]

const fallbackTestimonials = testimonials.length > 0 ? testimonials : [
  { id:'1', student_name:'Roshni Singh', course:'Python Programming', review:'ATEC changed my career completely. The teachers are amazing and I got placed within 2 months!', rating:5 },
  { id:'2', student_name:'Arjun Sharma', course:'MERN Stack', review:'Best institute in Punjab for web development. Very practical and industry-focused training.', rating:5 },
  { id:'3', student_name:'Priya Verma', course:'Tally Prime', review:'Got my accounts job immediately after completing the course. Highly recommend ATEC.', rating:5 },
]

const fallbackInstructors = instructors.length > 0 ? instructors : [
  { id:'1', name:'Er. Rajesh Kumar', specialization:'Hardware & Networking', photo_url:null },
  { id:'2', name:'Ms. Seema Rani', specialization:'Tally & Accounting', photo_url:null },
  { id:'3', name:'Mr. Aman Goyal', specialization:'MERN Stack Developer', photo_url:null },
  { id:'4', name:'Ms. Pooja Sharma', specialization:'GEN AI & Python', photo_url:null },
  { id:'5', name:'Er. Vikas Thakur', specialization:'Linux & Server Admin', photo_url:null },
]
---

<BaseLayout
  title="ATEC Educational Society — Learn Online | GEN AI, MERN Stack, Tally"
  description="India's trusted computer training institute. Online & hybrid courses in GEN AI, MERN Stack, Tally, Hardware Networking. 25+ years, 5000+ students placed."
>

  <!-- Announcement Strip -->
  <AnnouncementStrip />

  <!-- ══════════════════════════════════════════════════════════════
       HERO SECTION — tight 2-col grid, cream bg, no extra space
  ══════════════════════════════════════════════════════════════ -->
  <style>
    #hero-content { display:grid; grid-template-columns:1fr 1fr; align-items:center; gap:48px; }
    @media(max-width:768px){ #hero-content { grid-template-columns:1fr; } #hero-thumb { order:2; } }
  </style>

  <section id="hero-section" style={`background:${heroBg};`}>
    <div id="hero-content" style="width:100%;max-width:1200px;margin:0 auto;padding:52px 40px 48px;">

      <!-- Left: text -->
      <div>
        <h1
          id="hero-heading"
          style={`font-family:'Sora',sans-serif;font-size:clamp(2.2rem,4vw,3.5rem);font-weight:900;line-height:1.08;color:${heroTextColor};margin:0 0 14px;`}
          set:html={heroHeading}
        />
        <p
          id="hero-sub"
          style={`font-size:clamp(13px,1.5vw,16px);color:${heroSubColor};letter-spacing:0.05em;font-weight:600;margin:0 0 28px;`}
        >{heroSub}</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <a href="/courses" style="display:inline-flex;align-items:center;gap:8px;background:#d4f01a;color:#1a1a1a;padding:13px 26px;border-radius:10px;font-weight:700;font-size:14px;text-decoration:none;box-shadow:0 4px 16px rgba(212,240,26,0.35);">
            Explore Courses →
          </a>
          <a href="https://wa.me/917009933289" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:8px;background:#25D366;color:#fff;padding:13px 26px;border-radius:10px;font-weight:700;font-size:14px;text-decoration:none;">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Chat on WhatsApp
          </a>
        </div>
      </div>

      <!-- Right: video thumbnail — fills right column perfectly -->
      <div
        id="hero-thumb"
        style="width:100%;aspect-ratio:16/9;border-radius:14px;overflow:hidden;position:relative;cursor:pointer;background:#1c2a4a;box-shadow:0 10px 36px rgba(28,61,122,0.2);"
        title="Click to watch"
      >
        <img
          id="hero-yt-thumb"
          src=""
          alt="ATEC Student Stories"
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity 0.5s;"
        />
        <!-- dark overlay so play button is always visible -->
        <div style="position:absolute;inset:0;background:rgba(0,0,0,0.18);"></div>
        <!-- Play button -->
        <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
          <div style="width:64px;height:64px;background:rgba(255,255,255,0.93);border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 18px rgba(0,0,0,0.28);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="#1c3d7a"><polygon points="9,6 20,12 9,18"/></svg>
          </div>
        </div>
        <!-- countdown badge -->
        <div id="reveal-hint" style="position:absolute;bottom:10px;right:12px;background:rgba(0,0,0,0.6);color:#fff;font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;letter-spacing:0.04em;">
          Auto-plays in <span id="reveal-countdown">3</span>s
        </div>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       FULL-VIEWPORT VIDEO OVERLAY — position:fixed, zooms in at 3s
       Starts display:none to prevent black flash before animation
  ══════════════════════════════════════════════════════════════ -->
  <div
    id="video-overlay"
    style="
      position:fixed;
      inset:0;
      z-index:9999;
      display:none;
      flex-direction:column;
      background:#000;
      transform:scale(0.06);
      opacity:0;
      transform-origin:center center;
      border-radius:28px;
      overflow:hidden;
      pointer-events:none;
      transition:none;
    "
  >
    <!-- Top bar — address bar style -->
    <div id="video-top-bar" style={`background:${videoBarBg};padding:10px 20px;display:flex;align-items:center;gap:12px;flex-shrink:0;`}>
      <!-- Address-style pill -->
      <div style="display:flex;align-items:center;gap:8px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2);border-radius:6px;padding:5px 16px;flex:1;max-width:480px;">
        <svg width="13" height="13" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>
        <span id="video-bar-text" style={`font-size:13px;font-weight:500;color:${videoBarColor};`}>{videoBarText}</span>
      </div>
      <!-- Close -->
      <button
        id="video-close-btn"
        style="background:rgba(255,255,255,0.15);border:none;border-radius:6px;color:#fff;cursor:pointer;padding:6px 14px;font-size:13px;font-weight:700;margin-left:auto;transition:background 0.15s;"
      >✕ Close</button>
    </div>

    <!-- iframe area -->
    <div id="video-iframe-wrap" style="flex:1;position:relative;min-height:0;background:#000;">
      <!-- injected by JS -->
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════════
       STATS BAR
  ══════════════════════════════════════════════════════════════ -->
  <div style="background:#1c3d7a;padding:22px 32px;">
    <div style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-around;flex-wrap:wrap;gap:20px;">
      {[
        { n: siteStats.years     || '25+',   label:'Years of Excellence' },
        { n: siteStats.students  || '5000+', label:'Students Trained' },
        { n: siteStats.placement || '100%',  label:'Placement Support' },
        { n: siteStats.centres   || '3+',    label:'ATEC Centres' },
      ].map(s => (
        <div style="text-align:center;">
          <div style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:#d4f01a;font-family:'Sora',sans-serif;">{s.n}</div>
          <div style="font-size:13px;color:rgba(255,255,255,0.75);margin-top:2px;">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════════
       COURSES SECTION
  ══════════════════════════════════════════════════════════════ -->
  <section style="padding:72px 32px;background:#fff;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:40px;flex-wrap:wrap;gap:16px;">
        <div>
          <p style="font-size:13px;font-weight:700;color:#d4f01a;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 6px;">What We Offer</p>
          <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:800;color:#1c1c1c;margin:0;">Popular Courses</h2>
        </div>
        <a href="/courses" style="color:#1c3d7a;font-weight:700;font-size:14px;text-decoration:none;border:2px solid #1c3d7a;padding:8px 20px;border-radius:8px;">View All Courses →</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:24px;">
        {fallbackCourses.map(c => (
          <a href={`/courses/${c.slug}`} style="display:block;text-decoration:none;background:#fff;border:1px solid #e8ecf0;border-radius:16px;overflow:hidden;transition:box-shadow 0.2s,transform 0.2s;box-shadow:0 2px 8px rgba(0,0,0,0.06);"
            onmouseover="this.style.boxShadow='0 8px 28px rgba(0,0,0,0.12)';this.style.transform='translateY(-3px)'"
            onmouseout="this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)';this.style.transform='translateY(0)'">
            <div style={`background:${c.thumbnail_url ? '#000' : '#1c3d7a'};aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;position:relative;`}>
              {c.thumbnail_url
                ? <img src={c.thumbnail_url} alt={c.title} style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;" />
                : <span style="font-family:'Sora',sans-serif;font-size:1.4rem;font-weight:900;color:#d4f01a;">{c.title}</span>
              }
              <span style={`position:absolute;top:10px;left:10px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;text-transform:uppercase;background:${c.mode==='online'?'#d4f01a':'#60a5fa'};color:${c.mode==='online'?'#1a1a1a':'#fff'};`}>
                {c.mode}
              </span>
            </div>
            <div style="padding:16px;">
              <h3 style="font-family:'Sora',sans-serif;font-size:16px;font-weight:700;color:#1c1c1c;margin:0 0 6px;">{c.title}</h3>
              <p style="font-size:13px;color:#64748b;margin:0 0 12px;line-height:1.5;">{c.short_description}</p>
              <div style="display:flex;align-items:center;justify-content:space-between;">
                <div>
                  <span style="font-size:17px;font-weight:800;color:#1c3d7a;">₹{c.fee_inr?.toLocaleString('en-IN')}</span>
                  {c.original_fee_inr && <span style="font-size:12px;color:#94a3b8;text-decoration:line-through;margin-left:6px;">₹{c.original_fee_inr?.toLocaleString('en-IN')}</span>}
                </div>
                <span style="font-size:12px;color:#d4f01a;background:#1c3d7a;padding:4px 10px;border-radius:6px;font-weight:700;">Enroll →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       INSTRUCTORS MARQUEE
  ══════════════════════════════════════════════════════════════ -->
  <section style="padding:56px 0;background:#f8f4ef;overflow:hidden;">
    <div style="max-width:1200px;margin:0 auto 32px;padding:0 32px;">
      <p style="font-size:13px;font-weight:700;color:#d4f01a;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 6px;background:#1c3d7a;display:inline-block;padding:3px 10px;border-radius:4px;">Expert Faculty</p>
      <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.5rem,3vw,2rem);font-weight:800;color:#1c1c1c;margin:8px 0 0;">Learn from the Best</h2>
    </div>
    <style>
      @keyframes marquee { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
      .marquee-track { display:flex; width:max-content; animation:marquee 28s linear infinite; }
      .marquee-track:hover { animation-play-state:paused; }
    </style>
    <div class="marquee-track">
      {[...fallbackInstructors, ...fallbackInstructors].map((ins, i) => (
        <div key={`ins-${i}`} style="flex-shrink:0;width:200px;margin:0 12px;background:#fff;border-radius:14px;padding:20px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,0.06);">
          <div style={`width:64px;height:64px;border-radius:50%;margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-family:'Sora',sans-serif;font-weight:800;font-size:1.3rem;color:#fff;background:#1c3d7a;${ins.photo_url?'padding:0;overflow:hidden;':''}`}>
            {ins.photo_url
              ? <img src={ins.photo_url} alt={ins.name} style="width:100%;height:100%;object-fit:cover;" />
              : ins.name.split(' ').map((w:string)=>w[0]).slice(0,2).join('')
            }
          </div>
          <div style="font-weight:700;font-size:14px;color:#1c1c1c;">{ins.name}</div>
          <div style="font-size:12px;color:#64748b;margin-top:3px;">{ins.specialization}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       TESTIMONIALS
  ══════════════════════════════════════════════════════════════ -->
  <section style="padding:72px 32px;background:#fff;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:48px;">
        <p style="font-size:13px;font-weight:700;color:#1c3d7a;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 8px;">Student Stories</p>
        <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:800;color:#1c1c1c;margin:0;">What Our Students Say</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px;">
        {fallbackTestimonials.map(t => (
          <div style="background:#f8f4ef;border-radius:16px;padding:24px;border:1px solid #e8e0d5;">
            <div style="color:#d4f01a;font-size:1.1rem;margin-bottom:12px;">{'★'.repeat(t.rating || 5)}</div>
            <p style="font-size:14px;color:#374151;line-height:1.65;margin:0 0 16px;">"{t.review}"</p>
            <div style="display:flex;align-items:center;gap:10px;">
              <div style="width:38px;height:38px;border-radius:50%;background:#1c3d7a;display:flex;align-items:center;justify-content:center;color:#d4f01a;font-weight:800;font-size:14px;">
                {t.student_name?.charAt(0)}
              </div>
              <div>
                <div style="font-weight:700;font-size:14px;color:#1c1c1c;">{t.student_name}</div>
                <div style="font-size:12px;color:#64748b;">{t.course}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       WHY ATEC
  ══════════════════════════════════════════════════════════════ -->
  <section style="padding:72px 32px;background:#1c3d7a;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="text-align:center;margin-bottom:48px;">
        <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:800;color:#fff;margin:0 0 12px;">Why Choose ATEC?</h2>
        <p style="color:rgba(255,255,255,0.7);font-size:16px;margin:0;">25+ years of excellence. Real skills. Real placements.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;">
        {[
          { icon:'🎓', title:'Expert Faculty', desc:'Industry-certified trainers with 10+ years of experience' },
          { icon:'🏆', title:'ISO Certified', desc:'ISO 9001:2015 certified institute since 2000' },
          { icon:'💼', title:'100% Placement', desc:'Dedicated placement cell with 500+ hiring partners' },
          { icon:'🌐', title:'Online + Hybrid', desc:'Learn from anywhere or attend in-person at our centres' },
          { icon:'📜', title:'Recognized Certificates', desc:'Government & industry-recognised certifications' },
          { icon:'🛠️', title:'Practical Training', desc:'80% hands-on lab sessions, 20% theory' },
        ].map(f => (
          <div style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.12);border-radius:14px;padding:22px;">
            <div style="font-size:2rem;margin-bottom:12px;">{f.icon}</div>
            <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:16px;color:#d4f01a;margin:0 0 8px;">{f.title}</h3>
            <p style="font-size:13px;color:rgba(255,255,255,0.75);margin:0;line-height:1.55;">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       CTA SECTION
  ══════════════════════════════════════════════════════════════ -->
  <section style="padding:72px 32px;background:#f8f4ef;">
    <div style="max-width:760px;margin:0 auto;text-align:center;">
      <h2 style="font-family:'Sora',sans-serif;font-size:clamp(1.8rem,4vw,2.6rem);font-weight:900;color:#1c1c1c;margin:0 0 16px;">
        Ready to Start Your <span style="color:#1c3d7a;">Career Journey?</span>
      </h2>
      <p style="font-size:16px;color:#64748b;margin:0 0 32px;">New batches starting every month. Limited seats available.</p>
      <div style="display:flex;justify-content:center;gap:16px;flex-wrap:wrap;">
        <a href="/courses" style="background:#1c3d7a;color:#d4f01a;padding:15px 32px;border-radius:10px;font-weight:700;font-size:15px;text-decoration:none;">Browse All Courses →</a>
        <a href="tel:+917009933289" style="background:#fff;color:#1c3d7a;padding:15px 32px;border-radius:10px;font-weight:700;font-size:15px;text-decoration:none;border:2px solid #1c3d7a;">📞 Call +91 7009933289</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       SCALER-STYLE STICKY BOTTOM BAR — "Need help? Request a Call"
       Fixed to viewport bottom, dismissible, admin-controlled text
  ══════════════════════════════════════════════════════════════ -->
  <div
    id="bottom-cta-bar"
    style={`
      position:fixed;
      bottom:0;
      left:0;
      right:0;
      z-index:8888;
      background:${bottomBarBg};
      padding:14px 24px;
      display:flex;
      align-items:center;
      justify-content:center;
      gap:12px;
      flex-wrap:wrap;
      box-shadow:0 -4px 20px rgba(0,0,0,0.18);
      transform:translateY(100%);
      transition:transform 0.5s cubic-bezier(0.22,1,0.36,1);
    `}
  >
    <span id="bottom-bar-text" style="font-size:14px;color:rgba(255,255,255,0.85);font-weight:500;">{bottomBarText}</span>
    <a
      id="bottom-bar-phone"
      href={`tel:${bottomBarPhone.replace(/\s/g,'')}`}
      style="font-size:16px;font-weight:800;color:#d4f01a;text-decoration:none;letter-spacing:0.02em;"
    >{bottomBarPhone}</a>
    <span style="color:rgba(255,255,255,0.4);font-size:14px;">or</span>
    <a
      id="bottom-bar-cta"
      href={bottomBarLink}
      style="background:#d4f01a;color:#1a1a1a;padding:8px 20px;border-radius:7px;font-weight:700;font-size:14px;text-decoration:none;display:inline-flex;align-items:center;gap:5px;"
    >{bottomBarCTA} ↗</a>
    <!-- Dismiss button -->
    <button
      onclick="document.getElementById('bottom-cta-bar').style.transform='translateY(100%)';localStorage.setItem('atec_bar_dismissed','1');"
      style="background:none;border:none;color:rgba(255,255,255,0.5);cursor:pointer;font-size:18px;margin-left:8px;padding:0 4px;line-height:1;"
      title="Dismiss"
    >✕</button>
  </div>

</BaseLayout>

<!-- ══════════════════════════════════════════════════════════════
     VIDEO OVERLAY + HERO LIVE SETTINGS + BOTTOM BAR
══════════════════════════════════════════════════════════════ -->
<script>
  declare const window: any
  const SB_URL: string = window.__SB_URL
  const SB_KEY: string = window.__SB_KEY

  // ── Fallback YT ID — same video already in admin panel ────────────────────
  const FALLBACK_YT_ID = 'oEK34ybNFdQ'

  let activeYtId    = FALLBACK_YT_ID
  let revealDone    = false
  let countdownTick: ReturnType<typeof setInterval> | null = null

  // ── Extract 11-char ID from any YouTube URL format ────────────────────────
  function ytId(raw: string): string {
    if (!raw?.trim()) return ''
    raw = raw.trim()
    let m: RegExpMatchArray | null
    if ((m = raw.match(/youtu\.be\/([a-zA-Z0-9_-]{11})/)))  return m[1]
    if ((m = raw.match(/[?&]v=([a-zA-Z0-9_-]{11})/)))       return m[1]
    if ((m = raw.match(/\/embed\/([a-zA-Z0-9_-]{11})/)))     return m[1]
    if ((m = raw.match(/\/shorts\/([a-zA-Z0-9_-]{11})/)))    return m[1]
    if (/^[a-zA-Z0-9_-]{11}$/.test(raw))                    return raw
    return ''
  }

  // ── STEP 1: Start 3s countdown immediately on page load ──────────────────
  // Do NOT wait for Supabase fetch — countdown runs in parallel
  let secondsLeft = 3
  const countdownEl = document.getElementById('reveal-countdown') as HTMLElement

  function startCountdown() {
    if (countdownTick) return // already running
    countdownTick = setInterval(() => {
      secondsLeft--
      if (countdownEl) countdownEl.textContent = String(Math.max(secondsLeft, 0))
      if (secondsLeft <= 0) {
        clearInterval(countdownTick!)
        countdownTick = null
        // Hide the countdown badge
        const hint = document.getElementById('reveal-hint')
        if (hint) hint.style.display = 'none'
        triggerVideoReveal(activeYtId)
      }
    }, 1000)
  }

  // Apply YT thumbnail to placeholder card immediately
  function setThumbnail(id: string) {
    const img = document.getElementById('hero-yt-thumb') as HTMLImageElement
    if (!img || !id) return
    img.src = `https://img.youtube.com/vi/${id}/maxresdefault.jpg`
    img.onload  = () => { img.style.opacity = '1' }
    img.onerror = () => { img.src = `https://img.youtube.com/vi/${id}/hqdefault.jpg`; img.style.opacity = '1' }
  }

  // ── STEP 2: Inject iframe — mute=1 required for browser autoplay policy ──
  // YouTube's autoplay policy: ONLY muted video autoplays without user gesture.
  // User can unmute using the volume icon inside the player.
  function injectIframe(id: string) {
    const wrap = document.getElementById('video-iframe-wrap') as HTMLElement
    if (!wrap) return
    wrap.innerHTML = `
      <iframe
        src="https://www.youtube.com/embed/${id}?autoplay=1&mute=1&loop=1&playlist=${id}&controls=1&modestbranding=1&rel=0"
        allow="autoplay; encrypted-media; fullscreen; picture-in-picture"
        allowfullscreen
        style="position:absolute;inset:0;width:100%;height:100%;border:none;"
      ></iframe>
    `
  }

  // ── STEP 3: Zoom-in reveal — display:none→flex first, then animate ────────
  function triggerVideoReveal(id: string) {
    if (revealDone) return
    revealDone = true

    const overlay  = document.getElementById('video-overlay') as HTMLElement
    const heroContent = document.getElementById('hero-content') as HTMLElement

    // Make visible at scale(0.06) — browser can now process the iframe
    overlay.style.display = 'flex'
    overlay.style.transform = 'scale(0.06)'
    overlay.style.opacity = '0'
    overlay.style.borderRadius = '28px'
    overlay.style.transition = 'none'

    // Inject iframe now that element is in viewport rendering pipeline
    injectIframe(id)

    // One rAF tick to let browser process display:flex + iframe injection
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        overlay.style.transition = 'transform 1s cubic-bezier(0.16,1,0.3,1), opacity 0.6s ease, border-radius 1s ease'
        overlay.style.transform  = 'scale(1)'
        overlay.style.opacity    = '1'
        overlay.style.borderRadius = '0'
        overlay.style.pointerEvents = 'all'

        if (heroContent) {
          heroContent.style.transition = 'opacity 0.6s ease'
          heroContent.style.opacity = '0.08'
          heroContent.style.pointerEvents = 'none'
        }
      })
    })
  }

  // ── STEP 4: Close button ──────────────────────────────────────────────────
  document.getElementById('video-close-btn')?.addEventListener('click', () => {
    const overlay     = document.getElementById('video-overlay') as HTMLElement
    const heroContent = document.getElementById('hero-content') as HTMLElement

    overlay.style.transition = 'transform 0.55s ease, opacity 0.45s ease, border-radius 0.55s ease'
    overlay.style.transform  = 'scale(0.06)'
    overlay.style.opacity    = '0'
    overlay.style.borderRadius = '28px'
    overlay.style.pointerEvents = 'none'

    if (heroContent) {
      heroContent.style.opacity = '1'
      heroContent.style.pointerEvents = 'all'
    }

    // After animation: display:none + clear iframe (kills audio)
    setTimeout(() => {
      overlay.style.display = 'none'
      overlay.style.transition = 'none'
      const wrap = document.getElementById('video-iframe-wrap') as HTMLElement
      if (wrap) wrap.innerHTML = ''
    }, 580)
  })

  // ── STEP 5: Thumbnail click — skip countdown, open immediately ───────────
  document.getElementById('hero-thumb')?.addEventListener('click', () => {
    if (revealDone) return
    // Stop countdown
    if (countdownTick) { clearInterval(countdownTick); countdownTick = null }
    secondsLeft = 0
    const hint = document.getElementById('reveal-hint')
    if (hint) hint.style.display = 'none'
    triggerVideoReveal(activeYtId)
  })

  // ── STEP 6: Fetch Supabase settings (parallel to countdown) ──────────────
  async function loadSettings() {
    // Start thumbnail + countdown immediately with fallback
    setThumbnail(FALLBACK_YT_ID)
    startCountdown()

    if (!SB_URL || !SB_KEY) return

    try {
      const res  = await fetch(`${SB_URL}/rest/v1/site_settings?key=eq.hero&select=value`, {
        headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` }
      })
      const rows = await res.json()
      const v    = rows?.[0]?.value || {}

      // Apply colors/text
      const sec = document.getElementById('hero-section') as HTMLElement
      if (v.hero_bg_color)  sec.style.background = v.hero_bg_color
      const h = document.getElementById('hero-heading') as HTMLElement
      if (v.heading)        h.innerHTML = v.heading
      if (v.hero_text_color) h.style.color = v.hero_text_color
      const s = document.getElementById('hero-sub') as HTMLElement
      if (v.subheading)     s.textContent = v.subheading
      if (v.hero_sub_color) s.style.color = v.hero_sub_color

      // Video bar
      const barEl  = document.getElementById('video-bar-text') as HTMLElement
      const topBar = document.getElementById('video-top-bar') as HTMLElement
      if (v.video_bar_text)       barEl.textContent       = v.video_bar_text
      if (v.video_bar_bg)         topBar.style.background = v.video_bar_bg
      if (v.video_bar_text_color) barEl.style.color       = v.video_bar_text_color

      // Bottom bar
      const btText  = document.getElementById('bottom-bar-text')  as HTMLElement
      const btPhone = document.getElementById('bottom-bar-phone') as HTMLAnchorElement
      const btCTA   = document.getElementById('bottom-bar-cta')   as HTMLAnchorElement
      const btBar   = document.getElementById('bottom-cta-bar')   as HTMLElement
      if (v.bottom_bar_text  && btText)  btText.textContent = v.bottom_bar_text
      if (v.bottom_bar_phone && btPhone) { btPhone.textContent = v.bottom_bar_phone; btPhone.href = `tel:${v.bottom_bar_phone.replace(/\s/g,'')}` }
      if (v.bottom_bar_cta   && btCTA)   btCTA.textContent  = v.bottom_bar_cta + ' ↗'
      if (v.bottom_bar_link  && btCTA)   btCTA.href         = v.bottom_bar_link
      if (v.bottom_bar_bg    && btBar)   btBar.style.background = v.bottom_bar_bg

      // Update video ID if admin set a different one (only if countdown not yet fired)
      const adminId = ytId(v.youtube_video_id || '')
      if (adminId) {
        activeYtId = adminId
        setThumbnail(adminId)
      }

    } catch(e) {
      console.warn('Settings fetch failed, using fallbacks:', e)
    }
  }

  // ── STEP 7: Bottom bar slide-up after 2s ─────────────────────────────────
  function showBottomBar() {
    if (localStorage.getItem('atec_bar_dismissed') === '1') return
    setTimeout(() => {
      const bar = document.getElementById('bottom-cta-bar') as HTMLElement
      if (bar) bar.style.transform = 'translateY(0)'
    }, 2000)
  }

  // ── Boot ──────────────────────────────────────────────────────────────────
  loadSettings()
  showBottomBar()
</script>
