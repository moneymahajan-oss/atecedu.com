    },
    {
      name:'Commerce & Accounting', color:'#065f46', bg_color:'#ecfdf5',
      courses:[
        { title:'Tally Prime + GST', slug:'tally-prime', mode:'hybrid', fee_inr:2999, original_fee_inr:5999, thumbnail_url:'' },
        { title:'MS Office Advanced', slug:'ms-office', mode:'hybrid', fee_inr:1999, original_fee_inr:3999, thumbnail_url:'' },
        { title:'Digital Marketing', slug:'digital-marketing', mode:'online', fee_inr:3999, original_fee_inr:7999, thumbnail_url:'' },
        { title:'E-Commerce', slug:'ecommerce', mode:'online', fee_inr:2999, original_fee_inr:5999, thumbnail_url:'' },
      ]
    },
    {
      name:'Kids & Beginners', color:'#b45309', bg_color:'#fffbeb',
      courses:[
        { title:'Coding for Kids', slug:'kids-coding', mode:'online', fee_inr:2499, original_fee_inr:4999, thumbnail_url:'' },
        { title:'Scratch Programming', slug:'scratch', mode:'online', fee_inr:1999, original_fee_inr:3999, thumbnail_url:'' },
        { title:'Computer Basics', slug:'computer-basics', mode:'hybrid', fee_inr:1499, original_fee_inr:2999, thumbnail_url:'' },
        { title:'Robotics', slug:'robotics', mode:'hybrid', fee_inr:3499, original_fee_inr:6999, thumbnail_url:'' },
      ]
    },
    {
      name:'Hardware & Networking', color:'#be123c', bg_color:'#fff1f2',
      courses:[
        { title:'Hardware + Networking', slug:'hardware-networking', mode:'hybrid', fee_inr:3999, original_fee_inr:7999, thumbnail_url:'' },
        { title:'CCNA Networking', slug:'ccna', mode:'hybrid', fee_inr:4999, original_fee_inr:9999, thumbnail_url:'' },
        { title:'Linux Admin', slug:'linux', mode:'online', fee_inr:3499, original_fee_inr:6999, thumbnail_url:'' },
        { title:'Cybersecurity', slug:'cybersecurity', mode:'online', fee_inr:5499, original_fee_inr:10999, thumbnail_url:'' },
      ]
    },
  ]

  function makeCard(c: any, showFee: boolean): HTMLElement {
    const wrap = document.createElement('a')
    wrap.className = 'cat-card'
    wrap.href = '/courses/' + (c.slug || '')
    // Stop child button clicks from navigating
    wrap.addEventListener('click', (e: any) => { if ((e.target as HTMLElement).closest('.cat-card-btn')) e.preventDefault() })
    const modeBg = c.mode === 'online' ? '#d4f01a' : c.mode === 'classroom' ? '#fde68a' : '#bfdbfe'
    const modeColor = c.mode === 'online' ? '#1a1a1a' : '#1e40af'
    const duration = c.duration_weeks ? '<span>⏱ ' + c.duration_weeks + 'w</span>' : ''
    const level = c.level ? '<span>📶 ' + c.level + '</span>' : ''
    const enquireUrl = 'https://wa.me/917009933289?text=' + encodeURIComponent('Hi! I want to enquire about the course: ' + (c.title || ''))
    const syllabusUrl = c.syllabus_url || ('/courses/' + (c.slug || ''))
    wrap.innerHTML =
      '<div class="cat-card-thumb" style="background:' + (c.thumbnail_url ? '#000' : 'var(--cat-card-bg,#0b1525)') + ';">' +
        (c.thumbnail_url
          ? '<img class="cat-card-thumb-inner" src="' + c.thumbnail_url + '" alt="' + c.title + '" loading="lazy" />'
          : '<div style="display:flex;align-items:center;justify-content:center;height:100%;padding:16px;"><span style="font-family:Sora,sans-serif;font-size:16px;font-weight:900;color:#d4f01a;text-align:center;line-height:1.3;">' + c.title + '</span></div>'
        ) +
        '<span class="cat-card-mode" style="background:' + modeBg + ';color:' + modeColor + ';">' + (c.mode || 'hybrid') + '</span>' +
      '</div>' +
      '<div class="cat-card-body">' +
        '<div class="cat-card-title">' + (c.title || '') + '</div>' +
        (c.short_description ? '<div class="cat-card-desc">' + c.short_description + '</div>' : '') +
        ((duration || level) ? '<div class="cat-card-meta">' + duration + level + '</div>' : '') +
        (showFee && c.fee_inr
          ? '<div style="margin-bottom:12px;">' +
              '<span class="cat-card-fee">₹' + Number(c.fee_inr).toLocaleString('en-IN') + '</span>' +
              (c.original_fee_inr ? '<span class="cat-card-fee-orig">₹' + Number(c.original_fee_inr).toLocaleString('en-IN') + '</span>' : '') +
            '</div>'
          : '') +
        '<div class="cat-card-actions">' +
          '<a class="cat-card-btn enquire" href="' + enquireUrl + '" target="_blank" rel="noopener" onclick="event.stopPropagation()">' +
            '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>' +
            'Enquire' +
          '</a>' +
          '<a class="cat-card-btn syllabus" href="' + syllabusUrl + '" onclick="event.stopPropagation()">' +
            '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>' +
            'View Syllabus' +
          '</a>' +
        '</div>' +
      '</div>'
    return wrap
  }

  // ── Per-row slider state ──────────────────────────────────────────────
  const rowState: Record<number, { pos: number; total: number; visible: number }> = {}

  function getCardWidth(rowIdx: number): number {
    const track = document.getElementById(`cat-track-${rowIdx}`)
    const first = track?.querySelector('.cat-card') as HTMLElement | null
    if (!first) return 300
    const gap = 20
    return first.offsetWidth + gap
  }

  function getVisibleCount(): number {
    const outer = document.querySelector('.cat-slider-outer') as HTMLElement | null
    if (!outer) return 4
    const w = outer.offsetWidth - 80  // subtract padding
    const cardW = 300 // approx
    return Math.max(1, Math.floor(w / (cardW + 20)))
  }

  function slideCat(rowIdx: number, dir: number) {
    const state = rowState[rowIdx]
    if (!state) return
    const visible = getVisibleCount()
    const maxPos  = Math.max(0, state.total - visible)
    state.pos = Math.max(0, Math.min(state.pos + dir, maxPos))
    const track = document.getElementById(`cat-track-${rowIdx}`) as HTMLElement | null
    if (track) {
      const cw = getCardWidth(rowIdx)
      track.style.transform = `translateX(-${state.pos * cw}px)`
    }
    // Update dots
    const dotsEl = document.getElementById(`cat-dots-${rowIdx}`)
    if (dotsEl) {
      dotsEl.querySelectorAll('.cat-dot').forEach((d, i) => d.classList.toggle('active', i === state.pos))
    }
    // Update arrow disabled state
    const prev = document.getElementById(`cat-prev-${rowIdx}`) as HTMLButtonElement | null
    const next = document.getElementById(`cat-next-${rowIdx}`) as HTMLButtonElement | null
    if (prev) prev.disabled = state.pos <= 0
    if (next) next.disabled = state.pos >= maxPos
  }

  ;(window as any).catSlide = slideCat
  ;(window as any).catDotGo = function(rowIdx: number, pos: number) {
    const state = rowState[rowIdx]
    if (state) { state.pos = pos; slideCat(rowIdx, 0) }
  }

  function renderCategories(cfg: any) {
    const categories    = cfg?.categories     || DEFAULT_CATEGORIES
    const showFee       = cfg?.show_fee !== false
    const title         = cfg?.section_title  || 'Courses by Category'
    const sub           = cfg?.section_sub    || ''
    const font          = cfg?.font_name      || "'Sora',sans-serif"
    const cardBg       = cfg?.card_bg_color      || '#0b1525'
    const cardBodyBg   = cfg?.card_body_bg       || '#ffffff'
    const cardTitleCol = cfg?.card_title_color   || '#1c1c1c'
    const cardDescCol  = cfg?.card_desc_color    || '#475569'
    const cardFeeCol   = cfg?.card_fee_color     || '#0b1525'
    const cardFeeOrig  = cfg?.card_fee_orig_color|| '#94a3b8'
    const btn1Bg       = cfg?.btn1_bg            || '#ea580c'
    const btn1Color    = cfg?.btn1_color         || '#ffffff'
    const btn2Bg       = cfg?.btn2_bg            || '#0b1525'
    const btn2Color    = cfg?.btn2_color         || '#ffffff'

    document.documentElement.style.setProperty('--cat-font',           font)
    document.documentElement.style.setProperty('--cat-card-bg',        cardBg)
    document.documentElement.style.setProperty('--cat-card-body-bg',   cardBodyBg)
    document.documentElement.style.setProperty('--cat-card-title',     cardTitleCol)
    document.documentElement.style.setProperty('--cat-card-desc',      cardDescCol)
    document.documentElement.style.setProperty('--cat-card-fee',       cardFeeCol)
    document.documentElement.style.setProperty('--cat-card-fee-orig',  cardFeeOrig)
    document.documentElement.style.setProperty('--cat-card-btn1-bg',   btn1Bg)
    document.documentElement.style.setProperty('--cat-card-btn1-color',btn1Color)
    document.documentElement.style.setProperty('--cat-card-btn2-bg',   btn2Bg)
    document.documentElement.style.setProperty('--cat-card-btn2-color',btn2Color)

    const titleEl = document.getElementById('cat-title')
    if (titleEl) titleEl.textContent = title
    const subEl = document.getElementById('cat-sup')
    if (subEl && sub) subEl.textContent = sub

    const container = document.getElementById('cat-rows')
    if (!container) return
    container.innerHTML = ''

    categories.forEach((cat: any, idx: number) => {
      const courses = cat.courses || []
      if (!courses.length) return

      rowState[idx] = { pos: 0, total: courses.length, visible: 4 }

      // Dot count = max(1, total - 3) so we show a dot per slide position
      const dotCount = Math.max(1, courses.length - 3)

      const row = document.createElement('div')
      row.className = 'cat-row'
      row.style.background = cat.bg_color || '#fff'

      // Header: name + dots + arrows
      const head = document.createElement('div')
      head.className = 'cat-row-head'
      head.innerHTML = `
        <div class="cat-row-left">
          <span class="cat-row-name" style="color:${cat.color||'#0b1525'};">${cat.name}</span>
          <span class="cat-row-count">${courses.length} course${courses.length!==1?'s':''}</span>
        </div>
        <div class="cat-row-arrows">
          <div class="cat-dots" id="cat-dots-${idx}">
            ${Array.from({length:dotCount},(_,i)=>`<button class="cat-dot${i===0?' active':''}" onclick="catDotGo(${idx},${i})" aria-label="Slide ${i+1}"></button>`).join('')}
          </div>
          <button class="cat-arrow" id="cat-prev-${idx}" onclick="catSlide(${idx},-1)" disabled aria-label="Previous">‹</button>
          <button class="cat-arrow" id="cat-next-${idx}" onclick="catSlide(${idx},1)" aria-label="Next">›</button>
        </div>`
      row.appendChild(head)

      // Slider outer viewport
      const outer = document.createElement('div')
      outer.className = 'cat-slider-outer'

      const track = document.createElement('div')
      track.className = 'cat-slider-track'
      track.id = `cat-track-${idx}`

      courses.forEach((c: any) => track.appendChild(makeCard(c, showFee)))

      outer.appendChild(track)
      row.appendChild(outer)
      container.appendChild(row)
    })
  }

  async function loadCategories() {

    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string
    if (!SB_URL || !SB_KEY) { renderCategories(null); return }
    try {
      const res  = await fetch(
        `${SB_URL}/rest/v1/site_settings?key=eq.course_categories&select=value`,
        { headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}` } }
      )
      const rows = await res.json()
      const data = rows?.[0]?.value
      if (data?.categories?.length) {
        renderCategories(data)
      } else {
        renderCategories(null)
      }
    } catch(e) {
      renderCategories(null)
    }
  }

  // Render defaults immediately, then upgrade from DB
  renderCategories(null)
  function waitSB(cb:()=>void) {
    if ((window as any).__SB_URL) { cb(); return }
    let n=0; const t=setInterval(()=>{ n++; if((window as any).__SB_URL||n>40){clearInterval(t);cb()} },50)
  }
  if (document.readyState==='loading') document.addEventListener('DOMContentLoaded',()=>waitSB(loadCategories))
  else waitSB(loadCategories)
})()
</script>

<!-- ══════════════════════════════════════════════════════════════
     CONTACT SECTIONS — 4 runtime loaders
     1. Connect With Us (social QR cards)
     2. Get In Touch (contact info + map + form)
     3. FAQ (accordion)
     4. Download Resources
     All data from site_settings in Supabase — live, no rebuild needed.
══════════════════════════════════════════════════════════════ -->
<script>
;(function() {

  // ── Shared helpers ─────────────────────────────────────────────────
  function show(id) { const el=document.getElementById(id); if(el) el.style.display='' }
  function setText(id, txt) { const el=document.getElementById(id); if(el) el.textContent=txt }
  function setHtml(id, html) { const el=document.getElementById(id); if(el) el.innerHTML=html }

  function waitSB(cb) {
    if (window.__SB_URL) { cb(); return }
    let n=0; const t=setInterval(()=>{ n++; if(window.__SB_URL||n>40){clearInterval(t);cb()} },50)
  }

  async function sbFetch(key) {
    const r = await fetch(
      `${window.__SB_URL}/rest/v1/site_settings?key=eq.${key}&select=value`,
      { headers:{ apikey:window.__SB_KEY, Authorization:`Bearer ${window.__SB_KEY}` } }
    )
    const d = await r.json()
    return d?.[0]?.value ?? null
  }

  // ── PLATFORM ICON COLOURS ──────────────────────────────────────────
  const PLATFORM_COLORS = {
    whatsapp:  { bg:'#25d366', icon:'💬' },
    instagram: { bg:'linear-gradient(135deg,#833ab4,#fd1d1d,#fcb045)', icon:'📸' },
    facebook:  { bg:'#1877f2', icon:'👥' },
    youtube:   { bg:'#ff0000', icon:'▶️' },
    google:    { bg:'#4285f4', icon:'⭐' },
    twitter:   { bg:'#1da1f2', icon:'🐦' },
    linkedin:  { bg:'#0a66c2', icon:'💼' },
    telegram:  { bg:'#0088cc', icon:'✈️' },
    default:   { bg:'#64748b', icon:'🔗' },
  }

  // ── 1. CONNECT WITH US ─────────────────────────────────────────────
  const DEFAULT_CONNECT = {
    title:'Connect With Us',
    subtitle:'Scan a QR or tap a card to follow us — stay updated with latest courses, events & student wins',
    platforms:[
      { name:'WhatsApp', url:'https://wa.me/917009933289', platform:'whatsapp', qr_url:'', is_active:true },
      { name:'Instagram', url:'https://www.instagram.com/ateceducation/', platform:'instagram', qr_url:'', is_active:true },
      { name:'Facebook', url:'https://www.facebook.com/ateceducation', platform:'facebook', qr_url:'', is_active:true },
      { name:'YouTube', url:'https://www.youtube.com/@ATECEducationalSociety', platform:'youtube', qr_url:'', is_active:true },
      { name:'Google Reviews', url:'https://g.page/r/atec-gurdaspur', platform:'google', qr_url:'', is_active:true },
    ]
  }

  function renderConnect(cfg) {
    const c = cfg || DEFAULT_CONNECT
    setText('connect-title', c.title || 'Connect With Us')
    setText('connect-sub', c.subtitle || '')
    const grid = document.getElementById('connect-grid')
    if (!grid) return

    const active = (c.platforms||[]).filter(p=>p.is_active!==false)
    if (!active.length) return

    grid.innerHTML = active.map(p => {
      const key = (p.platform||p.name||'').toLowerCase().replace(/\s+/g,'')
      const style = PLATFORM_COLORS[key] || PLATFORM_COLORS.default
      const bg = style.bg
      const icon = p.custom_icon || style.icon
      const qrHtml = p.qr_url
        ? `<img src="${p.qr_url}" alt="${p.name} QR" />`
        : `<div class="connect-qr-placeholder">QR code<br/>coming soon</div>`
      return `<a class="connect-card" href="${p.url||'#'}" target="_blank" rel="noopener" aria-label="${p.name}">
        <div class="connect-icon-wrap" style="background:${bg}">
          <span style="font-size:26px">${icon}</span>
        </div>
        <div class="connect-qr">${qrHtml}</div>
        <div class="connect-name">${p.name}</div>
      </a>`
    }).join('')

    show('connect-section')
  }

  // ── 2. GET IN TOUCH ────────────────────────────────────────────────
  const DEFAULT_CONTACT = {
    title:'Get in Touch',
    subtitle:"We're here to help you choose the right course",
    address:'1st Floor, ATEC Avenue, Hardo Channi Road, Gurdaspur, Punjab – 143521',
    phone1:'+91 9878505706',
    phone2:'+91 7009933289',
    email1:'atecgsp@gmail.com',
    hours:'Mon – Sat: 9:00 AM – 7:00 PM',
    map_embed_url:'',
    show_form:true,
    form_title:'Send Us a Message',
    form_subtitle:"We'll call you back within 30 minutes",
  }

  function renderContact(cfg) {
    const c = cfg || DEFAULT_CONTACT
    setText('contact-title', c.title || 'Get in Touch')
    setText('contact-sub', c.subtitle || '')
    setText('cf-form-title', c.form_title || 'Send Us a Message')
    setText('cf-form-sub', c.form_subtitle || '')

    // Build phone HTML
    const phones = [c.phone1,c.phone2].filter(Boolean)
    const phoneHtml = phones.map(p=>`<a href="tel:${p.replace(/\s/g,'')}">${p}</a>`).join(' | ')
    setHtml('ci-phone', phoneHtml)

    // Build email HTML
    const emails = [c.email1,c.email2].filter(Boolean)
    const emailHtml = emails.map(e=>`<a href="mailto:${e}">${e}</a>`).join('<br/>')
    setHtml('ci-email', emailHtml)

    setText('ci-address', c.address||'')
    setText('ci-hours', c.hours||'')

    // Map embed
    const mapEl = document.getElementById('contact-map')
    if (mapEl && c.map_embed_url) {
      mapEl.innerHTML = `<iframe src="${c.map_embed_url}" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>`
    } else if (mapEl) {
      mapEl.innerHTML = `<a href="https://maps.google.com/?q=ATEC+Gurdaspur+Punjab" target="_blank" rel="noopener" style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:#0b1525;font-weight:700;text-decoration:none;width:100%;height:100%">📍 Open in Google Maps</a>`
    }

    // Hide form if disabled
    const formCol = document.getElementById('contact-form-col')
    if (formCol && c.show_form === false) formCol.style.display = 'none'

    show('contact-section')
  }

  // Contact form submit
  document.getElementById('cf-submit')?.addEventListener('click', async function() {
    const btn = this
    const errEl = document.getElementById('cf-error')
    const succEl = document.getElementById('cf-success')
    const name  = document.getElementById('cf-name').value.trim()
    const phone = document.getElementById('cf-phone').value.trim()
    const email = document.getElementById('cf-email').value.trim()
    const course= document.getElementById('cf-course').value.trim()
    const msg   = document.getElementById('cf-msg').value.trim()

    errEl.style.display='none'
    if (!name||!phone) { errEl.textContent='Please enter your name and phone number.'; errEl.style.display='block'; return }

    btn.disabled=true; btn.textContent='Sending…'
    const URL=window.__SB_URL; const KEY=window.__SB_KEY
    if(URL&&KEY) {
      try {
        await fetch(`${URL}/rest/v1/enquiries`,{
          method:'POST',
          headers:{apikey:KEY,Authorization:`Bearer ${KEY}`,'Content-Type':'application/json',Prefer:'return=minimal'},
          body:JSON.stringify({name,phone,email,course_interest:course,message:msg})
        })
      } catch(e){}
    }
    btn.style.display='none'; succEl.style.display='block'
    setTimeout(()=>{ succEl.style.display='none'; btn.style.display=''; btn.disabled=false; btn.textContent='Send Message →'; ['cf-name','cf-phone','cf-email','cf-course','cf-msg'].forEach(id=>{ const el=document.getElementById(id); if(el)el.value='' }) }, 3500)
  })

  // ── 3. FAQ ─────────────────────────────────────────────────────────
  const DEFAULT_FAQS = [
    { q:'What courses does ATEC Gurdaspur offer?', a:'ATEC offers 20+ courses including GEN AI, MERN Stack, Tally Prime, Hardware & Networking, Python Programming, Digital Marketing, Graphic Design, Coding for Kids, and more. Courses are available online, hybrid, and in-person.' },
    { q:'Where is ATEC Education located in Gurdaspur?', a:'Our centre is at 1st Floor, ATEC Avenue, Hardo Channi Road, Gurdaspur, Punjab – 143521. We are easily accessible from the main city.' },
    { q:'What is the fee for computer courses at ATEC Gurdaspur?', a:'Course fees range from ₹1,499 (basic) to ₹6,999 (advanced full-stack / AI). We offer flexible payment plans and frequent discounts on new batches.' },
    { q:'Does ATEC provide certificates?', a:'Yes. All ATEC courses provide an ISO-verified certificate on successful completion. Certificates can be verified online at atecedu.com/verification.' },
    { q:'What is the placement support like at ATEC?', a:'ATEC has a dedicated placement cell with 500+ hiring partners. We provide resume building, mock interviews, and direct placement assistance. Our placement rate is 100% for eligible students.' },
    { q:'Are ATEC courses available online?', a:'Yes. Most courses are available in online, hybrid (online + in-person), and classroom modes. Online courses include live sessions, recorded videos, and doubt-clearing support.' },
    { q:'How do I enroll at ATEC?', a:'Click "Enroll Now" at the top of this page to WhatsApp us directly. Or call +91 7009933289. New batches start every month — limited seats available.' },
  ]

  function renderFAQ(cfg) {
    const faqs = (cfg?.faqs||DEFAULT_FAQS).filter(f=>f.is_active!==false)
    if (!faqs.length) return
    setText('faq-title', cfg?.title||'Frequently Asked Questions')
    setText('faq-sub', cfg?.subtitle||'Everything you need to know about ATEC courses')

    const list = document.getElementById('faq-list')
    if (!list) return
    list.innerHTML = faqs.map((f,i)=>`
      <div class="faq-item" id="faq-${i}">
        <button class="faq-q" onclick="toggleFaq(${i})" aria-expanded="false">
          <span class="faq-q-text">${f.q}</span>
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-a">${f.a}</div>
      </div>`).join('')
    show('faq-section')
  }

  window.toggleFaq = function(i) {
    const item = document.getElementById('faq-'+i)
    if (!item) return
    item.classList.toggle('open')
  }

  // ── 4. DOWNLOAD RESOURCES ──────────────────────────────────────────
  const DEFAULT_RESOURCES = [
    { title:'ATEC Course Brochure 2026', description:'Full catalogue of all courses with fees, duration, and syllabus overview.', file_url:'#', category:'Brochure', thumbnail_url:'', is_active:true },
    { title:'Hardware & Networking Syllabus', description:'Detailed week-by-week syllabus for the Hardware & Networking course.', file_url:'#', category:'Syllabus', thumbnail_url:'', is_active:true },
    { title:'Tally Prime Study Guide', description:'Comprehensive Tally Prime notes covering GST, payroll, and advanced features.', file_url:'#', category:'Study Material', thumbnail_url:'', is_active:true },
    { title:'GEN AI Tools Cheatsheet', description:'Quick reference guide to the most useful AI tools for students and professionals.', file_url:'#', category:'Cheatsheet', thumbnail_url:'', is_active:true },
  ]

  function renderDownloads(cfg) {
    const items = (cfg?.resources||DEFAULT_RESOURCES).filter(r=>r.is_active!==false)
    if(!items.length) return
    setText('dl-title', cfg?.title||'Download Resources')
    setText('dl-sub', cfg?.subtitle||'Free course brochures, syllabus PDFs, and study materials')

    const grid = document.getElementById('downloads-grid')
    if(!grid) return
    grid.innerHTML = items.map(r=>{
      const emoji = r.category?.toLowerCase().includes('brochure') ? '📋'
        : r.category?.toLowerCase().includes('syllabus') ? '📄'
        : r.category?.toLowerCase().includes('cheat') ? '⚡'
        : '📚'
      const thumbHtml = r.thumbnail_url
        ? `<img src="${r.thumbnail_url}" alt="${r.title}" loading="lazy" />`
        : `<span style="font-size:3rem">${emoji}</span>`
      const catHtml = r.category ? `<span class="dl-category">${r.category}</span>` : ''
      return `<div class="dl-card">
        <div class="dl-thumb">${thumbHtml}${catHtml}</div>
        <div class="dl-body">
          <div class="dl-title">${r.title}</div>
          <div class="dl-desc">${r.description||''}</div>
          <a class="dl-btn" href="${r.file_url||'#'}" ${r.file_url&&r.file_url!=='#'?'target="_blank" rel="noopener" download':''}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download
          </a>
        </div>
      </div>`
    }).join('')
    show('downloads-section')
  }

  // ── Boot all 4 loaders ────────────────────────────────────────────
  async function loadAll() {
    // Render defaults immediately
    renderConnect(null)
    renderContact(null)
    renderFAQ(null)
    renderDownloads(null)

    // Then upgrade from DB
    if (!window.__SB_URL || !window.__SB_KEY) return
    try {
      const [connectCfg, contactCfg, faqCfg, dlCfg] = await Promise.all([
        sbFetch('social_connect'),
        sbFetch('contact_info'),
        sbFetch('faq_items'),
        sbFetch('download_resources'),
      ])
      if (connectCfg) renderConnect(connectCfg)
      if (contactCfg) renderContact(contactCfg)
      if (faqCfg)     renderFAQ(faqCfg)
      if (dlCfg)      renderDownloads(dlCfg)
    } catch(e) { console.warn('[ATEC Contact Sections]', e) }
  }

  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',()=>waitSB(loadAll))
  else waitSB(loadAll)

})()
</script>

<!-- ══════════════════════════════════════════════════════════════
     SCHOLARSHIP GAUGE — animated score counter + IntersectionObserver
══════════════════════════════════════════════════════════════ -->
<script>
;(function() {
  // Animate the gauge score counter when section scrolls into view
  function animateGauge() {
    const section = document.getElementById('scholarship-section')
    if (!section) return

    let animated = false

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !animated) {
          animated = true
          runGaugeAnimation()
        }
      })
    }, { threshold: 0.3 })

    observer.observe(section)
  }

  function runGaugeAnimation() {
    const scoreEl = document.getElementById('gauge-animated-score')
    const pillEl  = document.getElementById('gauge-status-pill')
    if (!scoreEl) return

    // Count from 0 to 42 (the "low readiness" demonstration score)
    let current = 0
    const target = 42
    const duration = 1400
    const step = duration / target
    const interval = setInterval(() => {
      current++
      if (scoreEl) scoreEl.textContent = String(current)
      if (current >= target) {
        clearInterval(interval)
        // Show "Low Readiness" message faded in
        if (pillEl) {
          pillEl.style.opacity = '0'
          pillEl.style.transition = 'opacity 0.4s'
          setTimeout(() => { if(pillEl) pillEl.style.opacity = '1' }, 200)
        }
      }
    }, step)
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', animateGauge)
  } else {
    animateGauge()
  }
})()
</script>
