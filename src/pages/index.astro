            </a>
            <a href="https://wa.me/917009933289?text=Hi! I want to know about ATEC courses." target="_blank" rel="noopener" class="cta-whatsapp" id="hero-cta2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <span class="cta-label" id="hero-cta2-label">Chat on WhatsApp</span>
            </a>
          </div>

          <div class="hero-feature-pills">
            <span class="feature-pill">⚡ Live Zoom Classes</span>
            <span class="feature-pill">🎓 Verified Certificate</span>
            <span class="feature-pill">💼 100% Placement Support</span>
          </div>
        </div>

        <div class="hero-right">
          <div class="hero-visual-card" id="hero-visual">
            <!-- Placeholder visual until admin sets YouTube ID -->
            <div class="visual-content">
              <div class="visual-shimmer"></div>
              <div class="visual-logo">A</div>
              <div class="visual-title">ATEC</div>
              <div class="visual-sub">Educational Society</div>
              <div class="visual-divider"></div>
              <div class="visual-stats">
                <div class="vs-item">
                  <div class="vs-num">25+</div>
                  <div class="vs-lbl">Years</div>
                </div>
                <div class="vs-item">
                  <div class="vs-num">5000+</div>
                  <div class="vs-lbl">Students</div>
                </div>
                <div class="vs-item">
                  <div class="vs-num">15+</div>
                  <div class="vs-lbl">Courses</div>
                </div>
              </div>
              <div class="visual-badge">ISO 9001:2015 ✓</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHY ATEC — Static
  ============================================================ -->
  <section class="why-section section">
    <div class="container">
      <div class="section-header center">
        <p class="section-label">Why ATEC</p>
        <h2>25 Years Of Producing<br />Industry-Ready Professionals</h2>
      </div>
      <div class="why-grid">
        {[
          { icon: '🏆', title: 'ISO 9001:2015 Certified', desc: 'Internationally certified quality training standards — verified and trusted by employers across India.' },
          { icon: '🔧', title: 'Chip-Level Hardware Repair', desc: 'India\'s most trusted laptop & desktop motherboard repair training institute. Practical, job-ready skills.' },
          { icon: '🌐', title: 'Online & Hybrid Learning', desc: 'Learn theory online from anywhere. Attend practical lab sessions at our Gurdaspur centre.' },
          { icon: '📜', title: 'Verified Certificates', desc: 'Every ATEC certificate is instantly verifiable online by employers using our verification portal.' },
          { icon: '🎯', title: '100% Placement Support', desc: 'Dedicated placement cell to help every student get hired after completing their course.' },
          { icon: '📹', title: 'Zoom Live Classes', desc: 'Interactive live classes via Zoom, recorded for later revision. Never miss a session.' },
        ].map(item => (
          <div class="why-card">
            <div class="why-icon">{item.icon}</div>
            <h3 class="why-title">{item.title}</h3>
            <p class="why-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       DYNAMIC CONTENT — courses, instructors, testimonials, etc.
  ============================================================ -->
  <HomepageDynamic client:load />

  <!-- ============================================================
       BLOG TEASER
  ============================================================ -->
  <section class="section" style="background:var(--off-white)">
    <div class="container">
      <div class="blog-teaser-header">
        <div>
          <p class="section-label">Learn More</p>
          <h2>Blog, Videos & Podcasts</h2>
          <p style="color:var(--text-secondary);font-size:16px;margin-top:8px">Career guides · Course tips · Student success stories · Free tutorials</p>
        </div>
        <a href="/blog" class="btn btn-outline btn-sm">View All →</a>
      </div>
      <div class="blog-teaser-grid">
        <a href="/blog/career-hardware-networking-2026" class="blog-teaser-card">
          <div class="btc-icon">💻</div>
          <div class="btc-tag">Career Guide</div>
          <h3>How to Start a Career in Hardware & Networking in 2026</h3>
          <p>Your complete 6-month roadmap to become a job-ready Network Engineer.</p>
          <span class="btc-read">Read Article →</span>
        </a>
        <a href="/blog/chip-level-laptop-repair-2026" class="blog-teaser-card">
          <div class="btc-icon">🔧</div>
          <div class="btc-tag">Course Guide</div>
          <h3>Chip-Level Laptop Repair: Is It Worth Learning in 2026?</h3>
          <p>One of India's highest-paying tech trade skills.</p>
          <span class="btc-read">Read Article →</span>
        </a>
        <a href="/blog/web-designing-vs-web-development" class="blog-teaser-card">
          <div class="btc-icon">🌐</div>
          <div class="btc-tag">Career Guide</div>
          <h3>Web Designing vs Web Development: Which Career is Right?</h3>
          <p>Difference, tools, jobs and salary breakdown.</p>
          <span class="btc-read">Read Article →</span>
        </a>
      </div>
      <div class="blog-teaser-extras">
        <a href="/blog" class="extra-pill"><span>📺</span> Free YouTube Tutorials</a>
        <a href="/blog" class="extra-pill"><span>🎙️</span> Student Success Podcast</a>
        <a href="/centres" class="extra-pill"><span>📍</span> Find a Centre Near You</a>
        <a href="/verification" class="extra-pill"><span>📜</span> Verify a Certificate</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA
  ============================================================ -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-text">
          <h2>Ready To Start Your Career In Tech?</h2>
          <p>Join 5,000+ students who launched their careers with ATEC since 2000. New batches starting every month.</p>
        </div>
        <div class="cta-btns">
          <a href="/courses" class="btn btn-primary">Browse Courses</a>
          <a href="https://wa.me/917009933289" target="_blank" rel="noopener" class="btn btn-outline-white">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- ── LIVE UPDATE FROM ADMIN — no rebuild ────────────────────── -->
<script>
  import { createClient } from '@supabase/supabase-js'

  const url = (window as any).__SB_URL
  const key = (window as any).__SB_KEY
  if (url && key) {
    const sb = createClient(url, key)

    sb.from('site_settings').select('value').eq('key', 'hero').single().then(({ data }) => {
      if (!data?.value) return
      const v = data.value

      // Heading — supports <em> for highlight
      if (v.heading) {
        const el = document.getElementById('hero-heading')
        if (el) {
          // Render heading: if contains <em>, use it. Else render plain.
          if (v.heading.includes('<') || v.heading.includes('|')) {
            // Pipe-split format: "Line 1|Highlight|Line 3" gradient on middle
            const parts = v.heading.split('|').map((s: string) => s.trim()).filter(Boolean)
            if (parts.length === 3) {
              el.innerHTML = `<span class="title-line">${parts[0]}</span><span class="title-line gradient-text">${parts[1]}</span><span class="title-line">${parts[2]}</span>`
            } else {
              el.innerHTML = v.heading
            }
          } else {
            el.innerHTML = `<span class="title-line gradient-text">${v.heading}</span>`
          }
        }
      }

      // Subheading
      if (v.subheading) {
        const el = document.getElementById('hero-sub')
        if (el) el.textContent = v.subheading
      }

      // Heading font size
      if (v.heading_font_size) {
        const el = document.getElementById('hero-heading') as HTMLElement
        if (el) el.style.fontSize = `clamp(2rem, ${v.heading_font_size}vw, ${v.heading_font_size}rem)`
      }

      // CTA 1 (primary)
      const cta1 = document.getElementById('hero-cta1') as HTMLAnchorElement
      if (cta1) {
        if (v.cta_link) cta1.href = v.cta_link
        const lbl = cta1.querySelector('.cta-label')
        if (lbl && v.cta_text) lbl.textContent = v.cta_text
        if ((v.cta_link||'').startsWith('http')) { cta1.target='_blank'; cta1.rel='noopener' }
      }

      // CTA 2 (WhatsApp)
      const cta2 = document.getElementById('hero-cta2') as HTMLAnchorElement
      if (cta2) {
        if (v.cta2_link) cta2.href = v.cta2_link
        const lbl = document.getElementById('hero-cta2-label')
        if (lbl && v.cta2_text) lbl.textContent = v.cta2_text
      }

      // Swap visual to YouTube embed if video ID provided
      if (v.youtube_video_id) {
        let ytId = (v.youtube_video_id || '').trim()
        const short = ytId.match(/youtu\.be\/([a-zA-Z0-9_-]{11})/)
        const long  = ytId.match(/(?:v=|\/embed\/|\/shorts\/|\/v\/)([a-zA-Z0-9_-]{11})/)
        if (short) ytId = short[1]
        else if (long) ytId = long[1]

        const visual = document.getElementById('hero-visual')
        if (visual && ytId.length === 11) {
          visual.innerHTML = `
            <div class="video-frame">
              <iframe src="https://www.youtube.com/embed/${ytId}?autoplay=1&mute=1&loop=1&playlist=${ytId}&controls=0&modestbranding=1&rel=0&showinfo=0&playsinline=1" allow="autoplay; encrypted-media" allowfullscreen loading="lazy" frameborder="0"></iframe>
            </div>`
        }
      }
    })
  }

  // Mouse-tracking glow on Enroll button
  document.querySelectorAll('.btn-enchant, .cta-primary').forEach((btn) => {
    btn.addEventListener('mousemove', (e: any) => {
      const r = btn.getBoundingClientRect()
      ;(btn as HTMLElement).style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%')
      ;(btn as HTMLElement).style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%')
    })
  })
</script>

<style>
/* ═══════════════════════════════════════════════════════════
   ENCHANTING HERO
   ═══════════════════════════════════════════════════════════ */
.hero-enchant {
  position: relative;
  background: radial-gradient(ellipse at top left, #1e4694 0%, #0b1f3f 60%, #050d1e 100%);
  padding: 80px 0 96px;
  overflow: hidden;
  min-height: 640px;
  color: #fff;
}

/* Animated orbs */
.orb {
  position: absolute; border-radius: 50%; filter: blur(80px);
  pointer-events: none; mix-blend-mode: screen;
  animation: float 14s ease-in-out infinite;
}
.orb-1 { width: 520px; height: 520px; background: rgba(212, 240, 26, 0.18); top: -180px; right: -100px; }
.orb-2 { width: 420px; height: 420px; background: rgba(78, 164, 255, 0.22); bottom: -150px; left: 10%; animation-delay: -5s; }
.orb-3 { width: 300px; height: 300px; background: rgba(255, 107, 157, 0.15); top: 40%; right: 30%; animation-delay: -10s; }
@keyframes float {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33%      { transform: translate(40px, -30px) scale(1.1); }
  66%      { transform: translate(-30px, 40px) scale(0.95); }
}

/* Grid overlay */
.grid-overlay {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
  mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
}

.hero-grid {
  position: relative; z-index: 2;
  display: grid; grid-template-columns: 1.1fr 1fr;
  gap: 60px; align-items: center;
}
@media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; gap: 40px; } }

/* Eyebrow */
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(212, 240, 26, 0.1);
  border: 1px solid rgba(212, 240, 26, 0.25);
  color: var(--lemon, #d4f01a);
  padding: 6px 14px; border-radius: 24px;
  font-size: 12px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1px;
  margin-bottom: 24px;
}
.eyebrow-pulse {
  width: 7px; height: 7px; border-radius: 50%;
  background: #4ade80; box-shadow: 0 0 10px #4ade80;
  animation: pulse-dot 1.5s infinite;
}
@keyframes pulse-dot { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.4); } }

/* Title */
.hero-title {
  font-family: var(--font-display, 'Sora', sans-serif);
  font-size: clamp(2rem, 5vw, 4rem);
  font-weight: 900; line-height: 1.05;
  letter-spacing: -0.02em;
  margin-bottom: 24px;
  color: #fff;
}
.title-line { display: block; }
.gradient-text {
  background: linear-gradient(90deg, #d4f01a 0%, #ffd84e 25%, #ff9c4e 50%, #ff6b9d 75%, #d4f01a 100%);
  background-size: 200% auto;
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  -webkit-text-fill-color: transparent;
  animation: gradient-shift 5s ease infinite;
}
@keyframes gradient-shift { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }

.hero-tagline {
  font-size: 17px;
  color: rgba(255,255,255,0.78);
  line-height: 1.65; max-width: 540px;
  margin-bottom: 36px;
}

/* CTAs */
.hero-actions {
  display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 36px;
}

.cta-primary {
  position: relative; overflow: hidden;
  display: inline-flex; align-items: center; gap: 10px;
  padding: 14px 28px;
  background: linear-gradient(135deg, #d4f01a 0%, #a8e000 50%, #d4f01a 100%);
  background-size: 200% 200%;
  color: #0f2347;
  font-family: var(--font-display, 'Sora', sans-serif);
  font-weight: 800; font-size: 15px;
  border-radius: 12px; text-decoration: none;
  box-shadow: 0 10px 32px rgba(212, 240, 26, 0.4), 0 0 0 1px rgba(15, 35, 71, 0.1);
  transition: all 0.3s ease;
  animation: enchant-shimmer 3s ease infinite;
}
.cta-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 48px rgba(212, 240, 26, 0.6);
}
.cta-shimmer {
  position: absolute; inset: 0;
  background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%), rgba(255,255,255,0.5), transparent 60%);
  opacity: 0; transition: opacity 0.2s; pointer-events: none;
}
.cta-primary:hover .cta-shimmer { opacity: 1; }
.cta-label, .cta-primary svg { position: relative; z-index: 1; }

.cta-whatsapp {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 14px 28px;
  background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
  color: #fff;
  font-family: var(--font-display, 'Sora', sans-serif);
  font-weight: 700; font-size: 15px;
  border-radius: 12px; text-decoration: none;
  box-shadow: 0 8px 24px rgba(37, 211, 102, 0.35);
  transition: all 0.25s ease;
}
.cta-whatsapp:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 36px rgba(37, 211, 102, 0.55);
}

/* Feature pills */
.hero-feature-pills {
  display: flex; gap: 10px; flex-wrap: wrap;
}
.feature-pill {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.85);
  padding: 7px 14px; border-radius: 24px;
  font-size: 12.5px; font-weight: 500;
  backdrop-filter: blur(10px);
}

/* Visual card */
.hero-visual-card {
  position: relative;
  aspect-ratio: 4 / 3;
  background: linear-gradient(135deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.02) 100%);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 24px;
  overflow: hidden;
  box-shadow:
    0 32px 80px rgba(0,0,0,0.4),
    inset 0 1px 0 rgba(255,255,255,0.08);
  backdrop-filter: blur(20px);
}

.visual-content {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 32px;
  text-align: center;
}
.visual-shimmer {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, transparent 30%, rgba(255,255,255,0.06) 50%, transparent 70%);
  transform: translateX(-100%);
  animation: visual-shimmer 4s ease-in-out infinite;
}
@keyframes visual-shimmer {
  0% { transform: translateX(-100%); }
  50%, 100% { transform: translateX(100%); }
}

.visual-logo {
  width: 80px; height: 80px;
  background: linear-gradient(135deg, #d4f01a, #a8e000);
  color: #0f2347;
  border-radius: 20px;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display, 'Sora', sans-serif);
  font-weight: 900; font-size: 40px;
  margin-bottom: 16px;
  box-shadow: 0 12px 32px rgba(212, 240, 26, 0.4);
  position: relative; z-index: 1;
}
.visual-title {
  font-family: var(--font-display); font-size: 32px; font-weight: 900;
  color: #fff; margin-bottom: 4px; letter-spacing: -0.5px;
  position: relative; z-index: 1;
}
.visual-sub {
  font-size: 13px; color: rgba(255,255,255,0.6);
  position: relative; z-index: 1; margin-bottom: 20px;
}
.visual-divider {
  width: 60px; height: 2px;
  background: linear-gradient(90deg, transparent, var(--lemon, #d4f01a), transparent);
  margin-bottom: 20px;
  position: relative; z-index: 1;
}
.visual-stats {
  display: flex; gap: 28px;
  position: relative; z-index: 1;
}
.vs-item { text-align: center; }
.vs-num {
