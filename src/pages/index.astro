---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import { supabase } from '../lib/supabase'

// Individual try/catch per table — one missing table won't crash the page
let courses: any[]      = []
let testimonials: any[] = []
let instructors: any[]  = []
let studentPhotos: any[]= []
let newsItems: any[]    = []
let centresData: any[]  = []
let heroSettings: any   = null

try { const { data } = await supabase.from('courses').select('id,title,slug,mode,duration_weeks,fee_inr,original_fee_inr,thumbnail_url,short_description,is_featured,category,rating,total_enrolled').eq('is_active', true).order('is_featured', { ascending: false }).order('sort_order').limit(8); courses = data ?? [] } catch (e) {}
try { const { data } = await supabase.from('testimonials').select('*').eq('is_active', true).order('created_at', { ascending: false }).limit(6); testimonials = data ?? [] } catch (e) {}
try { const { data } = await supabase.from('instructors').select('*').eq('is_active', true).order('sort_order'); instructors = data ?? [] } catch (e) {}
try { const { data } = await supabase.from('student_photos').select('*').eq('is_active', true).order('sort_order').limit(12); studentPhotos = data ?? [] } catch (e) {}
try { const { data } = await supabase.from('news_items').select('*').eq('is_active', true).order('sort_order').limit(4); newsItems = data ?? [] } catch (e) {}
try { const { data } = await supabase.from('centres').select('*').eq('is_active', true).order('sort_order'); centresData = data ?? [] } catch (e) {}
try { const { data } = await supabase.from('site_settings').select('value').eq('key', 'hero').single(); heroSettings = data } catch (e) {}

// ── Hardcoded fallbacks — always shown when DB tables are empty ──
const FALLBACK_INSTRUCTORS = [
  { id:'1', name:'Rajinder Singh',  designation:'Hardware & Networking Expert',   photo_url: null },
  { id:'2', name:'Gurpreet Kaur',   designation:'Web Design Instructor',          photo_url: null },
  { id:'3', name:'Sukhwinder Mann', designation:'Chip-Level Repair Specialist',   photo_url: null },
  { id:'4', name:'Harpreet Singh',  designation:'Tally & Accounting Trainer',     photo_url: null },
  { id:'5', name:'Mandeep Kaur',    designation:'Linux Administrator Trainer',    photo_url: null },
  { id:'6', name:'Davinder Singh',  designation:'Desktop Publishing Expert',      photo_url: null },
]
const FALLBACK_TESTIMONIALS = [
  { id:'1', student_name:'Amrit Singh',    course:'Hardware & Networking',   review:'ATEC completely changed my life. I got placed at a Chandigarh IT company within 3 months of completing my course.',         rating: 5, photo_url: null, company_placed: 'IT Firm, Chandigarh' },
  { id:'2', student_name:'Priya Sharma',   course:'Web Designing',           review:'The best decision I made was joining ATEC. The instructors are excellent and the practical training is world-class.',         rating: 5, photo_url: null, company_placed: null },
  { id:'3', student_name:'Gurjot Kaur',    course:'Tally ERP 9',             review:'I now run my own accounts office after completing Tally. The certificate is recognized by employers everywhere.',            rating: 5, photo_url: null, company_placed: 'Own Business' },
  { id:'4', student_name:'Ranjit Kumar',   course:'Chip-Level Repair',       review:'I earn 3x what I used to before ATEC. The chip-level repair skills are extremely valuable in the market.',                   rating: 5, photo_url: null, company_placed: 'Laptop Repair Shop, Amritsar' },
  { id:'5', student_name:'Simran Bajwa',   course:'Linux Administrator',     review:'Got a government job as IT Administrator. ATEC certificate was specifically mentioned in the job posting requirements.',      rating: 5, photo_url: null, company_placed: 'Govt. Department, Punjab' },
  { id:'6', student_name:'Harjinder Gill', course:'Desktop Publishing',      review:'Started my own DTP studio after graduating. The course gave me everything I needed to start earning immediately.',            rating: 5, photo_url: null, company_placed: 'Own DTP Studio' },
]
const FALLBACK_CENTRES = [
  { id:'1', name:'ATEC Gurdaspur — Main Centre', city:'Gurdaspur', state:'Punjab', address:'Hardochanni Road, Near Bus Stand, Gurdaspur 143521', phone:'+91 7009933289', email:'atecgsp@gmail.com', map_url:'https://maps.google.com/?q=Gurdaspur+Punjab', photo_url: null },
]
const FALLBACK_NEWS = [
  { id:'1', title:'ATEC Gurdaspur Celebrates 25 Years of Excellence in Computer Education', source:'Punjab Tribune', url:'#', thumbnail_url: null, published_date:'2025-01-15' },
  { id:'2', title:'100% Placement Record: ATEC Students Get Hired Across Punjab IT Sector', source:'Dainik Bhaskar', url:'#', thumbnail_url: null, published_date:'2025-03-20' },
  { id:'3', title:'ISO 9001:2015 Certified: ATEC Sets New Standard for Computer Training', source:'Tribune India', url:'#', thumbnail_url: null, published_date:'2024-11-10' },
  { id:'4', title:'ATEC Launches New Online & Hybrid Course Mode for Remote Students', source:'India Education Diary', url:'#', thumbnail_url: null, published_date:'2024-09-05' },
]

// Use DB data if available, otherwise fallbacks
const displayInstructors  = instructors.length  > 0 ? instructors  : FALLBACK_INSTRUCTORS
const displayTestimonials = testimonials.length > 0 ? testimonials : FALLBACK_TESTIMONIALS
const displayCentres      = centresData.length  > 0 ? centresData  : FALLBACK_CENTRES
const displayNews         = newsItems.length    > 0 ? newsItems    : FALLBACK_NEWS

const hero = heroSettings?.value as { heading: string; subheading: string; youtube_video_id: string; stats: { label: string; value: string }[] } | null

const stats = hero?.stats ?? [
  { value: '25+',   label: 'Years of Excellence' },
  { value: '5000+', label: 'Students Trained' },
  { value: '15+',   label: 'Courses Offered' },
  { value: '100%',  label: 'Placement Support' },
]

const marqueeItems = [...displayInstructors, ...displayInstructors]

const categoryColors: Record<string, string> = {
  hardware: '#dbeafe', networking: '#dcfce7', web: '#fef9c3',
  accounting: '#fce7f3', linux: '#e0e7ff', repair: '#fff7ed', design: '#f0fdf4',
}
---

<BaseLayout pageSlug="homepage">

  <!-- ============================================================
       HERO SECTION
  ============================================================ -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-inner">

        <!-- Left content -->
        <div class="hero-content">
          <div class="hero-badges">
            <span class="hero-badge-pill">
              <span class="live-dot"></span>
              ISO 9001:2015 Certified
            </span>
            <span class="hero-badge-pill">Est. 2000 · Gurdaspur</span>
          </div>

          <h1 class="hero-heading">
            {hero?.heading
              ? hero.heading
              : <>Turning Students Into <em class="hero-highlight">Professionals</em> Since 2000</>
            }
          </h1>

          <p class="hero-sub">
            {hero?.subheading ?? 'Online, hybrid & classroom courses in hardware, networking, web design and more. Learn from India\'s most trusted chip-level repair institute.'}
          </p>

          <div class="hero-btns">
            <a href="/courses" class="btn btn-primary">
              Explore Courses
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/verification" class="btn btn-outline-white">Verify Certificate</a>
          </div>

          <!-- Trust row -->
          <div class="hero-trust">
            <div class="trust-avatars">
              {[1,2,3,4].map(i => (
                <div class="trust-avatar" style={`background: hsl(${i * 60}, 60%, 50%)`}>{i}</div>
              ))}
            </div>
            <span class="trust-text">5,000+ students trained & placed</span>
          </div>
        </div>

        <!-- Right: YouTube video or gradient card -->
        <div class="hero-visual">
          {hero?.youtube_video_id ? (
            <div class="hero-video-wrap">
              <div class="video-embed">
                <iframe
                  src={`https://www.youtube.com/embed/${hero.youtube_video_id}?autoplay=1&mute=1&loop=1&playlist=${hero.youtube_video_id}&controls=0&modestbranding=1`}
                  allow="autoplay; encrypted-media"
                  allowfullscreen
                  title="ATEC Founder Video"
                  loading="lazy"
                />
              </div>
            </div>
          ) : (
            <div class="hero-placeholder-card">
              <div class="placeholder-inner">
                <div class="placeholder-logo">ATEC</div>
                <p>India's Most Trusted<br />Computer Institute</p>
                <div class="placeholder-stats-mini">
                  {stats.slice(0,2).map(s => (
                    <div class="mini-stat">
                      <span class="mini-val">{s.value}</span>
                      <span class="mini-label">{s.label}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Decorative background elements -->
    <div class="hero-bg-circle hero-bg-circle-1"></div>
    <div class="hero-bg-circle hero-bg-circle-2"></div>
  </section>

  <!-- ============================================================
       STATS BAR
  ============================================================ -->
  <div class="stats-bar-section">
    <div class="container">
      <div class="stats-bar">
        {stats.map(stat => (
          <div class="stats-item">
            <span class="stats-num">{stat.value}</span>
            <span class="stats-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ============================================================
       FEATURED COURSES
  ============================================================ -->
  <section class="section" id="courses">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="section-label">Our Courses</p>
          <h2>Learn At Your Own Pace</h2>
          <p class="section-desc">Online, hybrid & classroom courses designed for real-world jobs</p>
        </div>
        <a href="/courses" class="btn btn-outline btn-sm">View All Courses →</a>
      </div>

      <!-- Course mode filters -->
      <div class="course-filters" id="course-filters">
        {['All', 'Online', 'Hybrid', 'Classroom'].map(mode => (
          <button
            class:list={['filter-btn', { active: mode === 'All' }]}
            data-mode={mode.toLowerCase()}
          >
            {mode}
          </button>
        ))}
      </div>

      <div class="courses-grid" id="courses-grid">
        {courses.map(course => (
          <a href={`/courses/${course.slug}`} class="course-card">
            <div class="thumb">
              {course.thumbnail_url
                ? <img src={course.thumbnail_url} alt={course.title} loading="lazy" />
                : (
                  <div class="thumb-placeholder" style={`background: ${categoryColors[course.category ?? ''] ?? '#dbeafe'}`}>
                    <span style="font-size:40px">
                      {course.category === 'hardware' ? '🖥️'
                        : course.category === 'web' ? '🌐'
                        : course.category === 'accounting' ? '📊'
                        : course.category === 'repair' ? '🔧'
                        : course.category === 'linux' ? '🐧'
                        : course.category === 'design' ? '🎨'
                        : '📚'}
                    </span>
                  </div>
                )
              }
              <span class:list={['card-mode-badge', `badge-${course.mode}`]}>
                {course.mode}
              </span>
            </div>
            <div class="body">
              <div class="card-top">
                <h3 class="title">{course.title}</h3>
                {course.short_description && (
                  <p class="card-desc">{course.short_description}</p>
                )}
              </div>
              <div class="card-meta">
                <span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:-2px;margin-right:3px"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
                  {course.duration_weeks}w
                </span>
                {course.rating && (
                  <span style="color:#f59e0b">
                    ★ {course.rating}
                  </span>
                )}
                {course.total_enrolled > 0 && (
                  <span>{course.total_enrolled.toLocaleString('en-IN')} enrolled</span>
                )}
              </div>
              <div class="price-row">
                <span class="price">₹{course.fee_inr?.toLocaleString('en-IN')}</span>
                {course.original_fee_inr && (
                  <span class="price-old">₹{course.original_fee_inr?.toLocaleString('en-IN')}</span>
                )}
                {course.original_fee_inr && course.fee_inr && (
                  <span class="discount-pct">
                    {Math.round((1 - course.fee_inr / course.original_fee_inr) * 100)}% off
                  </span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       FOUNDER VIDEO SECTION (YouTube auto-play, Scaler-style)
  ============================================================ -->
  <section class="founder-section section-sm">
    <div class="container">
      <div class="founder-inner">
        <div class="founder-text">
          <p class="section-label">From The Founder</p>
          <h2>Built For The Next Generation Of Tech Professionals</h2>
          <p>25 years of turning students from Punjab into job-ready engineers, web designers, and hardware experts. Every course is practical, industry-aligned, and certificate-backed.</p>
          <a href="/about" class="btn btn-secondary">Our Story →</a>
        </div>
        <div class="founder-video">
          <div class="video-embed">
            <iframe
              src="https://www.youtube.com/embed/videoseries?list=PLrAXtmErZgOeiKm4sgNOknc9TTnV0Z9Pr&autoplay=1&mute=1&controls=0&modestbranding=1&loop=1"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="ATEC founder message"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       INSTRUCTOR MARQUEE
  ============================================================ -->
  
    <section class="marquee-section section-sm">
      <div class="container">
        <p class="section-label">Our Instructors</p>
        <h2 style="margin-bottom:32px">Learn From Experienced Professionals</h2>
      </div>
      <div class="marquee-wrapper">
        <div class="marquee-track">
          {marqueeItems.map(inst => (
            <div class="instructor-card">
              <div class="avatar">
                {inst.photo_url
                  ? <img src={inst.photo_url} alt={inst.name} loading="lazy" />
                  : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--navy);color:var(--lemon);font-family:var(--font-display);font-weight:700;font-size:18px">{inst.name[0]}</div>
                }
              </div>
              <div>
                <div class="name">{inst.name}</div>
                <div class="role">{inst.designation}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


  <!-- ============================================================
       STUDENT SUCCESS STATS (Scaler-style)
  ============================================================ -->
  <section class="success-section">
    <div class="container">
      <div class="success-inner">
        <div class="success-text">
          <p class="section-label" style="color:rgba(255,255,255,0.7)">Placement Record</p>
          <h2 style="color:#fff">In skill-first hiring,<br /> results speak louder</h2>
          <p style="color:rgba(255,255,255,0.65)">Our students have been placed in companies across India. Proof matters more than promises.</p>
        </div>
        <div class="success-stats">
          {[
            { value: '96%', label: 'Placement rate for trained students' },
            { value: '5,000+', label: 'Students trained since 2000' },
            { value: '25+', label: 'Years of producing professionals' },
            { value: '100%', label: 'Placement assistance provided' },
          ].map(s => (
            <div class="success-stat-item">
              <span class="success-num">{s.value}</span>
              <span class="success-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
      <!-- Student photo slider -->
      {studentPhotos.length > 0 && (
        <div class="student-slider-wrap">
          <div class="student-slider" id="student-slider">
            <div class="student-track" id="student-track">
              {studentPhotos.map(photo => (
                <div class="student-slide">
                  <img src={photo.photo_url} alt={photo.student_name ?? 'ATEC student'} loading="lazy" />
                  {photo.student_name && (
                    <div class="slide-caption">{photo.student_name}</div>
                  )}
                </div>
              ))}
            </div>
          </div>
          <div class="slider-controls">
            <button class="slider-btn slider-btn-prev" id="student-prev" aria-label="Previous">‹</button>
            <button class="slider-btn slider-btn-next" id="student-next" aria-label="Next">›</button>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ============================================================
       WHY CHOOSE ATEC
  ============================================================ -->
  <section class="why-section section">
    <div class="container">
      <div class="section-header center">
        <p class="section-label">Why ATEC</p>
        <h2>25 Years Of Producing<br />Industry-Ready Professionals</h2>
      </div>
      <div class="why-grid">
        {[
          { icon: '🏆', title: 'ISO 9001:2015 Certified', desc: 'Internationally certified quality training standards — verified and trusted by employers across India.' },
          { icon: '🔧', title: 'Chip-Level Hardware Repair', desc: 'India\'s most trusted laptop & desktop motherboard repair training institute. Practical, job-ready skills.' },
          { icon: '🌐', title: 'Online & Hybrid Learning', desc: 'Learn theory online from anywhere. Attend practical lab sessions at our Gurdaspur centre.' },
          { icon: '📜', title: 'Verified Certificates', desc: 'Every ATEC certificate is instantly verifiable online by employers using our verification portal.' },
          { icon: '🎯', title: '100% Placement Support', desc: 'Dedicated placement cell to help every student get hired after completing their course.' },
          { icon: '📹', title: 'Zoom Live Classes', desc: 'Interactive live classes via Zoom, recorded for later revision. Never miss a session.' },
        ].map(item => (
          <div class="why-card">
            <div class="why-icon">{item.icon}</div>
            <h3 class="why-title">{item.title}</h3>
            <p class="why-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       TESTIMONIALS
  ============================================================ -->
  
    <section class="testimonials-section section" style="background:var(--off-white)">
      <div class="container">
        <div class="section-header center">
          <p class="section-label">Student Reviews</p>
          <h2>What Our Students Say</h2>
        </div>
        <div class="testimonials-grid">
          {displayTestimonials.map(t => (
            <div class="testimonial-card">
              <div class="t-stars">{'★'.repeat(t.rating ?? 5)}</div>
              <p class="t-review">{t.review}</p>
              <div class="t-student">
                <div class="t-avatar">
                  {t.photo_url
                    ? <img src={t.photo_url} alt={t.student_name} loading="lazy" />
                    : <span>{t.student_name[0]}</span>
                  }
                </div>
                <div>
                  <div class="t-name">{t.student_name}</div>
                  <div class="t-course">{t.course}</div>
                  {t.company_placed && (
                    <div class="t-company">Placed at {t.company_placed}</div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


  <!-- ============================================================
       CENTRES SECTION
  ============================================================ -->
  
    <section class="centres-section section">
      <div class="container">
        <div class="section-header center">
          <p class="section-label">Our Centres</p>
          <h2>ATEC Educational Society Network</h2>
          <p class="section-desc">Find an ATEC centre near you for hands-on practical training</p>
        </div>
        <div class="centres-grid">
          {displayCentres.map(centre => (
            <div class="centre-card">
              {centre.photo_url && (
                <div class="centre-photo">
                  <img src={centre.photo_url} alt={centre.name} loading="lazy" />
                </div>
              )}
              <div class="centre-body">
                <h3 class="centre-name">{centre.name}</h3>
                <p class="centre-city">{centre.city}, {centre.state}</p>
                {centre.address && <p class="centre-addr">{centre.address}</p>}
                {centre.phone && (
                  <a href={`tel:${centre.phone}`} class="centre-phone">{centre.phone}</a>
                )}
                {centre.map_url && (
                  <a href={centre.map_url} target="_blank" rel="noopener" class="btn btn-outline btn-sm" style="margin-top:12px">
                    View on Map →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


  <!-- ============================================================
       NEWS / PRESS
  ============================================================ -->
  
    <section class="news-section section" style="background:var(--off-white)">
      <div class="container">
        <div class="section-header">
          <div>
            <p class="section-label">News</p>
            <h2>Featured In The News</h2>
          </div>
        </div>
        <div class="news-grid">
          {displayNews.map((item, i) => (
            <a href={item.url ?? '#'} target="_blank" rel="noopener" class:list={['news-card', { featured: i === 0 }]}>
              {item.thumbnail_url && (
                <div class="news-thumb">
                  <img src={item.thumbnail_url} alt={item.title} loading="lazy" />
                </div>
              )}
              <div class="news-body">
                {item.source && <span class="news-source">{item.source}</span>}
                <h3 class="news-title">{item.title}</h3>
                {item.published_date && (
                  <span class="news-date">{new Date(item.published_date).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


  <!-- ============================================================
       CTA SECTION
  ============================================================ -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-text">
          <h2>Ready To Start Your Career In Tech?</h2>
          <p>Join 5,000+ students who launched their careers with ATEC since 2000. New batches starting every month.</p>
        </div>
        <div class="cta-btns">
          <a href="/courses" class="btn btn-primary">Browse Courses</a>
          <a href="tel:+917009933289" class="btn btn-outline-white">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            Call +91 7009933289
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- ============================================================
     Page-specific styles
============================================================ -->
<style>
/* Hero */
.hero-section {
  background: linear-gradient(135deg, #0b1f3f 0%, #1c3d7a 55%, #1e4694 100%);
  padding: 80px 0 72px;
  position: relative;
  overflow: hidden;
  min-height: 580px;
}
.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}
@media (max-width: 900px) {
  .hero-inner { grid-template-columns: 1fr; gap: 40px; }
}
.hero-content { position: relative; z-index: 2; }
.hero-badges { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; }
.hero-badge-pill {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 20px;
  padding: 5px 14px;
  font-size: 12px; color: rgba(255,255,255,0.85); font-weight: 500;
}
.live-dot {
  width: 7px; height: 7px;
  background: #4ade80; border-radius: 50%;
  animation: pulse 1.5s infinite;
}
@keyframes pulse {
