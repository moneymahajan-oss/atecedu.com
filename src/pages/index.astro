  <div
    id="bottom-cta-bar"
    style={`
      position:fixed;bottom:0;left:0;right:0;z-index:10001;
      background:${bottomBarBg};padding:14px 24px;
      display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;
