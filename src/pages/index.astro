<!-- ══════════════════════════════════════════════════════════════
     YOUTUBE / BLOG / PODCAST / NEWS — runtime loaders
     Each section: hidden by default, shown only when DB has data.
     No rebuild needed — content updates instantly from admin panel.
══════════════════════════════════════════════════════════════ -->
<script>
;(function() {

  // ── Shared helpers ────────────────────────────────────────────────────────

  function waitForSB(cb: () => void) {
    if ((window as any).__SB_URL) { cb(); return }
    let n = 0
    const t = setInterval(() => {
      n++
      if ((window as any).__SB_URL || n > 40) { clearInterval(t); cb() }
    }, 50)
  }

  function show(id: string) {
    const el = document.getElementById(id)
    if (el) el.style.display = ''
  }

  function ytThumb(id: string) {
    return `https://img.youtube.com/vi/${id}/mqdefault.jpg`
  }

  // ── YOUTUBE VIDEOS ────────────────────────────────────────────────────────
  async function loadYouTube() {
    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string
    if (!SB_URL || !SB_KEY) return
    try {
      const res = await fetch(
        `${SB_URL}/rest/v1/youtube_videos?is_active=eq.true&order=sort_order.asc.nullslast,created_at.desc&limit=6&select=*`,
        { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
      )
      if (!res.ok) return
      const rows = await res.json()
      if (!Array.isArray(rows) || rows.length === 0) return

      const grid = document.getElementById('yt-grid')
      if (!grid) return
      grid.innerHTML = ''

      rows.forEach((v: any) => {
        const videoId = v.video_id || ''
        const thumb   = v.thumbnail_url || (videoId ? ytThumb(videoId) : '')
        const card    = document.createElement('a')
        card.href     = videoId ? `https://www.youtube.com/watch?v=${videoId}` : '#'
        card.target   = '_blank'
        card.rel      = 'noopener'
        card.style.cssText = 'display:block;text-decoration:none;background:#fff;border:1px solid #e8ecf0;border-radius:14px;overflow:hidden;transition:box-shadow 0.2s,transform 0.2s;box-shadow:0 2px 8px rgba(0,0,0,0.06);'
        card.onmouseover = () => { card.style.boxShadow='0 8px 28px rgba(0,0,0,0.12)'; card.style.transform='translateY(-3px)' }
        card.onmouseout  = () => { card.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'; card.style.transform='translateY(0)' }

        card.innerHTML = `
          <div style="position:relative;aspect-ratio:16/9;background:#111;overflow:hidden;">
            ${thumb ? `<img src="${thumb}" alt="${v.title}" style="width:100%;height:100%;object-fit:cover;" loading="lazy">` : '<div style="width:100%;height:100%;background:#0f2a5c;display:flex;align-items:center;justify-content:center;"><svg width="40" height="40" viewBox="0 0 24 24" fill="#d4f01a"><polygon points="8,5 20,12 8,19"/></svg></div>'}
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.2);opacity:0;transition:opacity 0.2s;" class="yt-play-hover">
              <div style="width:52px;height:52px;background:#ff0000;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#fff" style="margin-left:3px"><polygon points="8,5 20,12 8,19"/></svg>
              </div>
            </div>
            ${v.duration ? `<span style="position:absolute;bottom:8px;right:8px;background:rgba(0,0,0,0.8);color:#fff;font-size:11px;font-weight:700;padding:2px 7px;border-radius:4px;">${v.duration}</span>` : ''}
          </div>
          <div style="padding:14px 16px;">
            <h3 style="font-family:'Sora',sans-serif;font-size:14px;font-weight:700;color:#1c1c1c;margin:0 0 6px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${v.title}</h3>
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <span style="font-size:12px;color:#64748b;">${v.channel_name || 'ATEC'}</span>
              ${v.view_count ? `<span style="font-size:11px;color:#94a3b8;">${v.view_count} views</span>` : ''}
            </div>
          </div>`

        // Hover play overlay
        card.onmouseover = () => {
          card.style.boxShadow = '0 8px 28px rgba(0,0,0,0.12)'
          card.style.transform = 'translateY(-3px)'
          const ph = card.querySelector('.yt-play-hover') as HTMLElement
          if (ph) ph.style.opacity = '1'
        }
        card.onmouseout = () => {
          card.style.boxShadow = '0 2px 8px rgba(0,0,0,0.06)'
          card.style.transform = 'translateY(0)'
          const ph = card.querySelector('.yt-play-hover') as HTMLElement
          if (ph) ph.style.opacity = '0'
        }

        grid.appendChild(card)
      })

      show('yt-section')
    } catch(e) { console.warn('[ATEC YT]', e) }
  }

  // ── BLOG POSTS ────────────────────────────────────────────────────────────
  async function loadBlog() {
    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string
    if (!SB_URL || !SB_KEY) return
    try {
      const res = await fetch(
        `${SB_URL}/rest/v1/blog_posts?is_published=eq.true&order=published_at.desc&limit=3&select=title,slug,excerpt,thumbnail_url,author,published_at,category,read_time_mins`,
        { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
      )
      if (!res.ok) return
      const rows = await res.json()
      if (!Array.isArray(rows) || rows.length === 0) return

      const grid = document.getElementById('blog-grid')
      if (!grid) return
      grid.innerHTML = ''

      rows.forEach((p: any) => {
        const date = p.published_at ? new Date(p.published_at).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) : ''
        const card = document.createElement('a')
        card.href  = `/blog/${p.slug}`
        card.style.cssText = 'display:block;text-decoration:none;background:#fff;border:1px solid #e8ecf0;border-radius:16px;overflow:hidden;transition:box-shadow 0.2s,transform 0.2s;box-shadow:0 2px 8px rgba(0,0,0,0.06);'
        card.onmouseover = () => { card.style.boxShadow='0 8px 28px rgba(0,0,0,0.12)'; card.style.transform='translateY(-3px)' }
        card.onmouseout  = () => { card.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'; card.style.transform='translateY(0)' }

        card.innerHTML = `
          <div style="aspect-ratio:16/9;background:#0f2a5c;overflow:hidden;display:flex;align-items:center;justify-content:center;position:relative;">
            ${p.thumbnail_url
              ? `<img src="${p.thumbnail_url}" alt="${p.title}" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;" loading="lazy">`
              : `<span style="font-family:'Sora',sans-serif;font-size:3rem;color:#d4f01a;opacity:0.6;">📝</span>`}
            ${p.category ? `<span style="position:absolute;top:10px;left:10px;background:#d4f01a;color:#1a1a1a;font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;">${p.category}</span>` : ''}
          </div>
          <div style="padding:18px;">
            <h3 style="font-family:'Sora',sans-serif;font-size:16px;font-weight:700;color:#1c1c1c;margin:0 0 8px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${p.title}</h3>
            <p style="font-size:13px;color:#64748b;margin:0 0 14px;line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${p.excerpt || ''}</p>
            <div style="display:flex;justify-content:space-between;align-items:center;font-size:12px;color:#94a3b8;">
              <span>${p.author || 'ATEC Team'}</span>
              <span>${date}${p.read_time_mins ? ` · ${p.read_time_mins} min read` : ''}</span>
            </div>
          </div>`

        grid.appendChild(card)
      })

      show('blog-section')
    } catch(e) { console.warn('[ATEC Blog]', e) }
  }

  // ── PODCAST EPISODES ──────────────────────────────────────────────────────
  async function loadPodcast() {
    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string
    if (!SB_URL || !SB_KEY) return
    try {
      const res = await fetch(
        `${SB_URL}/rest/v1/podcast_episodes?is_published=eq.true&order=sort_order.asc.nullslast,published_at.desc&limit=4&select=*`,
        { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
      )
      if (!res.ok) return
      const rows = await res.json()
      if (!Array.isArray(rows) || rows.length === 0) return

      const grid = document.getElementById('podcast-grid')
      if (!grid) return
      grid.innerHTML = ''

      rows.forEach((ep: any) => {
        const ytId  = ep.youtube_url?.match(/(?:v=|youtu\.be\/)([A-Za-z0-9_-]{11})/)?.[1] || ''
        const thumb = ep.thumbnail_url || (ytId ? ytThumb(ytId) : '')
        const card  = document.createElement('div')
        card.style.cssText = 'background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:14px;overflow:hidden;display:flex;gap:0;flex-direction:column;'

        card.innerHTML = `
          <div style="display:flex;gap:14px;padding:16px;align-items:flex-start;">
            <div style="flex-shrink:0;width:72px;height:72px;border-radius:10px;overflow:hidden;background:#0f2a5c;">
              ${thumb ? `<img src="${thumb}" alt="${ep.title}" style="width:100%;height:100%;object-fit:cover;" loading="lazy">` : '<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:2rem;">🎙️</div>'}
            </div>
            <div style="flex:1;min-width:0;">
              ${ep.episode_number ? `<span style="font-size:11px;color:#d4f01a;font-weight:700;">EP ${ep.episode_number}${ep.season_number > 1 ? ' · S'+ep.season_number : ''}</span>` : ''}
              <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:14px;color:#fff;margin:3px 0 4px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${ep.title}</h3>
              ${ep.guest_name ? `<p style="font-size:12px;color:rgba(255,255,255,0.5);margin:0;">with ${ep.guest_name}${ep.guest_designation ? ', '+ep.guest_designation : ''}</p>` : ''}
              ${ep.duration ? `<p style="font-size:11px;color:rgba(255,255,255,0.4);margin:4px 0 0;">⏱ ${ep.duration}</p>` : ''}
            </div>
          </div>
          <div style="display:flex;gap:8px;padding:0 16px 14px;flex-wrap:wrap;">
            ${ytId ? `<a href="https://www.youtube.com/watch?v=${ytId}" target="_blank" rel="noopener" style="font-size:12px;font-weight:700;color:#fff;background:#ff0000;padding:5px 12px;border-radius:6px;text-decoration:none;display:flex;align-items:center;gap:4px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="#fff"><polygon points="8,5 20,12 8,19"/></svg>Watch</a>` : ''}
            ${ep.spotify_url ? `<a href="${ep.spotify_url}" target="_blank" rel="noopener" style="font-size:12px;font-weight:700;color:#fff;background:#1DB954;padding:5px 12px;border-radius:6px;text-decoration:none;">🎵 Spotify</a>` : ''}
            ${ep.audio_url ? `<a href="${ep.audio_url}" target="_blank" rel="noopener" style="font-size:12px;font-weight:700;color:#d4f01a;background:rgba(212,240,26,0.15);border:1px solid rgba(212,240,26,0.3);padding:5px 12px;border-radius:6px;text-decoration:none;">▶ Listen</a>` : ''}
          </div>`

        grid.appendChild(card)
      })

      show('podcast-section')
    } catch(e) { console.warn('[ATEC Podcast]', e) }
  }

  // ── NEWS ITEMS ────────────────────────────────────────────────────────────
  async function loadNews() {
    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string
    if (!SB_URL || !SB_KEY) return
    try {
      const res = await fetch(
        `${SB_URL}/rest/v1/news_items?is_active=eq.true&order=sort_order.asc.nullslast,created_at.desc&limit=4&select=*`,
        { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
      )
      if (!res.ok) return
      const rows = await res.json()
      if (!Array.isArray(rows) || rows.length === 0) return

      const grid = document.getElementById('news-grid')
      if (!grid) return
      grid.innerHTML = ''

      rows.forEach((n: any) => {
        const date = n.published_at || n.created_at
          ? new Date(n.published_at || n.created_at).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'})
          : ''
        const card = document.createElement('div')
        card.style.cssText = 'background:#fff;border:1px solid #e8ecf0;border-radius:14px;padding:20px;display:flex;flex-direction:column;gap:10px;box-shadow:0 2px 8px rgba(0,0,0,0.05);'

        card.innerHTML = `
          ${n.category ? `<span style="font-size:11px;font-weight:700;color:#0f2a5c;background:#eff6ff;padding:2px 10px;border-radius:20px;display:inline-block;width:fit-content;">${n.category}</span>` : ''}
          <h3 style="font-family:'Sora',sans-serif;font-weight:700;font-size:15px;color:#1c1c1c;margin:0;line-height:1.4;">${n.title || ''}</h3>
          ${n.description || n.excerpt ? `<p style="font-size:13px;color:#64748b;margin:0;line-height:1.55;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">${n.description || n.excerpt}</p>` : ''}
          <div style="display:flex;justify-content:space-between;align-items:center;margin-top:auto;">
            ${date ? `<span style="font-size:12px;color:#94a3b8;">${date}</span>` : '<span></span>'}
            ${n.link || n.url ? `<a href="${n.link || n.url}" target="_blank" rel="noopener" style="font-size:12px;font-weight:700;color:#0f2a5c;text-decoration:none;">Read more →</a>` : ''}
          </div>`

        grid.appendChild(card)
      })

      show('news-section')
    } catch(e) { console.warn('[ATEC News]', e) }
  }

  // ── Boot all loaders ──────────────────────────────────────────────────────
  function bootAll() {
    waitForSB(() => {
      loadYouTube()
      loadBlog()
      loadPodcast()
      loadNews()
    })
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bootAll)
  else bootAll()

})()
</script>

</BaseLayout>

<!-- ══════════════════════════════════════════════════════════════
     VIDEO OVERLAY + HERO LIVE SETTINGS + BOTTOM BAR
     (UNCHANGED from previous fix — all 5 fixes intact)
══════════════════════════════════════════════════════════════ -->
<script>
  ;(function() {
    const SB_URL   = (window as any).__SB_URL as string
    const SB_KEY   = (window as any).__SB_KEY as string
    const FALLBACK_YT = 'oEK34ybNFdQ'

    let videoType      = 'youtube'
    let activeId       = FALLBACK_YT
    let activeInstaUrl = ''
    let activeVideoUrl = ''

    let revealDone   = false
    let preloadEl: HTMLIFrameElement | null = null
    let tickTimer: ReturnType<typeof setInterval> | null = null
    let secs         = 3

    function ytId(raw: string): string {
      if (!raw?.trim()) return ''
      raw = raw.trim()
      let m: RegExpMatchArray | null
      if ((m = raw.match(/youtu\.be\/([A-Za-z0-9_-]{11})/)))  return m[1]
      if ((m = raw.match(/[?&]v=([A-Za-z0-9_-]{11})/)))       return m[1]
      if ((m = raw.match(/\/embed\/([A-Za-z0-9_-]{11})/)))     return m[1]
      if ((m = raw.match(/\/shorts\/([A-Za-z0-9_-]{11})/)))    return m[1]
      if (/^[A-Za-z0-9_-]{11}$/.test(raw))                    return raw
      return ''
    }

    function instaEmbedUrl(raw: string): string {
      if (!raw?.trim()) return ''
      raw = raw.trim()
      const m = raw.match(/instagram\.com\/(?:reel|p)\/([A-Za-z0-9_-]+)/)
      if (m) return `https://www.instagram.com/reel/${m[1]}/embed/`
      if (raw.includes('instagram.com') && raw.includes('/embed')) return raw
      return ''
    }

    function buildSrc(muted: boolean): string {
      if (videoType === 'instagram') return activeInstaUrl
      if (videoType === 'facebook') {
        return `https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(activeVideoUrl)}&show_text=false&autoplay=true`
      }
      if (videoType === 'vimeo') {
        const vm = activeVideoUrl.match(/vimeo\.com\/(\d+)/)
        return vm ? `https://player.vimeo.com/video/${vm[1]}?autoplay=1&muted=${muted?1:0}&loop=1` : ''
      }
      if (videoType === 'direct') return activeVideoUrl
      const m = muted ? '&mute=1' : ''
      return `https://www.youtube.com/embed/${activeId}?autoplay=1${m}&loop=1&playlist=${activeId}&controls=1&rel=0&modestbranding=1`
    }

    function injectCardIframe(id: string, type: string) {
      const card = document.getElementById('hero-thumb') as HTMLElement
      if (!card) return
      const old = document.getElementById('card-iframe')
      if (old) old.remove()
      if (type === 'direct' && activeVideoUrl) {
        const v = document.createElement('video')
        v.id = 'card-iframe'
        v.src = activeVideoUrl
        v.muted = true; v.loop = true; v.autoplay = true; v.playsInline = true
        v.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:14px;pointer-events:none;'
        card.insertBefore(v, card.firstChild)
        return
      }
      const f = document.createElement('iframe')
      f.id = 'card-iframe'
      const src = buildSrc(true)
      if (!src) return
      f.src = src
      f.setAttribute('allow', 'autoplay; encrypted-media; fullscreen; picture-in-picture')
      f.setAttribute('allowfullscreen', '')
      f.setAttribute('frameborder', '0')
      f.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none;border-radius:14px;pointer-events:none;'
      card.insertBefore(f, card.firstChild)
    }

    function startPreload(id: string) {
      if (videoType !== 'youtube') return
      if (preloadEl) { preloadEl.remove(); preloadEl = null }
      const f = document.createElement('iframe')
      f.id  = 'yt-preload-iframe'
      f.src = `https://www.youtube.com/embed/${id}?autoplay=1&mute=1&loop=1&playlist=${id}&controls=1&rel=0&modestbranding=1`
      f.setAttribute('allow', 'autoplay; encrypted-media; fullscreen; picture-in-picture')
      f.setAttribute('allowfullscreen', '')
      f.style.cssText = 'position:fixed;bottom:2px;right:2px;width:4px;height:4px;border:none;z-index:1;opacity:0.01;pointer-events:none;'
      document.body.appendChild(f)
      preloadEl = f
    }

    const cdEl = document.getElementById('reveal-countdown') as HTMLElement

    function startTick() {
      if (tickTimer) return
      tickTimer = setInterval(() => {
        secs--
        if (cdEl) cdEl.textContent = String(Math.max(secs, 0))
        if (secs <= 0) {
          clearInterval(tickTimer!); tickTimer = null
          const badge = document.getElementById('reveal-hint')
          if (badge) badge.style.display = 'none'
          doReveal()
        }
      }, 1000)
    }

    function doReveal() {
      if (revealDone) return
      revealDone = true
      const ov   = document.getElementById('video-overlay')    as HTMLElement
      const wrap = document.getElementById('video-iframe-wrap') as HTMLElement
      const hc   = document.getElementById('hero-content')     as HTMLElement
      if (videoType === 'youtube' && preloadEl && wrap) {
        preloadEl.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none;opacity:1;pointer-events:all;'
        wrap.innerHTML = ''
        wrap.appendChild(preloadEl)
        preloadEl = null
      } else {
        const f = document.createElement('iframe')
        f.src = buildSrc(true)
        f.setAttribute('allow', 'autoplay; encrypted-media; fullscreen; picture-in-picture')
        f.setAttribute('allowfullscreen', '')
        f.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none;'
        if (wrap) { wrap.innerHTML = ''; wrap.appendChild(f) }
      }
      const hint = document.getElementById('unmute-hint') as HTMLElement
      if (hint) hint.style.display = 'inline-flex'
      const bar = document.getElementById('bottom-cta-bar') as HTMLElement
      if (bar) bar.style.transform = 'translateY(0)'
      ov.style.pointerEvents = 'all'
      requestAnimationFrame(() => {
        ov.style.transition   = 'transform 1s cubic-bezier(0.16,1,0.3,1), opacity 0.6s ease, border-radius 1s ease'
        ov.style.transform    = 'scale(1)'
        ov.style.opacity      = '1'
        ov.style.borderRadius = '0'
      })
      if (hc) { hc.style.transition = 'opacity 0.6s ease'; hc.style.opacity = '0.08'; hc.style.pointerEvents = 'none' }
    }

    function closeOverlay() {
      const ov   = document.getElementById('video-overlay') as HTMLElement
      const hc   = document.getElementById('hero-content')  as HTMLElement
      const hint = document.getElementById('unmute-hint')   as HTMLElement
      const bar  = document.getElementById('bottom-cta-bar') as HTMLElement
      ov.style.transition    = 'transform 0.5s ease, opacity 0.4s ease, border-radius 0.5s ease'
      ov.style.transform     = 'scale(0.07)'
      ov.style.opacity       = '0'
      ov.style.borderRadius  = '24px'
      ov.style.pointerEvents = 'none'
      if (hint) hint.style.display = 'none'
      if (hc)  { hc.style.opacity = '1'; hc.style.pointerEvents = 'all' }
      if (bar) bar.style.transform = 'translateY(100%)'
      setTimeout(() => {
        const wrap = document.getElementById('video-iframe-wrap') as HTMLElement
        if (wrap) wrap.innerHTML = ''
        ov.style.transition = 'none'
        revealDone = false
        if (videoType === 'youtube') startPreload(activeId)
      }, 520)
    }

    document.getElementById('video-close-btn')?.addEventListener('click', closeOverlay)
    document.getElementById('video-backdrop')?.addEventListener('click', closeOverlay)

    document.getElementById('hero-thumb')?.addEventListener('click', () => {
      if (revealDone) return
      if (tickTimer) { clearInterval(tickTimer); tickTimer = null }
      secs = 0
      const badge = document.getElementById('reveal-hint')
      if (badge) badge.style.display = 'none'
      doReveal()
    })

    async function loadSettings() {
      if (!SB_URL || !SB_KEY) return
      try {
        const res  = await fetch(
          `${SB_URL}/rest/v1/site_settings?key=eq.hero&select=value`,
          { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
        )
        const rows = await res.json()
        const v    = rows?.[0]?.value || {}
        const sec = document.getElementById('hero-section') as HTMLElement
        if (v.hero_bg_color)    sec.style.background = v.hero_bg_color
        const h = document.getElementById('hero-heading') as HTMLElement
        if (v.heading)           h.innerHTML = v.heading
        if (v.hero_text_color)   h.style.color = v.hero_text_color
        const s = document.getElementById('hero-sub') as HTMLElement
        if (v.subheading)        s.textContent = v.subheading
        if (v.hero_sub_color)    s.style.color = v.hero_sub_color
        const barEl  = document.getElementById('video-bar-text') as HTMLElement
        const topBar = document.getElementById('video-top-bar')  as HTMLElement
        if (v.video_bar_text)       barEl.textContent       = v.video_bar_text
        if (v.video_bar_bg)         topBar.style.background = v.video_bar_bg
        if (v.video_bar_text_color) barEl.style.color       = v.video_bar_text_color
        const btText  = document.getElementById('bottom-bar-text')  as HTMLElement
        const btPhone = document.getElementById('bottom-bar-phone') as HTMLAnchorElement
        const btCTA   = document.getElementById('bottom-bar-cta')   as HTMLAnchorElement
        const btBar   = document.getElementById('bottom-cta-bar')   as HTMLElement
        if (v.bottom_bar_text  && btText)  btText.textContent = v.bottom_bar_text
        if (v.bottom_bar_phone && btPhone) { btPhone.textContent = v.bottom_bar_phone; btPhone.href = `tel:${v.bottom_bar_phone.replace(/\s/g,'')}` }
        if (v.bottom_bar_cta   && btCTA)   btCTA.textContent  = v.bottom_bar_cta + ' ↗'
        if (v.bottom_bar_link  && btCTA)   btCTA.href         = v.bottom_bar_link
        if (v.bottom_bar_bg    && btBar)   btBar.style.background = v.bottom_bar_bg
        const adminType = (v.video_type || 'youtube').toLowerCase()
        const adminUrl  = (v.video_url || v.youtube_video_id || '').trim()
        if (adminType === 'instagram') {
          const embedUrl = instaEmbedUrl(adminUrl)
          if (embedUrl) {
            videoType = 'instagram'; activeInstaUrl = embedUrl; activeVideoUrl = adminUrl
            if (preloadEl) { preloadEl.remove(); preloadEl = null }
            if (!revealDone) injectCardIframe('', 'instagram')
          }
        } else if (adminType === 'facebook' || adminType === 'vimeo' || adminType === 'direct') {
          videoType = adminType; activeVideoUrl = adminUrl
          if (preloadEl) { preloadEl.remove(); preloadEl = null }
          if (!revealDone) injectCardIframe('', adminType)
        } else {
          const adminId = ytId(adminUrl)
          if (adminId && adminId !== activeId) {
            videoType = 'youtube'; activeId = adminId; activeVideoUrl = adminUrl
            if (!revealDone) { injectCardIframe(adminId, 'youtube'); startPreload(adminId) }
          }
        }
      } catch(e) {
        console.warn('[ATEC] Settings fetch failed, fallback active:', e)
      }
    }

    function boot() {
      injectCardIframe(FALLBACK_YT, 'youtube')
      startPreload(FALLBACK_YT)
      startTick()
      loadSettings()
    }

    function waitAndBoot() {
      const sbUrl = (window as any).__SB_URL
      if (sbUrl) { boot(); return }
      let attempts = 0
      const poll = setInterval(() => {
        attempts++
        if ((window as any).__SB_URL || attempts >= 40) { clearInterval(poll); boot() }
      }, 50)
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', waitAndBoot)
    } else {
      waitAndBoot()
    }
  })()
</script>

<!-- ══════════════════════════════════════════════════════════════
     INSTRUCTORS MARQUEE — runtime JS loader
     Fetches from Supabase on page load.
     Photos saved in admin panel show INSTANTLY — no rebuild needed.
     Falls back to build-time data if DB unavailable.
══════════════════════════════════════════════════════════════ -->
<script>
  ;(function() {
    // Build-time fallback instructors (shown instantly while DB loads)
    const FALLBACK_INS = [
      { name:'Er. Rajesh Kumar',  specialization:'Hardware & Networking', photo_url:'' },
      { name:'Ms. Seema Rani',    specialization:'Tally & Accounting',    photo_url:'' },
      { name:'Mr. Aman Goyal',    specialization:'MERN Stack Developer',  photo_url:'' },
      { name:'Ms. Pooja Sharma',  specialization:'GEN AI & Python',       photo_url:'' },
      { name:'Er. Vikas Thakur',  specialization:'Linux & Server Admin',  photo_url:'' },
    ]

    function initials(name) {
      return (name || '?').split(' ').map(w => w[0]).slice(0, 2).join('').toUpperCase()
    }

    function makeCard(ins) {
      const card = document.createElement('div')
      card.className = 'ins-card'

      const avatar = document.createElement('div')
      avatar.className = 'ins-avatar'

      if (ins.photo_url) {
        const img = document.createElement('img')
        img.src = ins.photo_url
        img.alt = ins.name
        img.loading = 'lazy'
        img.onerror = () => {
          // If image fails, fall back to initials
          img.remove()
          avatar.textContent = initials(ins.name)
        }
        avatar.appendChild(img)
      } else {
        avatar.textContent = initials(ins.name)
      }

      const name = document.createElement('div')
      name.className = 'ins-name'
      name.textContent = ins.name

      const spec = document.createElement('div')
      spec.className = 'ins-spec'
      spec.textContent = ins.specialization || ''

      card.appendChild(avatar)
      card.appendChild(name)
      card.appendChild(spec)
      return card
    }

    function fillTrack(instructors) {
      const track = document.getElementById('ins-track')
      if (!track) return
      track.innerHTML = ''
      // Double for seamless loop
      const doubled = [...instructors, ...instructors]
      doubled.forEach(ins => track.appendChild(makeCard(ins)))
    }

    async function loadFromDB() {
      const SB_URL = (window as any).__SB_URL as string
      const SB_KEY = (window as any).__SB_KEY as string
      if (!SB_URL || !SB_KEY) return
      try {
        const res = await fetch(
          `${SB_URL}/rest/v1/instructors?is_active=eq.true&order=sort_order.asc.nullslast&limit=20&select=name,specialization,photo_url`,
          { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
        )
        if (!res.ok) return
        const rows = await res.json()
        if (Array.isArray(rows) && rows.length > 0) {
          fillTrack(rows)
        }
      } catch(e) {
        console.warn('[ATEC Instructors]', e)
      }
    }

    function boot() {
      // Show fallback immediately
      fillTrack(FALLBACK_INS)
      // Replace with real DB data (with photos) once SB_URL ready
      function tryLoad() {
        if ((window as any).__SB_URL) { loadFromDB(); return }
        let n = 0
        const t = setInterval(() => {
          n++
          if ((window as any).__SB_URL || n > 40) { clearInterval(t); loadFromDB() }
        }, 50)
      }
      tryLoad()
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot)
    else boot()
  })()
</script>

