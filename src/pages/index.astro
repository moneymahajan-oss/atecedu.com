---
// src/pages/index.astro
// Architecture: Static HTML shell (loads instantly, good SEO)
//               + HomepageDynamic React island (fetches live from Supabase)
// Result: Admin changes appear IMMEDIATELY — no rebuild needed.
import BaseLayout from '../layouts/BaseLayout.astro'
import HomepageDynamic from '../components/home/HomepageDynamic'
---

<BaseLayout
  title="ATEC Educational Society — Computer Courses Online & Hybrid | Gurdaspur"
  description="ATEC Gurdaspur — India's trusted computer institute since 2000. Online, hybrid and classroom courses in hardware, networking, web design, Tally and more. ISO 9001:2015 certified."
  pageSlug="homepage"
>

  <!-- ============================================================
       HERO — Static shell, text updated live by JS below
  ============================================================ -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="hero-badges">
            <span class="hero-badge-pill">
              <span class="live-dot"></span>
              ISO 9001:2015 Certified
            </span>
            <span class="hero-badge-pill">Est. 2000 · Gurdaspur</span>
          </div>
          <!-- Text updated live by script below — default shown until Supabase loads -->
          <h1 class="hero-heading" id="hero-heading">
            Turning Students Into <em class="hero-highlight">Professionals</em> Since 2000
          </h1>
          <p class="hero-sub" id="hero-sub">
            Online, hybrid &amp; classroom courses in hardware, networking, web design and more.
          </p>
          <div class="hero-btns">
            <a href="/courses" class="btn btn-primary">
              Explore Courses
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/verification" class="btn btn-outline-white">Verify Certificate</a>
          </div>
          <div class="hero-trust">
            <div class="trust-avatars">
              {[1,2,3,4].map(i => (
                <div class="trust-avatar" style={`background: hsl(${i * 60}, 60%, 50%)`}>{i}</div>
              ))}
            </div>
            <span class="trust-text">5,000+ students trained &amp; placed</span>
          </div>
        </div>

        <!-- Hero visual — YouTube embed or placeholder, updated live -->
        <div class="hero-visual" id="hero-visual">
          <div class="hero-placeholder-card" id="hero-placeholder">
            <div class="placeholder-inner">
              <div class="placeholder-logo">ATEC</div>
              <p>India's Most Trusted<br />Computer Institute</p>
              <div class="placeholder-stats-mini">
                <div class="mini-stat"><span class="mini-val">25+</span><span class="mini-label">Years</span></div>
                <div class="mini-stat"><span class="mini-val">5000+</span><span class="mini-label">Students</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-bg-circle hero-bg-circle-1"></div>
    <div class="hero-bg-circle hero-bg-circle-2"></div>
  </section>

  <!-- ============================================================
       WHY CHOOSE ATEC — Static (never changes, no need for DB)
  ============================================================ -->
  <section class="why-section section">
    <div class="container">
      <div class="section-header center">
        <p class="section-label">Why ATEC</p>
        <h2>25 Years Of Producing<br />Industry-Ready Professionals</h2>
      </div>
      <div class="why-grid">
        {[
          { icon: '🏆', title: 'ISO 9001:2015 Certified', desc: 'Internationally certified quality training standards — verified and trusted by employers across India.' },
          { icon: '🔧', title: 'Chip-Level Hardware Repair', desc: 'India\'s most trusted laptop & desktop motherboard repair training institute. Practical, job-ready skills.' },
          { icon: '🌐', title: 'Online & Hybrid Learning', desc: 'Learn theory online from anywhere. Attend practical lab sessions at our Gurdaspur centre.' },
          { icon: '📜', title: 'Verified Certificates', desc: 'Every ATEC certificate is instantly verifiable online by employers using our verification portal.' },
          { icon: '🎯', title: '100% Placement Support', desc: 'Dedicated placement cell to help every student get hired after completing their course.' },
          { icon: '📹', title: 'Zoom Live Classes', desc: 'Interactive live classes via Zoom, recorded for later revision. Never miss a session.' },
        ].map(item => (
          <div class="why-card">
            <div class="why-icon">{item.icon}</div>
            <h3 class="why-title">{item.title}</h3>
            <p class="why-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       DYNAMIC CONTENT — React island fetches live from Supabase
       Stats bar, Courses, Instructors, Testimonials, Centres, News
  ============================================================ -->
  <HomepageDynamic client:load />

  <!-- ============================================================
       BLOG TEASER — Static links to blog
  ============================================================ -->
  <section class="section" style="background:var(--off-white)">
    <div class="container">
      <div class="blog-teaser-header">
        <div>
          <p class="section-label">Learn More</p>
          <h2>Blog, Videos & Podcasts</h2>
          <p style="color:var(--text-secondary);font-size:16px;margin-top:8px">Career guides · Course tips · Student success stories · Free tutorials</p>
        </div>
        <a href="/blog" class="btn btn-outline btn-sm">View All →</a>
      </div>
      <div class="blog-teaser-grid">
        <a href="/blog/career-hardware-networking-2026" class="blog-teaser-card">
          <div class="btc-icon">💻</div>
          <div class="btc-tag">Career Guide</div>
          <h3>How to Start a Career in Hardware & Networking in 2026</h3>
          <p>Your complete 6-month roadmap to become a job-ready Network Engineer.</p>
          <span class="btc-read">Read Article →</span>
        </a>
        <a href="/blog/chip-level-laptop-repair-2026" class="blog-teaser-card">
          <div class="btc-icon">🔧</div>
          <div class="btc-tag">Course Guide</div>
          <h3>Chip-Level Laptop Repair: Is It Worth Learning in 2026?</h3>
          <p>One of India's highest-paying tech trade skills.</p>
          <span class="btc-read">Read Article →</span>
        </a>
        <a href="/blog/web-designing-vs-web-development" class="blog-teaser-card">
          <div class="btc-icon">🌐</div>
          <div class="btc-tag">Career Guide</div>
          <h3>Web Designing vs Web Development: Which Career is Right for You?</h3>
          <p>Difference, tools, jobs and salary breakdown.</p>
          <span class="btc-read">Read Article →</span>
        </a>
      </div>
      <div class="blog-teaser-extras">
        <a href="/blog" class="extra-pill"><span>📺</span> Free YouTube Tutorials</a>
        <a href="/blog" class="extra-pill"><span>🎙️</span> Student Success Podcast</a>
        <a href="/centres" class="extra-pill"><span>📍</span> Find a Centre Near You</a>
        <a href="/verification" class="extra-pill"><span>📜</span> Verify a Certificate</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA — Static
  ============================================================ -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-text">
          <h2>Ready To Start Your Career In Tech?</h2>
          <p>Join 5,000+ students who launched their careers with ATEC since 2000. New batches starting every month.</p>
        </div>
        <div class="cta-btns">
          <a href="/courses" class="btn btn-primary">Browse Courses</a>
          <a href="tel:+917009933289" class="btn btn-outline-white">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            Call +91 7009933289
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Live hero text update from Supabase (runs after page loads) -->
<script>
  import { createClient } from '@supabase/supabase-js'

  const url = window.__SB_URL
  const key = window.__SB_KEY
  if (url && key) {
    const sb = createClient(url, key)

    // Update hero text live
    sb.from('site_settings').select('value').eq('key', 'hero').single().then(({ data }) => {
      if (!data?.value) return
      const v = data.value

      if (v.heading) {
        const el = document.getElementById('hero-heading')
        if (el) el.innerHTML = v.heading
      }
      if (v.subheading) {
        const el = document.getElementById('hero-sub')
        if (el) el.textContent = v.subheading
      }
      // Swap placeholder for YouTube embed if video ID set
      if (v.youtube_video_id) {
        // Extract ID if a full URL was accidentally saved
        let ytId = v.youtube_video_id.trim()
        const short = ytId.match(/youtu\.be\/([a-zA-Z0-9_-]{11})/)
        const long  = ytId.match(/(?:v=|\/embed\/|\/shorts\/|\/v\/)([a-zA-Z0-9_-]{11})/)
        if (short) ytId = short[1]
        else if (long) ytId = long[1]

        const placeholder = document.getElementById('hero-placeholder')
        if (placeholder && ytId.length === 11) {
          const wrap = document.createElement('div')
          wrap.className = 'hero-video-wrap'
          wrap.innerHTML = `<div class="video-embed"><iframe src="https://www.youtube.com/embed/${ytId}?autoplay=1&mute=1&loop=1&playlist=${ytId}&controls=0&modestbranding=1" allow="autoplay; encrypted-media" allowfullscreen loading="lazy"></iframe></div>`
          placeholder.replaceWith(wrap)
        }
      }
    })

    // Update announcement strip live
    sb.from('site_settings').select('value').eq('key', 'announcement_strip').single().then(({ data }) => {
      if (!data?.value) return
      const v = data.value
      const strip = document.getElementById('atec-strip') as HTMLElement
      if (!strip) return

      if (!v.is_active) { strip.style.display = 'none'; return }
      strip.style.background = v.bg_color || '#0f2347'
      strip.style.color = v.text_color || '#fff'

      const textEl = strip.querySelector('.strip-text')
      if (textEl && v.text) textEl.textContent = v.text

      const linkEl = strip.querySelector('.strip-link') as HTMLAnchorElement
      if (linkEl) {
        linkEl.href = v.link || '#'
        linkEl.textContent = (v.link_text || 'Learn More') + ' →'
      }
    })
  }
</script>

<style>
/* Hero */
.hero-section{background:linear-gradient(135deg,#0b1f3f 0%,#1c3d7a 55%,#1e4694 100%);padding:80px 0 72px;position:relative;overflow:hidden;min-height:580px}
.hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
@media(max-width:900px){.hero-inner{grid-template-columns:1fr;gap:40px}}
.hero-content{position:relative;z-index:2}
.hero-badges{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px}
.hero-badge-pill{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);border-radius:20px;padding:5px 14px;font-size:12px;color:rgba(255,255,255,0.85);font-weight:500}
.live-dot{width:7px;height:7px;background:#4ade80;border-radius:50%;animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.6;transform:scale(1.3)}}
.hero-heading{font-size:clamp(2rem,4.5vw,3.2rem);font-weight:800;color:#fff;line-height:1.15;margin-bottom:20px}
.hero-highlight{color:var(--lemon);font-style:normal}
.hero-sub{font-size:17px;color:rgba(255,255,255,0.75);line-height:1.65;max-width:480px;margin-bottom:32px}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:32px}
.hero-trust{display:flex;align-items:center;gap:12px}
.trust-avatars{display:flex}
.trust-avatar{width:30px;height:30px;border-radius:50%;border:2px solid rgba(255,255,255,0.6);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;margin-left:-8px}
.trust-avatar:first-child{margin-left:0}
.trust-text{font-size:13px;color:rgba(255,255,255,0.7)}
.hero-visual{position:relative;z-index:2}
.hero-video-wrap{border-radius:var(--radius-xl);overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.4)}
.hero-placeholder-card{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:var(--radius-xl);padding:48px;text-align:center;color:#fff}
.placeholder-logo{font-family:var(--font-display);font-size:48px;font-weight:800;color:var(--lemon);margin-bottom:12px}
.placeholder-inner p{color:rgba(255,255,255,0.7);font-size:16px;margin-bottom:24px}
.placeholder-stats-mini{display:flex;gap:24px;justify-content:center}
.mini-stat{text-align:center}
.mini-val{display:block;font-family:var(--font-display);font-size:28px;font-weight:800;color:var(--lemon)}
.mini-label{font-size:12px;color:rgba(255,255,255,0.6)}
.hero-bg-circle{position:absolute;border-radius:50%;background:rgba(212,240,26,0.04);pointer-events:none}
.hero-bg-circle-1{width:600px;height:600px;top:-200px;right:-100px}
.hero-bg-circle-2{width:400px;height:400px;bottom:-150px;left:-100px}
/* Why */
.why-section{}
.why-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:24px;margin-top:48px}
.why-card{background:var(--white);border-radius:var(--radius-lg);border:1px solid var(--gray-200);padding:28px;transition:all 0.2s}
.why-card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px);border-color:var(--navy)}
.why-icon{font-size:32px;margin-bottom:14px}
.why-title{font-family:var(--font-display);font-size:16px;font-weight:700;margin-bottom:10px}
.why-desc{font-size:14px;color:var(--text-secondary);line-height:1.6}
/* Blog teaser */
.blog-teaser-header{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;margin-bottom:32px;flex-wrap:wrap}
.blog-teaser-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;margin-bottom:24px}
.blog-teaser-card{background:var(--white);border-radius:var(--radius-lg);border:1px solid var(--gray-200);padding:24px;text-decoration:none;color:inherit;transition:all 0.2s;display:flex;flex-direction:column;gap:8px}
.blog-teaser-card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px);border-color:var(--navy)}
.btc-icon{font-size:28px}
.btc-tag{font-size:11px;font-weight:700;color:var(--navy);text-transform:uppercase;letter-spacing:0.5px}
.blog-teaser-card h3{font-family:var(--font-display);font-size:15px;font-weight:700;line-height:1.3;color:var(--text-primary)}
.blog-teaser-card p{font-size:13px;color:var(--text-secondary);line-height:1.5;flex:1}
.btc-read{font-size:13px;font-weight:700;color:var(--navy);margin-top:auto}
.blog-teaser-extras{display:flex;gap:10px;flex-wrap:wrap}
.extra-pill{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:var(--white);border:1px solid var(--gray-200);border-radius:24px;font-size:13px;font-weight:600;color:var(--navy);text-decoration:none;transition:all 0.2s}
.extra-pill:hover{background:var(--navy);color:#fff;border-color:var(--navy)}
/* CTA */
.cta-section{background:var(--navy);padding:80px 0}
.cta-inner{display:flex;align-items:center;justify-content:space-between;gap:40px;flex-wrap:wrap}
.cta-text h2{color:#fff;margin-bottom:12px}
.cta-text p{color:rgba(255,255,255,0.7);max-width:480px}
.cta-btns{display:flex;gap:12px;flex-wrap:wrap;flex-shrink:0}
/* Section header */
.section-header{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;margin-bottom:40px;flex-wrap:wrap}
.section-header.center{flex-direction:column;align-items:center;text-align:center}
.section-header h2{margin-top:4px}
.section-desc{font-size:16px;color:var(--text-secondary);margin-top:8px}
</style>
