        company_placed:'Service Centre, Gurdaspur', rating:5,
        photo_url:'https://img.youtube.com/vi/PkZNo7MFNFg/mqdefault.jpg',
        video_url:'PkZNo7MFNFg', video_type:'youtube'
      },
      {
        student_name:'Harpreet Kaur', course:'DTP & Graphics',
        company_placed:'Print Studio, Amritsar', rating:5,
        photo_url:'https://img.youtube.com/vi/8jLOx1hD3_o/mqdefault.jpg',
        video_url:'8jLOx1hD3_o', video_type:'youtube'
      },
      {
        student_name:'Deepak Kumar', course:'MS Office',
        company_placed:'Govt Office, Punjab', rating:5,
        photo_url:'https://img.youtube.com/vi/GQe4RmUk2hU/mqdefault.jpg',
        video_url:'GQe4RmUk2hU', video_type:'youtube'
      },
      {
        student_name:'Navneet Sharma', course:'Cybersecurity',
        company_placed:'HCL Technologies', rating:5,
        photo_url:'https://img.youtube.com/vi/3NjQ9b3pgIg/mqdefault.jpg',
        video_url:'3NjQ9b3pgIg', video_type:'youtube'
      },
    ]

    // ── Muted-autoplay src for card iframe ───────────────────────────────
    function cardSrc(url, type) {
      if (!url) return ''
      const u = url.trim()
      if (!type) type = 'youtube'
      if (type === 'youtube') {
        const m = u.match(/youtu\.be\/([A-Za-z0-9_-]{11})/) ||
                  u.match(/(?:v=|\/embed\/|\/shorts\/|\/v\/)([A-Za-z0-9_-]{11})/)
        const id = m?.[1] || (/^[A-Za-z0-9_-]{11}$/.test(u) ? u : '')
        if (!id) return ''
        return `https://www.youtube.com/embed/${id}?autoplay=1&mute=1&loop=1&playlist=${id}&controls=0&rel=0&modestbranding=1&playsinline=1`
      }
      if (type === 'instagram') {
        const ig = u.match(/instagram\.com\/(?:reel|p)\/([A-Za-z0-9_-]+)/)
        return ig ? `https://www.instagram.com/reel/${ig[1]}/embed/` : u
      }
      if (type === 'vimeo') {
        const vm = u.match(/vimeo\.com\/(\d+)/)
        return vm ? `https://player.vimeo.com/video/${vm[1]}?autoplay=1&muted=1&loop=1&background=1` : ''
      }
      if (/\.(mp4|webm|ogg|mov)(\?.*)?$/i.test(u)) return u
      return ''
    }

    // ── Full-audio src for fullscreen overlay ────────────────────────────
    function fullSrc(url, type) {
      if (!url) return ''
      const u = url.trim()
      if (!type) type = 'youtube'
      if (type === 'youtube') {
        const m = u.match(/youtu\.be\/([A-Za-z0-9_-]{11})/) ||
                  u.match(/(?:v=|\/embed\/|\/shorts\/|\/v\/)([A-Za-z0-9_-]{11})/)
        const id = m?.[1] || (/^[A-Za-z0-9_-]{11}$/.test(u) ? u : '')
        if (!id) return ''
        return `https://www.youtube.com/embed/${id}?autoplay=1&mute=0&loop=1&playlist=${id}&controls=1&rel=0`
      }
      if (type === 'instagram') {
        const ig = u.match(/instagram\.com\/(?:reel|p)\/([A-Za-z0-9_-]+)/)
        return ig ? `https://www.instagram.com/reel/${ig[1]}/embed/` : u
      }
      if (type === 'facebook') {
        return `https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(u)}&show_text=false&autoplay=true`
      }
      if (type === 'vimeo') {
        const vm = u.match(/vimeo\.com\/(\d+)/)
        return vm ? `https://player.vimeo.com/video/${vm[1]}?autoplay=1&muted=0&loop=1` : ''
      }
      return u
    }

    // ── Extract YouTube ID from URL or bare ID ───────────────────────────
    function extractYtId(url) {
      if (!url) return ''
      const u = url.trim()
      const m = u.match(/youtu\.be\/([A-Za-z0-9_-]{11})/) ||
                u.match(/(?:v=|\/embed\/|\/shorts\/|\/v\/)([A-Za-z0-9_-]{11})/)
      return m?.[1] || (/^[A-Za-z0-9_-]{11}$/.test(u) ? u : '')
    }

    // ── Build one portrait card DOM element ──────────────────────────────
    function makeCard(t) {
      const hasVideo  = !!(t.video_url)
      const hasPhoto  = !!(t.photo_url)
      const vType     = t.video_type || 'youtube'
      const isDirect  = hasVideo && /\.(mp4|webm|ogg|mov)(\?.*)?$/i.test(t.video_url)

      const card = document.createElement('div')
      card.className = 'story-card' + (hasVideo ? '' : ' no-video')
      card.dataset.videoUrl  = t.video_url      || ''
      card.dataset.videoType = vType
      card.dataset.name      = t.student_name   || ''
      card.dataset.role      = t.course         || ''
      card.dataset.company   = t.company_placed || ''
      card.dataset.photo     = t.photo_url      || ''

      const initial = (t.student_name || '?').charAt(0).toUpperCase()
      const stars   = '★'.repeat(Math.min(parseInt(t.rating) || 5, 5))
      const badge   = t.company_placed
        ? `<div class="story-badge">🏢 ${t.company_placed}</div>`
        : ''
      const playIcon = hasVideo
        ? `<div class="story-play"><svg width="18" height="18" viewBox="0 0 24 24" fill="#fff" style="margin-left:3px"><polygon points="8,5 20,12 8,19"/></svg></div>`
        : ''

      // Photo or initial — base layer
      const photoLayer = hasPhoto
        ? `<img class="story-photo" src="${t.photo_url}" alt="${t.student_name}" loading="lazy">`
        : `<div class="story-initial">${initial}</div>`

      card.innerHTML =
        photoLayer +
        '<div class="story-grad"></div>' +
        badge + playIcon +
        `<div class="story-info">
          <div class="story-stars">${stars}</div>
          <div class="story-name">${t.student_name || ''}</div>
          <div class="story-role">${t.course || ''}</div>
        </div>`

      // ── Inline video autoplay in cards ───────────────────────────────
      // Direct mp4/webm: native <video> element, clean autoplay.
      // YouTube: iframe with autoplay+mute — works on all modern browsers.
      if (hasVideo && isDirect) {
        const v = document.createElement('video')
        v.src = t.video_url
        v.muted = true; v.loop = true; v.autoplay = true; v.playsInline = true
        v.className = 'story-card-video'
        card.insertBefore(v, card.firstChild)
      } else if (hasVideo && !isDirect) {
        // YouTube / Instagram / Vimeo — embed as iframe, muted autoplay
        const src = cardSrc(t.video_url, t.video_type || 'youtube')
        if (src) {
          const f = document.createElement('iframe')
          f.src = src
          f.className = 'story-card-video'
          f.setAttribute('allow', 'autoplay; encrypted-media; fullscreen; picture-in-picture')
          f.setAttribute('allowfullscreen', '')
          f.setAttribute('frameborder', '0')
          f.setAttribute('loading', 'lazy')
          card.insertBefore(f, card.firstChild)
        }
      }
      // If no photo and YouTube video — also auto-generate thumbnail as BG
      if (hasVideo && !isDirect && !hasPhoto) {
        const ytId = extractYtId(t.video_url)
        if (ytId) {
          const img = document.createElement('img')
          img.className = 'story-photo'
          img.src = `https://img.youtube.com/vi/${ytId}/mqdefault.jpg`
          img.alt = t.student_name || ''
          img.loading = 'lazy'
          card.insertBefore(img, card.firstChild)
        }
      }
      return card
    }

    // ── Fill 2 tracks ────────────────────────────────────────────────────
    // Row 1: first half of stories (doubled for seamless loop)
    // Row 2: second half of stories (doubled for seamless loop)
    // This ensures the two rows show DIFFERENT videos, not the same ones
    function fillTracks(stories) {
      if (!stories || !stories.length) return
      const t1 = document.getElementById('stories-track-1')
      const t2 = document.getElementById('stories-track-2')
      if (!t1 || !t2) return

      t1.innerHTML = ''
      t2.innerHTML = ''

      const half  = Math.ceil(stories.length / 2)
      const row1  = stories.slice(0, half)
      const row2  = stories.slice(half)

      // Need at least a few cards per row — if only 1 story total, duplicate
      const fill1 = row1.length >= 2 ? row1 : [...row1, ...row1]
      const fill2 = row2.length >= 2 ? row2 : (row2.length === 0 ? [...row1].reverse() : [...row2, ...row2])

      // Double each row for seamless CSS animation loop
      ;[...fill1, ...fill1].forEach(s => t1.appendChild(makeCard(s)))
      ;[...fill2, ...fill2].forEach(s => t2.appendChild(makeCard(s)))

      wireOverlay()
    }

    // ── Fullscreen overlay open/close ─────────────────────────────────────
    let storyOpen = false

    function openStory(card) {
      if (storyOpen) return
      storyOpen = true

      const url   = card.dataset.videoUrl  || ''
      const type  = card.dataset.videoType || 'youtube'
      const name  = card.dataset.name      || ''
      const role  = card.dataset.role      || ''
      const co    = card.dataset.company   || ''
      const photo = card.dataset.photo     || ''

      const avatarEl = document.getElementById('story-avatar-sm')
      const nameEl   = document.getElementById('story-name-sm')
      const roleEl   = document.getElementById('story-role-sm')
      if (avatarEl) {
        avatarEl.innerHTML = photo
          ? `<img src="${photo}" style="width:100%;height:100%;object-fit:cover;" alt="${name}">`
          : name.charAt(0).toUpperCase()
      }
      if (nameEl) nameEl.textContent = name
      if (roleEl) roleEl.textContent = co ? `${role} · ${co}` : role

      const wrap = document.getElementById('story-video-wrap')
      if (!wrap) return
      wrap.innerHTML = ''

      const isDirect = /\.(mp4|webm|ogg|mov)(\?.*)?$/i.test(url)
      if (isDirect) {
        const v = document.createElement('video')
        v.src = url; v.controls = true; v.autoplay = true
        v.style.cssText = 'width:100%;height:100%;object-fit:contain;'
        wrap.appendChild(v)
      } else {
        const src = fullSrc(url, type)
        if (src) {
          const f = document.createElement('iframe')
          f.src = src
          f.setAttribute('allow', 'autoplay;encrypted-media;fullscreen;picture-in-picture')
          f.setAttribute('allowfullscreen', '')
          f.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none;'
          wrap.appendChild(f)
        }
      }

      const ov = document.getElementById('story-overlay')
      if (!ov) return
      ov.style.pointerEvents = 'all'
      requestAnimationFrame(() => {
        ov.style.transition   = 'transform 0.8s cubic-bezier(0.16,1,0.3,1),opacity 0.5s ease,border-radius 0.8s ease'
        ov.style.transform    = 'scale(1)'
        ov.style.opacity      = '1'
        ov.style.borderRadius = '0'
      })
    }

    function closeStory() {
      const ov   = document.getElementById('story-overlay')
      const wrap = document.getElementById('story-video-wrap')
      if (!ov) return
      ov.style.transition    = 'transform 0.45s ease,opacity 0.35s ease,border-radius 0.45s ease'
      ov.style.transform     = 'scale(0.06)'
      ov.style.opacity       = '0'
      ov.style.borderRadius  = '24px'
      ov.style.pointerEvents = 'none'
      setTimeout(() => {
        if (wrap) wrap.innerHTML = ''
        ov.style.transition = 'none'
        storyOpen = false
      }, 460)
    }

    // ── Wire overlay — once only, event delegation ───────────────────────
    let overlayWired = false
    function wireOverlay() {
      if (overlayWired) return
      overlayWired = true
      document.getElementById('story-close-btn')?.addEventListener('click', closeStory)
      document.getElementById('story-backdrop')?.addEventListener('click', closeStory)
      const rows = document.getElementById('stories-rows')
      if (rows) {
        rows.addEventListener('click', (e) => {
          const card = (e.target as Element).closest('.story-card:not(.no-video)')
          if (card) openStory(card as HTMLElement)
        })
      }
    }

    // ── Load from Supabase ────────────────────────────────────────────────
    async function loadFromDB() {
      const SB_URL = (window as any).__SB_URL as string
      const SB_KEY = (window as any).__SB_KEY as string
      if (!SB_URL || !SB_KEY) return
      try {
        const res = await fetch(
          `${SB_URL}/rest/v1/testimonials?is_active=eq.true&order=sort_order.asc.nullslast&limit=24&select=*`,
          { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
        )
        if (!res.ok) return
        const rows = await res.json()
        if (Array.isArray(rows) && rows.length > 0) {
          fillTracks(rows)
        }
      } catch(e) {
        console.warn('[ATEC Stories]', e)
      }
    }

    // ── Boot ──────────────────────────────────────────────────────────────
    function boot() {
      fillTracks(DEFAULT_STORIES)   // instant cards visible
      wireOverlay()
      function tryLoad() {
        if ((window as any).__SB_URL) { loadFromDB(); return }
        let n = 0
        const t = setInterval(() => {
          n++
          if ((window as any).__SB_URL || n > 40) { clearInterval(t); loadFromDB() }
        }, 50)
      }
      tryLoad()
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot)
    else boot()
  })()
</script>

<!-- ══════════════════════════════════════════════════════════════
     HERO SLIDER — DB-driven runtime loader
     Fetches site_settings key='hero_sliders' (array of slides)
     Each slide: { badge, heading, subheading, cta_text, cta_link,
                   video_link, bg_color, text_color, image_url }
══════════════════════════════════════════════════════════════ -->
<script>
;(function() {
  const DEFAULT_SLIDES = [
    {
      badge:'🔥 New Batch June 2026',
      heading:'Industrial Training<br>for Real World Jobs',
      subheading:'GEN AI | MERN Stack | Machine Learning | Python | Ethical Hacking',
      cta_text:'Register Now',
      cta_link:'/courses',
      video_link:'',
      bg_color:'#0b1525',
      text_color:'#ffffff',
      image_url:''
    },
    {
      badge:'🌐 Online & Hybrid',
      heading:'Learn From Anywhere<br>in India',
      subheading:'Live classes, recorded sessions, doubt clearing — all from home',
      cta_text:'Explore Online Courses',
      cta_link:'/courses',
      video_link:'',
      bg_color:'#0b1525',
      text_color:'#ffffff',
      image_url:''
    },
  ]

  let slides:any[] = []
  let current = 0
  let autoTimer: any = null

  function ytEmbedUrl(raw:string):string {
    if (!raw?.trim()) return ''
    const u = raw.trim()
    const m = u.match(/youtu\.be\/([A-Za-z0-9_-]{11})/) ||
              u.match(/(?:v=|\/embed\/|\/shorts\/|\/v\/)([A-Za-z0-9_-]{11})/)
    const id = m?.[1] || (/^[A-Za-z0-9_-]{11}$/.test(u) ? u : '')
    return id ? `https://www.youtube.com/embed/${id}?autoplay=1&mute=1&loop=1&playlist=${id}&controls=0&rel=0&modestbranding=1&playsinline=1` : ''
  }

  function renderSlides(list:any[]) {
    slides = list
    const track = document.getElementById('hslider-track')
    const dots   = document.getElementById('hslider-dots')
    if (!track || !dots) return

    track.innerHTML = ''
    dots.innerHTML  = ''

    slides.forEach((s:any, i:number) => {
      const bg        = s.bg_color    || '#0b1525'
      const col       = s.text_color  || '#ffffff'
      const ctaBg     = s.cta_bg      || '#d4f01a'
      const ctaColor  = s.cta_color   || '#0b1525'
      const headSize  = s.heading_size || 'clamp(2rem,5vw,3.4rem)'
      const headFont  = s.heading_font || "'Sora',sans-serif"
      const subSize   = s.sub_size     || 'clamp(14px,2vw,18px)'
      const overlay   = s.overlay_opacity != null ? s.overlay_opacity : 0.45
      const hasImg    = !!(s.image_url?.trim())
      const hasVideo  = !!(s.video_link?.trim())
      const isDirectVid = hasVideo && /\.(mp4|webm|ogg)(\?.*)?$/i.test(s.video_link)
      const videoSrc  = ytEmbedUrl(s.video_link || '')

      const slide = document.createElement('div')
      slide.className = 'hslider-slide'
      // Solid bg color always shown; image goes on top as bg-img layer
      slide.style.background = bg
      slide.style.color = col

      // Background image layer
      const bgLayer = hasImg
        ? `<img class="hslider-bg-img" src="${s.image_url}" alt="" />`
        : (hasVideo && isDirectVid
            ? `<video class="hslider-bg-img" src="${s.video_link}" autoplay muted loop playsinline style="object-fit:cover;"></video>`
            : '')

      // Overlay for readability
      const overlayLayer = `<div class="hslider-bg-overlay" style="background:linear-gradient(90deg,rgba(0,0,0,${overlay}) 0%,rgba(0,0,0,${Math.max(0,overlay-0.15)}) 55%,rgba(0,0,0,${Math.max(0,overlay-0.3)}) 100%);"></div>`

      // YouTube bg video (muted, no controls, behind overlay)
      const ytBg = (hasVideo && !isDirectVid && videoSrc)
        ? `<iframe src="${videoSrc}" style="position:absolute;inset:0;width:100%;height:100%;border:none;pointer-events:none;z-index:0;object-fit:cover;transform:scale(1.05);" allow="autoplay;encrypted-media" frameborder="0"></iframe>`
        : ''

      slide.innerHTML = `
        ${bgLayer}
        ${ytBg}
        ${overlayLayer}
        <div class="hslider-content">
          <div class="hslider-text">
            ${s.badge ? `<div class="hslider-badge">${s.badge}</div>` : ''}
            <h2 class="hslider-h" style="color:${col};font-size:${headSize};font-family:${headFont};">${(s.heading||'').replace(/<br\s*\/?>/gi,' ')}</h2>
            <p class="hslider-sub" style="color:${col};font-size:${subSize};">${s.subheading||''}</p>
          </div>
          ${s.cta_text ? `<a href="${s.cta_link||'#'}" class="hslider-cta" style="background:${ctaBg};color:${ctaColor};">${s.cta_text} →</a>` : ''}
        </div>`

      track.appendChild(slide)

      const dot = document.createElement('button')
      dot.className = 'hslider-dot' + (i===0?' active':'')
      dot.addEventListener('click', () => { goTo(i); startAuto() })
      dots.appendChild(dot)
    })

    goTo(0, false)
    startAuto()
  }

  function goTo(idx:number, animate=true) {
    if (!slides.length) return
    current = (idx + slides.length) % slides.length
    const track = document.getElementById('hslider-track')
    if (track) track.style.transform = `translateX(-${current*100}%)`
    document.querySelectorAll('.hslider-dot').forEach((d,i) => {
      d.classList.toggle('active', i===current)
    })
  }

  function startAuto() {
    if (autoTimer) clearInterval(autoTimer)
    if (slides.length < 2) return
    autoTimer = setInterval(() => goTo(current+1), 5000)
  }

  document.getElementById('hslider-prev')?.addEventListener('click', () => { goTo(current-1); startAuto() })
  document.getElementById('hslider-next')?.addEventListener('click', () => { goTo(current+1); startAuto() })

  async function loadSlides() {
    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string
    if (!SB_URL || !SB_KEY) { renderSlides(DEFAULT_SLIDES); return }
    try {
      const res = await fetch(
        `${SB_URL}/rest/v1/site_settings?key=eq.hero_sliders&select=value`,
        { headers: { apikey: SB_KEY, Authorization: `Bearer ${SB_KEY}` } }
      )
      const rows = await res.json()
      const data = rows?.[0]?.value
      if (Array.isArray(data) && data.length > 0) {
        renderSlides(data)
      } else {
        renderSlides(DEFAULT_SLIDES)
      }
    } catch(e) {
      renderSlides(DEFAULT_SLIDES)
    }
  }

  function waitSB(cb:()=>void) {
    if ((window as any).__SB_URL) { cb(); return }
    let n=0; const t=setInterval(()=>{ n++; if((window as any).__SB_URL||n>40){clearInterval(t);cb()} },50)
  }
  // Render defaults IMMEDIATELY — no waiting for DB
  renderSlides(DEFAULT_SLIDES)
  // Then upgrade from DB when Supabase is ready
  function tryDBUpgrade() {
    if ((window as any).__SB_URL) { loadSlides(); return }
    let n=0; const t=setInterval(()=>{ n++; if((window as any).__SB_URL||n>40){clearInterval(t);loadSlides()} },50)
  }
  if (document.readyState==='loading') document.addEventListener('DOMContentLoaded', tryDBUpgrade)
  else tryDBUpgrade()
})()
</script>

<!-- ══════════════════════════════════════════════════════════════
     DROP US A QUERY POPUP — timer-based, DB-configurable
     site_settings key='popup_settings':
       { enabled, delay_seconds, title, subtitle, show_once_per_session }
══════════════════════════════════════════════════════════════ -->
<script>
;(function() {
  let popupShown = false

  function showPopup() {
    if (popupShown) return
    popupShown = true
    const popup = document.getElementById('drop-query-popup')
    if (popup) popup.classList.add('visible')
  }

  function hidePopup() {
    const popup = document.getElementById('drop-query-popup')
    if (popup) popup.classList.remove('visible')
  }

  document.getElementById('dq-close')?.addEventListener('click', hidePopup)

  // Submit enquiry to Supabase
  document.getElementById('dq-submit')?.addEventListener('click', async () => {
    const name   = (document.getElementById('dq-name') as HTMLInputElement)?.value?.trim()
    const phone  = (document.getElementById('dq-phone') as HTMLInputElement)?.value?.trim()
    const course = (document.getElementById('dq-course') as HTMLSelectElement)?.value
    const errEl  = document.getElementById('dq-err')

    if (!name || !phone) {
      if (errEl) { errEl.textContent='Please enter your name and phone number.'; errEl.style.display='block' }
      return
    }
    if (errEl) errEl.style.display='none'

    const btn = document.getElementById('dq-submit') as HTMLButtonElement
    if (btn) { btn.textContent='Sending...'; btn.disabled=true }

    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string
    if (SB_URL && SB_KEY) {
      try {
        await fetch(`${SB_URL}/rest/v1/enquiries`, {
          method:'POST',
          headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}`, 'Content-Type':'application/json', Prefer:'return=minimal' },
          body: JSON.stringify({ name, phone, course_interest:course, message:'Via Drop Query Popup' })
        })
      } catch(e) { console.warn('[ATEC Popup]', e) }
    }

    // Show success
    const body = document.getElementById('dq-body')
    const succ = document.getElementById('dq-success')
    if (body) body.style.display='none'
    if (succ) succ.style.display='block'
    setTimeout(hidePopup, 3500)
  })

  async function loadAndSchedule() {
    let delaySeconds = 15
    let enabled = true
    let oncePerSession = true

    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string

    if (SB_URL && SB_KEY) {
      try {
        const res = await fetch(
          `${SB_URL}/rest/v1/site_settings?key=eq.popup_settings&select=value`,
          { headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}` } }
        )
        const rows = await res.json()
        const cfg  = rows?.[0]?.value || {}
        if (typeof cfg.enabled !== 'undefined') enabled = !!cfg.enabled
        if (typeof cfg.delay_seconds === 'number') delaySeconds = cfg.delay_seconds
        if (typeof cfg.show_once_per_session !== 'undefined') oncePerSession = !!cfg.show_once_per_session
        if (cfg.title) {
          const t = document.getElementById('dq-title')
          if (t) t.textContent = cfg.title
        }
        if (cfg.subtitle) {
          const s = document.getElementById('dq-subtitle')
          if (s) s.textContent = cfg.subtitle
        }
        // Update course options from courses table
        const cr = await fetch(
          `${SB_URL}/rest/v1/courses?is_active=eq.true&select=title&order=sort_order.asc&limit=20`,
          { headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}` } }
        )
        const courses = await cr.json()
        if (Array.isArray(courses) && courses.length > 0) {
          const sel = document.getElementById('dq-course') as HTMLSelectElement
          if (sel) {
            sel.innerHTML = '<option value="">Select a course...</option>' +
              courses.map((c:any) => `<option>${c.title}</option>`).join('') +
              '<option value="Other">Other</option>'
          }
        }
      } catch(e) { console.warn('[ATEC Popup cfg]', e) }
    }

    if (!enabled) return
    if (oncePerSession && sessionStorage.getItem('atec_popup_shown')) return

    setTimeout(() => {
      showPopup()
      if (oncePerSession) sessionStorage.setItem('atec_popup_shown','1')
    }, delaySeconds * 1000)
  }

  function waitSB(cb:()=>void) {
    if ((window as any).__SB_URL) { cb(); return }
    let n=0; const t=setInterval(()=>{ n++; if((window as any).__SB_URL||n>40){clearInterval(t);cb()} },50)
  }
  if (document.readyState==='loading') document.addEventListener('DOMContentLoaded',()=>waitSB(loadAndSchedule))
  else waitSB(loadAndSchedule)
})()
</script>

<!-- ══════════════════════════════════════════════════════════════
     WHY ATEC — DB loader + SECTION COLORS loader
     Fetches site_settings key='why_features' (array of 5 cards)
     Each: { icon, title, desc }
     Also fetches key='section_colors' for per-section bg overrides
══════════════════════════════════════════════════════════════ -->
<script>
;(function() {

  // ── Why ATEC cards from DB ─────────────────────────────────────────────
  async function loadWhyCards() {
    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string
    if (!SB_URL || !SB_KEY) return
    try {
      const res  = await fetch(
        `${SB_URL}/rest/v1/site_settings?key=eq.why_features&select=value`,
        { headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}` } }
      )
      const rows = await res.json()
      const data = rows?.[0]?.value
      if (!Array.isArray(data) || !data.length) return

      const grid = document.getElementById('why-atec-grid')
      if (!grid) return
      grid.innerHTML = ''

      // Limit to 5
      data.slice(0,5).forEach((f:any) => {
        const card = document.createElement('div')
        card.className = 'why-card'
        card.style.cssText = 'background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.14);border-radius:16px;padding:24px;backdrop-filter:blur(4px);transition:transform 0.2s,box-shadow 0.2s;cursor:default;'
        card.onmouseover = () => { card.style.transform='translateY(-4px)'; card.style.boxShadow='0 12px 32px rgba(0,0,0,0.35)' }
        card.onmouseout  = () => { card.style.transform='translateY(0)';    card.style.boxShadow='none' }
        card.innerHTML = `
          <div style="font-size:2.2rem;margin-bottom:14px;filter:drop-shadow(0 3px 6px rgba(0,0,0,0.3));">${f.icon||'⭐'}</div>
          <h3 style="font-family:'Sora',sans-serif;font-weight:800;font-size:16px;color:#d4f01a;margin:0 0 8px;text-shadow:0 2px 8px rgba(212,240,26,0.3);">${f.title||''}</h3>
          <p style="font-size:13px;color:rgba(255,255,255,0.78);margin:0;line-height:1.6;">${f.desc||''}</p>`
        grid.appendChild(card)
      })

      // Also update section title/sub if stored
      const t = document.getElementById('why-atec-title')
      const s = document.getElementById('why-atec-sub')
      if (data.section_title && t) t.textContent = data.section_title
      if (data.section_sub   && s) s.textContent = data.section_sub
    } catch(e) { console.warn('[ATEC Why]', e) }
  }

  // ── Section colors from DB ─────────────────────────────────────────────
  // site_settings key='section_colors':
  //   { why_atec_bg, why_atec_gradient, courses_bg, stories_bg, etc. }
  async function loadSectionColors() {
    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string
    if (!SB_URL || !SB_KEY) return
    try {
      const res  = await fetch(
        `${SB_URL}/rest/v1/site_settings?key=eq.section_colors&select=value`,
        { headers:{ apikey:SB_KEY, Authorization:`Bearer ${SB_KEY}` } }
      )
      const rows = await res.json()
      const cfg  = rows?.[0]?.value || {}

      function applyBg(id:string, bg:string|undefined, gradient:string|undefined) {
        if (!bg && !gradient) return
        const el = document.getElementById(id)
        if (!el) return
        if (gradient) { el.style.background = gradient }
        else if (bg) { el.style.background = bg }
      }

      applyBg('why-atec-section', cfg.why_atec_bg, cfg.why_atec_gradient)
      // hero slider
      const slSec = document.getElementById('hero-slider-section')
      if (slSec && (cfg.slider_bg || cfg.slider_gradient)) {
        slSec.style.background = cfg.slider_gradient || cfg.slider_bg
      }
      // stories
      const storiesSec = document.querySelector('.stories-section') as HTMLElement|null
      if (storiesSec && (cfg.stories_bg || cfg.stories_gradient)) {
        storiesSec.style.background = cfg.stories_gradient || cfg.stories_bg
      }
      // instructors

      // Update CSS variable for primary dark blue if admin changed it
      if (cfg.primary_color) {
        document.documentElement.style.setProperty('--atec-primary', cfg.primary_color)
      }
    } catch(e) { console.warn('[ATEC Colors]', e) }
  }

  function waitSB(cb:()=>void) {
    if ((window as any).__SB_URL) { cb(); return }
    let n=0; const t=setInterval(()=>{ n++; if((window as any).__SB_URL||n>40){clearInterval(t);cb()} },50)
  }
  if (document.readyState==='loading') document.addEventListener('DOMContentLoaded',()=>waitSB(()=>{ loadWhyCards(); loadSectionColors() }))
  else waitSB(()=>{ loadWhyCards(); loadSectionColors() })
})()
</script>

