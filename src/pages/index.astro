---
// src/pages/index.astro
// Enchanting hero — no badges, no trust avatars. All admin-controlled.
import BaseLayout from '../layouts/BaseLayout.astro'
import HomepageDynamic from '../components/home/HomepageDynamic'
---

<BaseLayout
  title="ATEC Educational Society — Computer Courses Online & Hybrid | Gurdaspur"
  description="ATEC Gurdaspur — India's trusted computer institute since 2000. Online, hybrid and classroom courses in hardware, networking, web design, GenAI, MERN, Tally and more."
  pageSlug="homepage"
>

  <!-- ============================================================
       ENCHANTING HERO
  ============================================================ -->
  <section class="hero-enchant">
    <!-- Animated gradient orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="grid-overlay"></div>

    <div class="container">
      <div class="hero-grid">
        <div class="hero-left">
          <div class="hero-eyebrow">
            <span class="eyebrow-pulse"></span>
            <span id="hero-eyebrow-text">Trusted Since 2000 · Gurdaspur</span>
          </div>

          <h1 class="hero-title" id="hero-heading">
            <span class="title-line">Turning Students Into</span>
            <span class="title-line gradient-text">Professionals</span>
            <span class="title-line">Since 2000</span>
          </h1>

          <p class="hero-tagline" id="hero-sub">
            Online, hybrid &amp; classroom courses in hardware, networking, web design, GenAI, MERN, Tally and kids programs.
