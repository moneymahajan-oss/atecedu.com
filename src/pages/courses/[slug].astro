---
// src/pages/courses/[slug].astro
// UPDATED: course body (video, syllabus, brochure, FAQ, etc.) is now rendered
// by ONE shared runtime-live React island (CourseDetailContent), so every
// course — old or new — shows identical sections, refreshed from Supabase at
// page load. Build-time data is still passed as initial props for SEO.
import BaseLayout from '../../layouts/BaseLayout.astro'
import { supabase } from '../../lib/supabase'
import CoursePricingCard from '../../components/courses/CoursePricingCard'
import CourseDetailContent from '../../components/courses/CourseDetailContent'

export async function getStaticPaths() {
  // Fallback slugs ensure pages always build even if Supabase is empty at build time
  const FALLBACK_SLUGS = [
    'gen-ai', 'mern-stack', 'tally-prime', 'hardware-networking',
    'python', 'kids-coding', 'digital-marketing', 'ms-office',
    'react', 'php-mysql', 'wordpress', 'ccna', 'linux',
    'cybersecurity', 'deep-learning', 'machine-learning',
    'scratch', 'robotics', 'ecommerce', 'chip-level-repair',
    'hardware-networking', 'linux-administrator', 'tally', 'web-designing',
  ]

  let dbSlugs: string[] = []
  try {
    const { data: courses } = await supabase
      .from('courses')
      .select('slug')
      .eq('is_active', true)
    dbSlugs = (courses ?? []).map(c => c.slug)
  } catch (e) {}

  // Merge DB slugs + fallbacks, deduplicate
  const allSlugs = Array.from(new Set([...dbSlugs, ...FALLBACK_SLUGS]))
  return allSlugs.map(slug => ({ params: { slug } }))
}

const { slug } = Astro.params

const { data: course } = await supabase
  .from('courses')
  .select('*')
  .eq('slug', slug)
  .eq('is_active', true)
  .single()

if (!course) return Astro.redirect('/courses', 302)

// Fetch related courses
const { data: related } = await supabase
  .from('courses')
  .select('id,title,slug,mode,fee_inr,thumbnail_url,duration_weeks')
  .eq('is_active', true)
  .eq('category', course.category ?? '')
  .neq('slug', slug)
  .limit(3)

const syllabus = (course.syllabus as { week: number; topic: string; subtopics?: string[] }[]) ?? []

// Extract bare YouTube ID from any URL format or bare ID
function extractYouTubeId(raw: string | null | undefined): string | null {
  if (!raw) return null
  const s = raw.trim()
  // Already a bare 11-char ID (no slashes or dots)
  if (/^[A-Za-z0-9_-]{11}$/.test(s)) return s
  // youtu.be/ID
  const short = s.match(/youtu\.be\/([A-Za-z0-9_-]{11})/)
  if (short) return short[1]
  // youtube.com/watch?v=ID or /embed/ID or /shorts/ID
  const long = s.match(/(?:v=|\/embed\/|\/shorts\/|\/v\/)([A-Za-z0-9_-]{11})/)
  if (long) return long[1]
  return null
}

const promoVideoId = extractYouTubeId((course as any).promo_video_url)

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": course.title,
  "description": course.description ?? course.short_description,
  "url": `https://atecedu.com/courses/${slug}`,
  "image": course.thumbnail_url,
  "provider": {
    "@type": "EducationalOrganization",
    "name": "ATEC Educational Society",
    "url": "https://atecedu.com"
  },
  "offers": {
    "@type": "Offer",
    "price": course.fee_inr,
    "priceCurrency": "INR",
    "availability": "https://schema.org/InStock"
  },
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": course.mode,
    "duration": `P${course.duration_weeks}W`,
    "inLanguage": course.language ?? "hi"
  }
}
---

<BaseLayout
  title={`${course.title} — ATEC Educational Society`}
  description={course.short_description ?? course.description ?? ''}
  ogImage={course.thumbnail_url ?? undefined}
  pageSlug={`course-${slug}`}
>

  <!-- Breadcrumb + hero -->
  <div class="course-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <a href="/courses">Courses</a>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
        <span>{course.title}</span>
      </nav>

      <div class="hero-inner">
        <div class="hero-content">
          <div class="hero-badges">
            <span class:list={['badge', `badge-${course.mode}`]}>{course.mode}</span>
            {course.is_featured && <span class="badge badge-new">Featured</span>}
            {course.level && <span class="badge badge-outline">{course.level}</span>}
          </div>
          <h1 class="course-title">{course.title}</h1>
          {course.short_description && (
            <p class="course-sub">{course.short_description}</p>
          )}

          <!-- Metadata row -->
          <div class="meta-row">
            {course.rating && (
              <div class="meta-item">
                <span style="color:#f59e0b">{'★'.repeat(Math.round(course.rating ?? 4))}</span>
                <span class="meta-val">{course.rating}</span>
                {course.reviews_count > 0 && <span class="meta-label">({course.reviews_count} reviews)</span>}
              </div>
            )}
            {course.total_enrolled > 0 && (
              <div class="meta-item">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                <span class="meta-val">{course.total_enrolled.toLocaleString('en-IN')}</span>
                <span class="meta-label">enrolled</span>
              </div>
            )}
            <div class="meta-item">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
              <span class="meta-val">{course.duration_weeks} weeks</span>
            </div>
            {course.language && (
              <div class="meta-item">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 8l6 6M4 14l6-6 2-3M2 5h12M7 2h1M22 22l-5-10-5 10M14 18h6"/></svg>
                <span class="meta-val">{course.language}</span>
              </div>
            )}
          </div>

          <div class="hero-cert">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Certificate included upon completion
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Main content + sticky sidebar -->
  <div class="course-body">
    <div class="container">
      <div class="course-layout">

        <!-- Left: details — ONE shared runtime-live island for ALL courses -->
        <CourseDetailContent
          client:load
          slug={slug}
          initialCourse={course}
        />

        <!-- Right: sticky pricing sidebar -->
        <div class="sticky-sidebar">
          <CoursePricingCard
            client:load
            courseSlug={slug}
            courseId={course.id}
            courseTitle={course.title}
            initialFee={course.fee_inr ?? 0}
            initialOriginalFee={course.original_fee_inr ?? null}
            initialShortDesc={course.short_description ?? null}
            initialOneLine={(course as any).one_line_syllabus ?? null}
            initialSyllabus={syllabus}
            initialThumbnail={course.thumbnail_url ?? null}
            initialPromoVideoId={promoVideoId}
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Related courses -->
  {(related ?? []).length > 0 && (
    <section class="related-section">
      <div class="container">
        <h2 style="margin-bottom:28px">Related Courses</h2>
        <div class="related-grid">
          {(related ?? []).map(c => (
            <a href={`/courses/${c.slug}`} class="related-card">
              {c.thumbnail_url && (
                <div class="related-thumb">
                  <img src={c.thumbnail_url} alt={c.title} loading="lazy" />
                </div>
              )}
              <div class="related-body">
                <div class="related-mode badge" style="font-size:11px">{c.mode}</div>
                <h3 class="related-title">{c.title}</h3>
                <div class="related-meta">
                  <span>{c.duration_weeks}w</span>
                  <span style="margin-left:auto;font-family:var(--font-display);font-weight:700;color:var(--navy)">₹{c.fee_inr?.toLocaleString('en-IN')}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Mobile floating CTA -->
  <div class="floating-cta">
    <CoursePricingCard
      client:load
      courseSlug={slug}
      courseId={course.id}
      courseTitle={course.title}
      initialFee={course.fee_inr ?? 0}
      initialOriginalFee={course.original_fee_inr ?? null}
      initialShortDesc={null}
      initialOneLine={null}
      initialSyllabus={[]}
      initialThumbnail={null}
      initialPromoVideoId={null}
      compact
    />
  </div>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

</BaseLayout>

<!--
  IMPORTANT: styles below are is:global because the course body is now
  rendered inside a React island — Astro scoped styles do NOT reach inside
  framework components. All selectors are page-specific class names, so
  they are safe as globals.
-->
<style is:global>
/* Course hero */
.course-hero {
  background: linear-gradient(135deg, #0b1f3f 0%, #1c3d7a 100%);
  padding: 48px 0 56px;
}
.course-hero .hero-inner { display: block; max-width: 820px; }
@media (max-width: 1024px) { .course-hero .hero-inner { display: block; max-width: 820px; } }
.course-hero .hero-badges { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
.course-hero .badge-outline {
  background: rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.85);
  border: 1px solid rgba(255,255,255,0.25);
}
.course-hero .course-title {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 800; color: #fff; line-height: 1.2; margin-bottom: 14px;
}
.course-hero .course-sub { font-size: 16px; color: rgba(255,255,255,0.75); line-height: 1.6; margin-bottom: 20px; }
.course-hero .meta-row { display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 16px; }
.course-hero .meta-item { display: flex; align-items: center; gap: 5px; font-size: 13px; color: rgba(255,255,255,0.7); }
.course-hero .meta-val { font-weight: 600; color: #fff; }
.course-hero .meta-label { color: rgba(255,255,255,0.55); }
.course-hero .hero-cert {
  display: flex; align-items: center; gap: 6px;
  font-size: 13px; color: var(--lemon); font-weight: 600;
}
.course-hero .breadcrumb a { color: rgba(255,255,255,0.55) !important; }
.course-hero .breadcrumb { color: rgba(255,255,255,0.3); margin-bottom: 24px; }
.course-hero .breadcrumb span { color: rgba(255,255,255,0.85); }

/* Course body */
.course-body { padding: 48px 0; background: var(--gray-50); }
.course-layout {
  display: grid; grid-template-columns: 1fr 340px; gap: 40px; align-items: start;
}
@media (max-width: 1024px) {
  .course-layout { grid-template-columns: 1fr; }
  .sticky-sidebar { display: none; }
}
.sticky-sidebar {
  position: sticky; top: calc(var(--nav-height) + 20px);
}

/* Detail sections (rendered inside React island) */
.course-details .detail-section {
  background: var(--white);
  border-radius: var(--radius-lg);
  border: 1px solid var(--gray-200);
  padding: 32px;
  margin-bottom: 24px;
}
.course-details .detail-section h2 {
  font-family: var(--font-display);
  font-size: 1.4rem; font-weight: 800;
  margin-bottom: 20px; color: var(--text-primary);
  padding-bottom: 14px; border-bottom: 2px solid var(--lemon);
  display: inline-block;
}

.course-details .learn-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
}
@media (max-width: 640px) { .course-details .learn-grid { grid-template-columns: 1fr; } }
.course-details .learn-item {
  display: flex; align-items: flex-start; gap: 8px;
  font-size: 14px; color: var(--text-secondary); line-height: 1.5;
  background: #f9fff0; padding: 10px 14px; border-radius: 8px;
}

.course-details .highlights-grid { display: flex; flex-wrap: wrap; gap: 10px; }
.course-details .highlight-pill {
  display: flex; align-items: center; gap: 6px;
  background: #eff6ff; color: var(--navy);
  padding: 8px 16px; border-radius: 24px;
  font-size: 13px; font-weight: 600;
}

.course-details .course-description { font-size: 15px; color: var(--text-secondary); line-height: 1.8; }
.course-details .course-description p { margin-bottom: 12px; }
.course-details .course-description ul { margin-left: 20px; margin-bottom: 12px; }
.course-details .course-description li { margin-bottom: 4px; }

/* Syllabus + FAQ accordion */
.course-details .syllabus-summary { font-size: 13px; color: var(--text-muted); margin-bottom: 16px; }
.course-details .week-badge {
  display: inline-block; font-size: 11px; font-weight: 700;
  background: var(--lemon); color: var(--navy);
  padding: 2px 8px; border-radius: 4px; margin-right: 10px;
}
.course-details .acc-chevron { transition: transform 0.2s; flex-shrink: 0; }
.course-details .subtopic-list {
  list-style: none; padding: 0;
  display: flex; flex-direction: column; gap: 8px;
}
.course-details .subtopic-list li { font-size: 14px; color: var(--text-secondary); }

/* Related */
.related-section { padding: 60px 0; }
.related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 20px; }
.related-card {
  text-decoration: none; color: inherit;
  background: var(--white); border-radius: var(--radius-lg);
  border: 1px solid var(--gray-200); overflow: hidden;
  transition: all 0.2s;
}
.related-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.related-thumb { height: 140px; overflow: hidden; }
.related-thumb img { width: 100%; height: 100%; object-fit: cover; }
.related-body { padding: 16px; }
.related-mode { margin-bottom: 8px; }
.related-title { font-family: var(--font-display); font-size: 14px; font-weight: 700; margin-bottom: 10px; line-height: 1.3; }
.related-meta { display: flex; align-items: center; font-size: 13px; color: var(--text-muted); }

/* Floating CTA */
.floating-cta {
  display: none;
}
@media (max-width: 1024px) {
  .floating-cta {
    display: flex; align-items: center; justify-content: space-between;
    position: fixed; bottom: 0; left: 0; right: 0;
    background: var(--white); border-top: 1px solid var(--gray-200);
    padding: 12px 16px; z-index: 999;
    box-shadow: 0 -4px 16px rgba(0,0,0,0.08);
  }
}
</style>
