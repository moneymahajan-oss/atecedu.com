---
// src/pages/podcast.astro
import BaseLayout from '../layouts/BaseLayout.astro'
import { supabase } from '../lib/supabase'

let episodes: any[] = []

try {
  const { data } = await supabase
    .from('podcast_episodes')
    .select('*')
    .eq('is_published', true)
    .order('sort_order')
    .limit(20)
  episodes = data ?? []
} catch (e) {}

function ytId(url: string): string {
  if (!url) return ''
  const m = url.match(/youtu\.be\/([A-Za-z0-9_-]{11})/) || url.match(/(?:v=|\/embed\/|\/shorts\/)([A-Za-z0-9_-]{11})/)
  return m?.[1] || (/^[A-Za-z0-9_-]{11}$/.test(url) ? url : '')
}
---

<BaseLayout
  title="ATEC Talks Podcast — Career, Tech & Student Stories"
  description="ATEC Talks: career conversations, tech trends, and student transformation stories from ATEC Gurdaspur. Listen on YouTube and Spotify."
>
<style>
  .hero { background:#0b1525; padding:72px 32px 60px; text-align:center; color:#fff; }
  .hero .label { font-size:12px; font-weight:800; color:#d4f01a; text-transform:uppercase; letter-spacing:0.12em; display:block; margin-bottom:14px; }
  .hero h1 { font-family:'Sora',sans-serif; font-size:clamp(2rem,4vw,3rem); font-weight:900; margin:0 0 12px; }
  .hero p { font-size:16px; color:rgba(255,255,255,0.65); max-width:520px; margin:0 auto; }

  .section { padding:64px 32px 80px; background:#f8f4ef; }
  .inner { max-width:900px; margin:0 auto; }

  .empty-state { text-align:center; padding:64px 32px; background:#fff; border-radius:20px; border:2px dashed #e2e8f0; }
  .empty-icon { font-size:4rem; margin-bottom:16px; }
  .empty-state h2 { font-family:'Sora',sans-serif; font-weight:800; font-size:1.4rem; color:#0b1525; margin:0 0 8px; }
  .empty-state p { color:#64748b; margin:0 0 24px; line-height:1.6; }
  .btn-lemon { display:inline-flex; align-items:center; gap:8px; background:#d4f01a; color:#0b1525; padding:12px 24px; border-radius:10px; font-weight:800; text-decoration:none; font-size:15px; }

  /* Episode cards */
  .episode-card { background:#fff; border-radius:16px; padding:24px; border:1px solid #e2e8f0; box-shadow:0 2px 8px rgba(0,0,0,0.05); margin-bottom:16px; display:flex; gap:20px; align-items:flex-start; }
  @media(max-width:560px){ .episode-card { flex-direction:column; } }
  .ep-thumb { width:100px; height:100px; border-radius:12px; background:#0b1525; flex-shrink:0; overflow:hidden; display:flex; align-items:center; justify-content:center; font-size:2.5rem; }
  .ep-thumb img { width:100%; height:100%; object-fit:cover; }
  .ep-body { flex:1; min-width:0; }
  .ep-num { font-size:11px; font-weight:800; color:#d4f01a; background:#0b1525; padding:2px 9px; border-radius:20px; display:inline-block; margin-bottom:8px; }
  .ep-title { font-family:'Sora',sans-serif; font-weight:800; font-size:17px; color:#0b1525; margin:0 0 6px; }
  .ep-guest { font-size:13px; color:#64748b; margin:0 0 8px; }
  .ep-desc { font-size:14px; color:#475569; line-height:1.6; margin:0 0 14px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
  .ep-links { display:flex; gap:8px; flex-wrap:wrap; }
  .ep-btn { display:inline-flex; align-items:center; gap:5px; padding:6px 14px; border-radius:7px; font-size:12px; font-weight:700; text-decoration:none; }
  .ep-btn.yt { background:#ff0000; color:#fff; }
  .ep-btn.spotify { background:#1DB954; color:#fff; }
  .ep-btn.listen { background:#eff6ff; color:#0b1525; border:1px solid #bfdbfe; }
  .ep-duration { font-size:11px; color:#94a3b8; margin-top:6px; }

  /* Subscribe banner */
  .subscribe { background:#0b1525; padding:56px 32px; text-align:center; color:#fff; }
  .subscribe h2 { font-family:'Sora',sans-serif; font-size:1.8rem; font-weight:900; margin:0 0 12px; }
  .subscribe p { color:rgba(255,255,255,0.65); margin:0 0 28px; }
  .btn-group { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
  .btn-yt { background:#ff0000; color:#fff; padding:12px 24px; border-radius:10px; font-weight:800; text-decoration:none; font-size:15px; display:inline-flex; align-items:center; gap:8px; }
  .btn-wa { background:#25d366; color:#fff; padding:12px 24px; border-radius:10px; font-weight:800; text-decoration:none; font-size:15px; }
</style>

<div class="hero">
  <span class="label">🎙️ Podcast</span>
  <h1>ATEC Talks</h1>
  <p>Career conversations, tech trends, and student transformation stories from ATEC Gurdaspur.</p>
</div>

<section class="section">
  <div class="inner">
    {episodes.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">🎙️</div>
        <h2>Episodes Coming Soon</h2>
        <p>ATEC Talks is on its way. Subscribe to our YouTube channel to get notified when new episodes drop.<br/>Career conversations, tech trends, and student success stories — straight from ATEC.</p>
        <a href="https://www.youtube.com/@ATECEducationalSociety" target="_blank" rel="noopener" class="btn-lemon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#0b1525"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 00.5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 002.1 2.1C4.5 20.5 12 20.5 12 20.5s7.5 0 9.4-.6a3 3 0 002.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z"/></svg>
          Subscribe on YouTube
        </a>
      </div>
    ) : (
      episodes.map(ep => {
        const id = ytId(ep.youtube_url || '')
        const thumb = ep.thumbnail_url || (id ? `https://img.youtube.com/vi/${id}/mqdefault.jpg` : '')
        return (
          <div class="episode-card">
            <div class="ep-thumb">
              {thumb ? <img src={thumb} alt={ep.title} loading="lazy" /> : <span>🎙️</span>}
            </div>
            <div class="ep-body">
              {ep.episode_number && <span class="ep-num">EP {ep.episode_number}</span>}
              <div class="ep-title">{ep.title}</div>
              {ep.guest_name && <div class="ep-guest">with {ep.guest_name}{ep.guest_designation ? `, ${ep.guest_designation}` : ''}</div>}
              {ep.description && <p class="ep-desc">{ep.description}</p>}
              <div class="ep-links">
                {ep.youtube_url && <a href={ep.youtube_url} target="_blank" rel="noopener" class="ep-btn yt">▶ YouTube</a>}
                {ep.spotify_url && <a href={ep.spotify_url} target="_blank" rel="noopener" class="ep-btn spotify">🎵 Spotify</a>}
                {ep.audio_url && <a href={ep.audio_url} target="_blank" rel="noopener" class="ep-btn listen">🎧 Listen</a>}
              </div>
              {ep.duration && <div class="ep-duration">⏱ {ep.duration}</div>}
            </div>
          </div>
        )
      })
    )}
  </div>
</section>

<div class="subscribe">
  <h2>Never Miss an Episode</h2>
  <p>Subscribe to ATEC on YouTube and get notified about new episodes.</p>
  <div class="btn-group">
    <a href="https://www.youtube.com/@ATECEducationalSociety" target="_blank" rel="noopener" class="btn-yt">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 00.5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 002.1 2.1C4.5 20.5 12 20.5 12 20.5s7.5 0 9.4-.6a3 3 0 002.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z"/></svg>
      Subscribe on YouTube
    </a>
    <a href="https://wa.me/917009933289?text=Hi%20I%20want%20to%20know%20about%20ATEC%20Talks%20podcast" target="_blank" rel="noopener" class="btn-wa">💬 WhatsApp Updates</a>
  </div>
</div>
</BaseLayout>
