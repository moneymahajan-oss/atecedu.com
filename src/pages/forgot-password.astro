---
// src/pages/forgot-password.astro
// STANDALONE — does NOT use BaseLayout
---

<!DOCTYPE html>
<html lang="en-IN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forgot Password — ATEC</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@700;800&family=Inter:wght@400;500;600&display=swap" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter',sans-serif;background:linear-gradient(135deg,#0b1f3f 0%,#1c3d7a 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}
    .wrap{width:100%;max-width:420px;display:flex;flex-direction:column;align-items:center;gap:24px}
    .logo{display:inline-flex;align-items:center;gap:10px;text-decoration:none}
    .logo-mark{width:44px;height:44px;border-radius:12px;background:#d4f01a;display:flex;align-items:center;justify-content:center;font-family:'Sora',sans-serif;font-weight:800;font-size:20px;color:#0f2347}
    .logo-name{font-family:'Sora',sans-serif;font-weight:800;font-size:18px;color:#fff;line-height:1.1}
    .logo-sub{font-size:11px;color:rgba(255,255,255,0.5)}
    .card{width:100%;background:#fff;border-radius:20px;padding:36px 32px;box-shadow:0 24px 60px rgba(0,0,0,0.3)}
    h1{font-family:'Sora',sans-serif;font-size:1.5rem;font-weight:800;color:#0f1724;margin-bottom:4px}
    .sub{font-size:14px;color:#6b7280;margin-bottom:24px}
    label{display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:5px}
    input{width:100%;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:15px;font-family:'Inter',sans-serif;outline:none;transition:border-color 0.2s;margin-bottom:14px}
    input:focus{border-color:#1c3d7a}
    .error{background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:10px 14px;font-size:13px;color:#991b1b;margin-bottom:14px;display:none}
    .error.show{display:block}
    .btn{width:100%;padding:14px;background:#1c3d7a;color:#fff;border:none;border-radius:10px;font-family:'Sora',sans-serif;font-weight:800;font-size:15px;cursor:pointer}
    .btn:disabled{background:#9ca3af;cursor:not-allowed}
    .switch{text-align:center;font-size:14px;color:#6b7280;margin-top:18px}
    .switch a{color:#1c3d7a;font-weight:600;text-decoration:none}
    .sent{text-align:center;padding:10px 0;display:none}
    .sent.show{display:block}
  </style>
</head>
<body>
  <div class="wrap">
    <a href="/" class="logo">
      <div class="logo-mark">A</div>
      <div><div class="logo-name">ATEC</div><div class="logo-sub">Educational Society</div></div>
    </a>
    <div class="card">
      <h1>Reset Password</h1>
      <p class="sub">Enter your email and we'll send a reset link</p>
      <div id="error-box" class="error"></div>
      <div id="sent-box" class="sent">
        <div style="font-size:40px;margin-bottom:12px">📧</div>
        <p style="font-weight:600;font-size:15px;margin-bottom:6px">Reset link sent!</p>
        <p style="font-size:13px;color:#6b7280" id="sent-msg"></p>
      </div>
      <div id="form-area">
        <label for="email">Email Address</label>
        <input type="email" id="email" placeholder="you@example.com" required />
        <button class="btn" id="submit-btn">Send Reset Link</button>
      </div>
      <p class="switch"><a href="/login">← Back to Login</a></p>
    </div>
  </div>
  <script type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'
    const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY)
    const btn = document.getElementById('submit-btn')
    const errorBox = document.getElementById('error-box')
    btn.addEventListener('click', async () => {
      const email = document.getElementById('email').value.trim()
      if (!email) return
      errorBox.classList.remove('show')
      btn.disabled = true
      btn.textContent = 'Sending...'
      const { error } = await supabase.auth.resetPasswordForEmail(email, { redirectTo: window.location.origin + '/reset-password' })
      if (error) {
        errorBox.textContent = '⚠️ ' + error.message
        errorBox.classList.add('show')
        btn.disabled = false
        btn.textContent = 'Send Reset Link'
        return
      }
      document.getElementById('form-area').style.display = 'none'
      document.getElementById('sent-msg').textContent = 'Check ' + email + ' for the reset link.'
      document.getElementById('sent-box').classList.add('show')
    })
  </script>
</body>
</html>
