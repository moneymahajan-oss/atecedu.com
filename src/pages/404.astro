---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Page Not Found — ATEC Gurdaspur" noIndex={true}>
<style>
  .notfound {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 64px 32px;
    background: #f8f4ef;
  }
  .notfound .code {
    font-family: 'Sora', sans-serif;
    font-size: clamp(5rem, 15vw, 9rem);
    font-weight: 900;
    color: #e2e8f0;
    line-height: 1;
    margin-bottom: 8px;
  }
  .notfound h1 { font-family:'Sora',sans-serif; font-size:1.8rem; font-weight:800; color:#1e293b; margin:0 0 12px; }
  .notfound p { font-size:16px; color:#64748b; margin:0 0 32px; max-width:420px; }
  .btn-group { display:flex; gap:12px; flex-wrap:wrap; justify-content:center; }
  .btn-primary { background:#0f2a5c; color:#d4f01a; padding:12px 26px; border-radius:10px; font-weight:800; font-size:15px; text-decoration:none; }
  .btn-secondary { background:#fff; color:#0f2a5c; border:2px solid #0f2a5c; padding:12px 26px; border-radius:10px; font-weight:700; font-size:15px; text-decoration:none; }
</style>
<div class="notfound">
  <div class="code">404</div>
  <h1>Page Not Found</h1>
  <p>This page doesn't exist or may have moved. Let's get you back on track.</p>
  <div class="btn-group">
    <a href="/" class="btn-primary">Go Home</a>
    <a href="/courses" class="btn-secondary">Browse Courses</a>
  </div>
</div>
</BaseLayout>
