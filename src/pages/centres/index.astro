---
// src/pages/centres/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro'
import { supabase } from '../../lib/supabase'

const { data: centres } = await supabase
  .from('centres')
  .select('*')
  .eq('is_active', true)
  .order('sort_order')

// Fallback centres if table is empty
const fallbackCentres = [
  {
    id: '1',
    name: 'ATEC Gurdaspur — Main Centre',
    city: 'Gurdaspur',
    state: 'Punjab',
    address: 'Hardochanni Road, Near Bus Stand, Gurdaspur 143521',
    phone: '+91 7009933289',
    email: 'atecgsp@gmail.com',
    map_url: 'https://maps.google.com/?q=ATEC+Gurdaspur',
    photo_url: null,
    is_main: true,
  },
]

const displayCentres = (centres ?? []).length > 0 ? centres! : fallbackCentres

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": "ATEC Educational Society",
  "url": "https://atecedu.com",
  "description": "ATEC Educational Society — ISO 9001:2015 certified computer institute with multiple centres across Punjab.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Hardochanni Road",
    "addressLocality": "Gurdaspur",
    "addressRegion": "Punjab",
    "postalCode": "143521",
    "addressCountry": "IN"
  },
  "telephone": "+91-7009933289",
  "email": "atecgsp@gmail.com"
}
---

<BaseLayout
  title="Our Centres — ATEC Educational Society | Gurdaspur, Punjab"
  description="Find ATEC Educational Society computer training centres near you. Practical hands-on lab training available at all our centres across Punjab."
  pageSlug="centres"
>

  <!-- HERO -->
  <div class="centres-hero">
    <div class="container">
      <p class="section-label">Our Locations</p>
      <h1>ATEC Educational Society<br/>Centre Network</h1>
      <p class="hero-sub">
        Hands-on practical training at our fully equipped computer labs.
        Find a centre near you.
      </p>
      <div class="hero-badges">
        <span class="hero-badge">📍 {displayCentres.length}+ Centre{displayCentres.length !== 1 ? 's' : ''}</span>
        <span class="hero-badge">🔬 Fully Equipped Labs</span>
        <span class="hero-badge">✅ ISO 9001:2015 Certified</span>
      </div>
    </div>
  </div>

  <!-- CENTRES GRID -->
  <section class="section">
    <div class="container">
      <div class="centres-grid">
        {displayCentres.map((centre: typeof displayCentres[0], i: number) => (
          <div class:list={['centre-card', { main: i === 0 }]}>
            {centre.photo_url ? (
              <div class="centre-photo">
                <img src={centre.photo_url} alt={centre.name} loading="lazy" />
                {i === 0 && <span class="main-badge">⭐ Main Centre</span>}
              </div>
            ) : (
              <div class="centre-photo-placeholder">
                <div class="placeholder-inner">
                  <span class="centre-initial">{centre.name[0]}</span>
                  {i === 0 && <span class="main-badge-inline">⭐ Main Centre</span>}
                </div>
              </div>
            )}

            <div class="centre-body">
              <h2 class="centre-name">{centre.name}</h2>
              <p class="centre-location">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {centre.city}, {centre.state}
              </p>
              {centre.address && (
                <p class="centre-address">{centre.address}</p>
              )}

              <div class="centre-contacts">
                {centre.phone && (
                  <a href={`tel:${centre.phone}`} class="contact-row">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                    {centre.phone}
                  </a>
                )}
                {centre.email && (
                  <a href={`mailto:${centre.email}`} class="contact-row">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    {centre.email}
                  </a>
                )}
              </div>

              <div class="centre-features">
                {['Computer Lab', 'Hardware Lab', 'Live Classes', 'ISO Certified'].map(f => (
                  <span class="feature-chip">✓ {f}</span>
                ))}
              </div>

              <div class="centre-actions">
                {centre.map_url && (
                  <a href={centre.map_url} target="_blank" rel="noopener" class="btn btn-outline btn-sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    Get Directions
                  </a>
                )}
                {centre.phone && (
                  <a href={`https://wa.me/${centre.phone.replace(/\D/g, '')}?text=Hi! I want to know about courses at ${centre.name}`} target="_blank" rel="noopener" class="btn btn-secondary btn-sm">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    WhatsApp Us
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Enquiry CTA -->
      <div class="enquiry-box">
        <div class="enquiry-icon">📍</div>
        <div class="enquiry-text">
          <h3>Don't See a Centre Near You?</h3>
          <p>We offer fully online and hybrid courses so you can learn from anywhere in India. Live classes via Zoom, practical assignments, and a verified certificate — all without visiting a centre.</p>
        </div>
        <div class="enquiry-btns">
          <a href="/courses" class="btn btn-primary">Online Courses</a>
          <a href="tel:+917009933289" class="btn btn-outline">📞 Call Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY VISIT A CENTRE -->
  <section class="section" style="background:var(--off-white)">
    <div class="container">
      <div class="section-header-center">
        <p class="section-label">Centre Experience</p>
        <h2>Why Visit an ATEC Centre?</h2>
      </div>
      <div class="why-grid">
        {[
          { icon: '🖥️', title: 'Fully Equipped Labs', desc: 'Professional-grade computers, hardware components, soldering stations, and networking equipment for hands-on practice.' },
          { icon: '👨‍🏫', title: 'Expert Instructors', desc: 'Industry-experienced instructors who have worked in hardware repair, networking, and web development.' },
          { icon: '🔬', title: 'Practical Training', desc: 'Theory alone is not enough. Our lab sessions ensure you build real skills on real equipment before you graduate.' },
          { icon: '📜', title: 'Certificate at Centre', desc: 'Collect your ISO-certified certificate in person after completing your course and assessment.' },
        ].map(item => (
          <div class="why-item">
            <div class="why-icon">{item.icon}</div>
            <h3 class="why-title">{item.title}</h3>
            <p class="why-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

</BaseLayout>

<style>
/* Hero */
.centres-hero {
  background: linear-gradient(135deg, #0b1f3f 0%, #1c3d7a 100%);
  padding: 64px 0 56px;
  text-align: center;
}
.centres-hero h1 {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800; color: #fff;
  line-height: 1.2; margin: 10px 0 18px;
}
.hero-sub { font-size: 17px; color: rgba(255,255,255,0.75); max-width: 540px; margin: 0 auto 24px; }
.hero-badges { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
.hero-badge {
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.9);
  padding: 6px 16px; border-radius: 24px;
  font-size: 13px; font-weight: 600;
}

/* Section header */
.section-header-center { text-align: center; margin-bottom: 48px; }
.section-header-center h2 { margin: 8px 0; }

/* Centres grid */
.centres-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 28px;
  margin-bottom: 40px;
}

.centre-card {
  background: var(--white);
  border-radius: var(--radius-xl);
  border: 1px solid var(--gray-200);
  overflow: hidden;
  transition: all 0.2s;
}
.centre-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
.centre-card.main { border-color: var(--navy); }

.centre-photo { height: 220px; overflow: hidden; position: relative; }
.centre-photo img { width: 100%; height: 100%; object-fit: cover; }
.main-badge {
  position: absolute; top: 12px; left: 12px;
  background: var(--lemon); color: var(--navy-dark);
  font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 20px;
}

.centre-photo-placeholder {
  height: 220px;
  background: linear-gradient(135deg, #0b1f3f 0%, #1c3d7a 100%);
  display: flex; align-items: center; justify-content: center;
}
.placeholder-inner { text-align: center; }
.centre-initial {
  display: flex; width: 72px; height: 72px; border-radius: 50%;
  background: var(--lemon); color: var(--navy-dark);
  font-family: var(--font-display); font-weight: 800; font-size: 32px;
  align-items: center; justify-content: center;
  margin: 0 auto 10px;
}
.main-badge-inline {
  display: inline-block;
  background: var(--lemon); color: var(--navy-dark);
  font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 12px;
}

.centre-body { padding: 24px; }
.centre-name { font-family: var(--font-display); font-size: 18px; font-weight: 800; color: var(--text-primary); margin-bottom: 6px; }
.centre-location { display: flex; align-items: center; gap: 5px; font-size: 13px; color: var(--navy); font-weight: 600; margin-bottom: 8px; }
.centre-address { font-size: 13px; color: var(--text-muted); line-height: 1.5; margin-bottom: 16px; }

.centre-contacts { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
.contact-row {
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; color: var(--text-secondary); text-decoration: none;
  transition: color 0.15s;
}
.contact-row:hover { color: var(--navy); }

.centre-features { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 20px; }
.feature-chip {
  background: #f0fdf4; color: #166534;
  border: 1px solid #bbf7d0;
  font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 12px;
}

.centre-actions { display: flex; gap: 10px; flex-wrap: wrap; }

/* Enquiry box */
.enquiry-box {
  background: var(--off-white);
  border: 1px solid var(--gray-200);
  border-radius: var(--radius-xl);
  padding: 32px;
  display: flex; align-items: flex-start; gap: 20px;
  flex-wrap: wrap;
}
.enquiry-icon { font-size: 40px; flex-shrink: 0; }
.enquiry-text { flex: 1; min-width: 240px; }
.enquiry-text h3 { font-family: var(--font-display); font-size: 18px; font-weight: 800; margin-bottom: 8px; }
.enquiry-text p { font-size: 14px; color: var(--text-secondary); line-height: 1.7; }
.enquiry-btns { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; flex-shrink: 0; }

/* Why grid */
.why-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 24px;
}
.why-item {
  background: var(--white);
  border-radius: var(--radius-lg);
  border: 1px solid var(--gray-200);
  padding: 28px;
  transition: all 0.2s;
}
.why-item:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); border-color: var(--navy); }
.why-icon { font-size: 32px; margin-bottom: 14px; }
.why-title { font-family: var(--font-display); font-size: 16px; font-weight: 700; margin-bottom: 10px; }
.why-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.6; }
</style>
