---
// src/pages/news/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro'
import { supabase } from '../../lib/supabase'

let newsItems: any[] = []

try {
  const { data } = await supabase
    .from('news_items')
    .select('*')
    .eq('is_active', true)
    .order('sort_order')
    .order('created_at', { ascending: false })
  newsItems = data ?? []
} catch (e) {}

function formatDate(d: string): string {
  if (!d) return ''
  return new Date(d).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' })
}
---

<BaseLayout
  title="News & Announcements — ATEC Gurdaspur"
  description="Latest news, batch announcements, new courses, and updates from ATEC Educational Society, Gurdaspur."
>
<style>
  .hero { background:#0b1525; padding:64px 32px 48px; text-align:center; color:#fff; }
  .hero h1 { font-family:'Sora',sans-serif; font-size:clamp(1.8rem,4vw,2.8rem); font-weight:900; margin:0 0 10px; }
  .hero p { font-size:16px; color:rgba(255,255,255,0.65); max-width:500px; margin:0 auto; }

  .section { padding:56px 32px 80px; background:#f8f4ef; }
  .grid { max-width:1100px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:24px; }
  .card { background:#fff; border-radius:16px; overflow:hidden; border:1px solid #e2e8f0; box-shadow:0 2px 8px rgba(0,0,0,0.05); display:flex; flex-direction:column; transition:transform 0.18s,box-shadow 0.18s; }
  .card:hover { transform:translateY(-4px); box-shadow:0 10px 28px rgba(0,0,0,0.1); }
  .card-body { padding:20px; flex:1; display:flex; flex-direction:column; }
  .category { font-size:11px; font-weight:700; color:#0b1525; background:#eff6ff; padding:2px 10px; border-radius:20px; display:inline-block; margin-bottom:10px; text-transform:uppercase; }
  .card-title { font-family:'Sora',sans-serif; font-size:16px; font-weight:800; color:#1c1c1c; margin:0 0 8px; line-height:1.4; }
  .card-desc { font-size:14px; color:#475569; margin:0 0 16px; line-height:1.6; flex:1; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
  .card-footer { display:flex; justify-content:space-between; align-items:center; margin-top:auto; }
  .card-date { font-size:12px; color:#94a3b8; }
  .read-more { font-size:13px; font-weight:700; color:#0b1525; text-decoration:none; }
  .read-more:hover { text-decoration:underline; }

  .empty { text-align:center; padding:80px 32px; background:#fff; border-radius:16px; border:2px dashed #e2e8f0; grid-column:1/-1; }
  .empty h2 { font-family:'Sora',sans-serif; font-weight:800; font-size:1.3rem; color:#0b1525; margin:0 0 8px; }
  .empty p { color:#64748b; }
</style>

<div class="hero">
  <h1>News & Announcements</h1>
  <p>Latest updates, new batch announcements, and news from ATEC Gurdaspur.</p>
</div>

<section class="section">
  <div class="grid">
    {newsItems.length === 0 ? (
      <div class="empty">
        <div style="font-size:3rem;margin-bottom:12px">📰</div>
        <h2>No News Yet</h2>
        <p>Check back soon for announcements, new batch dates, and updates.</p>
      </div>
    ) : (
      newsItems.map(n => (
        <div class="card">
          <div class="card-body">
            {n.category && <span class="category">{n.category}</span>}
            <div class="card-title">{n.title}</div>
            {(n.description || n.excerpt) && <p class="card-desc">{n.description || n.excerpt}</p>}
            <div class="card-footer">
              <span class="card-date">{formatDate(n.published_at || n.created_at)}</span>
              {(n.link || n.url) && <a href={n.link || n.url} target="_blank" rel="noopener" class="read-more">Read more →</a>}
            </div>
          </div>
        </div>
      ))
    )}
  </div>
</section>
</BaseLayout>
