---
// src/pages/dashboard.astro
// Redirects authenticated users to /dashboard/certificates
// Unauthenticated users get redirected to /login via client-side JS
import BaseLayout from '../layouts/BaseLayout.astro'
---
<BaseLayout title="Student Dashboard — ATEC Gurdaspur" noIndex={true}>
<style>
  .loading-screen {
    min-height:80vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:16px;
    background:#f8f4ef;
    color:#64748b;
  }
  .spinner {
    width:40px;height:40px;
    border:3px solid #e2e8f0;
    border-top-color:#0f2a5c;
    border-radius:50%;
    animation:spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform:rotate(360deg) } }
  .fallback { text-align:center; padding:64px 32px; background:#f8f4ef; }
  .fallback h2 { font-family:'Sora',sans-serif; font-weight:800; font-size:1.4rem; color:#0f2a5c; margin:0 0 12px; }
  .fallback p { color:#64748b; margin:0 0 24px; }
  .btn { background:#0f2a5c; color:#d4f01a; padding:12px 28px; border-radius:10px; font-weight:800; text-decoration:none; font-size:15px; }
</style>

<div class="loading-screen" id="loading-screen">
  <div class="spinner"></div>
  <p>Loading your dashboard…</p>
</div>

<div class="fallback" id="fallback" style="display:none">
  <h2>Please Log In</h2>
  <p>You need to be logged in to access your student dashboard.</p>
  <a href="/login" class="btn">Login to Dashboard →</a>
</div>

<script>
;(function() {
  async function checkAndRedirect() {
    const SB_URL = (window as any).__SB_URL as string
    const SB_KEY = (window as any).__SB_KEY as string

    if (!SB_URL || !SB_KEY) {
      showFallback(); return
    }

    try {
      const { createClient } = await import('@supabase/supabase-js')
      const supabase = createClient(SB_URL, SB_KEY)
      const { data: { session } } = await supabase.auth.getSession()

      if (session?.user) {
        window.location.href = '/dashboard/certificates'
      } else {
        window.location.href = '/login'
      }
    } catch(e) {
      showFallback()
    }
  }

  function showFallback() {
    const ls = document.getElementById('loading-screen')
    const fb = document.getElementById('fallback')
    if (ls) ls.style.display = 'none'
    if (fb) fb.style.display = 'block'
  }

  // Wait for SB_URL to be set
  if ((window as any).__SB_URL) { checkAndRedirect(); return }
  let n = 0
  const t = setInterval(() => {
    n++
    if ((window as any).__SB_URL || n > 30) { clearInterval(t); checkAndRedirect() }
  }, 100)
})()
</script>
</BaseLayout>
