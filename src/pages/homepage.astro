---
// src/pages/admin/homepage.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
---
<AdminLayout title="Homepage Manager" activeSection="homepage">
  <div id="root"></div>
</AdminLayout>

<script>
import { createClient } from '@supabase/supabase-js'
import { createElement as h, useState, useEffect } from 'react'
import { createRoot } from 'react-dom/client'

const sb = createClient(window.__SB_URL, window.__SB_KEY)

function extractYTId(input: string): string {
  let v = (input||'').trim()
  const short = v.match(/youtu\.be\/([a-zA-Z0-9_-]{11})/)
  const long  = v.match(/(?:v=|\/embed\/|\/shorts\/|\/v\/)([a-zA-Z0-9_-]{11})/)
  if (short) return short[1]
  if (long) return long[1]
  return v
}

function Mgr() {
  const [tab, setTab] = useState('hero')
  const [hero, setHero] = useState<any>({
    heading: 'Turning Students Into Professionals Since 2000',
    subheading: 'Online, hybrid & classroom courses in hardware, networking, web design and more.',
    youtube_video_id: '',
    heading_font_size: '4',
    cta_text: 'Explore Courses',
    cta_link: '/courses',
    cta2_text: 'Chat on WhatsApp',
    cta2_link: 'https://wa.me/917009933289',
  })
  const [strip, setStrip] = useState<any>({ text:'',link:'',link_text:'',is_active:true,bg_color:'#0f2347',text_color:'#ffffff',show_timer:false,ends_at:'' })
  const [branding, setBranding] = useState<any>({ logo_url:'',logo_size:38,show_text:true,brand_name:'ATEC',brand_tagline:'Educational Society' })
  const [nav, setNav] = useState<any>({ links:[{label:'Home',href:'/'}], cta_text:'Enroll Now', cta_link:'https://wa.me/917009933289', cta_style:'lemon', show_login:true })
  const [theme, setTheme] = useState<any>({ primary:'#1c3d7a', accent:'#d4f01a', navy_dark:'#0f2347', off_white:'#f8fafc' })
  const [saving, setSaving] = useState('')
  const [saved, setSaved] = useState('')

  useEffect(() => { load() }, [])
  async function load() {
    const { data } = await sb.from('site_settings').select('key,value').in('key', ['hero','announcement_strip','branding','navigation','theme'])
    data?.forEach(d => {
      if (d.key==='hero')               setHero((p:any) => ({...p, ...d.value}))
      if (d.key==='announcement_strip') setStrip((p:any) => ({...p, ...d.value}))
      if (d.key==='branding')           setBranding((p:any) => ({...p, ...d.value}))
      if (d.key==='navigation')         setNav((p:any) => ({...p, ...d.value, links: d.value?.links ?? p.links}))
      if (d.key==='theme')              setTheme((p:any) => ({...p, ...d.value}))
    })
  }

  async function saveKey(key: string, value: any) {
    setSaving(key)
    await sb.from('site_settings').upsert({ key, value }, { onConflict: 'key' })
    setSaving('')
    setSaved(key)
    setTimeout(() => setSaved(''), 2000)
  }

  const s: any = {width:'100%',padding:'10px 14px',border:'1px solid #e2e8f0',borderRadius:'8px',fontSize:'13px',outline:'none',boxSizing:'border-box',fontFamily:'Inter,sans-serif'}
  const lbl = (t: string) => h('label', {style:{fontSize:'12px',fontWeight:'600',color:'#475569',display:'block',marginBottom:'6px'}}, t)

  const Card = ({ title, emoji, saveKeyName, children, onSave }: any) =>
    h('div', {style:{background:'#fff',borderRadius:'16px',border:'1px solid #e2e8f0',padding:'28px',marginBottom:'20px'}},
      h('div', {style:{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:'20px',borderBottom:'1px solid #f1f5f9',paddingBottom:'14px'}},
        h('h2', {style:{fontFamily:'Sora,sans-serif',fontWeight:'700',fontSize:'17px'}}, `${emoji} ${title}`),
        h('button', {onClick:onSave,disabled:saving===saveKeyName,
          style:{padding:'9px 22px',background:saved===saveKeyName?'#166534':saving===saveKeyName?'#94a3b8':'#1c3d7a',color:'#fff',border:'none',borderRadius:'8px',fontWeight:'700',fontSize:'13px',cursor:saving===saveKeyName?'not-allowed':'pointer'}},
          saved===saveKeyName?'✅ Saved!':saving===saveKeyName?'Saving...':'💾 Save'
        )
      ),
      ...children
    )

  const TabBtn = ({ id, label, icon }: any) =>
    h('button', {onClick:()=>setTab(id),
      style:{padding:'10px 18px',border:'none',borderRadius:'10px',fontSize:'13px',fontWeight:'600',cursor:'pointer',
        background: tab===id ? '#1c3d7a' : 'transparent',
        color: tab===id ? '#fff' : '#475569',
        transition: 'all 0.15s'}
    }, `${icon} ${label}`)

  return h('div', {style:{display:'flex',flexDirection:'column',gap:'20px'}},
    // Header
    h('div', {},
      h('h1', {style:{fontFamily:'Sora,sans-serif',fontSize:'1.6rem',fontWeight:'800',marginBottom:'4px'}}, '🏠 Homepage Manager'),
      h('p', {style:{fontSize:'13px',color:'#64748b'}}, 'All changes save to Supabase and appear live on the website — no rebuild needed.')
    ),

    // Tabs
    h('div', {style:{display:'flex',gap:'4px',background:'#f1f5f9',padding:'4px',borderRadius:'12px',flexWrap:'wrap'}},
      h(TabBtn, {id:'hero', label:'Hero Section', icon:'🦸'}),
      h(TabBtn, {id:'branding', label:'Logo & Branding', icon:'🎨'}),
      h(TabBtn, {id:'nav', label:'Navigation', icon:'🧭'}),
      h(TabBtn, {id:'theme', label:'Theme Colors', icon:'🌈'}),
      h(TabBtn, {id:'strip', label:'Announcement Strip', icon:'📢'}),
    ),

    // ─ HERO TAB ────────────────────────────────────────
    tab==='hero' && h(Card, {
      title:'Hero Section', emoji:'🦸', saveKeyName:'hero',
      onSave: () => saveKey('hero', hero),
      children: [
        h('div', {style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'16px'}},
          h('div', {style:{gridColumn:'1/-1'}},
            lbl('Main Heading (use | to highlight middle word: "Turning Students Into|Professionals|Since 2000")'),
            h('input', {type:'text',value:hero.heading||'',onChange:(e:any)=>setHero((p:any)=>({...p,heading:e.target.value})),style:s,placeholder:'Use | for gradient highlight'}),
            h('div', {style:{fontSize:'11px',color:'#94a3b8',marginTop:'4px'}}, '💡 Tip: Put your most important word between pipes — it gets the rainbow gradient effect')
          ),
          h('div', {style:{gridColumn:'1/-1'}},
            lbl('Sub Heading / Tagline'),
            h('textarea', {value:hero.subheading||'',onChange:(e:any)=>setHero((p:any)=>({...p,subheading:e.target.value})),rows:2,style:{...s,height:'auto',resize:'vertical'},placeholder:'Online, hybrid & classroom courses...'})
          ),
          h('div', {},
            lbl(`Heading Font Size: ${hero.heading_font_size||4}rem`),
            h('input', {type:'range',min:'2',max:'6',step:'0.25',value:hero.heading_font_size||'4',
              onChange:(e:any)=>setHero((p:any)=>({...p,heading_font_size:e.target.value})),
              style:{...s,padding:'0',height:'8px'}})
          ),
          h('div', {},
            lbl('YouTube Video ID or URL (for hero visual)'),
            h('input', {type:'text',value:hero.youtube_video_id||'',
              onChange:(e:any)=>setHero((p:any)=>({...p,youtube_video_id:extractYTId(e.target.value)})),
              style:s,placeholder:'Paste any YouTube URL'}),
            hero.youtube_video_id && h('div', {style:{marginTop:'6px',fontSize:'11px',color:'#166534'}}, `✅ ID: ${hero.youtube_video_id}`)
          ),
          h('div', {style:{gridColumn:'1/-1',marginTop:'8px',padding:'14px',background:'#f8fafc',borderRadius:'10px',border:'1px solid #e2e8f0'}},
            h('div', {style:{fontSize:'13px',fontWeight:'700',marginBottom:'12px',color:'#1c3d7a'}}, '🎯 Primary Call-to-Action Button'),
            h('div', {style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'12px'}},
              h('div', {},
                lbl('Button Text'),
                h('input', {type:'text',value:hero.cta_text||'',onChange:(e:any)=>setHero((p:any)=>({...p,cta_text:e.target.value})),style:s,placeholder:'Explore Courses'})
              ),
              h('div', {},
                lbl('Button Link'),
                h('input', {type:'text',value:hero.cta_link||'',onChange:(e:any)=>setHero((p:any)=>({...p,cta_link:e.target.value})),style:s,placeholder:'/courses or https://wa.me/...'})
              )
            )
          ),
          h('div', {style:{gridColumn:'1/-1',padding:'14px',background:'#f0fdf4',borderRadius:'10px',border:'1px solid #bbf7d0'}},
            h('div', {style:{fontSize:'13px',fontWeight:'700',marginBottom:'12px',color:'#166534'}}, '💬 Secondary Button (WhatsApp recommended)'),
            h('div', {style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'12px'}},
              h('div', {},
                lbl('Button Text'),
                h('input', {type:'text',value:hero.cta2_text||'',onChange:(e:any)=>setHero((p:any)=>({...p,cta2_text:e.target.value})),style:s,placeholder:'Chat on WhatsApp'})
              ),
              h('div', {},
                lbl('WhatsApp URL'),
                h('input', {type:'text',value:hero.cta2_link||'',onChange:(e:any)=>setHero((p:any)=>({...p,cta2_link:e.target.value})),style:s,placeholder:'https://wa.me/917009933289?text=Hi'})
              )
            ),
            h('div', {style:{fontSize:'11px',color:'#166534',marginTop:'8px'}}, '💡 WhatsApp link format: https://wa.me/917009933289?text=Hi%20I%20want%20to%20enroll')
          )
        )
      ]
    }),

    // ─ BRANDING TAB ────────────────────────────────────
    tab==='branding' && h(Card, {
      title:'Logo & Branding', emoji:'🎨', saveKeyName:'branding',
      onSave: () => saveKey('branding', branding),
      children: [
        h('div', {style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'16px'}},
          h('div', {style:{gridColumn:'1/-1'}},
            lbl('Logo Image URL (leave blank to use letter "A" mark)'),
            h('input', {type:'text',value:branding.logo_url||'',onChange:(e:any)=>setBranding((p:any)=>({...p,logo_url:e.target.value})),style:s,placeholder:'https://yourdomain.com/logo.png'}),
            h('div', {style:{fontSize:'11px',color:'#94a3b8',marginTop:'4px'}}, '💡 Upload your logo to a public CDN like Imgur, Cloudinary, or your Supabase Storage bucket')
          ),
          h('div', {},
            lbl(`Logo Size: ${branding.logo_size||38}px`),
            h('input', {type:'range',min:'24',max:'80',value:branding.logo_size||38,
              onChange:(e:any)=>setBranding((p:any)=>({...p,logo_size:parseInt(e.target.value)})),
              style:{...s,padding:'0',height:'8px'}})
          ),
          h('div', {style:{display:'flex',alignItems:'center',gap:'10px',marginTop:'24px'}},
            h('input', {type:'checkbox',checked:!!branding.show_text,onChange:(e:any)=>setBranding((p:any)=>({...p,show_text:e.target.checked})),style:{width:'16px',height:'16px',accentColor:'#1c3d7a'}}),
            lbl('Show brand name + tagline next to logo')
          ),
          h('div', {},
            lbl('Brand Name'),
            h('input', {type:'text',value:branding.brand_name||'',onChange:(e:any)=>setBranding((p:any)=>({...p,brand_name:e.target.value})),style:s})
          ),
          h('div', {},
            lbl('Brand Tagline'),
            h('input', {type:'text',value:branding.brand_tagline||'',onChange:(e:any)=>setBranding((p:any)=>({...p,brand_tagline:e.target.value})),style:s})
          ),
          // Preview
          h('div', {style:{gridColumn:'1/-1',padding:'20px',background:'#f8fafc',borderRadius:'10px',border:'1px solid #e2e8f0'}},
            h('div', {style:{fontSize:'11px',fontWeight:'700',color:'#94a3b8',marginBottom:'12px',textTransform:'uppercase'}}, 'Preview'),
            h('div', {style:{display:'flex',alignItems:'center',gap:'10px'}},
              branding.logo_url
                ? h('img', {src:branding.logo_url,alt:'Logo',style:{width:branding.logo_size+'px',height:branding.logo_size+'px',objectFit:'contain',borderRadius:'10px'}})
                : h('div', {style:{width:branding.logo_size+'px',height:branding.logo_size+'px',background:'#1c3d7a',color:'#d4f01a',borderRadius:'10px',display:'flex',alignItems:'center',justifyContent:'center',fontFamily:'Sora,sans-serif',fontWeight:'800',fontSize:Math.round((branding.logo_size||38)*0.45)+'px'}}, 'A'),
              branding.show_text && h('div', {style:{lineHeight:'1.1'}},
                h('div', {style:{fontFamily:'Sora,sans-serif',fontWeight:'800',fontSize:'18px',color:'#0f1724'}}, branding.brand_name||'ATEC'),
                h('div', {style:{fontSize:'11px',color:'#94a3b8'}}, branding.brand_tagline||'Educational Society')
              )
            )
          )
        )
      ]
    }),

    // ─ NAVIGATION TAB ──────────────────────────────────
    tab==='nav' && h(Card, {
      title:'Navigation Menu', emoji:'🧭', saveKeyName:'navigation',
      onSave: () => saveKey('navigation', nav),
      children: [
        h('div', {style:{padding:'14px 16px',background:'#fef9c3',border:'1px solid #fde68a',borderRadius:'10px',marginBottom:'16px',fontSize:'13px',color:'#713f12'}},
          '🧭 Drag links to reorder. Each link has a Label (what visitors see) and an Href (the URL).'
        ),
        h('div', {style:{marginBottom:'20px'}},
          h('div', {style:{fontSize:'13px',fontWeight:'700',color:'#475569',marginBottom:'10px'}}, 'Navigation Links'),
          ...(nav.links||[]).map((link: any, i: number) =>
            h('div', {key:i,style:{display:'flex',gap:'8px',alignItems:'center',marginBottom:'8px',padding:'10px',background:'#f8fafc',borderRadius:'8px',border:'1px solid #e2e8f0'}},
              h('span', {style:{color:'#94a3b8',fontSize:'12px',fontWeight:'700',width:'24px'}}, `${i+1}.`),
              h('input', {type:'text',placeholder:'Label',value:link.label||'',
                onChange:(e:any)=>{const ns=[...nav.links]; ns[i]={...ns[i],label:e.target.value}; setNav((p:any)=>({...p,links:ns}))},
                style:{...s,flex:1}}),
              h('input', {type:'text',placeholder:'/courses',value:link.href||'',
                onChange:(e:any)=>{const ns=[...nav.links]; ns[i]={...ns[i],href:e.target.value}; setNav((p:any)=>({...p,links:ns}))},
                style:{...s,flex:1}}),
              h('button', {onClick:()=>{const ns=[...nav.links]; if(i>0){[ns[i-1],ns[i]]=[ns[i],ns[i-1]]; setNav((p:any)=>({...p,links:ns}))}},
                style:{padding:'6px 10px',background:'#fff',border:'1px solid #e2e8f0',borderRadius:'6px',cursor:'pointer',fontSize:'12px'}}, '↑'),
              h('button', {onClick:()=>{const ns=[...nav.links]; if(i<ns.length-1){[ns[i+1],ns[i]]=[ns[i],ns[i+1]]; setNav((p:any)=>({...p,links:ns}))}},
                style:{padding:'6px 10px',background:'#fff',border:'1px solid #e2e8f0',borderRadius:'6px',cursor:'pointer',fontSize:'12px'}}, '↓'),
              h('button', {onClick:()=>{const ns=nav.links.filter((_:any,idx:number)=>idx!==i); setNav((p:any)=>({...p,links:ns}))},
                style:{padding:'6px 10px',background:'#fee2e2',border:'1px solid #fecaca',borderRadius:'6px',color:'#991b1b',cursor:'pointer',fontSize:'12px',fontWeight:'600'}}, '✕')
            )
          ),
          h('button', {onClick:()=>setNav((p:any)=>({...p,links:[...(p.links||[]),{label:'New Link',href:'/'}]})),
            style:{padding:'10px 18px',background:'#dbeafe',color:'#1e40af',border:'1px dashed #93c5fd',borderRadius:'8px',fontWeight:'600',fontSize:'13px',cursor:'pointer',marginTop:'8px'}},
            '+ Add Link'
          )
        ),
        h('div', {style:{borderTop:'1px solid #e2e8f0',paddingTop:'20px'}},
          h('div', {style:{fontSize:'13px',fontWeight:'700',color:'#475569',marginBottom:'12px'}}, 'Enroll Now Button (Top Right)'),
          h('div', {style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'12px',marginBottom:'12px'}},
            h('div', {},
              lbl('Button Text'),
              h('input', {type:'text',value:nav.cta_text||'',onChange:(e:any)=>setNav((p:any)=>({...p,cta_text:e.target.value})),style:s,placeholder:'Enroll Now'})
            ),
            h('div', {},
              lbl('Button Link (WhatsApp recommended)'),
              h('input', {type:'text',value:nav.cta_link||'',onChange:(e:any)=>setNav((p:any)=>({...p,cta_link:e.target.value})),style:s,placeholder:'https://wa.me/917009933289'})
            )
          ),
          h('div', {style:{marginBottom:'12px'}},
            lbl('Button Color Style'),
            h('div', {style:{display:'flex',gap:'8px',flexWrap:'wrap'}},
              ...[
                {id:'lemon',  label:'⚡ Lemon (default)',  bg:'linear-gradient(135deg, #d4f01a, #a8e000)'},
                {id:'pink',   label:'💖 Pink',             bg:'linear-gradient(135deg, #ff6b9d, #c44569)'},
                {id:'orange', label:'🔥 Orange',           bg:'linear-gradient(135deg, #ffa726, #fb8c00)'},
                {id:'blue',   label:'💙 Blue',             bg:'linear-gradient(135deg, #4ea4ff, #1c3d7a)'},
                {id:'green',  label:'💚 Green (WhatsApp)', bg:'linear-gradient(135deg, #25d366, #128c7e)'},
              ].map(c =>
                h('button', {key:c.id,onClick:()=>setNav((p:any)=>({...p,cta_style:c.id})),
                  style:{padding:'10px 16px',background:c.bg,color: c.id==='lemon'?'#0f2347':'#fff',border:nav.cta_style===c.id?'3px solid #0f2347':'3px solid transparent',borderRadius:'10px',fontSize:'12px',fontWeight:'700',cursor:'pointer'}
                }, c.label)
              )
            )
          ),
          h('div', {style:{display:'flex',alignItems:'center',gap:'10px'}},
            h('input', {type:'checkbox',checked:!!nav.show_login,onChange:(e:any)=>setNav((p:any)=>({...p,show_login:e.target.checked})),style:{width:'16px',height:'16px',accentColor:'#1c3d7a'}}),
            lbl('Show "Login" button next to CTA')
          )
        )
      ]
    }),

    // ─ THEME TAB ────────────────────────────────────────
    tab==='theme' && h(Card, {
      title:'Theme Colors', emoji:'🌈', saveKeyName:'theme',
      onSave: () => saveKey('theme', theme),
      children: [
        h('div', {style:{padding:'14px 16px',background:'#dbeafe',border:'1px solid #93c5fd',borderRadius:'10px',marginBottom:'16px',fontSize:'13px',color:'#1e40af'}},
          '🌈 Changing theme colors updates the entire website live — affects buttons, navbar, links, and accents everywhere.'
        ),
        h('div', {style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'20px'}},
          ...[
            {k:'primary',   l:'Primary (Navy Blue)',    desc:'Main brand color — buttons, headings, navbar'},
            {k:'accent',    l:'Accent (Lemon Yellow)',  desc:'Highlights, badges, primary CTA'},
            {k:'navy_dark', l:'Dark Background',        desc:'Hero background, footer'},
            {k:'off_white', l:'Off-White Background',   desc:'Section backgrounds'},
          ].map(({k,l,desc}) =>
            h('div', {key:k,style:{padding:'16px',background:'#f8fafc',borderRadius:'10px',border:'1px solid #e2e8f0'}},
              lbl(l),
              h('div', {style:{display:'flex',gap:'10px',alignItems:'center',marginBottom:'8px'}},
                h('input', {type:'color',value:theme[k]||'#000',onChange:(e:any)=>setTheme((p:any)=>({...p,[k]:e.target.value})),style:{width:'60px',height:'40px',border:'1px solid #e2e8f0',borderRadius:'8px',padding:'2px',cursor:'pointer'}}),
                h('input', {type:'text',value:theme[k]||'',onChange:(e:any)=>setTheme((p:any)=>({...p,[k]:e.target.value})),style:{...s,fontFamily:'monospace'}})
              ),
              h('div', {style:{fontSize:'11px',color:'#94a3b8'}}, desc)
            )
          )
        ),
        // Preset themes
        h('div', {style:{marginTop:'20px',padding:'16px',background:'#fefce8',border:'1px solid #fde047',borderRadius:'10px'}},
          h('div', {style:{fontSize:'13px',fontWeight:'700',marginBottom:'12px',color:'#713f12'}}, '🎨 Quick Presets'),
          h('div', {style:{display:'flex',gap:'8px',flexWrap:'wrap'}},
            ...[
              {n:'ATEC Default', c:{primary:'#1c3d7a',accent:'#d4f01a',navy_dark:'#0f2347',off_white:'#f8fafc'}},
              {n:'Vibrant Purple', c:{primary:'#7c3aed',accent:'#fbbf24',navy_dark:'#2e1065',off_white:'#faf5ff'}},
              {n:'Tech Cyan', c:{primary:'#0891b2',accent:'#fbbf24',navy_dark:'#164e63',off_white:'#f0fdfa'}},
              {n:'Bold Red', c:{primary:'#dc2626',accent:'#fef08a',navy_dark:'#7f1d1d',off_white:'#fef2f2'}},
              {n:'Forest Green', c:{primary:'#15803d',accent:'#fef08a',navy_dark:'#14532d',off_white:'#f0fdf4'}},
            ].map(p =>
              h('button', {key:p.n,onClick:()=>setTheme(p.c),
                style:{padding:'8px 14px',background:'#fff',border:'1px solid #e2e8f0',borderRadius:'8px',fontSize:'12px',fontWeight:'600',cursor:'pointer',display:'inline-flex',alignItems:'center',gap:'8px'}},
                h('span', {style:{width:'14px',height:'14px',background:p.c.primary,borderRadius:'4px'}}),
                h('span', {style:{width:'14px',height:'14px',background:p.c.accent,borderRadius:'4px'}}),
                p.n
              )
            )
          )
        )
      ]
    }),

    // ─ STRIP TAB ────────────────────────────────────────
    tab==='strip' && h(Card, {
      title:'Announcement Strip', emoji:'📢', saveKeyName:'announcement_strip',
      onSave: () => saveKey('announcement_strip', strip),
      children: [
        h('div', {style:{padding:'14px 16px',background:'#dcfce7',border:'1px solid #bbf7d0',borderRadius:'10px',marginBottom:'16px',fontSize:'13px',color:'#166534'}},
          '✅ Strip updates live on the website after Save — no rebuild needed.'
        ),
        h('div', {style:{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'14px'}},
          h('div', {style:{gridColumn:'1/-1'}},
            lbl('Strip Text'),
            h('input', {type:'text',value:strip.text||'',onChange:(e:any)=>setStrip((p:any)=>({...p,text:e.target.value})),style:s,placeholder:'🎓 New Batch Starting...'})
          ),
          h('div', {},
            lbl('Link Text'),
            h('input', {type:'text',value:strip.link_text||'',onChange:(e:any)=>setStrip((p:any)=>({...p,link_text:e.target.value})),style:s,placeholder:'Enroll Now'})
          ),
          h('div', {},
            lbl('Link URL'),
            h('input', {type:'text',value:strip.link||'',onChange:(e:any)=>setStrip((p:any)=>({...p,link:e.target.value})),style:s,placeholder:'/courses or https://wa.me/...'})
          ),
          h('div', {},
            lbl('Background Color'),
            h('input', {type:'color',value:strip.bg_color||'#0f2347',onChange:(e:any)=>setStrip((p:any)=>({...p,bg_color:e.target.value})),style:{...s,height:'42px',padding:'4px'}})
          ),
          h('div', {},
            lbl('Text Color'),
            h('input', {type:'color',value:strip.text_color||'#ffffff',onChange:(e:any)=>setStrip((p:any)=>({...p,text_color:e.target.value})),style:{...s,height:'42px',padding:'4px'}})
          ),
          h('div', {style:{display:'flex',alignItems:'center',gap:'10px'}},
            h('input', {type:'checkbox',checked:!!strip.is_active,onChange:(e:any)=>setStrip((p:any)=>({...p,is_active:e.target.checked})),style:{width:'16px',height:'16px',accentColor:'#1c3d7a'}}),
            lbl('Show strip on website')
          ),
          h('div', {style:{display:'flex',alignItems:'center',gap:'10px'}},
            h('input', {type:'checkbox',checked:!!strip.show_timer,onChange:(e:any)=>setStrip((p:any)=>({...p,show_timer:e.target.checked})),style:{width:'16px',height:'16px',accentColor:'#1c3d7a'}}),
            lbl('Show countdown timer')
          ),
          strip.show_timer && h('div', {style:{gridColumn:'1/-1'}},
            lbl('Timer End Date & Time'),
            h('input', {type:'datetime-local',value:strip.ends_at?.slice(0,16)||'',onChange:(e:any)=>setStrip((p:any)=>({...p,ends_at:e.target.value})),style:s})
          )
        )
      ]
    })
  )
}

createRoot(document.getElementById('root')).render(h(Mgr, null))
</script>
