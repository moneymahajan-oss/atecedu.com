---
// src/layouts/BaseLayout.astro
// KEY FIX: sets window.__SB_URL and window.__SB_KEY so ALL client components can use Supabase
import '../styles/global.css'
import Navbar from '../components/layout/Navbar.astro'
import Footer from '../components/layout/Footer.astro'
import AnnouncementStrip from '../components/layout/AnnouncementStrip.astro'
import FloatingChatbot from '../components/chatbot/FloatingChatbot'
import { supabase } from '../lib/supabase'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  canonical?: string
  pageSlug?: string
  noIndex?: boolean
}

const { title: propTitle, description: propDesc, ogImage: propOgImage, canonical, pageSlug, noIndex = false } = Astro.props

// Read env vars in frontmatter (this is where they work)
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY

let seoTitle = propTitle ?? 'ATEC Gurdaspur — Computer Courses Online & Hybrid'
let seoDesc  = propDesc  ?? "ATEC Gurdaspur — India's trusted computer institute since 2000. ISO 9001:2015 certified."
let seoImage = propOgImage ?? 'https://atecedu.com/og-default.jpg'

try {
  if (pageSlug) {
    const { data } = await supabase.from('seo_meta').select('meta_title,meta_description,og_image').eq('page_slug', pageSlug).single()
    if (data?.meta_title)       seoTitle = data.meta_title
    if (data?.meta_description) seoDesc  = data.meta_description
    if (data?.og_image)         seoImage = data.og_image
  }
} catch (e) {}

const canonicalUrl = canonical ?? `https://atecedu.com${Astro.url.pathname}`
---

<!DOCTYPE html>
<html lang="en-IN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{seoTitle}</title>
  <meta name="description" content={seoDesc} />
  <link rel="canonical" href={canonicalUrl} />
  {noIndex ? <meta name="robots" content="noindex,nofollow" /> : <meta name="robots" content="index,follow" />}
  <meta property="og:title" content={seoTitle} />
  <meta property="og:description" content={seoDesc} />
  <meta property="og:image" content={seoImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="ATEC Gurdaspur" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={seoTitle} />
  <meta name="twitter:description" content={seoDesc} />
  <meta name="twitter:image" content={seoImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="icon" type="image/png" href="/favicon.png" />

  <!-- Set Supabase credentials as window globals BEFORE any React component loads -->
  <!-- This is the correct way to pass build-time env vars to client-side code in Astro -->
  <script define:vars={{ SUPABASE_URL, SUPABASE_KEY }}>
    window.__SB_URL = SUPABASE_URL
    window.__SB_KEY = SUPABASE_KEY
  </script>
</head>
<body>
  <AnnouncementStrip />
  <Navbar />
  <main><slot /></main>
  <Footer />
  <FloatingChatbot client:idle />
</body>
</html>
