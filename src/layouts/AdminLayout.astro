---
// src/layouts/AdminLayout.astro
// UPDATED: Auth now checks user_roles table (DB-based) instead of hardcoded email list
// Added: LMS section (Student Progress, Live Sessions), Admin Users section
// UNCHANGED: all existing sidebar links, styles, hamburger, logout
import '../styles/global.css'

interface Props {
  title?: string
  activeSection?: string
}
const { title = 'Admin Panel', activeSection = '' } = Astro.props

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY
// Kept as fallback — DB check is primary, email list is secondary safety net
const ADMIN_EMAILS = ['atecgsp@gmail.com', 'admin@atecedu.com']
---

<!DOCTYPE html>
<html lang="en-IN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — ATEC Admin</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" />
  <link rel="icon" type="image/png" href="/favicon.png" />

  <script define:vars={{ SUPABASE_URL, SUPABASE_KEY, ADMIN_EMAILS }}>
    window.__SB_URL = SUPABASE_URL
    window.__SB_KEY = SUPABASE_KEY
    window.__ADMIN_EMAILS = ADMIN_EMAILS
  </script>

  <style>
    *,*::before,*::after { box-sizing:border-box; margin:0; padding:0 }
    body { font-family:'Inter',sans-serif; background:#f0f4f8; color:#1e293b; min-height:100vh }

    /* ── Auth overlay ── */
    #auth-checking { position:fixed; inset:0; background:#0b1a2e; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:16px; z-index:9999 }
    #auth-checking .spinner { width:36px; height:36px; border:3px solid rgba(255,255,255,0.15); border-top-color:#d4f01a; border-radius:50%; animation:spin 0.7s linear infinite }
    #auth-checking p { color:rgba(255,255,255,0.5); font-size:13px }
    @keyframes spin { to { transform:rotate(360deg) } }
    #admin-wrapper { display:none }

    /* ── Top bar ── */
    .topbar {
      position:fixed; top:0; left:0; right:0; z-index:100;
      height:52px; background:#0b1a2e;
      display:flex; align-items:center; justify-content:space-between;
      padding:0 16px; border-bottom:1px solid rgba(255,255,255,0.06);
    }
    .topbar-left { display:flex; align-items:center; gap:12px }
    .hamburger { background:none; border:none; cursor:pointer; padding:6px; border-radius:6px; display:flex; flex-direction:column; gap:4px }
    .hamburger:hover { background:rgba(255,255,255,0.08) }
    .hamburger span { display:block; width:18px; height:1.5px; background:rgba(255,255,255,0.65); border-radius:2px }
    .brand { display:flex; align-items:center; gap:10px; text-decoration:none }
    .brand-icon { width:30px; height:30px; border-radius:7px; background:#d4f01a; display:flex; align-items:center; justify-content:center; font-family:'Sora',sans-serif; font-weight:900; font-size:15px; color:#0b1a2e; flex-shrink:0 }
    .brand-name { font-family:'Sora',sans-serif; font-weight:800; font-size:14px; color:#fff }
    .brand-sub { font-size:10px; color:rgba(255,255,255,0.35); margin-top:1px }
    .topbar-right { display:flex; align-items:center; gap:8px }
    .topbar-chip { font-size:11px; color:rgba(255,255,255,0.4); padding:4px 10px; background:rgba(255,255,255,0.06); border-radius:6px; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap }
    .role-badge { font-size:10px; font-weight:700; padding:3px 8px; border-radius:4px; background:#d4f01a; color:#0b1a2e; text-transform:uppercase; letter-spacing:0.5px }
    .topbar-btn { padding:5px 13px; border-radius:7px; font-size:12px; font-weight:600; cursor:pointer; border:1px solid rgba(255,255,255,0.14); background:rgba(255,255,255,0.08); color:rgba(255,255,255,0.75); font-family:'Inter',sans-serif; transition:background 0.15s; text-decoration:none; display:inline-flex; align-items:center; gap:5px }
    .topbar-btn:hover { background:rgba(255,255,255,0.14) }
    .topbar-btn.danger { color:#fca5a5; border-color:rgba(252,165,165,0.2) }
    .topbar-btn.danger:hover { background:rgba(239,68,68,0.18) }

    /* ── Sidebar ── */
    .sidebar {
      position:fixed; top:52px; left:0; bottom:0; width:210px;
      background:#fff; border-right:1px solid #e8edf2;
      overflow-y:auto; z-index:50;
      transition:transform 0.25s ease;
    }
    .sidebar.collapsed { transform:translateX(-210px) }
    .sidebar-nav { padding:10px 0 20px }

    .nav-section { margin-bottom:2px }
    .nav-section-label {
      font-size:10px; font-weight:700; letter-spacing:0.7px;
      text-transform:uppercase; color:#b0b8c4;
      padding:10px 16px 5px; display:block;
    }
    .nav-link {
      display:flex; align-items:center; gap:9px;
      padding:8px 16px; font-size:13px; font-weight:500;
      color:#4a5568; text-decoration:none;
      border-left:3px solid transparent;
      transition:all 0.12s;
    }
    .nav-link:hover { background:#f7fafc; color:#1a3460 }
    .nav-link.active { background:#eff6ff; color:#1a3460; font-weight:700; border-left-color:#1a3460 }
    .nav-link .icon { font-size:14px; width:16px; text-align:center; flex-shrink:0 }
    /* Superadmin-only links hidden by default, shown by JS */
    .superadmin-only { display:none }

    /* ── Main content ── */
    .admin-main { margin-left:210px; padding:28px; padding-top:80px; min-height:100vh; transition:margin-left 0.25s }
    .admin-main.expanded { margin-left:0 }
    @media(max-width:768px) {
      .sidebar { transform:translateX(-210px) }
      .sidebar.mobile-open { transform:translateX(0) }
      .admin-main { margin-left:0 }
      .topbar-chip { display:none }
    }
  </style>
</head>
<body>

  <div id="auth-checking">
    <div class="spinner"></div>
    <p>Checking admin access…</p>
  </div>

  <div id="admin-wrapper">
    <!-- Top bar -->
    <header class="topbar">
      <div class="topbar-left">
        <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
        <a href="/admin" class="brand">
          <div class="brand-icon">A</div>
          <div><div class="brand-name">ATEC Admin</div><div class="brand-sub">Control Panel</div></div>
        </a>
      </div>
      <div class="topbar-right">
        <span class="role-badge" id="admin-role-badge"></span>
        <span class="topbar-chip" id="admin-email"></span>
        <a href="/" target="_blank" class="topbar-btn">🌐 Live Site</a>
        <button id="admin-logout" class="topbar-btn danger">🚪 Logout</button>
      </div>
    </header>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <nav class="sidebar-nav">

        <div class="nav-section">
          <span class="nav-section-label">Overview</span>
          <a href="/admin" class:list={['nav-link', { active: activeSection === 'dashboard' }]}>
            <span class="icon">📊</span> Dashboard
          </a>
        </div>

        <div class="nav-section">
          <span class="nav-section-label">Homepage</span>
          <a href="/admin/homepage" class:list={['nav-link', { active: activeSection === 'homepage' }]}>
            <span class="icon">🦸</span> Hero · Strip · Stories
          </a>
          <a href="/admin/homepage-new-features" class:list={['nav-link', { active: activeSection === 'new-features' }]}>
            <span class="icon">🎠</span> Slider · Cards · Popup
          </a>
          <a href="/admin/faculty" class:list={['nav-link', { active: activeSection === 'faculty' }]}>
            <span class="icon">🎓</span> Faculty
          </a>
          <a href="/admin/testimonials" class:list={['nav-link', { active: activeSection === 'testimonials' }]}>
            <span class="icon">⭐</span> Testimonials
          </a>
        </div>

        <div class="nav-section">
          <span class="nav-section-label">Contact & Info</span>
          <a href="/admin/contact-sections" class:list={['nav-link', { active: activeSection === 'contact-sections' }]}>
            <span class="icon">📞</span> Connect · FAQ · Downloads
          </a>
        </div>

        <div class="nav-section">
          <span class="nav-section-label">Mock Test</span>
          <a href="/admin/mock-test" class:list={['nav-link', { active: activeSection === 'mock-test' }]}>
            <span class="icon">🎯</span> Mock Test Manager
          </a>
        </div>

        <div class="nav-section">
          <span class="nav-section-label">Courses</span>
          <a href="/admin/courses" class:list={['nav-link', { active: activeSection === 'courses' }]}>
            <span class="icon">📚</span> All Courses
          </a>
          <a href="/admin/zoom" class:list={['nav-link', { active: activeSection === 'zoom' }]}>
            <span class="icon">🎥</span> Live Sessions
          </a>
          <a href="/admin/blog" class:list={['nav-link', { active: activeSection === 'blog' }]}>
            <span class="icon">✍️</span> Blog
          </a>
          <a href="/admin/youtube" class:list={['nav-link', { active: activeSection === 'youtube' }]}>
            <span class="icon">▶️</span> YouTube Videos
          </a>
          <a href="/admin/podcast" class:list={['nav-link', { active: activeSection === 'podcast' }]}>
            <span class="icon">🎙️</span> Podcast
          </a>
        </div>

        <!-- ── NEW: LMS section ── -->
        <div class="nav-section">
          <span class="nav-section-label">LMS</span>
          <a href="/admin/student-progress" class:list={['nav-link', { active: activeSection === 'student-progress' }]}>
            <span class="icon">📈</span> Student Progress
          </a>
          <a href="/admin/enrollments" class:list={['nav-link', { active: activeSection === 'enrollments' }]}>
            <span class="icon">🎓</span> Enrollments
          </a>
          <a href="/admin/students" class:list={['nav-link', { active: activeSection === 'students' }]}>
            <span class="icon">👥</span> All Students
          </a>
          <a href="/admin/certificates" class:list={['nav-link', { active: activeSection === 'certificates' }]}>
            <span class="icon">📜</span> Certificates
          </a>
        </div>

        <div class="nav-section">
          <span class="nav-section-label">Business</span>
          <a href="/admin/enquiries" class:list={['nav-link', { active: activeSection === 'enquiries' }]}>
            <span class="icon">💬</span> Enquiries
          </a>
          <a href="/admin/payments" class:list={['nav-link', { active: activeSection === 'payments' }]}>
            <span class="icon">💳</span> Payments
          </a>
        </div>

        <!-- ── NEW: Admin Users — superadmin only ── -->
        <div class="nav-section superadmin-only" id="superadmin-section">
          <span class="nav-section-label">Superadmin</span>
          <a href="/admin/admin-users" class:list={['nav-link', { active: activeSection === 'admin-users' }]}>
            <span class="icon">🔐</span> Manage Admins
          </a>
          <a href="/admin/superadmin-certificates" class:list={['nav-link', { active: activeSection === 'superadmin-certificates' }]}>
            <span class="icon">🛡️</span> Cert Superadmin
          </a>
        </div>

        <div class="nav-section">
          <span class="nav-section-label">Settings</span>
          <a href="/admin/seo" class:list={['nav-link', { active: activeSection === 'seo' }]}>
            <span class="icon">🔍</span> SEO
          </a>
          <a href="/admin/social" class:list={['nav-link', { active: activeSection === 'social' }]}>
            <span class="icon">📱</span> Social Links
          </a>
          <a href="/admin/theme" class:list={['nav-link', { active: activeSection === 'theme' }]}>
            <span class="icon">🎨</span> Theme
          </a>
        </div>

      </nav>
    </aside>

    <!-- Main -->
    <main class="admin-main" id="admin-main">
      <slot />
    </main>
  </div>

  <script>
    async function initAdmin() {
      try {
        const URL    = (window as any).__SB_URL
        const KEY    = (window as any).__SB_KEY
        const EMAILS = (window as any).__ADMIN_EMAILS || ['atecgsp@gmail.com']
        if (!URL || !KEY) { window.location.href = '/admin/login'; return }

        const { createClient } = await import('@supabase/supabase-js')
        const supabase = createClient(URL, KEY)
        const { data: { session } } = await supabase.auth.getSession()

        if (!session?.user) { window.location.href = '/admin/login'; return }

        const userEmail = session.user.email ?? ''

        // ── DB-based role check (primary) ──
        const { data: roleData } = await supabase
          .from('user_roles')
          .select('role, full_name, is_active')
          .eq('user_id', session.user.id)
          .single()

        const hasDBRole = roleData?.is_active && roleData?.role
        // Fallback: hardcoded email list (in case user_roles not set up yet)
        const hasEmailAccess = EMAILS.includes(userEmail)

        if (!hasDBRole && !hasEmailAccess) {
          window.location.href = '/admin/login'; return
        }

        const role = roleData?.role || 'admin'

        // Show role badge
        const roleEl = document.getElementById('admin-role-badge')
        if (roleEl) {
          roleEl.textContent = role.toUpperCase()
          if (role === 'superadmin') {
            roleEl.style.background = '#d4f01a'
            roleEl.style.color = '#0b1525'
          } else if (role === 'instructor') {
            roleEl.style.background = '#dbeafe'
            roleEl.style.color = '#1e40af'
          } else {
            roleEl.style.background = '#e0e7ff'
            roleEl.style.color = '#3730a3'
          }
        }

        const emailEl = document.getElementById('admin-email')
        if (emailEl) emailEl.textContent = roleData?.full_name || userEmail

        // Show superadmin-only UI
        if (role === 'superadmin') {
          document.getElementById('superadmin-section')!.style.display = 'block'
        }

        document.getElementById('auth-checking')!.style.display = 'none'
        document.getElementById('admin-wrapper')!.style.display = 'block'

        // Hamburger toggle
        const sidebar   = document.getElementById('sidebar')
        const main      = document.getElementById('admin-main')
        const hamburger = document.getElementById('hamburger')
        let collapsed   = false
        const isMobile  = () => window.innerWidth <= 768

        hamburger?.addEventListener('click', () => {
          if (isMobile()) {
            sidebar?.classList.toggle('mobile-open')
          } else {
            collapsed = !collapsed
            sidebar?.classList.toggle('collapsed', collapsed)
            main?.classList.toggle('expanded', collapsed)
          }
        })

        // Logout
        document.getElementById('admin-logout')?.addEventListener('click', async () => {
          await supabase.auth.signOut()
          window.location.href = '/admin/login'
        })

      } catch(err) {
        console.error('Admin init error:', err)
        window.location.href = '/admin/login'
      }
    }
    initAdmin()
  </script>
</body>
</html>
